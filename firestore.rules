rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───
    // Users can read their own document.
    // Users can create their own document on registration.
    // Users can update their own document BUT cannot touch subscription, isPromo, or maxTierPassed fields.
    // These protected fields are only writable via Firebase Admin SDK (server-side).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && (!('subscription' in request.resource.data)
                        || request.resource.data.subscription == 'free');

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['subscription', 'isPromo', 'maxTierPassed']);
    }

    // ─── Test Results ───
    // Users can read and create their own results.
    // Cannot update or delete results (immutable records).
    match /results/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // ─── AI Chat History ───
    // Users can read and create their own AI chats.
    match /ai_chats/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // ─── Promo Codes ───
    // Anyone authenticated can read promo codes (needed for referral validation).
    // Only Admin SDK can write (no client writes allowed).
    match /promo_codes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Webhook Events ───
    // Only Admin SDK can read/write (used for idempotency tracking).
    match /webhook_events/{eventId} {
      allow read, write: if false;
    }

    // ─── Default Deny ───
    // Block all access to any collection not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
