rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ───
    // Users can read their own document.
    // Users can create their own document on registration.
    // Users can update their own document BUT cannot touch protected fields.
    // Protected fields are only writable via Firebase Admin SDK (server-side).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && (!('subscription' in request.resource.data)
                        || request.resource.data.subscription == 'free'
                        || request.resource.data.subscription.plan == 'Free');

      // SECURITY: Block ALL server-managed fields from client-side updates.
      // This includes subscription, usage counters, gamification stats, and tier data.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['subscription', 'isPromo', 'usage', 'maxTierPassed',
                                 'weeklyPassUsed', 'mocksCompleted', 'questionsSolved', 'streak']);
    }

    // ─── Test Results ───
    // Users can read their own results.
    // SECURITY (VULN-01/02): Client-side create BLOCKED.
    // All results are created server-side via /api/exam/submit (Admin SDK).
    match /results/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create, update, delete: if false;
    }

    // ─── AI Chat History ───
    // Users can read their own AI chats.
    // SECURITY (VULN-03): Client-side create BLOCKED to prevent Firestore cost bomb.
    // All chats are saved server-side via /api/ai/save-chat (Admin SDK).
    match /ai_chats/{docId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create, update, delete: if false;
    }

    // ─── Promo Codes ───
    // Authenticated users can READ a specific promo code by ID (for referral validation).
    // List/query access is denied to prevent enumeration (MEDIUM-10).
    // Only Admin SDK can write (no client writes allowed).
    match /promo_codes/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if false;
    }

    // ─── AI Usage Tracking ───
    // Admin SDK only — tracks platform-wide daily token budget.
    match /ai_usage/{dateKey} {
      allow read, write: if false;
    }

    // ─── Webhook Events ───
    // Only Admin SDK can read/write (used for idempotency tracking).
    match /webhook_events/{eventId} {
      allow read, write: if false;
    }

    // ─── Rate Limits ───
    // Only Admin SDK can read/write (used for serverless rate limiting).
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }

    // ─── Admin Audit Log ───
    // Only Admin SDK can read/write — used for tracking admin actions.
    match /admin_audit_log/{logId} {
      allow read, write: if false;
    }

    // ─── Exam Sessions ───
    // Stores server-side answer keys for active exams.
    // Only Admin SDK can read/write — clients MUST NOT see answer keys.
    match /exam_sessions/{sessionId} {
      allow read, write: if false;
    }

    // ─── Institute Portal (B2B) ───
    // All institute data is managed via Admin SDK only.
    // No client-side reads or writes allowed.
    match /institutes/{instituteId} {
      allow read, write: if false;
    }
    match /institute_exams/{examId} {
      allow read, write: if false;
    }
    match /institute_attempts/{attemptId} {
      allow read, write: if false;
    }
    match /institute_exam_sessions/{sessionId} {
      allow read, write: if false;
    }

    // ─── Default Deny ───
    // Block all access to any collection not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
