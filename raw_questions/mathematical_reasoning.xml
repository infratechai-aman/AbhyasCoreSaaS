<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Mathematics" id="213" name="Mathematical Reasoning">
    <easy>
        <question>
            <text>A sentence which is either true or false but not both is a:</text>
            <option id="A">Statement</option><option id="B">Logic</option><option id="C">Hypothesis</option><option id="D">Equation</option>
            <answer>A</answer><explanation>Definition of a mathematical statement.</explanation></question>
        <question>
            <text>Which of the following is a statement?</text>
            <option id="A">2 is an even prime number.</option><option id="B">How are you?</option><option id="C">Open the door.</option><option id="D">Mathematics is difficult.</option>
            <answer>A</answer><explanation>Declarative and universally true/false.</explanation></question>
        <question>
            <text>Denial of a statement is called its:</text>
            <option id="A">Negation</option><option id="B">Contradiction</option><option id="C">Dual</option><option id="D">Converse</option>
            <answer>A</answer><explanation>Symbol: ~p.</explanation></question>
        <question>
            <text>Negation of 'The sum of 3 and 4 is 9' is:</text>
            <option id="A">Sum of 3 and 4 is not 9.</option><option id="B">Sum of 3 and 4 is 7.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Insert 'not' or 'It is false that...'.</explanation></question>
        <question>
            <text>Two statements joined by 'and' or 'or' are called:</text>
            <option id="A">Compound statements</option><option id="B">Simple statements</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Made of multiple component statements.</explanation></question>
        <question>
            <text>A compound statement with 'and' is true only if:</text>
            <option id="A">All component statements are true</option><option id="B">At least one is true</option><option id="C">None are true</option><option id="D">None</option>
            <answer>A</answer><explanation>Conjunction logic.</explanation></question>
        <question>
            <text>A compound statement with 'or' is false only if:</text>
            <option id="A">All component statements are false</option><option id="B">At least one is false</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Disjunction logic.</explanation></question>
        <question>
            <text>Exclusive 'or' means:</text>
            <option id="A">p or q but not both</option><option id="B">p or q or both</option><option id="C">Neither</option><option id="D">None</option>
            <answer>A</answer><explanation>One or the other, strictly.</explanation></question>
        <question>
            <text>Inclusive 'or' means:</text>
            <option id="A">p or q or both</option><option id="B">p or q but not both</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard logical 'or'.</explanation></question>
        <question>
            <text>Words like 'and', 'or', 'if-then' are called:</text>
            <option id="A">Connectives</option><option id="B">Variables</option><option id="C">Constants</option><option id="D">None</option>
            <answer>A</answer><explanation>They link simple statements.</explanation></question>
        <question>
            <text>Quantifiers are phrases like:</text>
            <option id="A">There exists / For all</option><option id="B">If / Then</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Universal and Existential.</explanation></question>
        <question>
            <text>'There exists a number which is even prime' uses:</text>
            <option id="A">Existential quantifier</option><option id="B">Universal quantifier</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Points to at least one entity.</explanation></question>
        <question>
            <text>'For all natural numbers n, n &gt; 0' uses:</text>
            <option id="A">Universal quantifier</option><option id="B">Existential quantifier</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Applies to the entire set.</explanation></question>
        <question>
            <text>Conditional statement is of the form:</text>
            <option id="A">If p, then q</option><option id="B">p and q</option><option id="C">Not p</option><option id="D">None</option>
            <answer>A</answer><explanation>Directional implication.</explanation></question>
        <question>
            <text>In 'If p, then q', p is called:</text>
            <option id="A">Hypothesis / Antecedent</option><option id="B">Conclusion / Consequent</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Start condition.</explanation></question>
        <question>
            <text>In 'If p, then q', q is called:</text>
            <option id="A">Conclusion / Consequent</option><option id="B">Hypothesis</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Resulting condition.</explanation></question>
        <question>
            <text>Converse of 'If p, then q' is:</text>
            <option id="A">If q, then p</option><option id="B">If ~p, then ~q</option><option id="C">If ~q, then ~p</option><option id="D">None</option>
            <answer>A</answer><explanation>Swapping the parts.</explanation></question>
        <question>
            <text>Contrapositive of 'If p, then q' is:</text>
            <option id="A">If ~q, then ~p</option><option id="B">If q, then p</option><option id="C">If ~p, then ~q</option><option id="D">None</option>
            <answer>A</answer><explanation>Swap and negate.</explanation></question>
        <question>
            <text>Inverse of 'If p, then q' is:</text>
            <option id="A">If ~p, then ~q</option><option id="B">If ~q, then ~p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Negating both parts in place.</explanation></question>
        <question>
            <text>Biconditional statement is of the form:</text>
            <option id="A">p if and only if q</option><option id="B">If p, then q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Double implication.</explanation></question>
        <question>
            <text>Negation of (~p) is:</text>
            <option id="A">p</option><option id="B">~p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Double negation law.</explanation></question>
        <question>
            <text>A statement which is always true is a:</text>
            <option id="A">Tautology</option><option id="B">Fallacy / Contradiction</option><option id="C">Theorem</option><option id="D">None</option>
            <answer>A</answer><explanation>Universal logical truth.</explanation></question>
        <question>
            <text>A statement which is always false is a:</text>
            <option id="A">Fallacy / Contradiction</option><option id="B">Tautology</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Logical absurdity.</explanation></question>
        <question>
            <text>Negation of (p and q) is equivalent to:</text>
            <option id="A">(~p) or (~q)</option><option id="B">(~p) and (~q)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>De Morgan's first law.</explanation></question>
        <question>
            <text>Negation of (p or q) is equivalent to:</text>
            <option id="A">(~p) and (~q)</option><option id="B">(~p) or (~q)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>De Morgan's second law.</explanation></question>
        <question>
            <text>Truth table for conjunction (and) has how many 'True' values out of 4?</text>
            <option id="A">1</option><option id="B">3</option><option id="C">2</option><option id="D">4</option>
            <answer>A</answer><explanation>Only when both are T.</explanation></question>
        <question>
            <text>Truth table for disjunction (or) has how many 'True' values out of 4?</text>
            <option id="A">3</option><option id="B">1</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Everything except F-F.</explanation></question>
        <question>
            <text>Truth table for 'If p, then q' is false only when:</text>
            <option id="A">p is true and q is false</option><option id="B">p is false and q is true</option><option id="C">Both false</option><option id="D">Both true</option>
            <answer>A</answer><explanation>Specific row in truth table.</explanation></question>
        <question>
            <text>Truth table for 'p iff q' is true when:</text>
            <option id="A">Both have same truth values</option><option id="B">Both have different values</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Equivalence logic.</explanation></question>
        <question>
            <text>Validated mathematical statements are called:</text>
            <option id="A">Theorems</option><option id="B">Axioms</option><option id="C">Postulates</option><option id="D">None</option>
            <answer>A</answer><explanation>Proven facts.</explanation></question>
        <question>
            <text>Statements assumed true without proof are:</text>
            <option id="A">Axioms / Postulates</option><option id="B">Theorems</option><option id="C">Corollaries</option><option id="D">None</option>
            <answer>A</answer><explanation>Starting points.</explanation></question>
        <question>
            <text>Direct proof starts from ____ and leads to ____.</text>
            <option id="A">Hypothesis, Conclusion</option><option id="B">Conclusion, Hypothesis</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Straight logical derivation.</explanation></question>
        <question>
            <text>Proving 'p is true' by showing ~p leads to absurdity is:</text>
            <option id="A">Proof by contradiction</option><option id="B">Direct proof</option><option id="C">Counter example</option><option id="D">None</option>
            <answer>A</answer><explanation>Reductio ad absurdum.</explanation></question>
        <question>
            <text>Disproving a general statement using one specific case is:</text>
            <option id="A">Counter example method</option><option id="B">Contradiction</option><option id="C">Induction</option><option id="D">None</option>
            <answer>A</answer><explanation>Universal 'For all' fails with one exception.</explanation></question>
        <question>
            <text>Negation of 'All cats are white' is:</text>
            <option id="A">Some cats are not white.</option><option id="B">No cats are white.</option><option id="C">All cats are black.</option><option id="D">None</option>
            <answer>A</answer><explanation>~ (∀x Px) ≡ ∃x (~Px).</explanation></question>
        <question>
            <text>Negation of 'There is an integer x such that x^2=2' is:</text>
            <option id="A">For all integers x, x^2 is not 2.</option><option id="B">There is an integer x such that x^2 is not 2.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>~ (∃x Px) ≡ ∀x (~Px).</explanation></question>
        <question>
            <text>Symbol for implication (if-then) is:</text>
            <option id="A">⇒</option><option id="B">⇔</option><option id="C">∧</option><option id="D">∨</option>
            <answer>A</answer><explanation>Standard notation.</explanation></question>
        <question>
            <text>Symbol for biconditional is:</text>
            <option id="A">⇔</option><option id="B">⇒</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard notation.</explanation></question>
        <question>
            <text>If C is converse and I is inverse, then C and I are ____ of each other.</text>
            <option id="A">Contrapositives</option><option id="B">Negations</option><option id="C">Identical</option><option id="D">None</option>
            <answer>A</answer><explanation>Logical property.</explanation></question>
        <question>
            <text>Dual of a statement (Set theory analogy) involves swapping:</text>
            <option id="A">and/or, T/F</option><option id="B">Negations</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common in boolean logic.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Contrapositive of 'If x is a prime number, then x is odd' is:</text>
            <option id="A">If x is not odd, then x is not a prime number.</option><option id="B">If x is not prime, then x is not odd.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Negate and swap.</explanation></question>
        <question>
            <text>Negation of 'p ⇒ q' is equivalent to:</text>
            <option id="A">p and ~q</option><option id="B">~p or q</option><option id="C">~p and q</option><option id="D">~p or ~q</option>
            <answer>A</answer><explanation>Def: p ⇒ q is ~p or q. Negation is p and ~q.</explanation></question>
        <question>
            <text>Which of the following is equivalent to p ⇒ q?</text>
            <option id="A">~q ⇒ ~p</option><option id="B">q ⇒ p</option><option id="C">~p ⇒ ~q</option><option id="D">None</option>
            <answer>A</answer><explanation>Contrapositive is logically equivalent.</explanation></question>
        <question>
            <text>If p is true and q is false, truth value of (p ∧ ~q) is:</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T ∧ T = T.</explanation></question>
        <question>
            <text>Expression (p ∨ ~p) is a:</text>
            <option id="A">Tautology</option><option id="B">Contradiction</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Law of excluded middle.</explanation></question>
        <question>
            <text>Expression (p ∧ ~p) is a:</text>
            <option id="A">Contradiction</option><option id="B">Tautology</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cannot be both true and false.</explanation></question>
        <question>
            <text>Negation of '√2 is rational' is '√2 is irrational'. This is true because:</text>
            <option id="A">A number is either rational or irrational.</option><option id="B">Definition of irrational.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Complementary sets.</explanation></question>
        <question>
            <text>Is 'x+y = y+x' a statement?</text>
            <option id="A">Yes (Universally true for real numbers)</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Always true declarative sentence.</explanation></question>
        <question>
            <text>Is 'x is a prime number' a statement?</text>
            <option id="A">No (depends on x)</option><option id="B">Yes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Open sentence.</explanation></question>
        <question>
            <text>A sentence with variables which becomes a statement when values are assigned is:</text>
            <option id="A">Open sentence</option><option id="B">Predicate</option><option id="C">Both A and B</option><option id="D">None</option>
            <answer>C</answer><explanation>Terminology.</explanation></question>
        <question>
            <text>Compound statement 'p and q' is false if:</text>
            <option id="A">p is F or q is F</option><option id="B">p is T</option><option id="C">q is T</option><option id="D">None</option>
            <answer>A</answer><explanation>Basic negation of conjunction.</explanation></question>
        <question>
            <text>Compound statement 'p or q' is true if:</text>
            <option id="A">At least one is true</option><option id="B">Both are true only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Inclusive or definition.</explanation></question>
        <question>
            <text>Negation of 'He is rich and happy':</text>
            <option id="A">He is not rich or not happy.</option><option id="B">He is not rich and not happy.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>De Morgan application.</explanation></question>
        <question>
            <text>Converse of 'If it rains, then I stay home':</text>
            <option id="A">If I stay home, then it rains.</option><option id="B">If it does not rain, I do not stay home.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Swap only.</explanation></question>
        <question>
            <text>Inverse of 'If it rains, then I stay home':</text>
            <option id="A">If it does not rain, then I do not stay home.</option><option id="B">If I stay home, then it rains.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Negate only.</explanation></question>
        <question>
            <text>Statement p: '2+3=5', q: 'Mumbai is in India'. p ∧ q is:</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T ∧ T = T.</explanation></question>
        <question>
            <text>Negation of 'p ⇔ q' is equivalent to:</text>
            <option id="A">(p ∧ ~q) ∨ (q ∧ ~p)</option><option id="B">~(p or q)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>XOR logic.</explanation></question>
        <question>
            <text>'If n is even, then n^2 is even' - Contrapositive:</text>
            <option id="A">If n^2 is odd, then n is odd.</option><option id="B">If n^2 is even, then n is even.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Non-even is odd for integers.</explanation></question>
        <question>
            <text>'There exists a real number whose square is negative' - Truth value:</text>
            <option id="A">False</option><option id="B">True</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Squares of reals are non-negative.</explanation></question>
        <question>
            <text>'For all n in N, n+1 &gt; n' - Truth value:</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Universal property of successor.</explanation></question>
        <question>
            <text>The statement 'p is necessary for q' means:</text>
            <option id="A">q ⇒ p</option><option id="B">p ⇒ q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>If q happens, p must have happened.</explanation></question>
        <question>
            <text>The statement 'p is sufficient for q' means:</text>
            <option id="A">p ⇒ q</option><option id="B">q ⇒ p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>If p happens, q is guaranteed.</explanation></question>
        <question>
            <text>Number of rows in truth table for n statements:</text>
            <option id="A">2^n</option><option id="B">2n</option><option id="C">n^2</option><option id="D">None</option>
            <answer>A</answer><explanation>Combinations of T/F.</explanation></question>
        <question>
            <text>Which connective has the highest precedence usually?</text>
            <option id="A">Negation (~)</option><option id="B">And</option><option id="C">Or</option><option id="D">Implies</option>
            <answer>A</answer><explanation>Evaluated first like '-' in arithmetic.</explanation></question>
        <question>
            <text>Is 'p ⇒ q' same as 'not p or q'?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Fundamental logical equivalence.</explanation></question>
        <question>
            <text>Negation of 'If I study, I pass' is:</text>
            <option id="A">I study and I do not pass.</option><option id="B">I do not study and I pass.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>p and ~q.</explanation></question>
        <question>
            <text>The dual of (p ∧ q) ∨ r is:</text>
            <option id="A">(p ∨ q) ∧ r</option><option id="B">(p ∧ q) ∨ r</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Swap ∧ and ∨.</explanation></question>
        <question>
            <text>Which illustrates inclusive OR?</text>
            <option id="A">To enter, you need ID card or Passport.</option><option id="B">The coffee is hot or cold.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>You can have both.</explanation></question>
        <question>
            <text>Which illustrates exclusive OR?</text>
            <option id="A">Either you are born in India or abroad.</option><option id="B">Students can take Hindi or Sanskrit.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mutually exclusive options.</explanation></question>
        <question>
            <text>Contrapositive of 'p implies q' in symbolic form:</text>
            <option id="A">~q ⇒ ~p</option><option id="B">q ⇒ p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Equivalent form.</explanation></question>
        <question>
            <text>If p is T, q is F, r is T. Truth value of (p ∧ q) ∨ r:</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>(T ∧ F) ∨ T = F ∨ T = T.</explanation></question>
        <question>
            <text>If p is T, q is F. Truth value of p ⇒ (~q):</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T ⇒ T = T.</explanation></question>
        <question>
            <text>Is (~p ⇒ q) same as (p ∨ q)?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Negation of first or second: ~(~p) or q = p or q.</explanation></question>
        <question>
            <text>Which quantifier corresponds to 'at least one'?</text>
            <option id="A">Existential</option><option id="B">Universal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Definition.</explanation></question>
        <question>
            <text>Which quantifier corresponds to 'each and every'?</text>
            <option id="A">Universal</option><option id="B">Existential</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Definition.</explanation></question>
        <question>
            <text>Is 'The Earth is flat' a statement?</text>
            <option id="A">Yes (False statement)</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>False declarative sentence.</explanation></question>
        <question>
            <text>Negation of 'x+2=5' in open sense:</text>
            <option id="A">x+2 is not 5.</option><option id="B">x=3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Direct negation.</explanation></question>
        <question>
            <text>If p is 'Sky is blue' and q is 'Sun is hot', ~p ∨ ~q is:</text>
            <option id="A">Sky is not blue or Sun is not hot.</option><option id="B">Sky is blue and Sun is hot.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Literal translation.</explanation></question>
        <question>
            <text>A statement that results in T, F, T, F patterns for p, q? No. Truth of p ∧ q depends only on:</text>
            <option id="A">Values of p and q</option><option id="B">Alphabetical order</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Functional nature of logic.</explanation></question>
        <question>
            <text>Law of Syllogism: (p ⇒ q) ∧ (q ⇒ r) yields:</text>
            <option id="A">p ⇒ r</option><option id="B">r ⇒ p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Transitive property.</explanation></question>
    </medium>
    <hard>
        <question>
            <text>Which is NOT logically equivalent to 'If a triangle is equilateral, then it is isosceles'?</text>
            <option id="A">If a triangle is equilateral, it is not isosceles.</option><option id="B">Being isosceles is necessary for being equilateral.</option><option id="C">Being equilateral is sufficient for being isosceles.</option><option id="D">If it is not isosceles, it is not equilateral.</option>
            <answer>A</answer><explanation>That's the opposite/negation of the claim.</explanation></question>
        <question>
            <text>Truth value of (~(p ∨ q) ⇔ (~p ∧ ~q)) is:</text>
            <option id="A">Always True (Tautology)</option><option id="B">Always False</option><option id="C">Depends</option><option id="D">None</option>
            <answer>A</answer><explanation>This is De Morgan's Law expressed as equivalence.</explanation></question>
        <question>
            <text>Expression (p ⇒ q) ⇔ (~q ⇒ ~p) is a:</text>
            <option id="A">Tautology</option><option id="B">Fallacy</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Contrapositive equivalence.</explanation></question>
        <question>
            <text>Negation of 'p ⇒ (q ⇒ r)' is:</text>
            <option id="A">p ∧ (q ∧ ~r)</option><option id="B">p ∨ (q ⇒ r)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>~(p ⇒ X) = p ∧ ~X. Here X = q ⇒ r. ~X = q ∧ ~r.</explanation></question>
        <question>
            <text>If p iff q is false, what can we say about p and q?</text>
            <option id="A">They have opposite truth values</option><option id="B">They are both true</option><option id="C">They are both false</option><option id="D">None</option>
            <answer>A</answer><explanation>Condition for biconditional failure.</explanation></question>
        <question>
            <text>Boolean term for Exclusive OR (XOR) p ⊕ q:</text>
            <option id="A">(p ∧ ~q) ∨ (~p ∧ q)</option><option id="B">p ∧ q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard definition.</explanation></question>
        <question>
            <text>Is ~ (~ p ∧ ~ q) equivalent to p ∨ q?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>De Morgan's negation.</explanation></question>
        <question>
            <text>Negation of 'Some humans are immortal' is:</text>
            <option id="A">All humans are mortal.</option><option id="B">No humans are mortal.</option><option id="C">Some humans are mortal.</option><option id="D">None</option>
            <answer>A</answer><explanation>Not (Exists x) = (For all x) Not.</explanation></question>
        <question>
            <text>'If x=y and y=z then x=z' uses which connective property?</text>
            <option id="A">Transitivity of implication</option><option id="B">Reflexivity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Linking component statements.</explanation></question>
        <question>
            <text>Dual of (p ∧ q ∧ T) is:</text>
            <option id="A">p ∨ q ∨ F</option><option id="B">p ∧ q ∧ F</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>and to or, True to False.</explanation></question>
        <question>
            <text>Method of proof by contradiction assumes ____ is true.</text>
            <option id="A">Negation of conclusion</option><option id="B">Conclusion</option><option id="C">Hypothesis only</option><option id="D">None</option>
            <answer>A</answer><explanation>Assume ~C and find flaw.</explanation></question>
        <question>
            <text>Statement 'p only if q' is symbolic for:</text>
            <option id="A">p ⇒ q</option><option id="B">q ⇒ p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard conditional phrasing.</explanation></question>
        <question>
            <text>Statement 'q if p' is symbolic for:</text>
            <option id="A">p ⇒ q</option><option id="B">q ⇒ p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Reversed order phrasing.</explanation></question>
        <question>
            <text>Statement p: 'Squaring a number is always positive' - Counter example?</text>
            <option id="A">0</option><option id="B">-1</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>0^2 = 0, which is not positive.</explanation></question>
        <question>
            <text>Negation of 'If x belongs to A ∩ B, then x belongs to A and x belongs to B':</text>
            <option id="A">x belongs to A ∩ B and (x doesn't belong to A or x doesn't belong to B).</option><option id="B">x belongs to A ∩ B and x doesn't belong to A.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>p ∧ ~(q ∧ r) = p ∧ (~q ∨ ~r).</explanation></question>
        <question>
            <text>Truth value of (p ∨ ~p) ∧ (q ∨ ~q):</text>
            <option id="A">True always</option><option id="B">False always</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T ∧ T = T.</explanation></question>
        <question>
            <text>Expression ~ (p ∧ q) ∨ q is equivalent to:</text>
            <option id="A">~p ∨ q</option><option id="B">~p ∧ q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>(~p ∨ ~q) ∨ q = ~p ∨ (~q ∨ q) = ~p ∨ T = T. Wait. ~p ∨ q isn't right. It's a tautology.</explanation></question>
        <question>
            <text>Correct result of ~ (p ∧ q) ∨ q is:</text>
            <option id="A">Tautology (Always True)</option><option id="B">~p</option><option id="C">q</option><option id="D">None</option>
            <answer>A</answer><explanation>Logical reduction.</explanation></question>
        <question>
            <text>Simplified form of ~ (p ∨ q) ∨ (~ p ∧ q):</text>
            <option id="A">~p</option><option id="B">~q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>(~p ∧ ~q) ∨ (~p ∧ q) = ~p ∧ (~q ∨ q) = ~p ∧ T = ~p.</explanation></question>
        <question>
            <text>Is (p ⇒ q) ∧ (q ⇒ p) equivalent to p ⇔ q?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Definition of biconditional.</explanation></question>
        <question>
            <text>Which of the following is logically equivalent to ~(p ∨ q)?</text>
            <option id="A">~p ∧ ~q</option><option id="B">p ∧ q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>De Morgan's again.</explanation></question>
        <question>
            <text>The statement (~p ∧ q) ∨ ~q is equivalent to:</text>
            <option id="A">~p ∨ ~q</option><option id="B">p ∧ q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>(~p ∨ ~q) ∧ (q ∨ ~q) = (~p ∨ ~q) ∧ T = ~p ∨ ~q.</explanation></question>
        <question>
            <text>Is 'x+2=2' where x is integer, a statement?</text>
            <option id="A">Yes (because x can only be 0, universally consistent fact? No, x can be any integer). So it varies.</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>B</answer><explanation>Open sentence.</explanation></question>
        <question>
            <text>Negation of 'p ∧ (q ∨ r)':</text>
            <option id="A">~p ∨ (~q ∧ ~r)</option><option id="B">~p ∧ (~q ∨ ~r)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>De Morgan + basic negation.</explanation></question>
        <question>
            <text>Truth value of '3 &lt; 2 or 5 &gt; 4':</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>F ∨ T = T.</explanation></question>
        <question>
            <text>Negation of 'p or q' where p:2+2=4, q:3+3=7:</text>
            <option id="A">2+2 is not 4 and 3+3 is not 7.</option><option id="B">2+2 is 4 and 3+3 is 7.</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>~(p ∨ q) = ~p ∧ ~q.</explanation></question>
        <question>
            <text>Which connective corresponds to 'Unless'?</text>
            <option id="A">Or (p unless q ≡ if not q then p ≡ q or p)</option><option id="B">And</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Logical equivalence of unless.</explanation></question>
        <question>
            <text>A statement involving 'For all' is true if ____ case works.</text>
            <option id="A">All cases work</option><option id="B">One case works</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Universal quantifier condition.</explanation></question>
        <question>
            <text>A statement involving 'There exists' is true if ____ case works.</text>
            <option id="A">At least one case works</option><option id="B">All cases work</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Existential quantifier condition.</explanation></question>
        <question>
            <text>Is (p ∧ q) ⇒ p a tautology?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard simplification rule.</explanation></question>
        <question>
            <text>Is p ⇒ (p ∨ q) a tautology?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard expansion rule.</explanation></question>
        <question>
            <text>Negation of 'Either p or q' generally matches:</text>
            <option id="A">Neither p nor q (~p ∧ ~q)</option><option id="B">Both p and q</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common language to logic mapping.</explanation></question>
        <question>
            <text>Conjunction is equivalent to set theory ____.</text>
            <option id="A">Intersection</option><option id="B">Union</option><option id="C">Complement</option><option id="D">None</option>
            <answer>A</answer><explanation>Common member logic.</explanation></question>
        <question>
            <text>Disjunction is equivalent to set theory ____.</text>
            <option id="A">Union</option><option id="B">Intersection</option><option id="C">Complement</option><option id="D">None</option>
            <answer>A</answer><explanation>Either member logic.</explanation></question>
        <question>
            <text>Negation is equivalent to set theory ____.</text>
            <option id="A">Complement</option><option id="B">Difference</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Opposite member logic.</explanation></question>
        <question>
            <text>Is (p ⇒ q) same as (~q ⇒ ~p)?</text>
            <option id="A">Yes (Contrapositive)</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Logical equivalence check.</explanation></question>
        <question>
            <text>Truth of 'All primes are odd' is:</text>
            <option id="A">False (2 is prime)</option><option id="B">True</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Counter example exists.</explanation></question>
        <question>
            <text>Statement p ∨ q with p=T, q=F is:</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
