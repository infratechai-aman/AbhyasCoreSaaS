<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Chemistry" id="212" name="Hydrocarbons">
    <easy>
        <question>
            <text>Compounds composed entirely of Carbon and Hydrogen are ____.</text>
            <option id="A">Hydrocarbons</option><option id="B">Carbohydrates</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Simplest organic compounds.</explanation></question>
        <question>
            <text>Saturated open chain hydrocarbons are called ____.</text>
            <option id="A">Alkanes</option><option id="B">Alkenes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>General formula CnH2n+2.</explanation></question>
        <question>
            <text>Hydrocarbons containing at least one C=C double bond are ____.</text>
            <option id="A">Alkenes</option><option id="B">Alkanes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>General formula CnH2n.</explanation></question>
        <question>
            <text>Hydrocarbons containing at least one C triple C bond are ____.</text>
            <option id="A">Alkynes</option><option id="B">Alkenes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>General formula CnH2n-2.</explanation></question>
        <question>
            <text>Simplest alkene is ____.</text>
            <option id="A">Ethene (C2H4)</option><option id="B">Methane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Common name Ethylene.</explanation></question>
        <question>
            <text>Simplest alkyne is ____.</text>
            <option id="A">Ethyne (C2H2)</option><option id="B">Propane</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common name Acetylene.</explanation></question>
        <question>
            <text>Alkanes are also known as ____ due to low reactivity.</text>
            <option id="A">Paraffins</option><option id="B">Olefins</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>From Latin 'parum affinis' (little affinity).</explanation></question>
        <question>
            <text>Alkenes are also known as ____ due to oil-forming nature of first members.</text>
            <option id="A">Olefins</option><option id="B">Paraffins</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>From Latin 'oleum' (oil).</explanation></question>
        <question>
            <text>IUPAC name of Isopentane is ____.</text>
            <option id="A">2-Methylbutane</option><option id="B">2,2-Dimethylpropane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Branched isomer of pentane.</explanation></question>
        <question>
            <text>Primary source of alkanes is ____ and natural gas.</text>
            <option id="A">Petroleum</option><option id="B">Coal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fossil fuel derivatives.</explanation></question>
        <question>
            <text>Reduction of alkyl halides with zinc and HCl gives ____.</text>
            <option id="A">Alkanes</option><option id="B">Alcohols</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>R-X + 2H -&gt; R-H + HX.</explanation></question>
        <question>
            <text>Wurtz reaction involves reaction of alkyl halides with ____ in dry ether.</text>
            <option id="A">Sodium (Na) metal</option><option id="B">Zinc</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Couples two alkyl groups.</explanation></question>
        <question>
            <text>Decarboxylation of sodium salt of fatty acid with soda lime (NaOH + CaO) gives ____.</text>
            <option id="A">Alkanes with one less C</option><option id="B">Alcohols</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Removes CO2 as carbonate.</explanation></question>
        <question>
            <text>Electrolysis of aqueous solution of sodium/potassium salt of carboxylic acid to get alkane is ____ method.</text>
            <option id="A">Kolbe's electrolytic</option><option id="B">Wurtz</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Occurs at anode.</explanation></question>
        <question>
            <text>Alkanes are ____ (polar/non-polar) and insoluble in water.</text>
            <option id="A">Non-polar</option><option id="B">Polar</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Held by weak van der Waals forces.</explanation></question>
        <question>
            <text>Boiling point of alkanes ____ as chain length increases.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Surface area increases, increasing dispersion forces.</explanation></question>
        <question>
            <text>Branching ____ the boiling point of isomeric alkanes.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Spherical shape reduces surface area.</explanation></question>
        <question>
            <text>Alkanes burn in air/oxygen to form ____ and ____ (combustion).</text>
            <option id="A">CO2 , H2O</option><option id="B">CO, H2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Highly exothermic process.</explanation></question>
        <question>
            <text>Reaction of alkanes with Halogens in presence of light/heat is ____.</text>
            <option id="A">Substitution / Halogenation</option><option id="B">Addition</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Free radical mechanism.</explanation></question>
        <question>
            <text>Controlled oxidation of methane with copper catalyst at 523 K gives ____.</text>
            <option id="A">Methanol (CH3OH)</option><option id="B">Formaldehyde</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Partial oxidation route.</explanation></question>
        <question>
            <text>Isomerization of n-alkanes to branched alkanes uses ____ as catalyst.</text>
            <option id="A">Anhydrous AlCl3 + HCl</option><option id="B">Ni</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Important for improving octane number of fuel.</explanation></question>
        <question>
            <text>Conversion of n-hexane to Benzene at 773 K over Cr2O3 catalyst is ____.</text>
            <option id="A">Aromatization / Reforming</option><option id="B">Cracking</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Forms aromatic ring from open chain.</explanation></question>
        <question>
            <text>Thermal decomposition of higher alkanes to lower ones is ____.</text>
            <option id="A">Cracking / Pyrolysis</option><option id="B">Combustion</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Breaks C-C and C-H bonds.</explanation></question>
        <question>
            <text>Ethene reacts with H2/Ni to form ____.</text>
            <option id="A">Ethane</option><option id="B">Ethyne</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Addition of dihydrogen.</explanation></question>
        <question>
            <text>Addition of Br2 in CCl4 to an alkene leads to ____ of reddish-orange color.</text>
            <option id="A">Decolorization / Disappearance</option><option id="B">Darkening</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard test for unsaturation.</explanation></question>
        <question>
            <text>Baeyer's reagent is cold dilute alkaline ____ solution.</text>
            <option id="A">KMnO4</option><option id="B">K2Cr2O7</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Pink color disappears on reaction with unsaturation.</explanation></question>
        <question>
            <text>Lindlar's catalyst is palladised charcoal deactivated with ____.</text>
            <option id="A">Quinoline / Sulfur</option><option id="B">Sodium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used for partial reduction of alkynes to cis-alkenes.</explanation></question>
        <question>
            <text>Acetylene reacts with Na metal to release ____ gas.</text>
            <option id="A">Dihydrogen (H2)</option><option id="B">Oxygen</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Shows acidic nature of terminal alkynes.</explanation></question>
        <question>
            <text>Arenes are ____ hydrocarbons.</text>
            <option id="A">Aromatic</option><option id="B">Cycloalkane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Based on benzene ring units.</explanation></question>
        <question>
            <text>Benzene was discovered by ____.</text>
            <option id="A">Michael Faraday</option><option id="B">Kekule</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Isolated from whale oil gas in 1825.</explanation></question>
        <question>
            <text>Proposed oscillating double bond structure of Benzene is named after ____.</text>
            <option id="A">Kekulé</option><option id="B">Huckel</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Explained C6H6 formula and reactivity partially.</explanation></question>
        <question>
            <text>Benzene resists ____ reactions and prefers ____ reactions.</text>
            <option id="A">Addition , Substitution</option><option id="B">Substitution, Addition</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Stability of aromatic sextet.</explanation></question>
        <question>
            <text>Nitrating mixture for Benzene consists of ____ and ____ acids.</text>
            <option id="A">Concentrated HNO3 , Concentrated H2SO4</option><option id="B">HCl, HNO3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Generates nitronium ion (NO2+).</explanation></question>
        <question>
            <text>Friedel-Crafts alkylation of Benzene uses ____ as catalyst.</text>
            <option id="A">Anhydrous AlCl3</option><option id="B">FeCl3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lewis acid catalyst.</explanation></question>
        <question>
            <text>Which hydrocarbon is used for ripening of fruits?</text>
            <option id="A">Ethene / Ethylene</option><option id="B">Ethyne</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Plant hormone.</explanation></question>
        <question>
            <text>Oxy-acetylene flame is used for ____ metal.</text>
            <option id="A">Welding and Cutting</option><option id="B">Painting</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Produces very high temp (approx 3300 C).</explanation></question>
        <question>
            <text>Stability of benzene is approx ____ kJ/mol higher than expected (Resonance Energy).</text>
            <option id="A">150</option><option id="B">50</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Extra stability due to delocalization.</explanation></question>
        <question>
            <text>Huckel's rule: Number of pi electrons for aromaticity = ____.</text>
            <option id="A">4n + 2</option><option id="B">4n</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>n = 0,1,2... (2, 6, 10... electrons).</explanation></question>
        <question>
            <text>Benzene + 3Cl2 in UV light gives ____ (BHC).</text>
            <option id="A">Benzene hexachloride (Gammaxene)</option><option id="B">Chlorobenzene</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used as insecticide.</explanation></question>
        <question>
            <text>Carcinogenic property is shown by some ____ hydrocarbons like benzopyrene.</text>
            <option id="A">Polynuclear aromatic</option><option id="B">Small alkane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Formed by incomplete combustion of organic matter.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Relative stability of alkenes: Trans isomer is ____ stable than Cis isomer.</text>
            <option id="A">More (Less steric hindrance)</option><option id="B">Less</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Groups are farther apart.</explanation></question>
        <question>
            <text>Dipole moment of Trans-but-2-ene is ____.</text>
            <option id="A">Zero</option><option id="B">High</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Symmetric cancellation of bond moments.</explanation></question>
        <question>
            <text>Markovnikov's rule: During addition to unsymmetrical alkene, negative part adds to C with ____ hydrogen atoms.</text>
            <option id="A">Fewer</option><option id="B">More</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Leads to more stable carbocations intermediate.</explanation></question>
        <question>
            <text>Kharasch effect (Peroxide effect) works only for addition of ____.</text>
            <option id="A">HBr</option><option id="B">HCl</option><option id="C">HI</option><option id="D">None</option>
            <answer>A</answer><explanation>Anti-Markovnikov addition through radical mechanism.</explanation></question>
        <question>
            <text>Ozonolysis of Ethene followed by hydrolysis with Zn gives ____.</text>
            <option id="A">Methanal (Formaldehyde)</option><option id="B">Ethanal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cleaves double bond into carbonyl groups.</explanation></question>
        <question>
            <text>Ozonolysis of propene gives ____ and ____.</text>
            <option id="A">Ethanal , Methanal</option><option id="B">Propanal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Uneven cleavage.</explanation></question>
        <question>
            <text>Ethyne on cyclic polymerization in red hot iron tube gives ____.</text>
            <option id="A">Benzene</option><option id="B">Graphite</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>3 molecules of C2H2 trimerize.</explanation></question>
        <question>
            <text>Which of the following has highest acidic hydrogen: Ethane, Ethene, Ethyne?</text>
            <option id="A">Ethyne (due to sp hybridization, high s-character)</option><option id="B">Ethane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Electronegativity of C increases with s-character.</explanation></question>
        <question>
            <text>Reagent used for hydration of ethyne to ethanal (acetaldehyde) is ____.</text>
            <option id="A">Dilute H2SO4 + HgSO4</option><option id="B">H2O</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Specific catalyst for alkyne hydration.</explanation></question>
        <question>
            <text>Kolbe's electrolysis of Sodium Acetate gives ____ at anode.</text>
            <option id="A">Ethane + CO2</option><option id="B">Methane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Radical dimerization.</explanation></question>
        <question>
            <text>Free radical halogenation: Selectivity order of halogens is ____.</text>
            <option id="A">Br2 &gt; Cl2 &gt; F2</option><option id="B">F2 &gt; Cl2 &gt; Br2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Bromine is more selective (Hammond's postulate).</explanation></question>
        <question>
            <text>Order of reactivity of H-atoms in alkanes: ____.</text>
            <option id="A">3° &gt; 2° &gt; 1°</option><option id="B">1° &gt; 2° &gt; 3°</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Based on stability of intermediate radical.</explanation></question>
        <question>
            <text>Sawhorse projection: The front carbon is represented as ____.</text>
            <option id="A">Lower point on diagonal line</option><option id="B">Circle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Visualizes conformations along C-C bond.</explanation></question>
        <question>
            <text>Newman projection: The front carbon is represented as a ____.</text>
            <option id="A">Point / Dot</option><option id="B">Circle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>The rear carbon is the circle.</explanation></question>
        <question>
            <text>Stability: Staggered conformation is ____ stable than Eclipsed.</text>
            <option id="A">More (Minimum torsional strain)</option><option id="B">Less</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Atoms are maximum apart.</explanation></question>
        <question>
            <text>Rotation about C-C single bond is restricted by energy of approx ____ kJ/mol (Torsional strain).</text>
            <option id="A">12 (for ethane)</option><option id="B">100</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Small but significant barrier.</explanation></question>
        <question>
            <text>Presence of -CH3 group in benzene ring is ____ directing for electrophilic substitution.</text>
            <option id="A">Ortho and Para</option><option id="B">Meta</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Activating due to +I and hyperconjugation.</explanation></question>
        <question>
            <text>Presence of -COOH group in benzene ring is ____ directing.</text>
            <option id="A">Meta</option><option id="B">Ortho/Para</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Deactivating due to -M effect.</explanation></question>
        <question>
            <text>Birch reduction of Benzene uses ____ to form cyclohexa-1,4-diene.</text>
            <option id="A">Na / liq NH3 + ROH</option><option id="B">H2/Ni</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Partial reduction of aromatic ring.</explanation></question>
        <question>
            <text>Isopropylbenzene is commonly known as ____.</text>
            <option id="A">Cumene</option><option id="B">Toluene</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Used in commercial phenol synthesis.</explanation></question>
        <question>
            <text>Ethylbenzene on vigorous oxidation with KMnO4 gives ____.</text>
            <option id="A">Benzoic acid</option><option id="B">Acetophenone</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Any alkyl side chain with benzylic H oxidizes to carboxyl.</explanation></question>
        <question>
            <text>Gause-Butane conformation stability order: ____.</text>
            <option id="A">Anti &gt; Gauche &gt; Eclipsed</option><option id="B">Eclipsed &gt; Gauche</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Anti brings bulkier methyls 180 apart.</explanation></question>
        <question>
            <text>Dehydration of Alcohols to alkenes uses ____ as catalyst.</text>
            <option id="A">Concentrated H2SO4 (Heat)</option><option id="B">NaOH</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>E1 / E2 mechanism depending on alcohol type.</explanation></question>
        <question>
            <text>Ease of dehydration of alcohols: ____.</text>
            <option id="A">3° &gt; 2° &gt; 1°</option><option id="B">1° &gt; 2° &gt; 3°</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Reflects stability of carbocations intermediate.</explanation></question>
        <question>
            <text>Addition of HOCl to ethene gives ____.</text>
            <option id="A">Ethylene chlorohydrin [Cl-CH2-CH2-OH]</option><option id="B">Ethyl chloride</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Addition of hypochlorous acid.</explanation></question>
        <question>
            <text>Synthesis of higher alkynes from lower ones involves reaction of sodium acetylide with ____.</text>
            <option id="A">Alkyl Halide</option><option id="B">Alcohol</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Nucleophilic substitution.</explanation></question>
        <question>
            <text>Product of 1,2-dibromoethane reacting with Zn dust? ____.</text>
            <option id="A">Ethene (Vicinal dibromide debromination)</option><option id="B">Ethane</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example of beta-elimination.</explanation></question>
        <question>
            <text>Hydrocarbon progress finalized for Batch 10?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option><option id="D">None</option>
            <answer>A</answer><explanation>Standardizing.</explanation></question>
        <question>
            <text>Which conformer of ethane has highest potential energy?</text>
            <option id="A">Eclipsed</option><option id="B">Staggered</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximum repulsion between electron clouds.</explanation></question>
        <question>
            <text>Which of the following reacts with ammoniacal Silver Nitrate (Tollen's reagent)?</text>
            <option id="A">Ethyne</option><option id="B">Ethene</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Forms white precipitate of silver acetylide.</explanation></question>
        <question>
            <text>Which of the following reacts with ammoniacal Cuprous Chloride?</text>
            <option id="A">Ethyne</option><option id="B">Ethane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Forms red precipitate of copper acetylide.</explanation></question>
        <question>
            <text>Cold dilute alkaline KMnO4 is used to distinguish between ____ and ____.</text>
            <option id="A">Alkanes and Alkenes</option><option id="B">Alkenes and Alkynes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Baeyer's test for unsaturation.</explanation></question>
        <question>
            <text>Which of the following is most stable: 1-butene, cis-2-butene, trans-2-butene?</text>
            <option id="A">trans-2-butene</option><option id="B">cis-2-butene</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Minimal steric repulsion.</explanation></question>
        <question>
            <text>The major product of reaction between propene and HBr in presence of Peroxide is ____.</text>
            <option id="A">1-Bromopropane</option><option id="B">2-Bromopropane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Anti-Markovnikov addition.</explanation></question>
        <question>
            <text>The major product of reaction between propene and HBr (no peroxide) is ____.</text>
            <option id="A">2-Bromopropane</option><option id="B">1-Bromopropane</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Markovnikov addition via 2° carbocation.</explanation></question>
        <question>
            <text>Ozonolysis of 2-butene followed by Zn/H2O gives ____.</text>
            <option id="A">Ethanal (Acetaldehyde)</option><option id="B">Methanal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Two molecules of CH3CHO are formed.</explanation></question>
        <question>
            <text>Addition of H2O to ethyne in presence of HgSO4/H2SO4 gives ____.</text>
            <option id="A">Ethanal</option><option id="B">Ethanol</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Via unstable vinyl alcohol enol.</explanation></question>
        <question>
            <text>Which of the following is used as an anti-knocking agent in petrol?</text>
            <option id="A">Tetraethyl lead (TEL)</option><option id="B">Ethene</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Reduces knocking in IC engines.</explanation></question>
