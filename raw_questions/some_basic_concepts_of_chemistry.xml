<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Chemistry" id="14" name="Some Basic Concepts of Chemistry">
    <easy>
        <question>
            <text>Anything that has mass and occupies space is called:</text>
            <option id="A">Matter</option><option id="B">Energy</option><option id="C">Vacuum</option><option id="D">Force</option>
            <answer>A</answer><explanation>Definition of matter.</explanation>
        </question>
        <question>
            <text>Which state of matter has neither definite shape nor volume?</text>
            <option id="A">Gaseous</option><option id="B">Solid</option><option id="C">Liquid</option><option id="D">None</option>
            <answer>A</answer><explanation>Particles are far apart and move freely.</explanation>
        </question>
        <question>
            <text>Substances consisting of only one type of particles are:</text>
            <option id="A">Pure substances</option><option id="B">Mixtures</option><option id="C">Solutions</option><option id="D">Colloids</option>
            <answer>A</answer><explanation>Includes elements and compounds.</explanation>
        </question>
        <question>
            <text>The SI unit of amount of substance is:</text>
            <option id="A">Mole</option><option id="B">Gram</option><option id="C">Kilogram</option><option id="D">Liter</option>
            <answer>A</answer><explanation>Symbol: mol.</explanation>
        </question>
        <question>
            <text>Avogadro's number (Na) is approximately:</text>
            <option id="A">6.022 x 10^23</option><option id="B">6.626 x 10^-34</option><option id="C">3.0 x 10^8</option><option id="D">None</option>
            <answer>A</answer><explanation>Number of entities in 1 mole.</explanation>
        </question>
        <question>
            <text>The mass of one mole of a substance in grams is its:</text>
            <option id="A">Molar mass</option><option id="B">Atomic mass</option><option id="C">Molecular mass</option><option id="D">Formula mass</option>
            <answer>A</answer><explanation>Expressed in g/mol.</explanation>
        </question>
        <question>
            <text>Standard temperature and pressure (STP) for gases (modern) is:</text>
            <option id="A">273.15 K and 1 bar</option><option id="B">298 K and 1 atm</option><option id="C">0 K and 1 bar</option><option id="D">None</option>
            <answer>A</answer><explanation>Current IUPAC standard.</explanation>
        </question>
        <question>
            <text>Molar volume of an ideal gas at STP (old, 1 atm) is:</text>
            <option id="A">22.4 L</option><option id="B">22.7 L</option><option id="C">24.0 L</option><option id="D">None</option>
            <answer>A</answer><explanation>Commonly used in textbooks.</explanation>
        </question>
        <question>
            <text>Which of the following is a homogeneous mixture?</text>
            <option id="A">Air</option><option id="B">Soil</option><option id="C">Sand and Water</option><option id="D">Oil and Water</option>
            <answer>A</answer><explanation>Composition is uniform throughout.</explanation>
        </question>
        <question>
            <text>A solution with uniform composition is called:</text>
            <option id="A">Homogeneous</option><option id="B">Heterogeneous</option><option id="C">Suspension</option><option id="D">None</option>
            <answer>A</answer><explanation>Components are indistinguishable.</explanation>
        </question>
        <question>
            <text>Rounding off 3.465 to two decimal places is:</text>
            <option id="A">3.46</option><option id="B">3.47</option><option id="C">3.5</option><option id="D">None</option>
            <answer>A</answer><explanation>Rule for 5: round to even digit.</explanation>
        </question>
        <question>
            <text>Significant figures in 0.0025 are:</text>
            <option id="A">2</option><option id="B">4</option><option id="C">5</option><option id="D">None</option>
            <answer>A</answer><explanation>Leading zeros are not significant.</explanation>
        </question>
        <question>
            <text>Prefix 'nano' represents:</text>
            <option id="A">10^-9</option><option id="B">10^-6</option><option id="C">10^-12</option><option id="D">10^9</option>
            <answer>A</answer><explanation>Common scale in chemistry.</explanation>
        </question>
        <question>
            <text>Atomic mass unit (amu) is now called:</text>
            <option id="A">Unified mass (u)</option><option id="B">Dalton</option><option id="C">Gram</option><option id="D">Newton</option>
            <answer>A</answer><explanation>Standard international term.</explanation>
        </question>
        <question>
            <text>Relative atomic mass is a ____ quantity.</text>
            <option id="A">Dimensionless</option><option id="B">Mass-defined</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ratio of two masses.</explanation>
        </question>
        <question>
            <text>Empirical formula represents the ____ ratio of atoms.</text>
            <option id="A">Simplest whole number</option><option id="B">Actual number</option><option id="C">Mass</option><option id="D">Size</option>
            <answer>A</answer><explanation>Basic chemical identity.</explanation>
        </question>
        <question>
            <text>Molecular formula relates to Empirical formula (EF) by:</text>
            <option id="A">MF = n x EF</option><option id="B">MF = EF / n</option><option id="C">MF = n + EF</option><option id="D">None</option>
            <answer>A</answer><explanation>n is a whole number factor.</explanation>
        </question>
        <question>
            <text>Sum of atomic masses in a molecule is its:</text>
            <option id="A">Molecular mass</option><option id="B">Formula mass</option><option id="C">Mole</option><option id="D">None</option>
            <answer>A</answer><explanation>Calculated in u.</explanation>
        </question>
        <question>
            <text>Molarity (M) is moles of solute per ____ of solution.</text>
            <option id="A">Liter</option><option id="B">Kilogram</option><option id="C">Milliliter</option><option id="D">None</option>
            <answer>A</answer><explanation>Volume based concentration.</explanation>
        </question>
        <question>
            <text>Molality (m) is moles of solute per ____ of solvent.</text>
            <option id="A">Kilogram</option><option id="B">Liter</option><option id="C">Gram</option><option id="D">None</option>
            <answer>A</answer><explanation>Mass based concentration.</explanation>
        </question>
        <question>
            <text>Which concentration term is independent of temperature?</text>
            <option id="A">Molality</option><option id="B">Molarity</option><option id="C">Normality</option><option id="D">Formality</option>
            <answer>A</answer><explanation>Mass does not change with temperature.</explanation>
        </question>
        <question>
            <text>Law of Conservation of Mass was proposed by:</text>
            <option id="A">Antoine Lavoisier</option><option id="B">John Dalton</option><option id="C">Joseph Proust</option><option id="D">None</option>
            <answer>A</answer><explanation>Matter is neither created nor destroyed.</explanation>
        </question>
        <question>
            <text>Law of Definite Proportions was proposed by:</text>
            <option id="A">Joseph Proust</option><option id="B">Lavoisier</option><option id="C">Dalton</option><option id="D">None</option>
            <answer>A</answer><explanation>Compound always has same elements in same mass ratio.</explanation>
        </question>
        <question>
            <text>Law of Multiple Proportions was proposed by:</text>
            <option id="A">John Dalton</option><option id="B">Gay-Lussac</option><option id="C">Avogadro</option><option id="D">None</option>
            <answer>A</answer><explanation>Ratios of masses are small whole numbers.</explanation>
        </question>
        <question>
            <text>Gay-Lussac's Law deals with ____ of reacting gases.</text>
            <option id="A">Volumes</option><option id="B">Masses</option><option id="C">Temperatures</option><option id="D">None</option>
            <answer>A</answer><explanation>At same temperature and pressure.</explanation>
        </question>
        <question>
            <text>Combining volumes of gases follow small whole number ratios. This is:</text>
            <option id="A">Gay-Lussac's Law</option><option id="B">Avogadro's Law</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Specific to gaseous reactants.</explanation>
        </question>
        <question>
            <text>Equal volumes of all gases contain equal moles at same T and P. This is:</text>
            <option id="A">Avogadro's Law</option><option id="B">Dalton's Law</option><option id="C">Boyles Law</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental gas hypothesis.</explanation>
        </question>
        <question>
            <text>The reactant that is consumed completely in a reaction is:</text>
            <option id="A">Limiting reagent</option><option id="B">Excess reagent</option><option id="C">Catalyst</option><option id="D">Buffer</option>
            <answer>A</answer><explanation>Determines the amount of product.</explanation>
        </question>
        <question>
            <text>Mole fraction of a component is ratio of its moles to:</text>
            <option id="A">Total moles of solution</option><option id="B">Moles of solvent</option><option id="C">100</option><option id="D">None</option>
            <answer>A</answer><explanation>Dimensionless unit.</explanation>
        </question>
        <question>
            <text>Sum of mole fractions of all components is always:</text>
            <option id="A">1</option><option id="B">0</option><option id="C">100</option><option id="D">None</option>
            <answer>A</answer><explanation>Definition check.</explanation>
        </question>
        <question>
            <text>SI unit of Density is:</text>
            <option id="A">kg/m3</option><option id="B">g/cm3</option><option id="C">kg/L</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard SI units for mass and volume.</explanation>
        </question>
        <question>
            <text>Mass percentage of an element is (mass of element / ____) x 100.</text>
            <option id="A">Molar mass of compound</option><option id="B">Atomic mass</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Part of composite mass.</explanation>
        </question>
        <question>
            <text>Density is an ____ property.</text>
            <option id="A">Intensive</option><option id="B">Extensive</option><option id="C">Variable</option><option id="D">None</option>
            <answer>A</answer><explanation>Independent of amount of substance.</explanation>
        </question>
        <question>
            <text>1 Liter is equal to how many dm3?</text>
            <option id="A">1</option><option id="B">10</option><option id="C">100</option><option id="D">1000</option>
            <answer>A</answer><explanation>Definition of decimeter cube.</explanation>
        </question>
        <question>
            <text>The term 'precision' refers to:</text>
            <option id="A">Closeness of various measurements for same quantity</option><option id="B">Closeness to true value</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Consistency of results.</explanation>
        </question>
        <question>
            <text>Atomic theory was first proposed by:</text>
            <option id="A">John Dalton (1808)</option><option id="B">Thomson</option><option id="C">Rutherford</option><option id="D">Bohr</option>
            <answer>A</answer><explanation>Scientific start of atomic concept.</explanation>
        </question>
        <question>
            <text>Atoms of different elements combine in ____ ratio to form compounds.</text>
            <option id="A">Simple whole number</option><option id="B">Fractional</option><option id="C">Arbitrary</option><option id="D">None</option>
            <answer>A</answer><explanation>Key postulate of Dalton.</explanation>
        </question>
        <question>
            <text>Matter can neither be created nor destroyed. This is:</text>
            <option id="A">Law of conservation of mass</option><option id="B">Law of multiple proportions</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Chemical change mass balance.</explanation>
        </question>
        <question>
            <text>Mass of 1 hydrogen atom in grams is approximately:</text>
            <option id="A">1.67 x 10^-24 g</option><option id="B">1.67 x 10^-27 g</option><option id="C">1 g</option><option id="D">None</option>
            <answer>A</answer><explanation>Calculated from Avogadro number.</explanation>
        </question>
        <question>
            <text>Relative density has unit:</text>
            <option id="A">No unit</option><option id="B">g/cm3</option><option id="C">kg/m3</option><option id="D">None</option>
            <answer>A</answer><explanation>It is a ratio.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Calculate the number of moles in 52g of Helium:</text>
            <option id="A">13</option><option id="B">26</option><option id="C">52</option><option id="D">4</option>
            <answer>A</answer><explanation>52 / 4 (Molar mass of He).</explanation>
        </question>
        <question>
            <text>Number of atoms in 0.1 mol of a triatomic gas is:</text>
            <option id="A">1.806 x 10^23</option><option id="B">6.022 x 10^22</option><option id="C">3 x 10^23</option><option id="D">None</option>
            <answer>A</answer><explanation>0.1 x 3 x Na.</explanation>
        </question>
        <question>
            <text>Percentage of Oxygen in water (H2O) is approximately:</text>
            <option id="A">88.89%</option><option id="B">11.11%</option><option id="C">50%</option><option id="D">33%</option>
            <answer>A</answer><explanation>(16 / 18) x 100.</explanation>
        </question>
        <question>
            <text>The empirical formula of Benzene (C6H6) is:</text>
            <option id="A">CH</option><option id="B">CH2</option><option id="C">C3H3</option><option id="D">None</option>
            <answer>A</answer><explanation>Simplest ratio is 1:1.</explanation>
        </question>
        <question>
            <text>Which of the following has maximum number of molecules?</text>
            <option id="A">1g H2</option><option id="B">1g N2</option><option id="C">1g CO2</option><option id="D">1g O2</option>
            <answer>A</answer><explanation>Smallest molar mass gives more moles for same mass.</explanation>
        </question>
        <question>
            <text>Molarity of solution containing 4g NaOH in 250mL solution:</text>
            <option id="A">0.4 M</option><option id="B">0.1 M</option><option id="C">1.0 M</option><option id="D">None</option>
            <answer>A</answer><explanation>(4/40) / 0.250.</explanation>
        </question>
        <question>
            <text>What volume of 10M HCl is needed to make 1L of 1M HCl?</text>
            <option id="A">100 mL</option><option id="B">10 mL</option><option id="C">500 mL</option><option id="D">None</option>
            <answer>A</answer><explanation>M1V1 = M2V2.</explanation>
        </question>
        <question>
            <text>Total number of electrons in 1.6g of CH4 is:</text>
            <option id="A">6.022 x 10^23 (Na)</option><option id="B">1.6 x Na</option><option id="C">10 x Na</option><option id="D">None</option>
            <answer>A</answer><explanation>0.1 mol x 10 electrons/molecule x Na.</explanation>
        </question>
        <question>
            <text>Mass of one atom of C-12 is exactly:</text>
            <option id="A">12 u</option><option id="B">12 g</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>By definition of atomic mass scale.</explanation>
        </question>
        <question>
            <text>How many entities in 1 mol of any substance?</text>
            <option id="A">Avogadro number</option><option id="B">Depends on identity</option><option id="C">Molar mass</option><option id="D">None</option>
            <answer>A</answer><explanation>Fixed constant value.</explanation>
        </question>
        <question>
            <text>CO2 produced by burning 12g C in 32g O2:</text>
            <option id="A">44 g</option><option id="B">12 g</option><option id="C">32 g</option><option id="D">None</option>
            <answer>A</answer><explanation>12 + 32 = 44 (Stoichiometry).</explanation>
        </question>
        <question>
            <text>Mass percentage of Copper in CuSO4.5H2O is approximately:</text>
            <option id="A">25.4%</option><option id="B">50%</option><option id="C">10%</option><option id="D">None</option>
            <answer>A</answer><explanation>63.5 / 249.5 x 100.</explanation>
        </question>
        <question>
            <text>Molar mass of CO2 is 44. Mass of 1 molecule in grams is:</text>
            <option id="A">44 / Na</option><option id="B">44</option><option id="C">Na / 44</option><option id="D">None</option>
            <answer>A</answer><explanation>Total mass / count.</explanation>
        </question>
        <question>
            <text>The standard for atomic mass is:</text>
            <option id="A">C-12</option><option id="B">H-1</option><option id="C">O-16</option><option id="D">None</option>
            <answer>A</answer><explanation>Unified atomic mass definition.</explanation>
        </question>
        <question>
            <text>Gram atomic mass of Hydrogen is:</text>
            <option id="A">1.008 g</option><option id="B">1.008 u</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mass of 1 mole of atoms.</explanation>
        </question>
        <question>
            <text>Definition of Density is Ratio of:</text>
            <option id="A">Mass / Volume</option><option id="B">Volume / Mass</option><option id="C">Mass x Volume</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental physical property.</explanation>
        </question>
        <question>
            <text>1 ppm is equivalent to:</text>
            <option id="A">1 mg per kg</option><option id="B">1 g per kg</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Concentration part per million.</explanation>
        </question>
        <question>
            <text>Molarity of pure water (density 1g/mL) is:</text>
            <option id="A">55.5 M</option><option id="B">18 M</option><option id="C">100 M</option><option id="D">None</option>
            <answer>A</answer><explanation>1000 / 18 moles per liter.</explanation>
        </question>
        <question>
            <text>Ratio of atoms in Glucose C6H12O6 is C:H:O =:</text>
            <option id="A">1 : 2 : 1</option><option id="B">1 : 1 : 1</option><option id="C">6 : 12 : 6</option><option id="D">None</option>
            <answer>A</answer><explanation>Empirical ratio.</explanation>
        </question>
        <question>
            <text>Molar mass of Glucose C6H12O6:</text>
            <option id="A">180 g/mol</option><option id="B">342 g/mol</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sum of atomic masses.</explanation>
        </question>
        <question>
            <text>Molality of 10% (w/w) NaOH aqueous solution:</text>
            <option id="A">2.77 m</option><option id="B">1.0 m</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>(10/40) / 0.090 kg water.</explanation>
        </question>
        <question>
            <text>Volume of 1 mole solid NaCl vs 1 mole gas at STP:</text>
            <option id="A">Solid volume &lt;&lt; Gas volume</option><option id="B">Equal</option><option id="C">Solid &gt; Gas</option><option id="D">None</option>
            <answer>A</answer><explanation>Gases expand to fill space.</explanation>
        </question>
        <question>
            <text>Unit of molality is:</text>
            <option id="A">mol/kg</option><option id="B">mol/L</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Moles per mass of solvent.</explanation>
        </question>
        <question>
            <text>Normality (N) equals Molarity (M) x ____.</text>
            <option id="A">Valency factor (n)</option><option id="B">Mass</option><option id="C">Volume</option><option id="D">None</option>
            <answer>A</answer><explanation>Relationship for equivalents.</explanation>
        </question>
        <question>
            <text>N2 + 3H2 -&gt; 2NH3. Volume ratio of reactants N2 and H2:</text>
            <option id="A">1 : 3</option><option id="B">1 : 1</option><option id="C">3 : 2</option><option id="D">None</option>
            <answer>A</answer><explanation>According to Gay-Lussac.</explanation>
        </question>
        <question>
            <text>Significant figures in 4.008 are:</text>
            <option id="A">4</option><option id="B">2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Captured zeros are significant.</explanation>
        </question>
        <question>
            <text>Symbol for Molarity is M and for Molality is:</text>
            <option id="A">m</option><option id="B">Mo</option><option id="C">Ml</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard convention.</explanation>
        </question>
        <question>
            <text>If density of gas is d at STP, molar mass M = d x ____.</text>
            <option id="A">22.4</option><option id="B">1</option><option id="C">100</option><option id="D">None</option>
            <answer>A</answer><explanation>Volume of 1 mole.</explanation>
        </question>
        <question>
            <text>Dalton's Partial Pressure Law relates to ____ gases.</text>
            <option id="A">Non-reacting mixture of gases</option><option id="B">Reacting gases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Independent partial pressures.</explanation>
        </question>
        <question>
            <text>Law of Reciprocal Proportions involves ____ elements.</text>
            <option id="A">Three</option><option id="B">Two</option><option id="C">Four</option><option id="D">None</option>
            <answer>A</answer><explanation>Richter's contribution.</explanation>
        </question>
        <question>
            <text>Maximum molecules in 1 mole of any substance is always:</text>
            <option id="A">Na (Fixed)</option><option id="B">Varies</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Definition of mole.</explanation>
        </question>
        <question>
            <text>Avogadro hypothesis states equal V of gases have equal ____.</text>
            <option id="A">Molecules</option><option id="B">Mass</option><option id="C">Atoms</option><option id="D">None</option>
            <answer>A</answer><explanation>At same T and P.</explanation>
        </question>
        <question>
            <text>Rounding off 0.04597 to 3 significant figures is:</text>
            <option id="A">0.0460</option><option id="B">0.046</option><option id="C">0.0459</option><option id="D">None</option>
            <answer>A</answer><explanation>Leading zeros not counted. Next digit rounds up.</explanation>
        </question>
        <question>
            <text>1 unified mass (u) is approximately ____ kg.</text>
            <option id="A">1.66 x 10^-27</option><option id="B">1.66 x 10^-24</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>SI mass unit conversion.</explanation>
        </question>
        <question>
            <text>Molecular mass of cane sugar C12H22O11:</text>
            <option id="A">342 u</option><option id="B">180 u</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sum of 12(12) + 22(1) + 11(16).</explanation>
        </question>
        <question>
            <text>Mass of one atom of Oxygen is approximately:</text>
            <option id="A">2.66 x 10^-23 g</option><option id="B">16 g</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>16 / Na.</explanation>
        </question>
