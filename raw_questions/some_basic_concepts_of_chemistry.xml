            <text>Cl has mass 35.5 because of isotopes:</text>
            <option id="A">35 and 37</option><option id="B">34 and 36</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ratio approx 3:1.</explanation>
        </question>
        <question>
            <text>Dulong and Petit's Law relates atomic mass to ____.</text>
            <option id="A">Specific heat of solid elements</option><option id="B">Gas volume</option><option id="C">Color</option><option id="D">None</option>
            <answer>A</answer><explanation>Product approx 6.4.</explanation>
        </question>
        <question>
            <text>Empirical formula mass of glucose vs molecular mass ratio:</text>
            <option id="A">1 : 6</option><option id="B">1 : 1</option><option id="C">6 : 1</option><option id="D">None</option>
            <answer>A</answer><explanation>30 vs 180.</explanation>
        </question>
