        </question>
        <question>
            <text>Heavy water is ____.</text>
            <option id="A">D2O</option><option id="B">H2O2</option><option id="C">T2O</option><option id="D">None</option>
            <answer>A</answer><explanation>Used as moderator in nuclear reactors.</explanation>
