        <question>
            <text>Hung weightless wire stress max location is ____.</text>
            <option id="A">Suspension point</option><option id="B">Free end</option>
            <answer>A</answer><explanation>Carries entire weight there.</explanation></question>
        <question>
            <text>Solid internal pressure numerical relation is to ____.</text>
            <option id="A">Bulk Modulus</option><option id="B">Shear Modulus</option>
            <answer>A</answer><explanation>Resistance to volume change.</explanation></question>
        <question>
            <text>Hollow cylinder torque formula includes ____ factor.</text>
            <option id="A">R^3 t</option><option id="B">R^2</option>
            <answer>A</answer><explanation>Thin-walled approximation.</explanation></question>
        <question>
            <text>Incompressible fluid limit for Poisson's ratio is ____.</text>
            <option id="A">0.5</option><option id="B">0</option>
            <answer>A</answer><explanation>Bulk modulus infinity result.</explanation></question>
        <question>
            <text>Linear elasticity mass stretching mass-extension relation is ____.</text>
            <option id="A">Directly proportional</option><option id="B">Inverse</option>
            <answer>A</answer><explanation>Hooke's Law application.</explanation></question>
        <question>
            <text>Cube to parallelepiped transformation modulus is ____.</text>
            <option id="A">Shear</option><option id="B">Young's</option>
            <answer>A</answer><explanation>Rigidity definition.</explanation></question>
        <question>
            <text>Physics elasticity meaning is ____.</text>
            <option id="A">Resistance to deformation</option><option id="B">Stretchability</option>
            <answer>A</answer><explanation>Opposite of common usage.</explanation></question>
        <question>
            <text>Internal energy increase equals work only if process is ____.</text>
            <option id="A">Isothermal and slow</option><option id="B">Fast</option>
            <answer>A</answer><explanation>Avoids heat generation losses.</explanation></question>
        <question>
            <text>Adiabatic vs Isothermal Bulk Modulus relationship is ____.</text>
            <option id="A">K_ad = gamma K_iso</option><option id="B">Equal</option>
            <answer>A</answer><explanation>Gas thermal resistance property.</explanation></question>
        <question>
            <text>Self-weight wire extension factor at denominator is ____.</text>
            <option id="A">2 A Y</option><option id="B">A Y</option>
            <answer>A</answer><explanation>Due to average tension being half.</explanation></question>
        <question>
            <text>Cutting wire to half sustains ____ weight before breaking.</text>
            <option id="A">Same</option><option id="B">Half</option>
            <answer>A</answer><explanation>Property only of area.</explanation></question>
        <question>
            <text>Compressibility measures volume ____.</text>
            <option id="A">Flexibility</option><option id="B">Hardness</option>
            <answer>A</answer><explanation>Reciprocal of stiffness.</explanation></question>
        <question>
            <text>Poisson's limit stable equilibrium condition range is ____.</text>
            <option id="A">-1 to 0.5</option><option id="B">0 to 1</option>
            <answer>A</answer><explanation>Mathematical thermodynamic limit.</explanation></question>
        <question>
            <text>Beam bending deflection delta proportional to ____.</text>
            <option id="A">L^3</option><option id="B">L</option>
            <answer>A</answer><explanation>Euler-Bernoulli beam theory.</explanation></question>
        <question>
            <text>Hydraulic stress equivalent is ____.</text>
            <option id="A">Pressure change</option><option id="B">Buoyancy</option>
            <answer>A</answer><explanation>Uniform compression origin.</explanation></question>
