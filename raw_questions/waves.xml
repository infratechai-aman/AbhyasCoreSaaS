<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="114" name="Waves">
    <easy>
        <question>
            <text>Disturbance that travels through a medium transferring energy without matter transport is a ____.</text>
            <option id="A">Wave</option><option id="B">Particle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental mechanism of energy transfer.</explanation>
        </question>
        <question>
            <text>Waves that require a material medium for propagation are ____ waves.</text>
            <option id="A">Mechanical</option><option id="B">Electromagnetic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Examples: Sound, Water waves.</explanation>
        </question>
        <question>
            <text>Waves that can travel through vacuum are ____ waves.</text>
            <option id="A">Electromagnetic</option><option id="B">Mechanical</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Light, X-rays, Radio waves.</explanation>
        </question>
        <question>
            <text>Wave where particles vibrate perpendicular to the direction of wave travel is ____ wave.</text>
            <option id="A">Transverse</option><option id="B">Longitudinal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Seen in light and string waves.</explanation>
        </question>
        <question>
            <text>Wave where particles vibrate parallel to the direction of wave travel is ____ wave.</text>
            <option id="A">Longitudinal</option><option id="B">Transverse</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Sound waves are longitudinal.</explanation>
        </question>
        <question>
            <text>Distance between two consecutive points in same phase (e.g. crest to next crest) is ____.</text>
            <option id="A">Wavelength (λ)</option><option id="B">Amplitude</option><option id="C">Frequency</option><option id="D">None</option>
            <answer>A</answer><explanation>Spatial period of the wave.</explanation>
        </question>
        <question>
            <text>Number of wave cycles passing a point per unit time is ____.</text>
            <option id="A">Frequency (f)</option><option id="B">Wavelength</option><option id="C">Time Period</option><option id="D">None</option>
            <answer>A</answer><explanation>Unit is Hz.</explanation>
        </question>
        <question>
            <text>Wave speed v is related to frequency f and wavelength λ by v = ____.</text>
            <option id="A">f λ</option><option id="B">f / λ</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Fundamental wave equation.</explanation>
        </question>
        <question>
            <text>Highest point of a transverse wave is ____.</text>
            <option id="A">Crest</option><option id="B">Trough</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximum positive displacement.</explanation>
        </question>
        <question>
            <text>Lowest point of a transverse wave is ____.</text>
            <option id="A">Trough</option><option id="B">Crest</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximum negative displacement.</explanation>
        </question>
        <question>
            <text>Regions of high pressure and density in longitudinal waves are ____.</text>
            <option id="A">Compressions</option><option id="B">Rarefactions</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equivalent to crests.</explanation>
        </question>
        <question>
            <text>Regions of low pressure and density in longitudinal waves are ____.</text>
            <option id="A">Rarefactions</option><option id="B">Compressions</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equivalent to troughs.</explanation>
        </question>
        <question>
            <text>Speed of sound in air at STP is approx ____ m/s.</text>
            <option id="A">331 / 340</option><option id="B">1500</option><option id="C">3 x 10^8</option><option id="D">None</option>
            <answer>A</answer><explanation>Depends on temperature and medium.</explanation>
        </question>
        <question>
            <text>Sound waves cannot travel through ____.</text>
            <option id="A">Vacuum</option><option id="B">Water</option><option id="C">Steel</option><option id="D">None</option>
            <answer>A</answer><explanation>Requires material medium for compression-rarefaction.</explanation>
        </question>
        <question>
            <text>Human audible frequency range is approx ____ Hz to ____ Hz.</text>
            <option id="A">20 - 20,000</option><option id="B">0 - 100</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Varies with age and health.</explanation>
        </question>
        <question>
            <text>Sound waves below 20 Hz are ____.</text>
            <option id="A">Infrasonic</option><option id="B">Ultrasonic</option><option id="C">Audible</option><option id="D">None</option>
            <answer>A</answer><explanation>Used by elephants and for seismic study.</explanation>
        </question>
        <question>
            <text>Sound waves above 20,000 Hz are ____.</text>
            <option id="A">Ultrasonic</option><option id="B">Infrasonic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Used in bats' sonar and ultrasound imaging.</explanation>
        </question>
        <question>
            <text>The parameter 'k' in wave equation y = A sin(kx - ωt) is ____.</text>
            <option id="A">Wave Number (Prop. constant)</option><option id="B">Spring constant</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>k = 2π / λ.</explanation>
        </question>
        <question>
            <text>Apparent change in frequency due to relative motion between source and observer is ____ Effect.</text>
            <option id="A">Doppler</option><option id="B">Photoelectric</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used in radar and astronomy.</explanation>
        </question>
        <question>
            <text>Result of superposition of two waves of slightly different frequencies is ____.</text>
            <option id="A">Beats</option><option id="B">Interference</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Waxing and waning of sound intensity.</explanation>
        </question>
        <question>
            <text>Beat frequency f_beat = ____.</text>
            <option id="A">|f1 - f2|</option><option id="B">f1 + f2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Difference of frequencies.</explanation>
        </question>
        <question>
            <text>Points of zero amplitude in a stationary wave are ____.</text>
            <option id="A">Nodes</option><option id="B">Antinodes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Destructive interference always.</explanation>
        </question>
        <question>
            <text>Points of maximum amplitude in a stationary wave are ____.</text>
            <option id="A">Antinodes</option><option id="B">Nodes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Constructive interference always.</explanation>
        </question>
        <question>
            <text>Distance between two consecutive nodes is ____.</text>
            <option id="A">λ / 2</option><option id="B">λ</option><option id="C">λ / 4</option><option id="D">None</option>
            <answer>A</answer><explanation>Half wavelength.</explanation>
        </question>
        <question>
            <text>Distance between a node and adjacent antinode is ____.</text>
            <option id="A">λ / 4</option><option id="B">λ / 2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Quarter wavelength.</explanation>
        </question>
        <question>
            <text>Tuning fork frequency is increased by ____.</text>
            <option id="A">Filing the prongs</option><option id="B">Loading with wax</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Reduces mass, increases frequency.</explanation>
        </question>
        <question>
            <text>Tuning fork frequency is decreased by ____.</text>
            <option id="A">Loading with wax</option><option id="B">Filing</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Increases inertia.</explanation>
        </question>
        <question>
            <text>Echo is heard if reflector is at least ____ m away (for 0.1s persistence).</text>
            <option id="A">17 (approx)</option><option id="B">100</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Based on v = 340 m/s: 2d = v * 0.1.</explanation>
        </question>
        <question>
            <text>Property of matter that allows waves to propagate is ____.</text>
            <option id="A">Elasticity and Inertia</option><option id="B">Density only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Required to store and transfer KE/PE.</explanation>
        </question>
        <question>
            <text>Newton's formula for sound speed in gas v = ____.</text>
            <option id="A">sqrt(P / ρ)</option><option id="B">sqrt(γ P / ρ)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Assuming isothermal process (erroneous).</explanation>
        </question>
        <question>
            <text>Laplace's correction to sound speed v = ____.</text>
            <option id="A">sqrt(γ P / ρ)</option><option id="B">sqrt(P / ρ)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Assuming adiabatic process (correct).</explanation>
        </question>
        <question>
            <text>Stationary waves ____ transfer energy.</text>
            <option id="A">Do not (net zero)</option><option id="B">Do</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Energy is trapped between nodes.</explanation>
        </question>
        <question>
            <text>Open pipe has antinodes at ____ ends.</text>
            <option id="A">Both</option><option id="B">Closed one</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pressure is atmospheric there.</explanation>
        </question>
        <question>
            <text>Closed pipe (one end) has node at ____ end.</text>
            <option id="A">Closed</option><option id="B">Open</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Bound boundary condition.</explanation>
        </question>
        <question>
            <text>Fundamental frequency of open organ pipe f1 = ____.</text>
            <option id="A">v / 2L</option><option id="B">v / 4L</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>L = λ/2.</explanation>
        </question>
        <question>
            <text>Fundamental frequency of closed organ pipe f1 = ____.</text>
            <option id="A">v / 4L</option><option id="B">v / 2L</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>L = λ/4.</explanation>
        </question>
        <question>
            <text>Open pipe contains ____ harmonics.</text>
            <option id="A">All (odd and even)</option><option id="B">Only odd</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>1f, 2f, 3f...</explanation>
        </question>
        <question>
            <text>Closed pipe contains ____ harmonics.</text>
            <option id="A">Only odd</option><option id="B">All</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1f, 3f, 5f...</explanation>
        </question>
        <question>
            <text>A wave reflects from a denser medium boundary with a phase change of ____.</text>
            <option id="A">π (180 deg)</option><option id="B">0</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equivalent to inversion.</explanation>
        </question>
        <question>
            <text>A wave reflects from a rarer medium/free boundary with phase change of ____.</text>
            <option id="A">0</option><option id="B">π</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No inversion.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Intensity of wave I ∝ ____.</text>
            <option id="A">Amplitude^2 (A^2)</option><option id="B">Frequency</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Also proportional to frequency^2.</explanation>
        </question>
        <question>
            <text>Velocity of wave on a stretched string v = ____.</text>
            <option id="A">sqrt(T / μ)</option><option id="B">sqrt(T x μ)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>T is tension, μ is mass per unit length.</explanation>
        </question>
        <question>
            <text>For a given string, frequency ∝ ____ proportional to length.</text>
            <option id="A">Inversely</option><option id="B">Directly</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Law of lengths: fL = constant.</explanation>
        </question>
        <question>
            <text>In sound propagation, what happens to speed if temperature increases?</text>
            <option id="A">Increases (v ∝ sqrt(T))</option><option id="B">Decreases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Molecules have more kinetic energy.</explanation>
        </question>
        <question>
            <text>Effect of humidity on sound speed: speed ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">Remains same</option><option id="D">None</option>
            <answer>A</answer><explanation>Humid air is less dense than dry air.</explanation>
        </question>
        <question>
            <text>Sound speed is independent of ____ at constant temperature.</text>
            <option id="A">Pressure</option><option id="B">Density change alone</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>P/ρ ratio remains constant for ideal gas.</explanation>
        </question>
        <question>
            <text>Superposition Principle: y_total = ____.</text>
            <option id="A">y1 + y2 + ...</option><option id="B">y1 x y2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Vector sum of displacements.</explanation>
        </question>
        <question>
            <text>If two waves of same frequency and amplitude interfere constructively, max amplitude is ____.</text>
            <option id="A">2A</option><option id="B">A</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Phase diff = 0.</explanation>
        </question>
        <question>
            <text>If two waves interfere destructively (phase diff π), min amplitude is ____.</text>
            <option id="A">0</option><option id="B">A</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>They cancel each other.</explanation>
        </question>
        <question>
            <text>In stationary waves, particles between two nodes have ____ phase.</text>
            <option id="A">Same</option><option id="B">Different</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Move up and down together.</explanation>
        </question>
        <question>
            <text>End correction 'e' for open pipe of radius r is approx ____.</text>
            <option id="A">0.6 r per end (total 1.2r)</option><option id="B">0.3 r</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Effective length L' = L + 2e.</explanation>
        </question>
        <question>
            <text>Reverberation refers to persistence of sound due to ____.</text>
            <option id="A">Multiple reflections</option><option id="B">Absorption</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Time taken for sound to decay by 60 dB.</explanation>
        </question>
        <question>
            <text>Shock waves are produced by objects moving at ____ speed.</text>
            <option id="A">Supersonic (v > v_sound)</option><option id="B">Subsonic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Conical wave front (Mach cone).</explanation>
        </question>
        <question>
            <text>Transverse waves can propagate through liquids?</text>
            <option id="A">No (unless surface waves / tension)</option><option id="B">Yes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Bulk liquids don't support shear.</explanation>
        </question>
        <question>
            <text>Wave equation y = A sin[2π(t/T - x/λ)]. Velocity of particle v_p = ____.</text>
            <option id="A">dy / dt</option><option id="B">dy / dx</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Speed of individual element of medium.</explanation>
        </question>
        <question>
            <text>Ratio of max particle velocity to wave velocity? v_p_max / v = ____.</text>
            <option id="A">kA (2πA / λ)</option><option id="B">1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ωA / (ω/k) = kA.</explanation>
        </question>
        <question>
            <text>A string of 1m length, 5g mass, 80N tension. Fundamental f = ____.</text>
            <option id="A">63.2 Hz approx (v = sqrt(80/0.005) = 126.5; f = 126.5/2)</option><option id="B">120</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Calculated from fundamental mode f = v/2L.</explanation>
        </question>
        <question>
            <text>In Doppler effect, if source moves toward stationary observer, f' ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Waves are crowded together.</explanation>
        </question>
        <question>
            <text>In Doppler effect, if observer moves away from stationary source, f' ____.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Observer receives fewer wave fronts per sec.</explanation>
        </question>
        <question>
            <text>For beats of 5 Hz, minimum time between a max and min intensity is ____ s.</text>
            <option id="A">0.1 (1/10)</option><option id="B">0.2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Time between two max is 1/5 = 0.2. Max to min is half of that.</explanation>
        </question>
        <question>
            <text>Power transmit by wave on string P = ____.</text>
            <option id="A">1/2 μ v ω^2 A^2</option><option id="B">1/2 m v^2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Rate of energy flow.</explanation>
        </question>
        <question>
            <text>Wavefront is a surface of constant ____.</text>
            <option id="A">Phase</option><option id="B">Amplitude</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Perpendicular to rays.</explanation>
        </question>
        <question>
            <text>Second harmonic of open pipe is equal to fundamental of ____ pipe? No.</text>
            <option id="A">Open pipe of half length</option><option id="B">Closed pipe</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>f2 = 2 * (v/2L) = v/L. If L becomes L/2, f1 = v/(2*L/2) = v/L.</explanation>
        </question>
        <question>
            <text>Overtones are frequencies ____ than fundamental.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Multiples or near multiples.</explanation>
        </question>
        <question>
            <text>Harmonics are integer ____ of fundamental.</text>
            <option id="A">Multiples</option><option id="B">Fractions</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>f, 2f, 3f...</explanation>
        </question>
        <question>
            <text>Which property of sound changes with amplitude?</text>
            <option id="A">Loudness</option><option id="B">Pitch</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Perceived intensity.</explanation>
        </question>
        <question>
            <text>Which property of sound changes with frequency?</text>
            <option id="A">Pitch</option><option id="B">Loudness</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Perceived shrillness.</explanation>
        </question>
        <question>
            <text>Quality (Timbre) of sound depends on ____.</text>
            <option id="A">Waveform / Harmonics present</option><option id="B">Amplitude only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Distinguishes two notes of same pitch and loudness.</explanation>
        </question>
        <question>
            <text>In a stationary wave, amplitude ____ from node to antinode.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>0 to 2A.</explanation>
        </question>
        <question>
            <text>In a travelling wave, energy ____ with the wave.</text>
            <option id="A">Moves</option><option id="B">Stays trapped</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Net transport of energy occurs.</explanation>
        </question>
        <question>
            <text>Wave in 1D: y(x,t) = f(ax ± bt)? ____ sign means wave moves in negative x.</text>
            <option id="A">Plus (+)</option><option id="B">Minus (-)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>e.g. sin(kx + ωt).</explanation>
        </question>
        <question>
            <text>Sound waves in solids are ____.</text>
            <option id="A">Both transverse and longitudinal</option><option id="B">Only longitudinal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Solids can have shear elasticity.</explanation>
        </question>
        <question>
            <text>S-waves in seismology are ____.</text>
            <option id="A">Transverse (Secondary)</option><option id="B">Longitudinal (Primary)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Slower than P waves, can't pass through liquid outer core.</explanation>
        </question>
        <question>
            <text>P-waves in seismology are ____.</text>
            <option id="A">Longitudinal (Primary)</option><option id="B">Transverse</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fastest seismic waves.</explanation>
        </question>
        <question>
            <text>Velocity of sound is highest in ____.</text>
            <option id="A">Solids (e.g. Steel)</option><option id="B">Gases</option><option id="C">Liquids</option><option id="D">None</option>
            <answer>A</answer><explanation>High Bulk modulus / Elasticity.</explanation>
        </question>
        <question>
            <text>If temperature of air increases by 1 K, sound speed increases by approx ____ m/s.</text>
            <option id="A">0.61</option><option id="B">1</option><option id="C">0.33</option><option id="D">None</option>
            <answer>A</answer><explanation>Linear approximation near 0 deg C.</explanation>
        </question>
        <question>
            <text>String f1 = 100 Hz. Second overtone is ____ Hz.</text>
            <option id="A">300 (3rd harmonic)</option><option id="B">200</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Fundamental = 1st, 1st overtone = 2nd, 2nd overtone = 3rd.</explanation>
        </question>
        <question>
            <text>Closed pipe f1 = 100 Hz. First overtone is ____ Hz.</text>
            <option id="A">300 (3rd harmonic)</option><option id="B">200</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Next allowed mode for closed pipe is 3f.</explanation>
        </question>
        <question>
            <text>Human ear is most sensitive to frequencies around ____ Hz.</text>
            <option id="A">2000 - 5000</option><option id="B">20,000</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Related to resonance frequency of ear canal.</explanation>
        </question>
        <question>
            <text>Intensity of sound is measured in ____.</text>
            <option id="A">dB (decibels) / W/m^2</option><option id="B">Hz</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Decibel is log scale.</explanation>
        </question>
    </medium>
    <hard>
        <question>
            <text>Phase difference between two points x1, x2 on a wave is Δφ = ____.</text>
            <option id="A">k |x2 - x1|</option><option id="B">ω |x2 - x1|</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Δφ = 2π / λ * Δx.</explanation>
        </question>
        <question>
            <text>Group velocity is the velocity of the ____.</text>
            <option id="A">Wave packet / envelope</option><option id="B">Individual phase</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v_g = dω / dk.</explanation>
        </question>
        <question>
            <text>Phase velocity v_p = ____.</text>
            <option id="A">ω / k</option><option id="B">k / ω</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Speed of constant phase point.</explanation>
        </question>
        <question>
            <text>In dispersive medium, group velocity and phase velocity are ____.</text>
            <option id="A">Different</option><option id="B">Same</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v_p depends on frequency.</explanation>
        </question>
        <question>
            <text>Speed of sound in ideal gas depends ∝ temperature T as ____.</text>
            <option id="A">T^(1/2)</option><option id="B">T</option><option id="C">T^2</option><option id="D">None</option>
            <answer>A</answer><explanation>v = sqrt(γRT / M).</explanation>
        </question>
        <question>
            <text>A stationary wave is represented by y = 2A sin(kx) cos(ωt). Position of nodes satisfies ____.</text>
            <option id="A">kx = n π (x = n λ / 2)</option><option id="B">kx = odd * π/2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>sin(kx) = 0.</explanation>
        </question>
        <question>
            <text>A string of density ρ and radius r has tension T. v = ____ (in terms of r).</text>
            <option id="A">sqrt( T / (ρ π r^2) )</option><option id="B">sqrt(T/r)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>μ = ρ x Area = ρ π r^2.</explanation>
        </question>
        <question>
            <text>Fundamental of open pipe L is same as fundamental of closed pipe L'? ____.</text>
            <option id="A">L' = L / 2</option><option id="B">L' = 2L</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v/2L = v/4L' -> 2L = 4L' -> L' = 0.5 L.</explanation>
        </question>
        <question>
            <text>Doppler effect for light differs from sound because ____.</text>
            <option id="A">Light speed is same in all frames (Relativistic)</option><option id="B">Light is faster</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Depends only on relative velocity, no 'medium' frame.</explanation>
        </question>
        <question>
            <text>Two strings A and B produce 6 beats. A is 300Hz. If tension in B is reduced, beat frequency increases to 10. B was? ____ Hz.</text>
            <option id="A">294 (v decreases, f decreases from 294 -> 290? No, 300-290=10)</option><option id="B">306</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Possible: 306 or 294. If B=306 -> (less T) -> 304 -> beat=4? No. If B=294 -> (less T) -> 290 -> beat=10. Correct.</explanation>
        </question>
        <question>
            <text>Sound level increases by 20 dB. Intensity increases by factor ____.</text>
            <option id="A">100</option><option id="B">10</option><option id="C">20</option><option id="D">None</option>
            <answer>A</answer><explanation>10 log(I2/I1) = 20 -> log ratio = 2 -> ratio = 10^2 = 100.</explanation>
        </question>
        <question>
            <text>Speed of sound in hydrogen (M=2) vs oxygen (M=32) at same T ____.</text>
            <option id="A">v_H = 4 v_O</option><option id="B">v_H = 16 v_O</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>v ∝ 1/sqrt(M). sqrt(32/2) = sqrt(16) = 4.</explanation>
        </question>
        <question>
            <text>Energy density of a harmonic wave u = ____.</text>
            <option id="A">1/2 ρ ω^2 A^2</option><option id="B">1/2 m v^2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy per unit volume.</explanation>
        </question>
        <question>
            <text>Interference pattern depends on ____ difference.</text>
            <option id="A">Phase / Path</option><option id="B">Intensity only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Δφ = k Δx.</explanation>
        </question>
        <question>
            <text>If an source of 500Hz moves at half speed of sound toward observer? f' = ____.</text>
            <option id="A">1000 Hz (f' = f * v / (v - 0.5v) = 500 * 2)</option><option id="B">750</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard source moving toward stationary observer.</explanation>
        </question>
        <question>
            <text>Mach Number M = ____.</text>
            <option id="A">v_object / v_sound</option><option id="B">v_sound / v_object</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Measure of supersonicity.</explanation>
        </question>
        <question>
            <text>Standing waves in string clamped at both ends: allowed λ = ____.</text>
            <option id="A">2L / n (n=1,2,3...)</option><option id="B">L / n</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>L must be multiple of λ/2.</explanation>
        </question>
        <question>
            <text>Fundamental of closed pipe f = 200 Hz. Third overtone f7 = ____ Hz.</text>
            <option id="A">1400 (Fundamental 1, OT1=3, OT2=5, OT3=7th Harmonic)</option><option id="B">600</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Closed pipe overtone numbering is tricky: only odd allowed.</explanation>
        </question>
        <question>
            <text>Is it possible for sound to be polarized?</text>
            <option id="A">No (Longitudinal waves cannot be polarized)</option><option id="B">Yes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Vibration is along one line already.</explanation>
        </question>
        <question>
            <text>Reflection of pulse @ rigid wall: displacement inversion happens? ____.</text>
            <option id="A">Yes (Phase π)</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Fixed end condition.</explanation>
        </question>
        <question>
            <text>Reflection at open end: pulse returns with ____ side upwards.</text>
            <option id="A">Same</option><option id="B">Opposite</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No phase inversion.</explanation>
        </question>
        <question>
            <text>Velocity of sound in air is independent of ____? No. It depends on T.</text>
            <option id="A">Frequency / wavelength</option><option id="B">Temperature</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ideally non-dispersive.</explanation>
        </question>
        <question>
            <text>Intensity of sound from point source I ∝ ____.</text>
            <option id="A">1 / r^2</option><option id="B">1 / r</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Spreading over surface of sphere (4πr^2).</explanation>
        </question>
        <question>
            <text>Intensity of sound from infinitely long line source I ∝ ____.</text>
            <option id="A">1 / r</option><option id="B">1 / r^2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Spreading over cylinder (2πrL).</explanation>
        </question>
        <question>
            <text>Loudness level in phons is numerically equal to dB at ____ Hz.</text>
            <option id="A">1000</option><option id="B">20</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard reference for loudness measurement.</explanation>
        </question>
        <question>
            <text>Beating between 300Hz and 304Hz tuning forks. Rate? ____.</text>
            <option id="A">4 Hz</option><option id="B">604</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Difference.</explanation>
        </question>
        <question>
            <text>Pitch of mosquito hum is ____ than lion roar.</text>
            <option id="A">Higher (Higher frequency)</option><option id="B">Lower</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>High pitched buzz vs low frequency roar.</explanation>
        </question>
        <question>
            <text>If tension of string is increased by 21%, frequency increases by ____%.</text>
            <option id="A">10% (sqrt(1.21) = 1.1)</option><option id="B">21%</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>f ∝ sqrt(T).</explanation>
        </question>
        <question>
            <text>Wavefront produced by a point source in 3D is ____.</text>
            <option id="A">Spherical</option><option id="B">Planar</option><option id="C">Cylindrical</option><option id="D">None</option>
            <answer>A</answer><explanation>Symmetric in all directions.</explanation>
        </question>
        <question>
            <text>Wavefront produced by point source at very large distance is ____.</text>
            <option id="A">Plane</option><option id="B">Spherical</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Curvature becomes negligible.</explanation>
        </question>
        <question>
            <text>Energy of wave is ____ shared between potential and kinetic forms? Yes.</text>
            <option id="A">Equally</option><option id="B">Unequally</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Analogous to SHM energy sharing.</explanation>
        </question>
        <question>
            <text>Final check for Waves: 120 count reached?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option><option id="D">None</option>
            <answer>A</answer><explanation>Done.</explanation>
        </question>
    </hard>
