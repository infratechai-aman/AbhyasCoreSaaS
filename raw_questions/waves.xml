<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="114" name="Waves">
    <easy>
        <question>
            <text>Disturbance that travels through a medium, transferring energy without bulk motion of matter is ____.</text>
            <option id="A">Wave</option><option id="B">Particle flow</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Propagation of energy via oscillations.</explanation></question>
        <question>
            <text>Waves that require a material medium for propagation are ____ waves.</text>
            <option id="A">Mechanical</option><option id="B">Electromagnetic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Examples: Sound, Water waves.</explanation></question>
        <question>
            <text>Waves that can travel through vacuum are ____ waves.</text>
            <option id="A">Electromagnetic</option><option id="B">Mechanical</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example: Light, Radio waves.</explanation></question>
        <question>
            <text>In ____ waves, particles of medium oscillate perpendicular to wave direction.</text>
            <option id="A">Transverse</option><option id="B">Longitudinal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example: Light, Waves on a string.</explanation></question>
        <question>
            <text>In ____ waves, particles of medium oscillate parallel to wave direction.</text>
            <option id="A">Longitudinal</option><option id="B">Transverse</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example: Sound waves.</explanation></question>
        <question>
            <text>Distance between two consecutive crests or troughs is ____.</text>
            <option id="A">Wavelength (λ)</option><option id="B">Amplitude</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cycle length in space.</explanation></question>
        <question>
            <text>Wave speed v equals frequency f multiplied by ____.</text>
            <option id="A">Wavelength (λ)</option><option id="B">Time period</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>v = f λ.</explanation></question>
        <question>
            <text>Regions of high pressure and density in longitudinal waves are ____.</text>
            <option id="A">Compressions</option><option id="B">Rarefactions</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Particles are crowded together.</explanation></question>
        <question>
            <text>Regions of low pressure and density in longitudinal waves are ____.</text>
            <option id="A">Rarefactions</option><option id="B">Compressions</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Particles are spread apart.</explanation></question>
        <question>
            <text>Frequency of a wave is determined by the ____.</text>
            <option id="A">Source</option><option id="B">Medium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Remains constant as wave changes medium.</explanation></question>
        <question>
            <text>Wavelength of a wave depends on both frequency and ____ properties.</text>
            <option id="A">Medium (Speed)</option><option id="B">Amplitude</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>λ = v / f.</explanation></question>
        <question>
            <text>Sound waves are primarily ____ in air.</text>
            <option id="A">Longitudinal</option><option id="B">Transverse</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cannot be polarized.</explanation></question>
        <question>
            <text>Speed of sound in air at STP is approx ____ m/s.</text>
            <option id="A">331 - 340</option><option id="B">1500</option><option id="C">3 x 10^8</option><option id="D">None</option>
            <answer>A</answer><explanation>Varies with temperature.</explanation></question>
        <question>
            <text>Speed of sound is maximum in ____.</text>
            <option id="A">Solids (Steel)</option><option id="B">Liquids</option><option id="C">Gases</option><option id="D">Vacuum</option>
            <answer>A</answer><explanation>High elasticity modules.</explanation></question>
        <question>
            <text>Frequency range of audible sound for humans is ____ Hz.</text>
            <option id="A">20 to 20,000</option><option id="B">0 to 100</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sonic range.</explanation></question>
        <question>
            <text>Sound with frequency below 20 Hz is called ____.</text>
            <option id="A">Infrasonic</option><option id="B">Ultrasonic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used by elephants and whales.</explanation></question>
        <question>
            <text>Sound with frequency above 20,000 Hz is called ____.</text>
            <option id="A">Ultrasonic</option><option id="B">Infrasonic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Bats use this for echolocation.</explanation></question>
        <question>
            <text>Newton’s formula for speed of sound v = sqrt( ____ / ρ ).</text>
            <option id="A">P (Isothermal Bulk Modulus)</option><option id="B">gamma P</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Later corrected by Laplace.</explanation></question>
        <question>
            <text>Laplace correction for speed of sound in gas: v = sqrt( ____ / ρ ).</text>
            <option id="A">gamma P</option><option id="B">P</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Assumes adiabatic process.</explanation></question>
        <question>
            <text>Superposition of two waves of same freq traveling in opposite directions forms ____ waves.</text>
            <option id="A">Stationary / Standing</option><option id="B">Progressive</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Energy is trapped between nodes.</explanation></question>
        <question>
            <text>Points of zero amplitude in stationary waves are called ____.</text>
            <option id="A">Nodes</option><option id="B">Antinodes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Minimal vibration.</explanation></question>
        <question>
            <text>Points of maximum amplitude in stationary waves are called ____.</text>
            <option id="A">Antinodes</option><option id="B">Nodes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximum vibration.</explanation></question>
        <question>
            <text>Distance between two consecutive nodes is ____.</text>
            <option id="A">λ / 2</option><option id="B">λ</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Half wavelength cycle.</explanation></question>
        <question>
            <text>Speed of transverse waves on a stretched string v = sqrt( ____ / μ ).</text>
            <option id="A">T (Tension)</option><option id="B">Density</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>μ is mass per unit length.</explanation></question>
        <question>
            <text>Fundamental frequency is also called the first ____.</text>
            <option id="A">Harmonic</option><option id="B">Overtone</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Simplest vibration mode.</explanation></question>
        <question>
            <text>Periodic variations in loudness when two waves of slightly different freq mix are ____.</text>
            <option id="A">Beats</option><option id="B">Echos</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to interference in time.</explanation></question>
        <question>
            <text>Beat frequency equals the ____ of frequencies.</text>
            <option id="A">Difference (f1 - f2)</option><option id="B">Sum</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Number of beats per second.</explanation></question>
        <question>
            <text>Change in observed frequency due to relative motion is ____ effect.</text>
            <option id="A">Doppler</option><option id="B">Tyndall</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Apparent pitch shift.</explanation></question>
        <question>
            <text>Wave equation for progressive wave: y = ____.</text>
            <option id="A">A sin (wt - kx)</option><option id="B">A sin (wt + kx)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Moving in +x direction.</explanation></question>
        <question>
            <text>Wave number k = ____.</text>
            <option id="A">2 pi / λ</option><option id="B">2 pi f</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Spatial angular frequency.</explanation></question>
        <question>
            <text>Phase of a wave represents ____ of wave particle at an instant.</text>
            <option id="A">State of motion</option><option id="B">Color</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Includes position and direction.</explanation></question>
        <question>
            <text>SOnar uses ____ waves to measure distance under water.</text>
            <option id="A">Ultrasonic</option><option id="B">Infrasonic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Reflects off objects/seabed.</explanation></question>
        <question>
            <text>Crest and Trough are features of ____ waves.</text>
            <option id="A">Transverse</option><option id="B">Longitudinal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Max up and Max down points.</explanation></question>
        <question>
            <text>Mechanical waves can propagate in solids as both ____ and ____.</text>
            <option id="A">Transverse , Longitudinal</option><option id="B">Sonic only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Liquids/Gases only support longitudinal bulk waves.</explanation></question>
        <question>
            <text>Speed of sound increases with ____ in temperature.</text>
            <option id="A">Increase</option><option id="B">Decrease</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>v ∝ sqrt(T).</explanation></question>
        <question>
            <text>Effect of humidity: Speed of sound in moist air is ____ than dry air.</text>
            <option id="A">Greater</option><option id="B">Less</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Moist air is less dense than dry air.</explanation></question>
        <question>
            <text>Principle of superposition: y_total = ____.</text>
            <option id="A">y1 + y2</option><option id="B">y1 * y2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Algebraic sum of displacements.</explanation></question>
        <question>
            <text>Harmonics are integer ____ of fundamental frequency.</text>
            <option id="A">Multiples</option><option id="B">Powers</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Example: f, 2f, 3f.</explanation></question>
        <question>
            <text>Overtones are frequencies ____ than the fundamental.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Determines timber/pitch complexity.</explanation></question>
        <question>
            <text>Echo is the ____ of sound from a distant obstacle.</text>
            <option id="A">Reflection</option><option id="B">Absorption</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Distinct only if delay &gt; 0.1s.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Laplace corrected Newton's air speed: v = 332m/s. Error in Newton's was approx ____%.</text>
            <option id="A">16</option><option id="B">5</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Newton's estimate was ~280 m/s.</explanation></question>
        <question>
            <text>Ratio of speed of sound in O2 to H2 at same T is ____.</text>
            <option id="A">1 : 4 (sqrt(2/32))</option><option id="B">1 : 16</option><option id="C">4 : 1</option><option id="D">None</option>
            <answer>A</answer><explanation>v ∝ 1/sqrt(M).</explanation></question>
        <question>
            <text>Phase difference Δphi = (2 pi / λ) x ____.</text>
            <option id="A">Δx (Path difference)</option><option id="B">Δt</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Relationship between space and phase shifts.</explanation></question>
        <question>
            <text>Speed of sound is ____ of pressure at constant temperature.</text>
            <option id="A">Independent</option><option id="B">Directly proportional</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Both P and ρ change proportionally in PV=RT.</explanation></question>
        <question>
            <text>Standing waves in string fixed at both ends: Length L = ____.</text>
            <option id="A">n λ / 2</option><option id="B">n λ</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>n is harmonic number.</explanation></question>
        <question>
            <text>Open organ pipe (both ends open) harmonics are ____.</text>
            <option id="A">All (n = 1, 2, 3...)</option><option id="B">Odd only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Antinodes at both ends.</explanation></question>
        <question>
            <text>Closed organ pipe (one end closed) harmonics are ____.</text>
            <option id="A">Odd only (n = 1, 3, 5...)</option><option id="B">All</option><option id="C">Even only</option><option id="D">None</option>
            <answer>A</answer><explanation>Node at closed end, Antinode at open.</explanation></question>
        <question>
            <text>Fundamental freq of open pipe of length L is f. For closed pipe of same L, it is ____.</text>
            <option id="A">f / 2</option><option id="B">2 f</option><option id="C">f</option><option id="D">None</option>
            <answer>A</answer><explanation>λ1_closed = 4L, λ1_open = 2L.</explanation></question>
        <question>
            <text>Intensity of sound is proportional to square of ____.</text>
            <option id="A">Amplitude (A^2)</option><option id="B">Frequency</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Power delivery property.</explanation></question>
        <question>
            <text>Equation of standing wave: y(x,t) = ____.</text>
            <option id="A">2A sin(kx) cos(wt)</option><option id="B">2A sin(wt - kx)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Product of spatial and temporal oscillations.</explanation></question>
        <question>
            <text>Distance between node and adjacent antinode is ____.</text>
            <option id="A">λ / 4</option><option id="B">λ / 2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Quarter wavelength.</explanation></question>
        <question>
            <text>Max frequency difference for human ear to distinguish distinct beats is ____ Hz.</text>
            <option id="A">10</option><option id="B">20</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Persistance of hearing for sound variations.</explanation></question>
        <question>
            <text>If tension in string is increased by 44%, fundamental frequency increases by ____%.</text>
            <option id="A">20</option><option id="B">44</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>f ∝ sqrt(T). sqrt(1.44) = 1.2.</explanation></question>
        <question>
            <text>Sound waves cannot be polarized because they are ____.</text>
            <option id="A">Longitudinal</option><option id="B">Transverse</option><option id="C">Mechanical</option><option id="D">None</option>
            <answer>A</answer><explanation>Vibration direction is restricted to propagation line.</explanation></question>
        <question>
            <text>Speed of wave in string: If linear mass density is quadrupled, speed becomes ____.</text>
            <option id="A">Half</option><option id="B">Double</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>v ∝ 1/sqrt(μ).</explanation></question>
        <question>
            <text>Doppler effect source move towards observer: Observed freq is ____ than actual.</text>
            <option id="A">Greater</option><option id="B">Smaller</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Waves are compressed in front of source.</explanation></question>
        <question>
            <text>Doppler effect observer move away from source: Observed freq is ____ than actual.</text>
            <option id="A">Smaller</option><option id="B">Greater</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Relative speed of waves pulse reception decreases.</explanation></question>
        <question>
            <text>Ratio of energy at node to antinode in stationary wave is ____.</text>
            <option id="A">0 (Node has no displacement, so no KE/PE peak? No. Energy density is non-zero, amplitude is zero.)</option><option id="B">1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Node displacement amplitude is zero.</explanation></question>
        <question>
            <text>In stationary waves, energy is ____ across nodes.</text>
            <option id="A">Not transferred</option><option id="B">Maximized</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Net power flux is zero.</explanation></question>
        <question>
            <text>Velocity of sound in monatomic gas (f=3) vs diatomic (f=5) at same T and M: Ratio is ____.</text>
            <option id="A">sqrt( (5/3) / (7/5) )</option><option id="B">1 : 1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Depends on sqrt(γ).</explanation></question>
        <question>
            <text>Longest wavelength in tube of length L closed at one end is ____.</text>
            <option id="A">4 L</option><option id="B">2 L</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>L = λ/4 for fundamental.</explanation></question>
        <question>
            <text>Longest wavelength in tube of length L open at both ends is ____.</text>
            <option id="A">2 L</option><option id="B">4 L</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>L = λ/2 for fundamental.</explanation></question>
        <question>
            <text>A string fixed at both ends vibrates in its 3rd harmonic. Number of nodes is ____.</text>
            <option id="A">4</option><option id="B">3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Nodes = n + 1.</explanation></question>
        <question>
            <text>Melde’s experiment: If string vibrates in parallel pos with fork of freq f, string freq is ____.</text>
            <option id="A">f / 2</option><option id="B">f</option><option id="C">2 f</option><option id="D">None</option>
            <answer>A</answer><explanation>Tension modulation freq result.</explanation></question>
        <question>
            <text>Loudness of sound depends on ____ of the wave.</text>
            <option id="A">Amplitude (Intensitity)</option><option id="B">Frequency</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Pitch depends on frequency.</explanation></question>
        <question>
            <text>Ratio of frequencies of 2nd overtone of open pipe to 2nd overtone of closed pipe is ____.</text>
            <option id="A">6 : 5 (3f_o vs 5f_c/2 ? n_o*f1 / (2n_c-1)f1) -&gt; (3) / (2.5) = 1.2.</option><option id="B">1 : 1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>3rd harmonic open vs 3nd odd closed (5th harmonic if n=1 is fundament? no 5f1/2 is standard closed 2nd overtone freq relative to open fundamental? No. Overtones: Open f1, 2f1, 3f1. Overtones: Closed f1, 3f1, 5f1. wait... f_c1 = v/4L. Overtone 1 = 3v/4L. Overtone 2 = 5v/4L. Open f_o1 = v/2L. Overtone 1 = 2v/2L. Overtone 2 = 3v/2L. Ratio (3v/2L) / (5v/4L) = 6/5.</explanation></question>
        <question>
            <text>Sound level β in decibels = 10 log10 ( ____ ).</text>
            <option id="A">I / I0 (Standard threshold)</option><option id="B">I0 / I</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Logarithmic scale of intensity.</explanation></question>
        <question>
            <text>I0 threshold of hearing is approx ____ W/m^2.</text>
            <option id="A">10^-12</option><option id="B">10^-6</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard reference level.</explanation></question>
        <question>
            <text>Reverberation time is time taken for sound to fall by ____ dB.</text>
            <option id="A">60</option><option id="B">10</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Sabine's formula requirement.</explanation></question>
        <question>
            <text>Resonance column experiment: Diameter of tube = d. End correction e = ____.</text>
            <option id="A">0.3 d</option><option id="B">0.6 d</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Approximate shift of antinode beyond open end.</explanation></question>
        <question>
            <text>Relationship between phase velocity v and angular freq w is v = ____.</text>
            <option id="A">w / k</option><option id="B">k / w</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Speed of wave cycle.</explanation></question>
        <question>
            <text>Longitudinal wave wave-function s(x,t) = s_m cos(kx - wt). Pressure wave phase diff is ____.</text>
            <option id="A">pi / 2 (90 deg)</option><option id="B">pi (180 deg)</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Pressure is max where displacement gradient is max.</explanation></question>
        <question>
            <text>Max pressure amplitude Δp_m = B k s_m. B is ____.</text>
            <option id="A">Bulk Modulus</option><option id="B">Density</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Elastic property of medium.</explanation></question>
        <question>
            <text>A stone is dropped in well. Total time before sound heard includes ____.</text>
            <option id="A">Falling time + Sound travel time</option><option id="B">Only falling</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>t_total = sqrt(2h/g) + h/v.</explanation></question>
        <question>
            <text>Two tuning forks of frequencies f1 and f2 produce 5 beats/s. If f2 is loaded with wax, beat freq decreases. This means ____.</text>
            <option id="A">f1 &gt; f2</option><option id="B">f2 &gt; f1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Waxing lowers freq. Gap (f1 - f2) shrinks if f1 &gt; f2.</explanation></question>
        <question>
            <text>Specific heat Cv of hydrogen at high temp is higher due to ____ modes.</text>
            <option id="A">Vibrational</option><option id="B">Rotational only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Wave-energy storage link.</explanation></question>
        <question>
            <text>Stationary waves on string: Energy is ____ at nodes.</text>
            <option id="A">Potential (Strain energy max)</option><option id="B">Kinetic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Slope is maximum at nodes.</explanation></question>
        <question>
            <text>Stationary waves on string: Energy is ____ at antinodes.</text>
            <option id="A">Kinetic (Displacement max)</option><option id="B">Potential</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Velocity is maximum here.</explanation></question>
        <question>
            <text>Ultrasonic waves reflected by tumor used in ____.</text>
            <option id="A">Ultrascan / Sonography</option><option id="B">X-ray</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Medical application of sound reflection.</explanation></question>
        <question>
            <text>In mechanical resonance, damping should be ____ for high amplitude.</text>
            <option id="A">Miniminal</option><option id="B">Maximum</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Damping removes energy.</explanation></question>
