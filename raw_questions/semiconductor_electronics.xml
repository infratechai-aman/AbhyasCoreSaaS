<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="112" name="Semiconductor Electronics">
    <easy>
        <question>
            <text>Which of these is an example of an elemental semiconductor?</text>
            <option id="A">Silicon (Si)</option><option id="B">Gallium Arsenide (GaAs)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Silicon and Germanium are the most common elemental semiconductors.</explanation>
        </question>
        <question>
            <text>Materials having conductivity between conductors and insulators are called ____.</text>
            <option id="A">Semiconductors</option><option id="B">Superconductors</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Their resistivity is in range 10^-5 to 10^6 Ωm.</explanation>
        </question>
        <question>
            <text>In energy band theory, the band completely filled with electrons at 0K is ____.</text>
            <option id="A">Valence Band</option><option id="B">Conduction Band</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Contains the valence electrons.</explanation>
        </question>
        <question>
            <text>In energy band theory, the band which is empty at 0K is ____.</text>
            <option id="A">Conduction Band</option><option id="B">Valence Band</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Allows travel of free electrons when excited.</explanation>
        </question>
        <question>
            <text>Energy gap (Eg) for insulators is generally ____.</text>
            <option id="A">> 3 eV</option><option id="B">&lt; 0.1 eV</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Very large gap makes it difficult for electrons to jump to conduction band.</explanation>
        </question>
        <question>
            <text>Energy gap for Silicon is approx ____ eV.</text>
            <option id="A">1.1</option><option id="B">0.7</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard value at room temperature.</explanation>
        </question>
        <question>
            <text>Energy gap for Germanium is approx ____ eV.</text>
            <option id="A">0.7</option><option id="B">1.1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Smaller than Silicon.</explanation>
        </question>
        <question>
            <text>In metals, the valence and conduction bands ____.</text>
            <option id="A">Overlap</option><option id="B">Have a large gap</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Results in high availability of free electrons for conduction.</explanation>
        </question>
        <question>
            <text>Pure semiconductors are called ____ semiconductors.</text>
            <option id="A">Intrinsic</option><option id="B">Extrinsic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No intentional impurities added.</explanation>
        </question>
        <question>
            <text>In intrinsic semiconductors, number of electrons (ne) is ____ to number of holes (nh).</text>
            <option id="A">Equal</option><option id="B">Greater than</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Thermal agitation creates electron-hole pairs.</explanation>
        </question>
        <question>
            <text>Process of adding deliberate impurities to a semiconductor is called ____.</text>
            <option id="A">Doping</option><option id="B">Excitation</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To increase the conductivity significantly.</explanation>
        </question>
        <question>
            <text>Pentavalent impurities (P, As, Sb) added to Si produce ____-type semiconductor.</text>
            <option id="A">N-type</option><option id="B">P-type</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Provide extra electrons (negative charge carriers).</explanation>
        </question>
        <question>
            <text>Trivalent impurities (B, Al, In, Ga) added to Si produce ____-type semiconductor.</text>
            <option id="A">P-type</option><option id="B">N-type</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Provide extra holes (positive charge carriers).</explanation>
        </question>
        <question>
            <text>In n-type semiconductors, majority charge carriers are ____.</text>
            <option id="A">Electrons</option><option id="B">Holes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ne >> nh.</explanation>
        </question>
        <question>
            <text>In p-type semiconductors, majority charge carriers are ____.</text>
            <option id="A">Holes</option><option id="B">Electrons</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>nh >> ne.</explanation>
        </question>
        <question>
            <text>A p-n junction consists of a p-type and n-type semiconductor in ____ contact.</text>
            <option id="A">Atomic</option><option id="B">Mechanical only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Requires continuous crystal structure.</explanation>
        </question>
        <question>
            <text>The region near the junction devoid of mobile charge carriers is the ____ region.</text>
            <option id="A">Depletion</option><option id="B">Conduction</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Contains only immobile ions.</explanation>
        </question>
        <question>
            <text>The movement of charge carriers from high to low concentration across junction is ____.</text>
            <option id="A">Diffusion</option><option id="B">Drift</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Initial process forming the depletion layer.</explanation>
        </question>
        <question>
            <text>When p-side of junction is connected to positive terminal of battery, it is ____ biased.</text>
            <option id="A">Forward</option><option id="B">Reverse</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Reduces depletion layer width and barrier height.</explanation>
        </question>
        <question>
            <text>In forward bias, current is in range of ____.</text>
            <option id="A">milli-ampere (mA)</option><option id="B">micro-ampere (μA)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Large current flow due to low resistance.</explanation>
        </question>
        <question>
            <text>In reverse bias, current is in range of ____.</text>
            <option id="A">micro-ampere (μA)</option><option id="B">milli-ampere (mA)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Very small current due to majority carrier blockage.</explanation>
        </question>
        <question>
            <text>A device that allows current to flow in one direction only is a ____.</text>
            <option id="A">Diode / Rectifier</option><option id="B">Resistor</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Main application of p-n junction.</explanation>
        </question>
        <question>
            <text>Process of converting AC to DC is called ____.</text>
            <option id="A">Rectification</option><option id="B">Amplification</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Uses diodes to filter half or full cycle.</explanation>
        </question>
        <question>
            <text>A full-wave rectifier requires at least ____ diodes.</text>
            <option id="A">2 (center-tapped) or 4 (bridge)</option><option id="B">1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To rectify both halves of AC cycle.</explanation>
        </question>
        <question>
            <text>A Zener diode is designed to operate in ____ region.</text>
            <option id="A">Reverse Breakdown</option><option id="B">Forward Bias</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used for voltage regulation.</explanation>
        </question>
        <question>
            <text>Photodiode operates in ____ bias.</text>
            <option id="A">Reverse</option><option id="B">Forward</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Illumination increases reverse saturation current significantly.</explanation>
        </question>
        <question>
            <text>A Light Emitting Diode (LED) operates in ____ bias.</text>
            <option id="A">Forward</option><option id="B">Reverse</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Recombination of carriers releases energy as photons.</explanation>
        </question>
        <question>
            <text>Solar cells convert ____ energy into ____ energy.</text>
            <option id="A">Light, Electrical</option><option id="B">Heat, Electrical</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Based on photovoltaic effect across p-n junction.</explanation>
        </question>
        <question>
            <text>A NOT gate is also called an ____.</text>
            <option id="A">Inverter</option><option id="B">Amplifier</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Output is opposite of input.</explanation>
        </question>
        <question>
            <text>The Boolean expression for an AND gate is Y = ____.</text>
            <option id="A">A . B</option><option id="B">A + B</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Output is high only if both inputs are high.</explanation>
        </question>
        <question>
            <text>The Boolean expression for an OR gate is Y = ____.</text>
            <option id="A">A + B</option><option id="B">A . B</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Output is high if any input is high.</explanation>
        </question>
        <question>
            <text>The Universal logic gates are ____ and ____.</text>
            <option id="A">NAND, NOR</option><option id="B">AND, OR</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Any other logic gate can be built using these.</explanation>
        </question>
        <question>
            <text>A NAND gate is an ____ gate followed by a NOT gate.</text>
            <option id="A">AND</option><option id="B">OR</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Negated AND.</explanation>
        </question>
        <question>
            <text>Resistivity of semiconductors ____ with increase in temperature.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Negative temperature coefficient of resistance (NTCR).</explanation>
        </question>
        <question>
            <text>Pure water is an insulator, but semiconductors reach conductivity due to ____.</text>
            <option id="A">Carrier generation</option><option id="B">Transparency</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Thermal release of bound electrons.</explanation>
        </question>
        <question>
            <text>Is a p-type semiconductor positively charged?</text>
            <option id="A">No (Electrically neutral)</option><option id="B">Yes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Atoms are neutral; holes are just missing electrons in bonds.</explanation>
        </question>
        <question>
            <text>Number of valence electrons in Silicon is ____.</text>
            <option id="A">4</option><option id="B">5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Group 14 element.</explanation>
        </question>
        <question>
            <text>Width of depletion layer ____ in reverse bias.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Carriers pulled away from junction.</explanation>
        </question>
        <question>
            <text>Dynamic resistance of a diode is r = ΔV / ____.</text>
            <option id="A">ΔI</option><option id="B">I</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Reciprocal of the slope of V-I characteristic.</explanation>
        </question>
        <question>
            <text>Semiconductor Electronics initialization done.</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Verified.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>If ni is intrinsic carrier concentration, and ne, nh are electron and hole concentrations, then at equilibrium ____.</text>
            <option id="A">ni² = ne * nh</option><option id="B">ni = ne + nh</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Mass action law.</explanation>
        </question>
        <question>
            <text>Doping Si with 1 ppm of Arsenic (As). If 1 cm³ has 5e22 atoms, then ne is approx ____ cm⁻³.</text>
            <option id="A">5 x 10^16</option><option id="B">5 x 10^22</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ne ≈ n_impurity = 1e-6 * 5e22 = 5e16.</explanation>
        </question>
        <question>
            <text>The ratio of majority to minority carriers in an n-type semiconductor with ni = 10^10 and ne = 10^16 is ____.</text>
            <option id="A">10^12 (nh = ni²/ne = 10^20 / 10^16 = 10^4. Ratio = 10^16/10^4 = 10^12)</option><option id="B">10^6</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Extreme imbalance created by doping.</explanation>
        </question>
        <question>
            <text>Conductivity of semiconductor σ = ____.</text>
            <option id="A">e (ne μe + nh μh)</option><option id="B">e (ne + nh) μ</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Sum of contributions from both types of carriers.</explanation>
        </question>
        <question>
            <text>Mobility μ of a carrier is defined as ____.</text>
            <option id="A">Drift velocity per unit electric field (vd / E)</option><option id="B">E / vd</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Measures how easily a carrier moves through the lattice.</explanation>
        </question>
        <question>
            <text>In Silicon, mobility of ____ is larger than ____.</text>
            <option id="A">Electrons, Holes</option><option id="B">Holes, Electrons</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Electrons being lighter and moving in conduction band have less scattering.</explanation>
        </question>
        <question>
            <text>Barrier potential of Silicon diode is approx ____ V.</text>
            <option id="A">0.7</option><option id="B">0.3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Potential needed to overcome the depletion layer barrier.</explanation>
        </question>
        <question>
            <text>Barrier potential of Germanium diode is approx ____ V.</text>
            <option id="A">0.3</option><option id="B">0.7</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lower than Silicon.</explanation>
        </question>
        <question>
            <text>Efficiency of a half-wave rectifier is approx ____ %.</text>
            <option id="A">40.6</option><option id="B">81.2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Theoretical limit due to losing half the energy.</explanation>
        </question>
        <question>
            <text>Efficiency of a full-wave rectifier is approx ____ %.</text>
            <option id="A">81.2</option><option id="B">40.6</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Twice the half-wave efficiency.</explanation>
        </question>
        <question>
            <text>Ripple frequency of half-wave rectifier with input frequency f is ____.</text>
            <option id="A">f</option><option id="B">2f</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>One pulse per cycle.</explanation>
        </question>
        <question>
            <text>Ripple frequency of full-wave rectifier with input frequency f is ____.</text>
            <option id="A">2f</option><option id="B">f</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Two pulses per cycle.</explanation>
        </question>
        <question>
            <text>Input resistance of a common-emitter transistor is generally ____.</text>
            <option id="A">Low (~ kilo-ohms)</option><option id="B">High (~ mega-ohms)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Forward biased base-emitter junction.</explanation>
        </question>
        <question>
            <text>Output resistance of a common-emitter transistor is generally ____.</text>
            <option id="A">High (~ 10-100 kΩ)</option><option id="B">Low</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Reverse biased collector-base junction.</explanation>
        </question>
        <question>
            <text>Current gain β in CE configuration is β = ____.</text>
            <option id="A">ΔIc / ΔIb</option><option id="B">ΔIc / ΔIe</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ratio of collector current change to base current change.</explanation>
        </question>
        <question>
            <text>Current gain α in CB configuration is α = ____.</text>
            <option id="A">ΔIc / ΔIe</option><option id="B">ΔIc / ΔIb</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ratio of collector current change to emitter current change (always &lt; 1).</explanation>
        </question>
        <question>
            <text>Relation between α and β: β = ____.</text>
            <option id="A">α / (1 - α)</option><option id="B">(1 - α) / α</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental transistor parameter coupling.</explanation>
        </question>
        <question>
            <text>A common emitting amplifier has a phase difference of ____ between input and output.</text>
            <option id="A">180° (π radians)</option><option id="B">0°</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Output voltage decreases as base current increases.</explanation>
        </question>
        <question>
            <text>Power gain of an amplifier is Current Gain x ____.</text>
            <option id="A">Voltage Gain</option><option id="B">Resistance Gain</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>P = VI.</explanation>
        </question>
        <question>
            <text>Zener breakdown occurs in ____ doped junctions.</text>
            <option id="A">Heavily</option><option id="B">Lightly</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Narrow depletion layer allows tunneling under high field.</explanation>
        </question>
        <question>
            <text>Avalanche breakdown occurs in ____ doped junctions.</text>
            <option id="A">Lightly</option><option id="B">Heavily</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Impact ionization by accelerated carriers in thick depletion layer.</explanation>
        </question>
        <question>
            <text>Ideal diode resistance in forward bias is ____.</text>
            <option id="A">Zero</option><option id="B">Infinite</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Perfect conductor assumption.</explanation>
        </question>
        <question>
            <text>Ideal diode resistance in reverse bias is ____.</text>
            <option id="A">Infinite</option><option id="B">Zero</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Perfect insulator assumption.</explanation>
        </question>
        <question>
            <text>Knee voltage is the voltage at which ____ starts increasing abruptly in forward bias.</text>
            <option id="A">Current</option><option id="B">Resistance</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Corresponds to overcoming the internal barrier potential.</explanation>
        </question>
        <question>
            <text>Fermi level in n-type semiconductor shifts towards ____ band.</text>
            <option id="A">Conduction</option><option id="B">Valence</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Probability of finding electrons at higher energies increases.</explanation>
        </question>
        <question>
            <text>Fermi level in p-type semiconductor shifts towards ____ band.</text>
            <option id="A">Valence</option><option id="B">Conduction</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Probability of finding holes at lower energies increases.</explanation>
        </question>
        <question>
            <text>If Temperature T increases, Eg ____ slightly.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to thermal expansion and lattice vibrations.</explanation>
        </question>
        <question>
            <text>In a transistor, the ____ region is always thin and lightly doped.</text>
            <option id="A">Base</option><option id="B">Emitter</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To minimize recombination of carriers before they reach collector.</explanation>
        </question>
        <question>
            <text>In a transistor, the ____ region is heavily doped.</text>
            <option id="A">Emitter</option><option id="B">Collector</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To supply large number of majority carriers.</explanation>
        </question>
        <question>
            <text>In a transistor, the ____ region is largest in size.</text>
            <option id="A">Collector</option><option id="B">Emitter</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To dissipate heat generated during carrier collection.</explanation>
        </question>
        <question>
            <text>De Morgan's First Law: NOT (A AND B) = ____.</text>
            <option id="A">(NOT A) OR (NOT B)</option><option id="B">(NOT A) AND (NOT B)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Boolean algebra fundamental.</explanation>
        </question>
        <question>
            <text>De Morgan's Second Law: NOT (A OR B) = ____.</text>
            <option id="A">(NOT A) AND (NOT B)</option><option id="B">(NOT A) OR (NOT B)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Logic simplification rule.</explanation>
        </question>
        <question>
            <text>Binary equivalent of decimal 10 is ____.</text>
            <option id="A">1010</option><option id="B">1100</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1*8 + 0*4 + 1*2 + 0*1 = 10.</explanation>
        </question>
        <question>
            <text>Adding binary 1 + 1 results in ____.</text>
            <option id="A">10 (Binary ten, meaning sum 0 and carry 1)</option><option id="B">2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Base-2 addition.</explanation>
        </question>
        <question>
            <text>Solar cells work on the principle of ____.</text>
            <option id="A">Photovoltaic effect (Voltage generation under light)</option><option id="B">Photoelectric emission</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Spontaneous separation of generated e-h pairs by junction field.</explanation>
        </question>
        <question>
            <text>Standardizing Semiconductor electronics Medium section progress.</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Verified.</explanation>
        </question>
        <question>
            <text>What is the current gain in a transistor used as a switch?</text>
            <option id="A">Very High (saturated)</option><option id="B">0</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Operates in saturation or cut-off regions.</explanation>
        </question>
        <question>
            <text>Diodes made of materials like GaAsP can emit ____ light.</text>
            <option id="A">Visible (Red, Green etc)</option><option id="B">Only Infrared</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy of recombination corresponds to visible spectrum.</explanation>
        </question>
        <question>
