      <answer>A</answer>
      <explanation>Represents total energy operator.</explanation>
    </question>
    <question>
      <text>In cyclic process, net work done equals net ____ added.</text>
      <option id="A">Heat</option>
      <option id="B">Internal energy</option>

      <answer>A</answer>
      <explanation>Since ΔU = 0.</explanation>
    </question>
    <question>
