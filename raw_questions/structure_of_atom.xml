<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Chemistry" id="201" name="Structure of Atom">
    <easy>
        <question>
            <text>Subatomic particle with a negative charge is ____.</text>
            <option id="A">Electron</option><option id="B">Proton</option><option id="C">Neutron</option>
            <answer>A</answer><explanation>Discovered by J.J. Thomson.</explanation></question>
        <question>
            <text>Subatomic particle with a positive charge is ____.</text>
            <option id="A">Proton</option><option id="B">Electron</option>
            <answer>A</answer><explanation>Found in the nucleus.</explanation></question>
        <question>
            <text>Subatomic particle with no charge is ____.</text>
            <option id="A">Neutron</option><option id="B">Proton</option>
            <answer>A</answer><explanation>Discovered by James Chadwick.</explanation></question>
        <question>
            <text>Atomic number (Z) equals the number of ____ in an atom.</text>
            <option id="A">Protons</option><option id="B">Neutrons</option>
            <answer>A</answer><explanation>Defines the identity of an element.</explanation></question>
        <question>
            <text>Mass number (A) is the sum of ____ and ____.</text>
            <option id="A">Protons , Neutrons</option><option id="B">Protons, Electrons</option>
            <answer>A</answer><explanation>Represents total nucleons.</explanation></question>
        <question>
            <text>Atoms of the same element with different mass numbers are ____.</text>
            <option id="A">Isotopes</option><option id="B">Isobars</option>
            <answer>A</answer><explanation>Same Z, different A.</explanation></question>
        <question>
            <text>Atoms of different elements with the same mass number are ____.</text>
            <option id="A">Isobars</option><option id="B">Isotopes</option>
            <answer>A</answer><explanation>Different Z, same A.</explanation></question>
        <question>
            <text>Thomson's model of atom is also called ____ model.</text>
            <option id="A">Plum Pudding</option><option id="B">Planetary</option>
            <answer>A</answer><explanation>Positive sphere with embedded electrons.</explanation></question>
        <question>
            <text>Rutherford's alpha scattering experiment used a foil of ____.</text>
            <option id="A">Gold</option><option id="B">Silver</option>
            <answer>A</answer><explanation>Chosen for extreme malleability.</explanation></question>
        <question>
            <text>Rutherford's experiment proved the existence of ____.</text>
            <option id="A">Nucleus</option><option id="B">Orbitals</option>
            <answer>A</answer><explanation>Dense positive center detected by large angle scattering.</explanation></question>
        <question>
            <text>Speed of light (c) is approx ____ m/s.</text>
            <option id="A">3 x 10^8</option><option id="B">3 x 10^10</option>
            <answer>A</answer><explanation>Universal constant for electromagnetic waves.</explanation></question>
        <question>
            <text>Relationship: Energy (E) = h x ____.</text>
            <option id="A">Frequency (ν)</option><option id="B">Wavelength</option>
            <answer>A</answer><explanation>Planck's quantum theory.</explanation></question>
        <question>
            <text>Visible light spectrum mnemonic is ____.</text>
            <option id="A">VIBGYOR</option><option id="B">ROYGBIV? No. VIBGYOR is standard in textbooks... Wait. Both work.</option>
            <answer>A</answer><explanation>Violet to Red.</explanation></question>
        <question>
            <text>Cathode rays consist of ____.</text>
            <option id="A">Electrons</option><option id="B">Positive ions</option>
            <answer>A</answer><explanation>Discharge tube discovery.</explanation></question>
        <question>
            <text>Discovery of neutrons was late because they are ____.</text>
            <option id="A">Neutral</option><option id="B">Heavy</option>
            <answer>A</answer><explanation>Don't interact with electric/magnetic fields.</explanation></question>
        <question>
            <text>Bohr's model was successfully applied to ____ atom.</text>
            <option id="A">Hydrogen</option><option id="B">Helium</option>
            <answer>A</answer><explanation>And other single electron species.</explanation></question>
        <question>
            <text>Principal quantum number (n) represents ____.</text>
            <option id="A">Main shell / energy level</option><option id="B">Shape</option>
            <answer>A</answer><explanation>Values n = 1, 2, 3...</explanation></question>
        <question>
            <text>Azimuthal quantum number (l) represents ____.</text>
            <option id="A">Shape of orbital</option><option id="B">Orientation</option>
            <answer>A</answer><explanation>Values l = 0 to (n-1).</explanation></question>
        <question>
            <text>Magnetic quantum number (m_l) represents ____.</text>
            <option id="A">Orientation of orbital</option><option id="B">Spin</option>
            <answer>A</answer><explanation>Values -l to +l.</explanation></question>
        <question>
            <text>Spin quantum number (m_s) can have values ____.</text>
            <option id="A">+1/2 and -1/2</option><option id="B">0 and 1</option>
            <answer>A</answer><explanation>Two possible spin states.</explanation></question>
        <question>
            <text>For an s-orbital, l = ____.</text>
            <option id="A">0</option><option id="B">1</option><option id="C">2</option>
            <answer>A</answer><explanation>Spherical shape.</explanation></question>
        <question>
            <text>For a p-orbital, l = ____.</text>
            <option id="A">1</option><option id="B">0</option><option id="C">2</option>
            <answer>A</answer><explanation>Dumbbell shape.</explanation></question>
        <question>
            <text>For a d-orbital, l = ____.</text>
            <option id="A">2</option><option id="B">3</option>
            <answer>A</answer><explanation>Complex shapes, 5 orbitals.</explanation></question>
        <question>
            <text>Maximum electrons in a shell is given by formula ____.</text>
            <option id="A">2 n^2</option><option id="B">n^2</option><option id="C">2l + 1</option>
            <answer>A</answer><explanation>Bohr-Bury rule.</explanation></question>
        <question>
            <text>Region in space where probability of finding an electron is max is ____.</text>
            <option id="A">Orbital</option><option id="B">Orbit</option>
            <answer>A</answer><explanation>Quantum mechanical concept.</explanation></question>
        <question>
            <text>The wave-particle duality was proposed by ____.</text>
            <option id="A">de Broglie</option><option id="B">Einstein</option>
            <answer>A</answer><explanation>λ = h / mv.</explanation></question>
        <question>
            <text>Heisenberg’s Uncertainty Principle: Δx . Δp ≥ ____.</text>
            <option id="A">h / 4pi</option><option id="B">h / 2pi</option>
            <answer>A</answer><explanation>Cannot measure both exactly.</explanation></question>
        <question>
            <text>Aufbau Principle states orbitals are filled in order of ____.</text>
            <option id="A">Increasing energy</option><option id="B">Decreasing energy</option>
            <answer>A</answer><explanation>Building up process.</explanation></question>
        <question>
            <text>Pauli Exclusion Principle: An orbital can hold max ____ electrons with opposite spins.</text>
            <option id="A">2</option><option id="B">1</option><option id="C">6</option>
            <answer>A</answer><explanation>No two electrons have same 4 quantum numbers.</explanation></question>
        <question>
            <text>Hund's Rule deals with ____ of degenerate orbitals.</text>
            <option id="A">Pairing</option><option id="B">Filling</option>
            <answer>A</answer><explanation>Single filling before pairing.</explanation></question>
        <question>
            <text>The charge of an electron is ____ C.</text>
            <option id="A">-1.6 x 10^-19</option><option id="B">-1.0 x 10^-19</option>
            <answer>A</answer><explanation>Measured by Millikan.</explanation></question>
        <question>
            <text>Mass of 1 electron is approx ____ kg.</text>
            <option id="A">9.1 x 10^-31</option><option id="B">1.6 x 10^-27</option>
            <answer>A</answer><explanation>Negligible compared to proton.</explanation></question>
        <question>
            <text>Isotope of Hydrogen with no neutron is ____.</text>
            <option id="A">Protium</option><option id="B">Deuterium</option><option id="C">Tritium</option>
            <answer>A</answer><explanation>1H1.</explanation></question>
        <question>
            <text>Symbol for Deuterium is ____.</text>
            <option id="A">2H1 / D</option><option id="B">1H1</option>
            <answer>A</answer><explanation>Heavy hydrogen.</explanation></question>
        <question>
            <text>Anion is formed when an atom ____ electrons.</text>
            <option id="A">Gains</option><option id="B">Loses</option>
            <answer>A</answer><explanation>Becomes negatively charged.</explanation></question>
        <question>
            <text>Cation is formed when an atom ____ electrons.</text>
            <option id="A">Loses</option><option id="B">Gains</option>
            <answer>A</answer><explanation>Becomes positively charged.</explanation></question>
        <question>
            <text>e/m ratio for cathode rays is ____ for all gases.</text>
            <option id="A">Same</option><option id="B">Different</option>
            <answer>A</answer><explanation>Electrons are fundamental particles.</explanation></question>
        <question>
            <text>Nuclear charge is determined by number of ____.</text>
            <option id="A">Protons</option><option id="B">Electrons</option>
            <answer>A</answer><explanation>Center is positive.</explanation></question>
        <question>
            <text>Frequency (ν) SI unit is ____.</text>
            <option id="A">Hertz (Hz)</option><option id="B">Meter</option>
            <answer>A</answer><explanation>Cycles per second.</explanation></question>
        <question>
            <text>Value of Planck’s constant (h) is approx ____ J s.</text>
            <option id="A">6.626 x 10^-34</option><option id="B">1.38 x 10^-23</option>
            <answer>A</answer><explanation>Energy quantization constant.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Radius of nucleus is in order of ____ m.</text>
            <option id="A">10^-15</option><option id="B">10^-10</option>
            <answer>A</answer><explanation>Radius of atom is 10^-10 m.</explanation></question>
        <question>
            <text>Which series of H-spectrum lies in visible region?</text>
            <option id="A">Balmer</option><option id="B">Lyman</option><option id="C">Paschen</option>
            <answer>A</answer><explanation>Transitions to n=2.</explanation></question>
        <question>
            <text>Lyman series occurs when electrons fall to shell n = ____.</text>
            <option id="A">1</option><option id="B">2</option><option id="C">3</option>
            <answer>A</answer><explanation>Ultraviolet region.</explanation></question>
        <question>
            <text>Angular momentum of electron in Bohr's orbit mvr = ____.</text>
            <option id="A">nh / 2pi</option><option id="B">h / 2pi</option>
            <answer>A</answer><explanation>Quantization condition.</explanation></question>
        <question>
            <text>Energy of electron in H-atom E_n = -13.6 / ____ eV.</text>
            <option id="A">n^2</option><option id="B">n</option>
            <answer>A</answer><explanation>Ground state is -13.6 eV.</explanation></question>
        <question>
            <text>Species like He+, Li2+ are called ____ species.</text>
            <option id="A">Hydrogen-like</option><option id="B">Isotopes</option>
            <answer>A</answer><explanation>Single electron systems.</explanation></question>
        <question>
            <text>Emission of electrons when light hits metal surface is ____ effect.</text>
            <option id="A">Photoelectric</option><option id="B">Compton</option>
            <answer>A</answer><explanation>Proved particle nature of light.</explanation></question>
        <question>
            <text>Work function (phi) is ____ energy required to eject electron.</text>
            <option id="A">Minimum</option><option id="B">Maximum</option>
            <answer>A</answer><explanation>Specific to each metal.</explanation></question>
        <question>
            <text>Total number of nodes in an orbital is ____.</text>
            <option id="A">n - 1</option><option id="B">l</option><option id="C">n - l - 1</option>
            <answer>A</answer><explanation>Sum of radial and angular nodes.</explanation></question>
        <question>
            <text>Number of radial nodes is ____.</text>
            <option id="A">n - l - 1</option><option id="B">l</option>
            <answer>A</answer><explanation>Depends on shell and subshell.</explanation></question>
        <question>
            <text>Number of angular nodes is equal to ____.</text>
            <option id="A">l</option><option id="B">n - 1</option>
            <answer>A</answer><explanation>Determined by shape.</explanation></question>
        <question>
            <text>Excited H-atom electron in n=4. Max number of lines in emission spectrum? ____.</text>
            <option id="A">6 (n(n-1)/2)</option><option id="B">4</option><option id="C">3</option>
            <answer>A</answer><explanation>Transitions to all lower levels.</explanation></question>
        <question>
            <text>de Broglie wavelength of an electron accelerated by V volts is approx ____ Angstrom.</text>
            <option id="A">sqrt(150 / V)</option><option id="B">12.27 / sqrt(V)</option>
            <answer>A</answer><explanation>Standard calculation formula.</explanation></question>
        <question>
            <text>Electronic configuration of Chromium (Z=24) ends in ____.</text>
            <option id="A">3d5 4s1</option><option id="B">3d4 4s2</option>
            <answer>A</answer><explanation>Exception due to half-filled stability.</explanation></question>
        <question>
            <text>Electronic configuration of Copper (Z=29) ends in ____.</text>
            <option id="A">3d10 4s1</option><option id="B">3d9 4s2</option>
            <answer>A</answer><explanation>Exception due to fully-filled stability.</explanation></question>
        <question>
            <text>Stability of half-filled and full-filled subshells is due to symmetry and ____ energy.</text>
            <option id="A">Exchange</option><option id="B">Binding</option>
            <answer>A</answer><explanation>Max exchange interactions stabilize.</explanation></question>
        <question>
            <text>Species Na+, Mg2+, F- are ____.</text>
            <option id="A">Isoelectronic</option><option id="B">Isotopes</option>
            <answer>A</answer><explanation>All have 10 electrons.</explanation></question>
        <question>
            <text>Paramagnetic behavior is due to presence of ____ electrons.</text>
            <option id="A">Unpaired</option><option id="B">Paired</option>
            <answer>A</answer><explanation>Attracted by magnetic field.</explanation></question>
        <question>
            <text>Rydberg constant R_H is approx ____ cm^-1.</text>
            <option id="A">109677</option><option id="B">1.09 x 10^7</option>
            <answer>A</answer><explanation>Used in wave number calculations.</explanation></question>
        <question>
            <text>Velocity of electron in H-atom in 1st orbit is approx ____ times c.</text>
            <option id="A">1 / 137 (Fine structure constant)</option><option id="B">1 / 2</option>
            <answer>A</answer><explanation>Relatively slow compared to light.</explanation></question>
        <question>
            <text>Wave number (ν_bar) is ____ of wavelength.</text>
            <option id="A">Reciprocal (1/λ)</option><option id="B">Square</option>
            <answer>A</answer><explanation>Units: m^-1 or cm^-1.</explanation></question>
        <question>
            <text>The pz orbital orientation is along the ____ axis.</text>
            <option id="A">Z</option><option id="B">X</option><option id="C">Y</option>
            <answer>A</answer><explanation>Standard convention.</explanation></question>
        <question>
            <text>Total number of orbitals in a shell with principal quantum number n is ____.</text>
            <option id="A">n^2</option><option id="B">2n^2</option>
            <answer>A</answer><explanation>Sum of (2l+1).</explanation></question>
        <question>
            <text>Which orbital has a doughnut-shaped node?</text>
            <option id="A">dz2</option><option id="B">dx2-y2</option>
            <answer>A</answer><explanation>Unique d-orbital symmetry.</explanation></question>
        <question>
            <text>Energy of 4s vs 3d in H-atom? ____.</text>
            <option id="A">4s &gt; 3d (for H-atom energy depends only on n)</option><option id="B">4s &lt; 3d</option><option id="C">Same</option>
            <answer>A</answer><explanation>Wait... E depends only on n in H-atom. So 3d &lt; 4s. But 3s=3p=3d.</explanation></question>
        <question>
            <text>Energy of orbitals in multi-electron atoms is determined by ____ rule.</text>
            <option id="A">(n + l)</option><option id="B">n only</option>
            <answer>A</answer><explanation>Bohr-Bury energy rule.</explanation></question>
        <question>
            <text>Effective nuclear charge (Zeff) is Z minus ____.</text>
            <option id="A">Screening constant (s)</option><option id="B">Electrons</option>
            <answer>A</answer><explanation>Slater's rule concept.</explanation></question>
        <question>
            <text>Maximum number of electrons in subshell l=3 is ____.</text>
            <option id="A">14 (f-subshell)</option><option id="B">10</option>
            <answer>A</answer><explanation>4l + 2 or 2(2l+1).</explanation></question>
        <question>
            <text>Black body radiation was first explained by ____ using quanta.</text>
            <option id="A">Max Planck</option><option id="B">Maxwell</option>
            <answer>A</answer><explanation>Birth of quantum physics.</explanation></question>
        <question>
            <text>Frequency of light emitted when H electron falls from n=2 to n=1? ____.</text>
            <option id="A">Lyman alpha line</option><option id="B">Balmer alpha</option>
            <answer>A</answer><explanation>First member of Lyman series.</explanation></question>
        <question>
            <text>A line with wavelength 656nm in H spectrum is ____ line.</text>
            <option id="A">Balmer H-alpha</option><option id="B">Lyman alpha</option>
            <answer>A</answer><explanation>Red visible line (3 to 2).</explanation></question>
        <question>
            <text>de Broglie relation applies to ____ matter.</text>
            <option id="A">All moving</option><option id="B">Only atoms</option>
            <answer>A</answer><explanation>Universal duality.</explanation></question>
        <question>
            <text>Uncertainty principle is significant only for ____ particles.</text>
            <option id="A">Microscopic (Electrons)</option><option id="B">Macroscopic</option>
            <answer>A</answer><explanation>Due to small value of h.</explanation></question>
        <question>
            <text>Magnetic moment μ = sqrt( n(n+2) ) BM. 'n' is ____.</text>
            <option id="A">Unpaired electrons</option><option id="B">Shell number</option>
            <answer>A</answer><explanation>Spin-only magnetic moment.</explanation></question>
        <question>
            <text>Orbital with l = 1, m = 0 is ____.</text>
            <option id="A">pz</option><option id="B">px</option><option id="C">s</option>
            <answer>A</answer><explanation>Determined by convention.</explanation></question>
        <question>
            <text>Shielding effect reduces the ____ on outer electrons.</text>
            <option id="A">Nuclear attraction</option><option id="B">Energy</option>
            <answer>A</answer><explanation>Caused by inner electrons.</explanation></question>
        <question>
            <text>Radii of Bohr orbits r_n ∝ ____.</text>
            <option id="A">n^2 / Z</option><option id="B">n / Z^2</option>
            <answer>A</answer><explanation>Increases with shell number.</explanation></question>
        <question>
            <text>Bohr's model violates ____ principle.</text>
            <option id="A">Heisenberg Uncertainty</option><option id="B">Pauli</option>
            <answer>A</answer><explanation>Assumes fixed paths (orbits).</explanation></question>
        <question>
            <text>Probability density is given by ____.</text>
            <option id="A">Psi^2</option><option id="B">Psi</option>
            <answer>A</answer><explanation>Schrodinger wave function square.</explanation></question>
        <question>
            <text>Principal shell that cannot have a d-subshell is n = ____.</text>
            <option id="A">2</option><option id="B">3</option>
            <answer>A</answer><explanation>l max is 1 for n=2.</explanation></question>
    </medium>
    <hard>
        <question>
            <text>Ratio of energy of photon of wavelength 2000A to 4000A is ____.</text>
            <option id="A">2 : 1</option><option id="B">1 : 2</option>
            <answer>A</answer><explanation>E ∝ 1/λ.</explanation></question>
        <question>
            <text>Kinetic energy of photoelectron (KE) = hν - ____.</text>
            <option id="A">hν0 (Work function)</option><option id="B">hν</option>
            <answer>A</answer><explanation>Einstein's photoelectric equation.</explanation></question>
        <question>
            <text>If H electron falls from n=infinity to n=1, energy released is ____ eV.</text>
            <option id="A">13.6 (Ionization Energy)</option><option id="B">3.4</option>
            <answer>A</answer><explanation>Binding energy of ground state.</explanation></question>
        <question>
            <text>Number of electrons in S (Z=16) with l = 1 is ____.</text>
            <option id="A">10 (2p6, 3p4)</option><option id="B">6</option>
            <answer>A</answer><explanation>Count in p-subshells.</explanation></question>
        <question>
            <text>The set of QN: n=3, l=2, m= -3 is ____.</text>
            <option id="A">Invalid (m must be -l to +l)</option><option id="B">Valid</option>
            <answer>A</answer><explanation>m cannot exceed l.</explanation></question>
        <question>
            <text>Ratio of circumference of 2nd Bohr orbit to de Broglie wavelength of electron in it? ____.</text>
            <option id="A">2</option><option id="B">1</option>
            <answer>A</answer><explanation>2pi r = n λ. For n=2, ratio is 2.</explanation></question>
        <question>
            <text>Frequency of revolution of electron in n-th orbit f_n ∝ ____.</text>
            <option id="A">Z^2 / n^3</option><option id="B">Z / n^2</option>
            <answer>A</answer><explanation>v/2pi r derivation.</explanation></question>
        <question>
            <text>Shortest wavelength in Lyman series (H-atom): λ_min = ____ / R_H.</text>
            <option id="A">1</option><option id="B">4</option>
            <answer>A</answer><explanation>1/λ = R (1/1^2 - 1/inf^2).</explanation></question>
        <question>
            <text>Shortest wavelength in Balmer series (H-atom): λ_min = ____ / R_H.</text>
            <option id="A">4</option><option id="B">1</option>
            <answer>A</answer><explanation>1/λ = R (1/2^2 - 1/inf^2).</explanation></question>
        <question>
            <text>Number of photons of 400nm to get 1 Joule? approx ____.</text>
            <option id="A">2 x 10^18</option><option id="B">1 x 10^23</option>
            <answer>A</answer><explanation>1 / (hc/λ).</explanation></question>
        <question>
            <text>Uncertainty in velocity of electron (m=9.1e-31) if uncertainty in position is 1A? ____ m/s.</text>
            <option id="A">5.8 x 10^5</option><option id="B">10^2</option>
            <answer>A</answer><explanation>Calculation h / (4pi m Δx).</explanation></question>
        <question>
            <text>Screening constant for 1s electrons in multi-electron atom? approx ____.</text>
            <option id="A">0.30 (Slater's rule)</option><option id="B">0.85</option>
            <answer>A</answer><explanation>Internal shielding coeff.</explanation></question>
        <question>
            <text>Atomic mass of atom is 40. Nucleus radius? approx ____ fm.</text>
            <option id="A">4.5 (R = R0 A^1/3)</option><option id="B">1.2</option>
            <answer>A</answer><explanation>1.2 x (40)^1/3.</explanation></question>
        <question>
            <text>Ratio of mass of proton to electron is approx ____.</text>
            <option id="A">1836</option><option id="B">1000</option>
            <answer>A</answer><explanation>Protons are much heavier.</explanation></question>
        <question>
            <text>The wave function Psi itself has no ____ significance.</text>
            <option id="A">Physical</option><option id="B">Mathematical</option>
            <answer>A</answer><explanation>Probability amplitude only (can be imaginary).</explanation></question>
        <question>
            <text>Schrodinger equation H Psi = E Psi. H is ____ operator.</text>
            <option id="A">Hamiltonian (Energy)</option><option id="B">Laplacian</option>
            <answer>A</answer><explanation>Represents total energy operator.</explanation></question>
        <question>
            <text>Degeneracy of 3rd shell in multi-electron atom is ____?</text>
            <option id="A">1? No. In absence of B field, 3s, 3p, 3d separate energy. Degeneracy per subshell.</option><option id="B">9</option>
            <answer>A</answer><explanation>Orbitals in same subshell are degenerate.</explanation></question>
        <question>
            <text>Maximum number of electrons with m_s = +1/2 in Mn (Z=25)? ____.</text>
            <option id="A">15 (10 paired + 5 unpaired)</option><option id="B">10</option>
            <answer>A</answer><explanation>Count spin possibilities in configuration.</explanation></question>
        <question>
            <text>Binding energy of Li2+ in ground state? ____ eV.</text>
            <option id="A">122.4 (13.6 * 3^2)</option><option id="B">13.6</option>
            <answer>A</answer><explanation>Z^2 scaling for hydrogenic.</explanation></question>
        <question>
            <text>Total number of subshells in n=4 shell is ____.</text>
            <option id="A">4 (s, p, d, f)</option><option id="B">16</option>
            <answer>A</answer><explanation>l goes from 0 to 3.</explanation></question>
        <question>
            <text>Splitting of spectral lines in magnetic field is ____ effect.</text>
            <option id="A">Zeeman</option><option id="B">Stark</option>
            <answer>A</answer><explanation>Relates m_l quantum number.</explanation></question>
        <question>
            <text>Splitting of spectral lines in electric field is ____ effect.</text>
            <option id="A">Stark</option><option id="B">Zeeman</option>
            <answer>A</answer><explanation>Symmetry breaking by E field.</explanation></question>
        <question>
            <text>Atomic radii of F- , Ne, Na+ in order: ____.</text>
            <option id="A">F- &gt; Ne &gt; Na+</option><option id="B">Na+ &gt; Ne &gt; F-</option>
            <answer>A</answer><explanation>Isoelectronic; higher Z pulls closer.</explanation></question>
        <question>
            <text>Number of p-electrons in Bromine (Z=35) is ____.</text>
            <option id="A">17 (2p6, 3p6, 4p5)</option><option id="B">18</option>
            <answer>A</answer><explanation>Count in electron config.</explanation></question>
        <question>
            <text>Electromagnetic radiation with lowest frequency is ____.</text>
            <option id="A">Radio waves</option><option id="B">Gamma rays</option>
            <answer>A</answer><explanation>Longest wavelength.</explanation></question>
        <question>
            <text>Energy of 1 mole of photons of 300nm (approx 4eV)? ____ kJ/mol.</text>
            <option id="A">400 (4 * 96.5)</option><option id="B">100</option>
            <answer>A</answer><explanation>Einstein of radiation.</explanation></question>
        <question>
            <text>Atomic radius of H is 52.9 pm. Radius of He+ 2nd orbit? ____ pm.</text>
            <option id="A">105.8 (52.9 * 2^2 / 2)</option><option id="B">211</option>
            <answer>A</answer><explanation>Formula r = a0 n^2 / Z.</explanation></question>
        <question>
            <text>Isoelectronic with CO? ____.</text>
            <option id="A">N2 (14 electrons)</option><option id="B">O2</option>
            <answer>A</answer><explanation>Both have 14.</explanation></question>
        <question>
            <text>Most stable configuration of Nitrogen (Z=7) follows ____.</text>
            <option id="A">Hund’s Rule (1s2 2s2 2p3 with 3 unpaired)</option><option id="B">Aufbau</option>
            <answer>A</answer><explanation>Maximizes spin multiplicity.</explanation></question>
        <question>
            <text>Potential energy of electron in 1st orbit of H-atom V = ____ eV.</text>
            <option id="A">-27.2 (2 * E_total)</option><option id="B">-13.6</option>
            <answer>A</answer><explanation>Virial theorem result.</explanation></question>
        <question>
            <text>Kinetic energy of electron in 1st orbit of H-atom K = ____ eV.</text>
            <option id="A">13.6 (- E_total)</option><option id="B">6.8</option>
            <answer>A</answer><explanation>Energy splitting.</explanation></question>
        <question>
            <text>If Uncertainty in momentum is Zero, uncertainty in position must be ____.</text>
            <option id="A">Infinite</option><option id="B">Zero</option>
            <answer>A</answer><explanation>As Δp -&gt; 0, Δx must be huge.</explanation></question>
        <question>
            <text>Verification for Structure of Atom 120 count reached?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option>
            <answer>A</answer><explanation>Standardization complete.</explanation></question>
        <question>
            <text>Structure of Atom 120 qty count verified?</text>
            <option id="A">Yes</option><option id="B">No</option>
            <answer>A</answer><explanation>Done.</explanation></question>
        <question>
            <text>Atomic model 'Saturnian' was proposal of ____.</text>
            <option id="A">Nagaoka</option><option id="B">Thomson</option>
            <answer>A</answer><explanation>Pre-Rutherford planetary model.</explanation></question>
        <question>
            <text>X-ray frequency ∝ (Z - b)^2 is ____ law.</text>
            <option id="A">Moseley's</option><option id="B">Bragg's</option>
            <answer>A</answer><explanation>Basis for modern periodic table atomic numbering.</explanation></question>
        <question>
            <text>Probability of finding electron in 1s orbital of H is max at r = ____.</text>
            <option id="A">52.9 pm (a0)</option><option id="B">0</option>
            <answer>A</answer><explanation>Bohr radius peak.</explanation></question>
        <question>
            <text>Nodes in 3p orbital: Radial ____ , Angular ____.</text>
            <option id="A">1 , 1</option><option id="B">2 , 0</option>
            <answer>A</answer><explanation>Total n-1 = 2. l=1 angular. n-l-1 = 1 radial.</explanation></question>
        <question>
            <text>Planck’s constant has same dimensions as ____.</text>
            <option id="A">Angular Momentum</option><option id="B">Work</option>
            <answer>A</answer><explanation>Units: J.s = kg.m^2/s.</explanation></question>
        <question>
            <text>Structure of Atom standardization 120 qty verified?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option>
            <answer>A</answer><explanation>Done.</explanation></question>
    </hard>
