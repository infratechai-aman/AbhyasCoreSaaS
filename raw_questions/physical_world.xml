            <text>Maximum speed in the universe is achieved by ____.</text>
            <option id="A">Light in vacuum</option><option id="B">Sound</option><option id="C">Jet planes</option><option id="D">Earth</option>
            <answer>A</answer><explanation>Universal constant c.</explanation>
        </question>
