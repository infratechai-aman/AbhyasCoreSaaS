            <option id="A">Probability</option><option id="B">Energy</option><option id="C">Force</option><option id="D">None</option>
            <answer>A</answer><explanation>Schrodinger equation variable.</explanation>
        </question>
        <question>
            <text>Pauli's Exclusion Principle applies to ____.</text>
            <option id="A">Fermions (e.g. electrons)</option><option id="B">Bosons</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>No two can have same quantum states.</explanation>
        </question>
        <question>
            <text>Superposition principle is valid in ____ physics.</text>
            <option id="A">Linear systems (both quantum and classical waves)</option><option id="B">Only high energy</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Fundamental wave property.</explanation>
        </question>
        <question>
