        </question>
        <question>
            <text>LHC stands for ____.</text>
            <option id="A">Large Hadron Collider</option><option id="B">Low Heat Capacity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>World's largest experiment.</explanation>
        </question>
        <question>
            <text>Thermodynamic equilibrium requires ____ equilibrium.</text>
            <option id="A">Thermal, Chemical, and Mechanical</option><option id="B">Only Thermal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Complete balance states.</explanation>
        </question>
        <question>
            <text>Heat flows from ____ to ____ naturally.</text>
            <option id="A">High temp, Low temp</option><option id="B">Low, High</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Second Law directionality.</explanation>
        </question>
