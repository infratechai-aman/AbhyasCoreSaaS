            <option id="A">Quantum and Relativity</option><option id="B">Classical mechanics only</option><option id="C">Thermodynamics only</option><option id="D">None</option>
            <answer>A</answer><explanation>20th century developments.</explanation>
        </question>
        <question>
            <text>Albert Einstein is famous for ____.</text>
            <option id="A">General Relativity</option><option id="B">Calculus</option><option id="C">Electricity</option><option id="D">Steam Engine</option>
            <answer>A</answer><explanation>Revolutionized space-time.</explanation>
        </question>
