        <question>
            <text>Who discovered X-rays?</text>
            <option id="A">Rontgen</option><option id="B">Bohr</option><option id="C">Rutherford</option><option id="D">Fermi</option>
            <answer>A</answer><explanation>W.K. Rontgen in 1895.</explanation>
        </question>
        <question>
            <text>Who is the father of experimental physics?</text>
            <option id="A">Galileo</option><option id="B">Aristotle</option><option id="C">Dalton</option><option id="D">None</option>
