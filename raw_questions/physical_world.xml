        <question>
            <text>Electromagnetic force is ____ than gravity.</text>
            <option id="A">Much stronger</option><option id="B">Weaker</option><option id="C">Equal</option><option id="D">None</option>
            <answer>A</answer><explanation>About 10^36 times stronger for protons.</explanation>
        </question>
        <question>
            <text>Which law states mass can neither be created nor destroyed?</text>
            <option id="A">Law of conservation of mass</option><option id="B">Newton's second law</option><option id="C">Kepler's law</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental conservation law.</explanation>
        </question>
