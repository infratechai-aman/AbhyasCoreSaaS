<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="109" name="Mechanical Properties of Fluids">
    <easy>
        <question>
            <text>Fluids are substances that can ____.</text>
            <option id="A">Flow</option><option id="B">Break</option><option id="C">Stay rigid</option><option id="D">None</option>
            <answer>A</answer><explanation>Includes liquids and gases.</explanation>
        </question>
        <question>
            <text>Normal force per unit area exerted by fluid at rest is ____.</text>
            <option id="A">Pressure</option><option id="B">Stress</option><option id="C">Force</option><option id="D">None</option>
            <answer>A</answer><explanation>P = F/A.</explanation>
        </question>
        <question>
            <text>SI unit of Pressure is ____.</text>
            <option id="A">Pascal (Pa)</option><option id="B">Newton</option><option id="C">Bar</option><option id="D">None</option>
            <answer>A</answer><explanation>1 Pa = 1 N/m^2.</explanation>
        </question>
        <question>
            <text>Pressure at a point in fluid at rest is ____ in all directions.</text>
            <option id="A">Same</option><option id="B">Different</option><option id="C">Zero</option><option id="D">None</option>
            <answer>A</answer><explanation>Pascal's Law for fluids.</explanation>
        </question>
        <question>
            <text>Pressure exerted by a liquid column of height h and density ρ is ____.</text>
            <option id="A">hρg</option><option id="B">ρg/h</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Derived from weight of fluid column.</explanation>
        </question>
        <question>
            <text>Atmospheric pressure at sea level is approximately ____ Pa.</text>
            <option id="A">1.013 x 10^5</option><option id="B">1.0 x 10^3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Equivalent to 1 atmosphere (atm).</explanation>
        </question>
        <question>
            <text>Device used to measure atmospheric pressure is ____.</text>
            <option id="A">Barometer</option><option id="B">Manometer</option><option id="C">Thermometer</option><option id="D">None</option>
            <answer>A</answer><explanation>Invented by Torricelli.</explanation>
        </question>
        <question>
            <text>Difference between absolute pressure and atmospheric pressure is ____ pressure.</text>
            <option id="A">Gauge</option><option id="B">Total</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>P_gauge = P - P_atm.</explanation>
        </question>
        <question>
            <text>Hydraulic lift works on ____ Law.</text>
            <option id="A">Pascal's</option><option id="B">Archimedes'</option><option id="C">Newton's</option><option id="D">None</option>
            <answer>A</answer><explanation>Transmission of fluid pressure.</explanation>
        </question>
        <question>
            <text>Upward force exerted by a fluid on a submerged body is ____ force.</text>
            <option id="A">Buoyant</option><option id="B">Drag</option><option id="C">Viscous</option><option id="D">None</option>
            <answer>A</answer><explanation>Also called upthrust.</explanation>
        </question>
        <question>
            <text>Archimedes' Principle states that buoyant force equals ____ of fluid displaced.</text>
            <option id="A">Weight</option><option id="B">Mass</option><option id="C">Volume</option><option id="D">None</option>
            <answer>A</answer><explanation>Reason for objects floating or sinking.</explanation>
        </question>
        <question>
            <text>A body floats if its density is ____ than fluid density.</text>
            <option id="A">Less or Equal</option><option id="B">Greater</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equilibrium condition for floating.</explanation>
        </question>
        <question>
            <text>Fluids in motion: Study of fluid flow is ____.</text>
            <option id="A">Fluid Dynamics</option><option id="B">Statics</option><option id="C">Kinematics only</option><option id="D">None</option>
            <answer>A</answer><explanation>Involves forces and motion.</explanation>
        </question>
        <question>
            <text>Steady flow where velocity at a point doesn't change with time is ____ flow.</text>
            <option id="A">Streamline / Laminar</option><option id="B">Turbulent</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Characterized by smooth paths.</explanation>
        </question>
        <question>
            <text>Flow where velocity changes erratically in magnitude and direction is ____ flow.</text>
            <option id="A">Turbulent</option><option id="B">Streamline</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Occurs at high velocities.</explanation>
        </question>
        <question>
            <text>Equation of Continuity for incompressible fluid: A1V1 = ____.</text>
            <option id="A">A2V2</option><option id="B">A2/V2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mass conservation in flow.</explanation>
        </question>
        <question>
            <text>Bernoulli's Principle relates pressure, speed, and ____.</text>
            <option id="A">Height (Potential energy)</option><option id="B">Color</option><option id="C">Temperature</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy conservation for ideal fluid flow.</explanation>
        </question>
        <question>
            <text>Internal friction of a fluid that resists flow is ____.</text>
            <option id="A">Viscosity</option><option id="B">Surface tension</option><option id="C">Density</option><option id="D">None</option>
            <answer>A</answer><explanation>Analogous to friction in solids.</explanation>
        </question>
        <question>
            <text>SI unit of coefficient of viscosity (η) is ____.</text>
            <option id="A">Poiseuille (Pa.s)</option><option id="B">Poise</option><option id="C">N/m</option><option id="D">None</option>
            <answer>A</answer><explanation>1 Poiseuille = 10 Poise.</explanation>
        </question>
        <question>
            <text>Stokes' Law gives viscous drag on a sphere: F = ____.</text>
            <option id="A">6 π η r v</option><option id="B">π r^2 h</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Applies for small velocities in viscous medium.</explanation>
        </question>
        <question>
            <text>Constant velocity attained by a body falling through viscous fluid is ____ velocity.</text>
            <option id="A">Terminal</option><option id="B">Critical</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>When drag + buoyancy = weight.</explanation>
        </question>
        <question>
            <text>Dimensionless number that determines nature of flow is ____ Number.</text>
            <option id="A">Reynolds (Re)</option><option id="B">Mach</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Re = ρvd / η.</explanation>
        </question>
        <question>
            <text>Force per unit length acting in the surface of a liquid is ____.</text>
            <option id="A">Surface Tension</option><option id="B">Viscosity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T = F/l.</explanation>
        </question>
        <question>
            <text>SI unit of Surface Tension is ____.</text>
            <option id="A">N/m</option><option id="B">N/m^2</option><option id="C">J/m</option><option id="D">None</option>
            <answer>A</answer><explanation>Force per length.</explanation>
        </question>
        <question>
            <text>Curvature of liquid surface in a container is called ____.</text>
            <option id="A">Meniscus</option><option id="B">Lens</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Concave or convex depending on adhesion/cohesion.</explanation>
        </question>
        <question>
            <text>Angle between tangent to liquid surface and solid surface is Angle of ____.</text>
            <option id="A">Contact</option><option id="B">Incidence</option><option id="C">Refraction</option><option id="D">None</option>
            <answer>A</answer><explanation>Determines wetting property.</explanation>
        </question>
        <question>
            <text>Rise or fall of liquid in a narrow tube is ____.</text>
            <option id="A">Capillarity</option><option id="B">Viscosity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Due to surface tension and small diameter.</explanation>
        </question>
        <question>
            <text>Pressure difference across a spherical liquid drop is ____.</text>
            <option id="A">2T / R</option><option id="B">4T / R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Excess pressure inside drop.</explanation>
        </question>
        <question>
            <text>Pressure difference across a soap bubble (2 surfaces) is ____.</text>
            <option id="A">4T / R</option><option id="B">2T / R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Double because of inner and outer surface.</explanation>
        </question>
        <question>
            <text>Effect of temperature increase on surface tension is ____.</text>
            <option id="A">Decrease</option><option id="B">Increase</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Molecular kinetic energy overcomes attraction.</explanation>
        </question>
        <question>
            <text>Density of water is max at ____ Celsius.</text>
            <option id="A">4</option><option id="B">0</option><option id="C">100</option><option id="D">None</option>
            <answer>A</answer><explanation>Anomalous expansion property.</explanation>
        </question>
        <question>
            <text>Velocity of efflux through a hole is √(2gh). This is ____ theorem.</text>
            <option id="A">Torricelli's</option><option id="B">Bernoulli's</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Special case of Bernoulli's.</explanation>
        </question>
        <question>
            <text>Venturi meter measures ____ of fluid flow.</text>
            <option id="A">Speed / Rate</option><option id="B">Pressure only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Uses pressure difference between throat and wide part.</explanation>
        </question>
        <question>
            <text>Ratio of density of substance to density of water is ____.</text>
            <option id="A">Relative Density / Specific Gravity</option><option id="B">Mass density</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Dimensionless quantity.</explanation>
        </question>
        <question>
            <text>Blood pressure in humans is measured using ____.</text>
            <option id="A">Sphygmomanometer</option><option id="B">Barometer</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Measures gauge pressure in artery.</explanation>
        </question>
        <question>
            <text>Viscosity of gases ____ with increase in temperature.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Due to increased molecular collisions.</explanation>
        </question>
        <question>
            <text>Viscosity of liquids ____ with increase in temperature.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cohesive forces weaken.</explanation>
        </question>
        <question>
            <text>Dynamic lift on a spinning ball in air is called ____ Effect.</text>
            <option id="A">Magnus</option><option id="B">Doppler</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Due to pressure difference induced by spin.</explanation>
        </question>
        <question>
            <text>Atomizer works on the basis of ____.</text>
            <option id="A">Bernoulli's Principle</option><option id="B">Pascal's Law</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>High speed air creates low pressure zone.</explanation>
        </question>
        <question>
            <text>Surface of a liquid behaves like a stretched elastic ____.</text>
            <option id="A">Membrane</option><option id="B">Wire</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Due to surface tension.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Hydraulic brake system uses fluid to multiply ____.</text>
            <option id="A">Force</option><option id="B">Pressure</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Small force on pedal -> large force on brake pads.</explanation>
        </question>
        <question>
            <text>Bernoulli's equation P + 1/2ρv^2 + ρgh = ____.</text>
            <option id="A">Constant</option><option id="B">Zero</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Along a streamline for non-viscous flow.</explanation>
        </question>
        <question>
            <text>Terminal velocity depends on square of ____ of falling body.</text>
            <option id="A">Radius (r^2)</option><option id="B">Mass</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Formula contains term (2r^2 g (ρ-σ) / 9η).</explanation>
        </question>
        <question>
            <text>Critical velocity is velocity above which flow becomes ____.</text>
            <option id="A">Turbulent</option><option id="B">Steady</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>End of streamline regime.</explanation>
        </question>
        <question>
            <text>For a drop to be spherical, potential energy of surface must be ____.</text>
            <option id="A">Minimum</option><option id="B">Maximum</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sphere has minimum area for given volume.</explanation>
        </question>
        <question>
            <text>Excess pressure in a cylindrical bubble in liquid is ____.</text>
            <option id="A">T / R</option><option id="B">2T / R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>One principal radius of curvature is infinity.</explanation>
        </question>
        <question>
            <text>Capillary rise h = ____.</text>
            <option id="A">2T cos θ / (rρg)</option><option id="B">T / (rρg)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Balancing weight with surface tension force.</explanation>
        </question>
        <question>
            <text>If Re &lt; 1000, the flow is usually ____.</text>
            <option id="A">Streamline</option><option id="B">Turbulent</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Low Reynolds number indicates laminar flow.</explanation>
        </question>
        <question>
            <text>If Re > 2000, the flow is usually ____.</text>
            <option id="A">Turbulent</option><option id="B">Streamline</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Inertia forces dominate over viscous forces.</explanation>
        </question>
        <question>
            <text>Dimension of Surface Energy is same as ____.</text>
            <option id="A">Surface Tension</option><option id="B">Work</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy per area [M T^-2].</explanation>
        </question>
        <question>
            <text>Work done in blowing a soap bubble of radius R is ____.</text>
            <option id="A">8 π R^2 T</option><option id="B">4 π R^2 T</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 x Area x T.</explanation>
        </question>
        <question>
            <text>Angle of contact for pure water and clean glass is ____.</text>
            <option id="A">Zero</option><option id="B">90</option><option id="C">135</option><option id="D">None</option>
            <answer>A</answer><explanation>Complete wetting.</explanation>
        </question>
        <question>
            <text>Angle of contact for mercury and glass is ____.</text>
            <option id="A">Obtuse (~135 deg)</option><option id="B">Acute</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mercury doesn't wet glass.</explanation>
        </question>
        <question>
            <text>In a horizontal pipe, where area is narrow, pressure is ____.</text>
            <option id="A">Lower</option><option id="B">Higher</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Increased speed leads to decreased pressure.</explanation>
        </question>
        <question>
            <text>Bernoulli's equation represents conservation of ____ pulse? No. Energy.</text>
            <option id="A">Energy per unit volume</option><option id="B">Momentum</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Work-energy theorem for fluids.</explanation>
        </question>
        <question>
            <text>Effect of salt on surface tension of water ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Highly soluble impurities increase T.</explanation>
        </question>
        <question>
            <text>Effect of detergents on surface tension of water ____.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Makes water spread and penetrate more.</explanation>
        </question>
        <question>
            <text>Poiseuille's formula for flow rate Q through tube: Q = ____.</text>
            <option id="A">pi P r^4 / (8 η L)</option><option id="B">P r / η</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Rate proportional to 4th power of radius.</explanation>
        </question>
        <question>
            <text>Hydraulic machine multiplier is F2 = F1 x (____).</text>
            <option id="A">A2 / A1</option><option id="B">A1 / A2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pressure is constant, so F1/A1 = F2/A2.</explanation>
        </question>
        <question>
            <text>Total pressure at bottom of a pool is P_atm + ____.</text>
            <option id="A">hρg</option><option id="B">2 hρg</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sum of air and water pressure.</explanation>
        </question>
        <question>
            <text>If an object is submerged, apparent weight = Actual weight - ____.</text>
            <option id="A">Buoyant force</option><option id="B">Viscous force</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Net downward pull.</explanation>
        </question>
        <question>
            <text>Water rises in a capillary. If the tube is tilted, the vertical height h ____.</text>
            <option id="A">Stays same</option><option id="B">Increases</option><option id="C">Decreases</option><option id="D">None</option>
            <answer>A</answer><explanation>But length of liquid column increases.</explanation>
        </question>
        <question>
            <text>Streamlines never ____ each other.</text>
            <option id="A">Intersect</option><option id="B">Touch</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Velocity at a point must be unique.</explanation>
        </question>
        <question>
            <text>Terminal velocity is attained when acceleration is ____.</text>
            <option id="A">Zero</option><option id="B">Max</option><option id="C">9.8</option><option id="D">None</option>
            <answer>A</answer><explanation>Net force is zero.</explanation>
        </question>
        <question>
            <text>Coefficient of viscosity for air is ____ than water.</text>
            <option id="A">Much less</option><option id="B">More</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Gases have lower viscosity than liquids usually.</explanation>
        </question>
        <question>
            <text>Viscous force is independent of area of layers? No. F = η A (____).</text>
            <option id="A">dv/dx (Velocity gradient)</option><option id="B">v</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Proportional to area and gradient.</explanation>
        </question>
        <question>
            <text>Pressure depends on shape of container?</text>
            <option id="A">No (Hydrostatic paradox)</option><option id="B">Yes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Only depth and density matter.</explanation>
        </question>
        <question>
            <text>A piece of wood floats in water with 1/2 outside. Relative density is ____.</text>
            <option id="A">0.5</option><option id="B">1.0</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fraction submerged = ρ_body / ρ_fluid.</explanation>
        </question>
        <question>
            <text>If Re of flow is changed from 500 to 1500, flow remains ____.</text>
            <option id="A">Laminar (often transitioning / unstable)</option><option id="B">Turbulent</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Transition typically 1000-2000.</explanation>
        </question>
        <question>
            <text>Pressure of 10m of water column is approx ____ atm.</text>
            <option id="A">1</option><option id="B">10</option><option id="C">None</option><option id="D">D</option>
            <answer>A</explanation>10^5 Pa approx.</explanation>
        </question>
        <question>
            <text>Surface of liquid in a capillary tube is flat if contact angle is ____.</text>
            <option id="A">90 deg</option><option id="B">0</option><option id="C">180</option><option id="D">None</option>
            <answer>A</answer><explanation>Pressure difference is zero (cos 90 = 0).</explanation>
        </question>
        <question>
            <text>Effect of increase in pressure on viscosity of water ____.</text>
            <option id="A">Decreases (initially)</option><option id="B">Increases always</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Anomalous behavior of water.</explanation>
        </question>
        <question>
            <text>Effect of increase in pressure on viscosity of most other liquids ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Molecules are packed tighter.</explanation>
        </question>
        <question>
            <text>Velocity of efflux depends on density of liquid?</text>
            <option id="A">No (v = sqrt(2gh))</option><option id="B">Yes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Independent for open tanks.</explanation>
        </question>
        <question>
            <text>Laminar flow is characterized by ____ layers.</text>
            <option id="A">Parallel</option><option id="B">Crossing</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>No mixing between layers.</explanation>
        </question>
        <question>
            <text>Small drops are spherical due to ____.</text>
            <option id="A">Surface Tension</option><option id="B">Gravity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Large drops are flattened by gravity.</explanation>
        </question>
        <question>
            <text>Internal energy of a liquid surface is ____ than bulk.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Surface molecules are in un-balanced force state.</explanation>
        </question>
        <question>
            <text>A capillary tube of radius r is in water. h is rise. If r is doubled, h becomes ____.</text>
            <option id="A">h/2</option><option id="B">h/4</option><option id="C">2h</option><option id="D">None</option>
            <answer>A</answer><explanation>By Jurin's Law, h ∝ 1/r.</explanation>
        </question>
        <question>
            <text>Pressure across a soap bubble of 2cm diameter (T=0.03 N/m) is ____ Pa.</text>
            <option id="A">12</option><option id="B">6</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>ΔP = 4T/R = 4(0.03)/0.01 = 12.</explanation>
        </question>
        <question>
            <text>Viscosity is a ____ property.</text>
            <option id="A">Transport (momentum)</option><option id="B">Colligative</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Relates to transfer of momentum between layers.</explanation>
        </question>
    </medium>
    <hard>
        <question>
            <text>Excess pressure inside a drop of radius R submerged in another liquid is ____.</text>
            <option id="A">2T / R</option><option id="B">4T / R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Only one interface.</explanation>
        </question>
        <question>
            <text>Two soap bubbles of radii r1, r2 coalesce at constant temp. New radius R satisfies ____.</text>
            <option id="A">R^2 = r1^2 + r2^2</option><option id="B">R^3 = r1^3 + r2^3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Surface area is conserved? No. Energy conservation/isothermal condition.</explanation>
        </question>
        <question>
            <text>Velocity profile of liquid in pipe (laminar) is ____.</text>
            <option id="A">Parabolic</option><option id="B">Linear</option><option id="C">Uniform</option><option id="D">None</option>
            <answer>A</answer><explanation>V_max at center, zero at walls.</explanation>
        </question>
        <question>
            <text>Kinematic viscosity is defined as η / ____.</text>
            <option id="A">ρ (Density)</option><option id="B">v (Velocity)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Units m^2/s.</explanation>
        </question>
        <question>
            <text>In Bernoulli's principle, if P and v decrease then height must ____?</text>
            <option id="A">Increase</option><option id="B">Decrease</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>To keep constant sum.</explanation>
        </question>
        <question>
            <text>Equation of motion for a fluid particle is ____ Equation.</text>
            <option id="A">Euler's</option><option id="B">Newton's second only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>F_net = ma for fluid volume.</explanation>
        </question>
        <question>
            <text>Work done against surface tension to break a drop of R into n small drops? ____.</text>
            <option id="A">4 π R^2 T (n^(1/3) - 1)</option><option id="B">4 π R^2 T n</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Increased surface area x T.</explanation>
        </question>
        <question>
            <text>Coefficient of viscosity for water is around ____ Pa.s at room temp.</text>
            <option id="A">10^-3</option><option id="B">1</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>1 centiPoise.</explanation>
        </question>
        <question>
            <text>Laminar boundary layer is layer near wall where velocity is ____.</text>
            <option id="A">Changing from 0 to bulk velocity</option><option id="B">Max</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Viscous effects are dominant here.</explanation>
        </question>
        <question>
            <text>Pitot tube measures ____ at a point in fluid flow.</text>
            <option id="A">Velocity</option><option id="B">Static pressure only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>By converting kinetic energy to pressure head.</explanation>
        </question>
        <question>
            <text>Ideal fluid is ____ and ____.</text>
            <option id="A">Incompressible , Non-viscous</option><option id="B">Compressible</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Assumptions for Bernoulli's derivation.</explanation>
        </question>
        <question>
            <text>Stability of a floating body depends on position of ____.</text>
            <option id="A">Metacentre</option><option id="B">Centre of gravity only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Must be above Centre of Gravity for stable equilibrium.</explanation>
        </question>
        <question>
            <text>Torricelli's vacuum is the space above mercury in ____.</text>
            <option id="A">Barometer</option><option id="B">Manometer</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Contains only mercury vapor (negligible pressure).</explanation>
        </question>
        <question>
            <text>If Re of a flow is doubled, viscous drag becomes ____?</text>
            <option id="A">Depends on flow regime (linear for laminar, square for turbulent)</option><option id="B">Double</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Physics of drag changes.</explanation>
        </question>
        <question>
            <text>Correction for liquid rise in wider capillary includes ____.</text>
            <option id="A">r/3 term for volume of meniscus</option><option id="B">Zero</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Advanced capillary rise formula h' = h + r/3.</explanation>
        </question>
        <question>
            <text>Surface tension vanishes at ____ temperature.</text>
            <option id="A">Critical</option><option id="B">Boiling</option><option id="C">Freezing</option><option id="D">None</option>
            <answer>A</answer><explanation>Interface disappears.</explanation>
        </question>
        <question>
            <text>Hydraulic force on side wall of tank: F = ____.</text>
            <option id="A">1/2 ρ g L H^2</option><option id="B">ρ g L H</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Average pressure ρgH/2 x Area LH.</explanation>
        </question>
        <question>
            <text>Pressure inside a fluid is a ____ quantity?</text>
            <option id="A">Scalar</option><option id="B">Vector</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Direction is always normal to surface.</explanation>
        </question>
        <question>
            <text>Terminal velocity of rain drop is small because ____ η is small? No. Because r is small.</text>
            <option id="A">r is small</option><option id="B">η is high</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v ~ r^2.</explanation>
        </question>
        <question>
            <text>Work done against surface tension to merge two drops into one? ____ is released.</text>
            <option id="A">Energy</option><option id="B">Force</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Surface area decreases.</explanation>
        </question>
        <question>
            <text>Pressure of gas on walls is due to ____ of molecules.</text>
            <option id="A">Momentum transfer during collisions</option><option id="B">Weight</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Kinetic theory origin.</explanation>
        </question>
        <question>
            <text>Isothermal bulk modulus of ideal gas is P. Adiabatic is ____ P.</text>
            <option id="A">gamma</option><option id="B">1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>C_p / C_v factor.</explanation>
        </question>
        <question>
            <text>Coefficient of viscosity depends on ____ of fluid?</text>
            <option id="A">Nature and Pressure/Temperature</option><option id="B">Only velocity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intrinsic material property.</explanation>
        </question>
        <question>
            <text>Dynamic pressure in Bernoulli's is ____.</text>
            <option id="A">1/2 ρ v^2</option><option id="B">P</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Velocity head contribution.</explanation>
        </question>
        <question>
            <text>Static pressure in Bernoulli's is ____.</text>
            <option id="A">P</option><option id="B">ρgh</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Thermodynamic pressure.</explanation>
        </question>
        <question>
            <text>Poiseuille's law assumes ____ flow.</text>
            <option id="A">Viscous laminar</option><option id="B">Ideal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Required for velocity profile derivation.</explanation>
        </question>
        <question>
            <text>Reynolds number for flow in tube using diameter d: Re = ____.</text>
            <option id="A">ρ v d / η</option><option id="B">v / d</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard definition.</explanation>
        </question>
