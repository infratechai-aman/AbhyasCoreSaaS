<chapter subject="Physics" id="112" name="Kinetic Theory">
    <easy>
        <question>
            <text>Kinetic theory explains gas behavior based on ____ motion.</text>
            <option id="A">Molecular</option><option id="B">Macro</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Statistical mechanics approach.</explanation>
        </question>
        <question>
            <text>Gas molecules are considered to be ____ spheres.</text>
            <option id="A">Perfectly Elastic</option><option id="B">Inelastic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Energy and momentum conserved during collisions.</explanation>
        </question>
        <question>
            <text>Pressure of gas is due to ____ of molecules with walls.</text>
            <option id="A">Collisions</option><option id="B">Gravity</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Momentum transfer per unit area.</explanation>
        </question>
        <question>
            <text>Average kinetic energy of a molecule is proportional to ____.</text>
            <option id="A">Absolute Temperature (T)</option><option id="B">Pressure</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>E = 3/2 kT for monatomic.</explanation>
        </question>
        <question>
            <text>Boyle’s Law holds at constant ____.</text>
            <option id="A">Temperature</option><option id="B">Pressure</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>P ∝ 1/V.</explanation>
        </question>
        <question>
            <text>Charle’s Law holds at constant ____.</text>
            <option id="A">Pressure</option><option id="B">Temperature</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>V ∝ T.</explanation>
        </question>
        <question>
            <text>Gay-Lussac’s Law holds at constant ____.</text>
            <option id="A">Volume</option><option id="B">Temperature</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>P ∝ T.</explanation>
        </question>
        <question>
            <text>Avogadro’s Number N_A is approx ____ mol^-1.</text>
            <option id="A">6.022 x 10^23</option><option id="B">1.38 x 10^-23</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Molecules per mole.</explanation>
        </question>
        <question>
            <text>Boltzmann constant k_B = R / ____.</text>
            <option id="A">N_A</option><option id="B">T</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Gas constant per molecule.</explanation>
        </question>
        <question>
            <text>Values of Boltzmann constant is approx ____ J/K.</text>
            <option id="A">1.38 x 10^-23</option><option id="B">8.314</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental gas constant.</explanation>
        </question>
        <question>
            <text>Value of Universal Gas Constant R is approx ____ J/molK.</text>
            <option id="A">8.314</option><option id="B">0.0821</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>For S.I. calculations.</explanation>
        </question>
        <question>
            <text>At STP, molar volume of an ideal gas is ____ liters.</text>
            <option id="A">22.4</option><option id="B">11.2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard for gas calculations.</explanation>
        </question>
        <question>
            <text>Root mean square (rms) speed v_rms = sqrt( 3RT / ____ ).</text>
            <option id="A">M (Molar mass)</option><option id="B">P</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Derived from kinetic energy formula.</explanation>
        </question>
        <question>
            <text>Avg distance a molecule travels between collisions is ____.</text>
            <option id="A">Mean Free Path</option><option id="B">RMS distance</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Symbol λ.</explanation>
        </question>
        <question>
            <text>Volume occupied by gas molecules is ____ compared to volume of container.</text>
            <option id="A">Negligible</option><option id="B">Significant</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Core assumption of ideal gas.</explanation>
        </question>
        <question>
            <text>Attractive forces between ideal gas molecules are ____.</text>
            <option id="A">Zero</option><option id="B">Large</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Molecules move independently.</explanation>
        </question>
        <question>
            <text>Dalton’s Law of partial pressures: P_total = ____.</text>
            <option id="A">Sum of partial pressures</option><option id="B">Product of pressures</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>For non-interacting gases.</explanation>
        </question>
        <question>
            <text>Number of degrees of freedom for monatomic gas is ____.</text>
            <option id="A">3</option><option id="B">5</option><option id="C">6</option><option id="D">None</option>
            <answer>A</answer><explanation>3 translational only.</explanation>
        </question>
        <question>
            <text>Number of degrees of freedom for diatomic gas (e.g. O2) at room T is ____.</text>
            <option id="A">5</option><option id="B">3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>3 translational + 2 rotational.</explanation>
        </question>
        <question>
            <text>Law of equipartition of energy: Energy per degree of freedom = ____.</text>
            <option id="A">1/2 k_B T</option><option id="B">k_B T</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy distributed equally.</explanation>
        </question>
        <question>
            <text>C_v for monatomic gas is ____ R.</text>
            <option id="A">3/2</option><option id="B">5/2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Using f=3.</explanation>
        </question>
        <question>
            <text>C_p for monatomic gas is ____ R.</text>
            <option id="A">5/2</option><option id="B">3/2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cp = Cv + R.</explanation>
        </question>
        <question>
            <text>Adiabatic index γ for monatomic gas is ____.</text>
            <option id="A">1.67 (5/3)</option><option id="B">1.40</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ratio Cp/Cv.</explanation>
        </question>
        <question>
            <text>Adiabatic index γ for diatomic gas is ____.</text>
            <option id="A">1.40 (7/5)</option><option id="B">1.67</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ratio Cp/Cv.</explanation>
        </question>
        <question>
            <text>An ideal gas obeys PV = nRT at ____ temperatures and ____ pressures.</text>
            <option id="A">All</option><option id="B">High T , Low P</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>By definition of 'Ideal' gas.</explanation>
        </question>
        <question>
            <text>Ratio of rms speed to most probable speed is ____.</text>
            <option id="A">sqrt(3/2)</option><option id="B">sqrt(8/pi)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v_rms > v_mp.</explanation>
        </question>
        <question>
            <text>Molar heat capacity C_v = f/2 x ____.</text>
            <option id="A">R</option><option id="B">T</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>General formula for gas C_v.</explanation>
        </question>
        <question>
            <text>At absolute zero, molecular motion ____.</text>
            <option id="A">Ceases</option><option id="B">Is maximum</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>KE = 0 at T = 0 K.</explanation>
        </question>
        <question>
            <text>Relation P = 1/3 n m v_rms^2 : 'n' is ____.</text>
            <option id="A">Number density (N/V)</option><option id="B">Moles</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Molecules per unit volume.</explanation>
        </question>
        <question>
            <text>Ideal gas potential energy is ____.</text>
            <option id="A">Zero</option><option id="B">Negative</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No intermolecular forces.</explanation>
        </question>
        <question>
            <text>Internal energy of ideal gas equals total ____ energy.</text>
            <option id="A">Kinetic</option><option id="B">Potential</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Since PE = 0.</explanation>
        </question>
        <question>
            <text>Gas fills container completely due to ____ random motion.</text>
            <option id="A">Infinite / Constant</option><option id="B">Gravity</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Entropy drive.</explanation>
        </question>
        <question>
            <text>Relationship v_avg = sqrt( 8RT / ____ ).</text>
            <option id="A">pi M</option><option id="B">3 M</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Mean speed formula.</explanation>
        </question>
        <question>
            <text>Brownian motion is evidence of ____ nature of matter.</text>
            <option id="A">Molecular / Kinetic</option><option id="B">Wave</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Observed in smoke/pollen particles.</explanation>
        </question>
        <question>
            <text>Mean free path decreases as pressure ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>More frequent collisions.</explanation>
        </question>
        <question>
            <text>Real gases behave ideally at ____ pressures.</text>
            <option id="A">Low</option><option id="B">High</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Molecules are far apart.</explanation>
        </question>
        <question>
            <text>Real gases behave ideally at ____ temperatures.</text>
            <option id="A">High</option><option id="B">Low</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>High kinetic energy overcomes attractions.</explanation>
        </question>
        <question>
            <text>The parameter 'a' in van der Waals equation accounts for ____.</text>
            <option id="A">Intermolecular Forces</option><option id="B">Molecule size</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pressure correction.</explanation>
        </question>
        <question>
            <text>The parameter 'b' in van der Waals equation accounts for ____.</text>
            <option id="A">Finite volume of molecules</option><option id="B">Forces</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Volume correction.</explanation>
        </question>
        <question>
            <text>Degrees of freedom for monatomic gas at very high temperature: ____.</text>
            <option id="A">3 (Trans remains dominant)</option><option id="B">5</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>No rotation/vibration possible for point atom.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>In kinetic theory, pressure P = (1/3) ρ v_rms^2. ρ is ____.</text>
            <option id="A">Density of gas</option><option id="B">Weight</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mass per unit volume.</explanation>
        </question>
        <question>
            <text>Ratio of v_rms for H2 to O2 at same temperature is ____.</text>
            <option id="A">4 (sqrt(32/2))</option><option id="B">16</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>v_rms ∝ 1/sqrt(M).</explanation>
        </question>
        <question>
            <text>Total kinetic energy of n moles of diatomic gas: E = ____.</text>
            <option id="A">5/2 nRT</option><option id="B">3/2 nRT</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Using f=5.</explanation>
        </question>
        <question>
            <text>Average translational KE of O2 molecules at 300K is ____ as that of H2.</text>
            <option id="A">Same</option><option id="B">Higher</option><option id="C">Lower</option><option id="D">None</option>
            <answer>A</answer><explanation>Translational KE depends only on T (3/2 kT).</explanation>
        </question>
        <question>
            <text>Mean free path formula λ = 1 / (sqrt(2) n pi d^2). 'd' is ____.</text>
            <option id="A">Diameter of molecule</option><option id="B">Distance</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cross-section determines collisions.</explanation>
        </question>
        <question>
            <text>Maxwell-Boltzmann distribution curve: Peak corresponds to ____ speed.</text>
            <option id="A">Most Probable (v_mp)</option><option id="B">Average</option><option id="C">RMS</option><option id="D">None</option>
            <answer>A</answer><explanation>Most frequent value.</explanation>
        </question>
        <question>
            <text>Relationship: v_mp &lt; v_avg &lt; ____.</text>
            <option id="A">v_rms</option><option id="B">Sound speed</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ordering of molecular speeds.</explanation>
        </question>
        <question>
            <text>v_rms of gas at 27 C is v. At what temp will speed be 2v?</text>
            <option id="A">927 C (1200 K)</option><option id="B">108 C</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v ∝ sqrt(T). Double v implies quadruple T.</explanation>
        </question>
        <question>
            <text>Specific heat capacity of solid at high T approaches ____ R.</text>
            <option id="A">3 (Dulong-Petit Law)</option><option id="B">1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Classical limit for lattice vibration.</explanation>
        </question>
        <question>
            <text>Diatomic gas with vibrational mode (high T) has f = ____.</text>
            <option id="A">7</option><option id="B">5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>3 trans + 2 rot + 2 vib (KE+PE).</explanation>
        </question>
        <question>
            <text>Graham’s Law of Diffusion: Rate ∝ ____.</text>
            <option id="A">1 / sqrt(M)</option><option id="B">1 / M</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lighter gases diffuse faster.</explanation>
        </question>
        <question>
            <text>Avogadro’s hypothesis says equal volumes of gases at same P and T contain ____.</text>
            <option id="A">Same number of molecules</option><option id="B">Same mass</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>N = PV / kT.</explanation>
        </question>
        <question>
            <text>Number of degrees of freedom f = (2 / (____ - 1)).</text>
            <option id="A">gamma</option><option id="B">alpha</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Relationship between f and adiabatic index.</explanation>
        </question>
        <question>
            <text>Air temp at altitude is low. v_rms of molecules ____ compared to ground level.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>v_rms ∝ sqrt(T).</explanation>
        </question>
        <question>
            <text>Kinetic energy per mole U = (f/2) ____.</text>
            <option id="A">RT</option><option id="B">kT</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>N_A x (f/2) kT = (f/2) RT.</explanation>
        </question>
        <question>
            <text>Collision frequency of gas molecules ∝ ____.</text>
            <option id="A">1 / lambda (Mean free path inverse)</option><option id="B">Volume</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Frequency = speed / path.</explanation>
        </question>
        <question>
            <text>Pressure of gas mixture containing n1 and n2 moles at V and T: P = ____.</text>
            <option id="A">(n1+n2) RT / V</option><option id="B">(n1*n2) RT / V</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Dalton's law application.</explanation>
        </question>
        <question>
            <text>Diatomic gas (e.g. CO) at high temp includes ____ vibrational modes.</text>
            <option id="A">2 (one mode contributes 2 degrees)</option><option id="B">1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>vibration energy has KE and PE terms.</explanation>
        </question>
        <question>
            <text>Ratio of Cp for He and H2 (at room temp) is ____.</text>
            <option id="A">5/7</option><option id="B">3/5</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>(5/2 R) / (7/2 R).</explanation>
        </question>
        <question>
            <text>Mean free path ∝ ____ at constant pressure.</text>
            <option id="A">Temperature (T)</option><option id="B">1 / T</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>λ ∝ V/N, and V ∝ T (Charle's Law).</explanation>
        </question>
        <question>
            <text>Mean free path ∝ ____ at constant temperature.</text>
            <option id="A">1 / Pressure (P)</option><option id="B">P</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>λ ∝ 1/n, and n ∝ P (at const T).</explanation>
        </question>
        <question>
            <text>Kinetic gas constant per molecule is ____.</text>
            <option id="A">k_B (Boltzmann constant)</option><option id="B">R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>R / N_A.</explanation>
        </question>
        <question>
            <text>Volume of real gas at absolute zero is ____.</text>
            <option id="A">Finite (b)</option><option id="B">Zero</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to molecule size.</explanation>
        </question>
        <question>
            <text>For diatomic gas γ = CP/CV = ____.</text>
            <option id="A">1.4</option><option id="B">1.6</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>7/5 ratio.</explanation>
        </question>
        <question>
            <text>Cv of a rigid diatomic molecule is ____.</text>
            <option id="A">5/2 R</option><option id="B">3/2 R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>f = 5.</explanation>
        </question>
        <question>
            <text>Internal energy change ΔU for ideal gas expansion in vacuum is ____.</text>
            <option id="A">Zero</option><option id="B">Positive</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No work (P=0) and constant T (no forces).</explanation>
        </question>
        <question>
            <text>In kinetic model, molecules are in ____ motion.</text>
            <option id="A">Random / Chaotic</option><option id="B">Circular</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No preferred direction.</explanation>
        </question>
        <question>
            <text>Mean energy per degree of freedom for water molecule vibrational? Standard ____.</text>
            <option id="A">kT</option><option id="B">1/2 kT</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Each vibration mode has 2 degrees of freedom.</explanation>
        </question>
        <question>
            <text>Relationship between P, ρ and v_avg: P = (____ / 8) ρ v_avg^2.</text>
            <option id="A">pi / 3</option><option id="B">1 / 3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Derived by substituting v_rms.</explanation>
        </question>
        <question>
            <text>Coefficient of viscosity of gas ∝ ____.</text>
            <option id="A">sqrt(T)</option><option id="B">1/T</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Depends on molecular velocity.</explanation>
        </question>
        <question>
            <text>Pressure exerted by 1g of gas is ____ than by 1g of heavier gas in same V, T.</text>
            <option id="A">Greater</option><option id="B">Same</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>More moles in lighter gas (n = m/M).</explanation>
        </question>
        <question>
            <text>Energy of 1 L air at NTP? P = 10^5 Pa. E = 3/2 PV = ____ J.</text>
            <option id="A">150</option><option id="B">100</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Calculation for monatomic approx.</explanation>
        </question>
        <question>
            <text>Fraction of molecules with speed between v and v+dv is given by ____ distribution.</text>
            <option id="A">Maxwell</option><option id="B">Boltzmann</option><option id="C">Planck</option><option id="D">None</option>
            <answer>A</answer><explanation>Classic kinetic theory result.</explanation>
        </question>
        <question>
            <text>v_rms of gas molecules is approx ____ speed of sound in the gas.</text>
            <option id="A">Larger (v_rms = sqrt(3/gamma) v_sound)</option><option id="B">Smaller</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Both depend on sqrt(T/M).</explanation>
        </question>
        <question>
            <text>Methane (CH4) gas degrees of freedom f = ____.</text>
            <option id="A">6 (3 trans + 3 rot)</option><option id="B">5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Non-linear polyatomic.</explanation>
        </question>
        <question>
            <text>Specific heat Cv of polyatomic gas (non-linear) is ____ R.</text>
            <option id="A">3 (6/2)</option><option id="B">4</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>f = 6.</explanation>
        </question>
        <question>
            <text>Specific heat Cp of polyatomic gas (non-linear) is ____ R.</text>
            <option id="A">4</option><option id="B">3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cp = Cv + R.</explanation>
        </question>
        <question>
            <text>Ratio Cp/Cv for polyatomic non-linear gas is ____.</text>
            <option id="A">1.33 (4/3)</option><option id="B">1.40</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Limit for large complex molecules.</explanation>
        </question>
        <question>
            <text>Van der Waals gas correction for volume 'b' is ____ times the volume of molecules.</text>
