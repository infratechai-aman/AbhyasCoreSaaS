            <answer>A</answer><explanation>Example: Camphor, Iodine.</explanation>
        </question>
        <question>
            <text>Specific heat of water is unusually ____.</text>
            <option id="A">High (~4200 J/kgK)</option><option id="B">Low</option><option id="C">phi</option><option id="D">None</option>
