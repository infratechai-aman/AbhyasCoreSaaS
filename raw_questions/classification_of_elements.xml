<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Chemistry" id="202" name="Classification of Elements and Periodicity in Properties">
    <easy>
        <question>
            <text>Modern periodic law states that properties of elements are periodic functions of their ____.</text>
            <option id="A">Atomic Number</option><option id="B">Atomic Mass</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Proposed by Moseley.</explanation>
        </question>
        <question>
            <text>Mendeleev's periodic law was based on ____.</text>
            <option id="A">Atomic Mass</option><option id="B">Atomic Number</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Original classification basis.</explanation>
        </question>
        <question>
            <text>Horizontal rows in the periodic table are called ____.</text>
            <option id="A">Periods</option><option id="B">Groups</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>There are 7 periods in IUPAC table.</explanation>
        </question>
        <question>
            <text>Vertical columns in the periodic table are called ____.</text>
            <option id="A">Groups</option><option id="B">Periods</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>There are 18 groups in long form.</explanation>
        </question>
        <question>
            <text>Group 1 elements are known as ____ metals.</text>
            <option id="A">Alkali</option><option id="B">Alkaline Earth</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Li, Na, K, Rb, Cs, Fr.</explanation>
        </question>
        <question>
            <text>Group 2 elements are known as ____ metals.</text>
            <option id="A">Alkaline Earth</option><option id="B">Alkali</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Be, Mg, Ca, Sr, Ba, Ra.</explanation>
        </question>
        <question>
            <text>Elements of Group 17 are called ____.</text>
            <option id="A">Halogens</option><option id="B">Noble Gases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>F, Cl, Br, I, At.</explanation>
        </question>
        <question>
            <text>Elements of Group 18 are called ____.</text>
            <option id="A">Noble Gases</option><option id="B">Chalcogens</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>He, Ne, Ar, Kr, Xe, Rn.</explanation>
        </question>
        <question>
            <text>Groups 3 to 12 contain ____ elements.</text>
            <option id="A">Transition</option><option id="B">Representative</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>d-block elements.</explanation>
        </question>
        <question>
            <text>Lanthanides and Actinides are called ____ transition elements.</text>
            <option id="A">Inner</option><option id="B">Outer</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>f-block elements.</explanation>
        </question>
        <question>
            <text>Most electronegative element in the periodic table is ____.</text>
            <option id="A">Fluorine</option><option id="B">Cesium</option><option id="C">O</option><option id="D">None</option>
            <answer>A</answer><explanation>Top right (excluding noble gases).</explanation>
        </question>
        <question>
            <text>Element with highest metallic character is ____.</text>
            <option id="A">Cesium (Fr is radioactive)</option><option id="B">Fluorine</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Bottom left trend.</explanation>
        </question>
        <question>
            <text>Atomic radius ____ along a period from left to right.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to increase in effective nuclear charge.</explanation>
        </question>
        <question>
            <text>Atomic radius ____ down a group.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to addition of new shells.</explanation>
        </question>
        <question>
            <text>Ionization enthalpy ____ along a period left to right.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Harder to remove electron from smaller atom.</explanation>
        </question>
        <question>
            <text>Ionization enthalpy ____ down a group.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Easier to remove from far outer shells.</explanation>
        </question>
        <question>
            <text>Non-metallic character ____ along a period left to right.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Electronegativity increases.</explanation>
        </question>
        <question>
            <text>s-block and p-block elements (except group 18) are called ____ elements.</text>
            <option id="A">Representative</option><option id="B">Inert</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Main group elements.</explanation>
        </question>
        <question>
            <text>Noble gases have ____ ionization enthalpy.</text>
            <option id="A">Very high</option><option id="B">Low</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Stable octet configuration.</explanation>
        </question>
        <question>
            <text>Which element belongs to the 1st period?</text>
            <option id="A">Hydrogen</option><option id="B">Lithium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Period 1 has H and He.</explanation>
        </question>
        <question>
            <text>Group 16 elements are called ____.</text>
            <option id="A">Chalcogens</option><option id="B">Halogens</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Oxygen family.</explanation>
        </question>
        <question>
            <text>Valence electrons in Group 13 elements is ____.</text>
            <option id="A">3</option><option id="B">13</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>ns2 np1.</explanation>
        </question>
        <question>
            <text>Diagonal relationship exists between Lithium and ____.</text>
            <option id="A">Magnesium</option><option id="B">Aluminum</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Similar charge/radius ratio.</explanation>
        </question>
        <question>
            <text>Diagonal relationship exists between Beryllium and ____.</text>
            <option id="A">Aluminum</option><option id="B">Magnesium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Periodic sibling.</explanation>
        </question>
        <question>
            <text>Which block contains metals, non-metals and metalloids?</text>
            <option id="A">p-block</option><option id="B">s-block</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Most diverse block.</explanation>
        </question>
        <question>
            <text>Maximum oxidation state of Oxygen is usually ____.</text>
            <option id="A">+2 (in OF2)</option><option id="B">+6</option><option id="C">-2</option><option id="D">None</option>
            <answer>A</answer><explanation>Oxygen is 2nd most EN.</explanation>
        </question>
        <question>
            <text>The first noble gas discovered was ____.</text>
            <option id="A">Helium</option><option id="B">Argon</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>In the sun's spectrum.</explanation>
        </question>
        <question>
            <text>Number of elements in the second period is ____.</text>
            <option id="A">8</option><option id="B">2</option><option id="C">18</option><option id="D">None</option>
            <answer>A</answer><explanation>Li to Ne.</explanation>
        </question>
        <question>
            <text>Which group contains liquid metals? (Only Hg? No elements! Group is 12?)</text>
            <option id="A">Group 12 (Hg)</option><option id="B">Group 1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard room temp liquid metal.</explanation>
        </question>
        <question>
            <text>Unit of electronegativity on Pauling scale? ____.</text>
            <option id="A">No unit</option><option id="B">eV</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Relative qualitative scale.</explanation>
        </question>
        <question>
            <text>Lanthanides are elements from Z=____ to Z=____.</text>
            <option id="A">58 to 71</option><option id="B">90 to 103</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Filling 4f subshell.</explanation>
        </question>
        <question>
            <text>Actinides are elements from Z=____ to Z=____.</text>
            <option id="A">90 to 103</option><option id="B">58 to 71</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Filling 5f subshell.</explanation>
        </question>
        <question>
            <text>Ionic radius ____ with increase in negative charge for isoelectronic.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>More repulsion, less net pull.</explanation>
        </question>
        <question>
            <text>Ionic radius ____ with increase in positive charge for isoelectronic.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Stronger pull on fewer electrons.</explanation>
        </question>
        <question>
            <text>First ionization enthalpy of Mg is ____ than Na.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Trend to the right increases IE.</explanation>
        </question>
        <question>
            <text>First ionization enthalpy of Mg is ____ than Al.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mg has stable full s-subshell.</explanation>
        </question>
        <question>
            <text>First ionization enthalpy of Nitrogen is ____ than Oxygen.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Nitrogen has stable half-filled p-subshell.</explanation>
        </question>
        <question>
            <text>General electronic configuration of d-block: (n-1)d^ ____ ns^ ____.</text>
            <option id="A">1-10 , 1-2</option><option id="B">1-10, 0</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Outer and penultimate shell filling.</explanation>
        </question>
        <question>
            <text>An element with Z=114 would belong to ____ group.</text>
            <option id="A">14 (below Lead)</option><option id="B">16</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Carbon family extension.</explanation>
        </question>
        <question>
            <text>Elements with Z > 92 are called ____ elements.</text>
            <option id="A">Transuranic</option><option id="B">Transition</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Synthetic elements after Uranium.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Screening effect order for subshells: ____.</text>
            <option id="A">s > p > d > f</option><option id="B">f > d > p > s</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Penetration power affects shielding.</explanation>
        </question>
        <question>
            <text>Effective nuclear charge (Zeff) felt by 2s vs 2p? 2s feels ____.</text>
            <option id="A">Higher Zeff (more penetration)</option><option id="B">Lower</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>s-electrons penetrate closer to nucleus.</explanation>
        </question>
        <question>
            <text>Electron gain enthalpy becomes ____ negative across a period generally.</text>
            <option id="A">More</option><option id="B">Less</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Atoms want octet (except noble gases).</explanation>
        </question>
        <question>
            <text>Electron gain enthalpy of Noble gases is ____.</text>
            <option id="A">Positive / Large</option><option id="B">Highly Negative</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy needed to force an electron in.</explanation>
        </question>
        <question>
            <text>Which has more negative electron gain enthalpy: Cl or F?</text>
            <option id="A">Cl</option><option id="B">F</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cl has less electron-electron repulsion in 3p.</explanation>
        </question>
        <question>
            <text>Correct order of IE1: Li ____ Be ____ B ____ C.</text>
            <option id="A">Li &lt; B &lt; Be &lt; C</option><option id="B">Li &lt; Be &lt; B &lt; C</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Anomalous jump at Be (2s2).</explanation>
        </question>
        <question>
            <text>Correct order of IE1: C ____ N ____ O ____ F.</text>
            <option id="A">C &lt; O &lt; N &lt; F</option><option id="B">C &lt; N &lt; O &lt; F</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Anomalous jump at N (2p3).</explanation>
        </question>
        <question>
            <text>Second ionization enthalpy is always ____ than first.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Removing from cation is harder.</explanation>
        </question>
        <question>
            <text>IE2 of Sodium is ____ than Magnesium.</text>
            <option id="A">Much Higher</option><option id="B">Lower</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Na+ has stable Ne-like octet.</explanation>
        </question>
        <question>
            <text>Newlands' Law of Octaves was applicable only up to ____.</text>
            <option id="A">Calcium</option><option id="B">Iron</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Valid only for lighter elements.</explanation>
        </question>
        <question>
            <text>Eka-Aluminum predicted by Mendeleev is ____.</text>
            <option id="A">Gallium</option><option id="B">Germanium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Eka-Silicon was Germanium.</explanation>
        </question>
        <question>
            <text>Eka-Boron predicted by Mendeleev is ____.</text>
            <option id="A">Scandium</option><option id="B">Yttrium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Successfully filled the gap.</explanation>
        </question>
        <question>
            <text>The IUPAC name for Z=101 is ____.</text>
            <option id="A">Unnilunium</option><option id="B">Unnilseptium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Digits: un(1) nil(0) un(1).</explanation>
        </question>
        <question>
            <text>The IUPAC name for Z=110 is ____.</text>
            <option id="A">Ununnilium</option><option id="B">Ununquadium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>un(1) un(1) nil(0).</explanation>
        </question>
        <question>
            <text>Electronic configuration of Lanthanum (Z=57) ends in ____.</text>
            <option id="A">5d1 6s2</option><option id="B">4f1 6s2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Technically d-block start, but parent of f-series.</explanation>
        </question>
        <question>
            <text>Metallic character decreases as electronegativity ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Opposite trends.</explanation>
        </question>
        <question>
            <text>Acidic character of oxides ____ across period.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Transition from basic Na2O to acidic Cl2O7.</explanation>
        </question>
        <question>
            <text>Basic character of oxides ____ down a group.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Li2O to Cs2O (more basic).</explanation>
        </question>
        <question>
            <text>Oxides of Al and Zn are ____.</text>
            <option id="A">Amphoteric</option><option id="B">Acidic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>React with both acids and bases.</explanation>
        </question>
        <question>
            <text>Transition metals show variable oxidation states because ____.</text>
            <option id="A">(n-1)d and ns energies are close</option><option id="B">Octet not complete</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Electrons from both can participate.</explanation>
        </question>
        <question>
            <text>Group 11 elements (Cu, Ag, Au) are called ____ metals.</text>
            <option id="A">Coinage</option><option id="B">Transition</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Historical usage.</explanation>
        </question>
        <question>
            <text>Which period is the shortest?</text>
            <option id="A">1st (2 elements)</option><option id="B">2nd</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Contains H and He.</explanation>
        </question>
        <question>
            <text>Which period is the longest (currently)?</text>
            <option id="A">6th and 7th (32 elements each)</option><option id="B">5th</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Full rows with f-block inclusion.</explanation>
        </question>
        <question>
            <text>Effective nuclear charge Z* = Z - σ. Value of σ for outer electron in Li is approx ____.</text>
            <option id="A">1.7 (Slater's rule for 2s1? no 2*0.85 = 1.7. Correct.)</option><option id="B">1.0</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Shielding by two 1s electrons.</explanation>
        </question>
        <question>
            <text>Ratio of radii of Na+ to F- is approx ____.</text>
            <option id="A">&lt; 1 (cation is smaller than anion)</option><option id="B">> 1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Na+ (Z=11) vs F- (Z=9). Na+ pull is stronger.</explanation>
        </question>
        <question>
            <text>The element with Z=43? ____.</text>
            <option id="A">Technetium (First synthetic)</option><option id="B">Rhenium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Radioactive transition metal.</explanation>
        </question>
        <question>
            <text>Valency across a period (ref H) first ____ then ____.</text>
            <option id="A">Increases (1 to 4) then Decreases (to 0)</option><option id="B">Stays same</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Based on octet requirement.</explanation>
        </question>
        <question>
            <text>Reducing power down Group 1 ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Oxidation potential increases down group (except Li anomalous hydration).</explanation>
        </question>
        <question>
            <text>Oxidizing power down Group 17 ____.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>F2 is the strongest oxidant.</explanation>
        </question>
        <question>
            <text>Hydration energy of alkali metals: ____.</text>
            <option id="A">Li+ > Na+ > K+ > Cs+</option><option id="B">Cs+ > K+ > Na+ > Li+</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Small Li+ attracts more water.</explanation>
        </question>
        <question>
            <text>Ionic mobility of alkali metals in water: ____.</text>
            <option id="A">Cs+ > K+ > Na+ > Li+</option><option id="B">Li+ > Na+ > K+ > Cs+</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Heavily hydrated Li+ is slow.</explanation>
        </question>
        <question>
            <text>Periodicity in properties is due to repetition of ____.</text>
            <option id="A">Outer electronic configuration</option><option id="B">Mass</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Similar valence shell = similar chemistry.</explanation>
        </question>
        <question>
            <text>Total number of s-block elements (Inc He) is ____.</text>
            <option id="A">14</option><option id="B">12</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Grp 1 (7) + Grp 2 (6) + He (1).</explanation>
        </question>
        <question>
            <text>Element with max electron affinity (absolute) is ____.</text>
            <option id="A">Chlorine</option><option id="B">Fluorine</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Trend jump due to repulsion in F.</explanation>
        </question>
        <question>
            <text>Size of an atom: r_cov ____ r_vdw.</text>
            <option id="A">&lt;</option><option id="B">&gt;</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Van der Waals radius is always larger.</explanation>
        </question>
        <question>
            <text>Ionic radii of N3- , O2- , F- in order: ____.</text>
            <option id="A">N3- > O2- > F-</option><option id="B">F- > O2- > N3-</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>More negative = larger size for isoelectronic.</explanation>
        </question>
        <question>
            <text>First p-block metal in Period 2 is ____.</text>
            <option id="A">None? Group 13 B is metalloid? Al is period 3? periodic 2 Al position is B.</option><option id="B">Aluminum</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Period 2 has no p-block metal (B is metalloid).</explanation>
        </question>
        <question>
            <text>Group with most gaseous elements is ____.</text>
            <option id="A">Group 18</option><option id="B">Group 17</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>All noble gases are gases.</explanation>
        </question>
        <question>
            <text>Which of these is a liquid non-metal?</text>
            <option id="A">Bromine</option><option id="B">Mercury</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard room temperature liquid.</explanation>
