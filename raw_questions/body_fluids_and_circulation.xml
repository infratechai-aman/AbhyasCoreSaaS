<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Biology" id="318" name="Body Fluids and Circulation">
    <easy>
        <question>
            <text>Most commonly used body fluid in higher organisms for transport is ____.</text>
            <option id="A">Blood</option><option id="B">Lymph</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Liquid connective tissue containing plasma and formed elements.</explanation></question>
        <question>
            <text>Another body fluid that helps in transport of certain substances is ____.</text>
            <option id="A">Lymph</option><option id="B">Urine</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Also known as tissue fluid.</explanation></question>
        <question>
            <text>Plasma is a straw-colored, viscous fluid constituting nearly ____% of the blood.</text>
            <option id="A">55</option><option id="B">45</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Water is about 90-92% of plasma.</explanation></question>
        <question>
            <text>Major proteins in plasma include Fibrinogen, ____ and ____.</text>
            <option id="A">Globulins / Albumins</option><option id="B">Hemoglobin / Keratin</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fibrinogen is needed for clotting.</explanation></question>
        <question>
            <text>Plasma proteins involved in defense mechanism of the body are ____.</text>
            <option id="A">Globulins</option><option id="B">Albumins</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Source of antibodies.</explanation></question>
        <question>
            <text>Plasma proteins that help in osmotic balance are ____.</text>
            <option id="A">Albumins</option><option id="B">Fibrinogens</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maintains water retention in blood vessels.</explanation></question>
        <question>
            <text>Formed elements of blood constitute ____% of the blood.</text>
            <option id="A">45</option><option id="B">55</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Includes RBCs, WBCs and platelets.</explanation></question>
        <question>
            <text>Most abundant of all cells in blood are ____.</text>
            <option id="A">RBCs (Erythrocytes)</option><option id="B">WBCs</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Average adult has 5 - 5.5 million RBCs per cubic mm.</explanation></question>
        <question>
            <text>RBCs are formed in the ____ in adults.</text>
            <option id="A">Red bone marrow</option><option id="B">Spleen</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Process is called erythropoiesis.</explanation></question>
        <question>
            <text>Most mammals have RBCs that are ____ and lack a nucleus.</text>
            <option id="A">Biconcave</option><option id="B">Biconvex</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Increases surface area for oxygen transport.</explanation></question>
        <question>
            <text>Average life span of RBCs is ____ days.</text>
            <option id="A">120</option><option id="B">10</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Destroyed in the spleen.</explanation></question>
        <question>
            <text>Spleen is often called the '____' of RBCs.</text>
            <option id="A">Graveyard</option><option id="B">Cradle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Old RBCs are removed from circulation here.</explanation></question>
        <question>
            <text>Leucocytes are also known as ____.</text>
            <option id="A">WBCs</option><option id="B">Platelets</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Colorless due to lack of hemoglobin.</explanation></question>
        <question>
            <text>Average number of WBCs per cubic mm of blood? ____.</text>
            <option id="A">6000 - 8000</option><option id="B">5 million</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Relatively short-lived.</explanation></question>
        <question>
            <text>Two main categories of WBCs are Granulocytes and ____.</text>
            <option id="A">Agranulocytes</option><option id="B">Mast cells</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Based on presence of visible granules in cytoplasm.</explanation></question>
        <question>
            <text>Most abundant cells of total WBCs? ____.</text>
            <option id="A">Neutrophils (60-65%)</option><option id="B">Lymphocytes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Phagocytic cells.</explanation></question>
        <question>
            <text>Least abundant leucocytes are ____.</text>
            <option id="A">Basophils (0.5-1%)</option><option id="B">Eosinophils</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Secretes histamine, serotonin and heparin.</explanation></question>
        <question>
            <text>Phagocytic WBCs include Neutrophils and ____.</text>
            <option id="A">Monocytes</option><option id="B">Lymphocytes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Destroy foreign organisms entering the body.</explanation></question>
        <question>
            <text>The two major types of lymphocytes are ____ and ____.</text>
            <option id="A">B / T</option><option id="B">Neutral/Acidic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Responsible for immune responses.</explanation></question>
        <question>
            <text>Platelets are also called ____.</text>
            <option id="A">Thrombocytes</option><option id="B">Erythrocytes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cell fragments produced from megakaryocytes.</explanation></question>
        <question>
            <text>Reduction in platelet count can lead to clotting disorders and excessive ____.</text>
            <option id="A">Blood loss</option><option id="B">Clotting</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Hemorrhage risk.</explanation></question>
        <question>
            <text>ABO grouping is based on the presence or absence of two surface ____ on RBCs.</text>
            <option id="A">Antigens (A and B)</option><option id="B">Antibody</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Chemicals that can induce immune response.</explanation></question>
        <question>
            <text>Plasma of different individuals contains natural ____ (proteins produced in response to antigens).</text>
            <option id="A">Antibodies</option><option id="B">Antigens</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Anti-A or Anti-B.</explanation></question>
        <question>
            <text>Universal donor blood group is ____.</text>
            <option id="A">O</option><option id="B">AB</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Lacks surface antigens A and B.</explanation></question>
        <question>
            <text>Universal recipient blood group is ____.</text>
            <option id="A">AB</option><option id="B">O</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lacks antibodies Anti-A and Anti-B in plasma.</explanation></question>
        <question>
            <text>Rh antigen (similar to Rhesus monkey) is present in approx ____% of humans.</text>
            <option id="A">80</option><option id="B">50</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Such individuals are Rh positive.</explanation></question>
        <question>
            <text>Mechanism of blood clotting is also called ____.</text>
            <option id="A">Coagulation</option><option id="B">Evacuation</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Forms a reddish brown scum at sight of injury.</explanation></question>
        <question>
            <text>The dark reddish brown scum formed at the site of a cut? ____.</text>
            <option id="A">Clot (Coagulum)</option><option id="B">Plasma</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Mainly formed of network of fibrils called fibrins.</explanation></question>
        <question>
            <text>Enzyme complex required for conversion of prothrombin to thrombin? ____.</text>
            <option id="A">Thrombokinase</option><option id="B">Heparin</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Formed by a series of linked enzymatic reactions (cascade process).</explanation></question>
        <question>
            <text>Certain factors in plasma without clotting factors are called ____.</text>
            <option id="A">Serum</option><option id="B">Lymph</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Plasma minus fibrinogen and other factors.</explanation></question>
        <question>
            <text>Fluid present in international spaces between cells is ____.</text>
            <option id="A">Lymph (Interstitial fluid)</option><option id="B">Blood</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Has same mineral distribution as in plasma.</explanation></question>
        <question>
            <text>Lymph is a ____ fluid containing specialized lymphocytes.</text>
            <option id="A">Colorless</option><option id="B">Red</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Carries digested fats in lacteals.</explanation></question>
        <question>
            <text>Open circulatory system is found in ____ and ____.</text>
            <option id="A">Arthropods / Molluscs</option><option id="B">Annelids / Mammals</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Blood pumped into body cavities (sinuses).</explanation></question>
        <question>
            <text>Closed circulatory system is found in ____ and Chordates.</text>
            <option id="A">Annelids (e.g. Earthworm)</option><option id="B">Arthropods</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Blood circulates through a series of vessels.</explanation></question>
        <question>
            <text>Fishes have a ____ chambered heart.</text>
            <option id="A">2 (one atrium, one ventricle)</option><option id="B">3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pumps deoxygenated blood only (Venous heart).</explanation></question>
        <question>
            <text>Amphibians and reptiles (except crocodiles) have a ____ chambered heart.</text>
            <option id="A">3 (two atria, one ventricle)</option><option id="B">4</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Mixing of blood occurs in the single ventricle.</explanation></question>
        <question>
            <text>Mammals and birds have a ____ chambered heart.</text>
            <option id="A">4</option><option id="B">3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Complete separation of oxygenated and deoxygenated blood.</explanation></question>
        <question>
            <text>Double circulation is essential for ____ animals.</text>
            <option id="A">Homeothermic (Warm-blooded)</option><option id="B">Poikilothermic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maintains efficient oxygen supply.</explanation></question>
        <question>
            <text>The human heart is ____ in origin.</text>
            <option id="A">Mesodermal</option><option id="B">Ectodermal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Situated in thoracic cavity between lungs.</explanation></question>
        <question>
            <text>Easy 40 complete?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">none</option><option id="D">none</option>
            <answer>A</answer><explanation>Done.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Heart is protected by a double-walled membranous bag called ____.</text>
            <option id="A">Pericardium</option><option id="B">Pleura</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Contains pericardial fluid.</explanation></question>
        <question>
            <text>Small upper chambers of heart are called ____.</text>
            <option id="A">Atria</option><option id="B">Ventricles</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Receiving chambers.</explanation></question>
        <question>
            <text>Large lower chambers of heart are called ____.</text>
            <option id="A">Ventricles</option><option id="B">Atria</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pumping chambers; have thicker walls.</explanation></question>
        <question>
            <text>Wall dividing left and right atria is ____ septum.</text>
            <option id="A">Inter-atrial (thin)</option><option id="B">Inter-ventricular</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Separates oxygenated from deoxygenated blood at receiving end.</explanation></question>
        <question>
            <text>Valve between right atrium and right ventricle is ____ valve.</text>
            <option id="A">Tricuspid</option><option id="B">Bicuspid (Mitral)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Has three muscular flaps.</explanation></question>
        <question>
            <text>Valve between left atrium and left ventricle is ____ valve.</text>
            <option id="A">Bicuspid (Mitral)</option><option id="B">Tricuspid</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Has two flaps.</explanation></question>
        <question>
            <text>Valves at the openings of pulmonary artery and aorta are ____ valves.</text>
            <option id="A">Semilunar</option><option id="B">AV valves</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Prevent backflow of blood into ventricles.</explanation></question>
        <question>
            <text>Muscle of heart is exclusively ____ muscle.</text>
            <option id="A">Cardiac</option><option id="B">Skeletal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Involuntary and branched.</explanation></question>
        <question>
            <text>Special nodal tissue that generates action potential in heart? ____.</text>
            <option id="A">SAN (Sino-atrial node)</option><option id="B">AVN</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Located in upper right corner of right atrium.</explanation></question>
        <question>
            <text>SAN is called the '____' of the heart.</text>
            <option id="A">Pacemaker</option><option id="B">Governor</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Initiates and maintains rhythmic contractile activity.</explanation></question>
        <question>
            <text>Nodal tissue near lower left corner of right atrium is ____.</text>
            <option id="A">AVN (Atrio-ventricular node)</option><option id="B">SAN</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Delays impulse to allow atria to empty.</explanation></question>
        <question>
            <text>AV bundle / Bundle of ____ carries impulse to ventricles.</text>
            <option id="A">His</option><option id="B">Purkinje</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Divides into right and left branches.</explanation></question>
        <question>
            <text>Minute fibers arising from branches of AV bundle in ventricular wall are ____.</text>
            <option id="A">Purkinje fibers</option><option id="B">Cordae tendinae</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cause rapid contraction of ventricles.</explanation></question>
        <question>
            <text>Cardiac cycle starts with all four chambers in a relaxed state? ____.</text>
            <option id="A">Joint Diastole</option><option id="B">Atrial Systole</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Blood flows from pulmonary veins and vena cava into atria then ventricles.</explanation></question>
        <question>
            <text>Duration of one cardiac cycle in man? ____ seconds.</text>
            <option id="A">0.8</option><option id="B">0.5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Based on 75 beats per minute.</explanation></question>
        <question>
            <text>Volume of blood pumped out by each ventricle during a cardiac cycle? ____.</text>
            <option id="A">Stroke Volume (approx 70 mL)</option><option id="B">Cardiac output</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Efficiency measure of heart.</explanation></question>
        <question>
            <text>Cardiac Output = Stroke Volume x ____.</text>
            <option id="A">Heart Rate</option><option id="B">Pulse Pressure</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Average is approx 5000 mL or 5 liters per minute.</explanation></question>
        <question>
            <text>First heart sound (Lubb) is associated with closure of ____.</text>
            <option id="A">AV valves (Tricuspid/Bicuspid)</option><option id="B">Semilunar valves</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Occurs at start of ventricular systole.</explanation></question>
        <question>
            <text>Second heart sound (Dupp) is associated with closure of ____.</text>
            <option id="A">Semilunar valves</option><option id="B">AV valves</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Occurs at start of ventricular diastole.</explanation></question>
        <question>
            <text>Machine used to obtain electrocardiogram? ____.</text>
            <option id="A">Electrocardiograph</option><option id="B">Electrocardiogram (this is the record)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Clinical diagnostic tool.</explanation></question>
        <question>
            <text>The P-wave in ECG represents ____.</text>
            <option id="A">Atrial depolarization (Excitation)</option><option id="B">Ventricular depolarization</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Leads to contraction of both atria.</explanation></question>
        <question>
            <text>The QRS complex in ECG represents ____.</text>
            <option id="A">Ventricular depolarization</option><option id="B">Atrial relaxation</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Initiates ventricular contraction.</explanation></question>
        <question>
            <text>The T-wave in ECG represents ____.</text>
            <option id="A">Ventricular repolarization (Return to normal)</option><option id="B">Atrial depolarization</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>End of T-wave marks end of systole.</explanation></question>
        <question>
            <text>Count of QRS complexes in a given time period determines ____.</text>
            <option id="A">Heart rate</option><option id="B">Blood pressure</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Abnormal shapes indicate heart ailments.</explanation></question>
        <question>
            <text>Circulation between heart and lungs is ____ circulation.</text>
            <option id="A">Pulmonary</option><option id="B">Systemic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Via Pulmonary artery and Pulmonary veins.</explanation></question>
        <question>
            <text>Circulation providing oxygenated blood to all body parts is ____ circulation.</text>
            <option id="A">Systemic</option><option id="B">Pulmonary</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Deoxygenated blood returns via Vena Cava.</explanation></question>
        <question>
            <text>Unique vascular connection between digestive tract and liver? ____.</text>
            <option id="A">Hepatic portal system</option><option id="B">Renal portal system</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Carries nutrients to liver before systemic circulation.</explanation></question>
        <question>
            <text>Blood supply specifically for heart musculature? ____.</text>
            <option id="A">Coronary system</option><option id="B">Hepatic system</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cardiac muscles need constant oxygen.</explanation></question>
        <question>
            <text>Regulating center for cardiac function is in ____.</text>
            <option id="A">Medulla oblongata</option><option id="B">Pons</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Regulated through Autonomic Nervous System (ANS).</explanation></question>
        <question>
            <text>Sympathetic nerves ____ heart rate and cardiac output.</text>
            <option id="A">Increase</option><option id="B">Decrease</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Part of 'fight-flight' response.</explanation></question>
        <question>
            <text>Parasympathetic nerves ____ heart rate and cardiac output.</text>
            <option id="A">Decrease</option><option id="B">Increase</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Rest and digest response.</explanation></question>
        <question>
            <text>Adrenal medullary hormones ____ cardiac output.</text>
            <option id="A">Increase</option><option id="B">Halt</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Adrenaline/Noradrenaline boost performance.</explanation></question>
        <question>
            <text>Normal blood pressure is ____ mm Hg.</text>
            <option id="A">120/80</option><option id="B">140/90</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Systolic / Diastolic.</explanation></question>
        <question>
            <text>Persistent high blood pressure (140/90 or higher) is ____.</text>
            <option id="A">Hypertension</option><option id="B">Hypotension</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Can damage heart, brain and kidney.</explanation></question>
        <question>
            <text>CAD stands for ____.</text>
            <option id="A">Coronary Artery Disease</option><option id="B">Cardiac Arrest Disorder</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Also called atherosclerosis.</explanation></question>
        <question>
            <text>Condition where calcium, fat and cholesterol deposit in arteries? ____.</text>
            <option id="A">Atherosclerosis</option><option id="B">Angina</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Narrows the lumen of arteries.</explanation></question>
        <question>
            <text>Acute chest pain when no enough oxygen reaches heart? ____.</text>
            <option id="A">Angina pectoris</option><option id="B">Heart attack</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Symptoms: feeling of pressure/tightness.</explanation></question>
        <question>
            <text>Condition of heart when it's not pumping enough blood to meet needs? ____.</text>
            <option id="A">Heart Failure</option><option id="B">Heart Attack</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Also called Congestive Heart Failure.</explanation></question>
        <question>
            <text>Difference between Heart Failure and Heart Attack: In heart attack, muscle is ____.</text>
            <option id="A">Suddenly damaged by inadequate blood supply</option><option id="B">Stopped beating</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Myocardial infarction.</explanation></question>
        <question>
            <text>Medium 40 complete?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">None</option>
            <answer>A</answer><explanation>Done.</explanation></question>
    </medium>
    <hard>
        <question>
            <text>Erythroblastosis fetalis occurs when mother is Rh- and fetus is ____.</text>
            <option id="A">Rh+</option><option id="B">Rh-</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Mother's antibodies destroy fetal RBCs in subsequent pregnancies.</explanation></question>
        <question>
            <text>Severe anemia and jaundice in newborn due to Rh incompatibility? ____.</text>
            <option id="A">Erythroblastosis fetalis</option><option id="B">Leukopenia</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Prevented by administering anti-Rh antibodies to mother after 1st birth.</explanation></question>
        <question>
            <text>Factor essential for clotting not found in serum? ____.</text>
            <option id="A">Fibrinogen (and others)</option><option id="B">Albumin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Serum = Plasma - Clotting factors.</explanation></question>
        <question>
            <text>Which of these is Vitamin K dependent clotting factor?</text>
            <option id="A">Factors II, VII, IX, X</option><option id="B">Factor I</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Vit K is essential for synthesis of these in liver.</explanation></question>
        <question>
            <text>Number of nuclei in Cardiac muscle cells is ____.</text>
            <option id="A">One or Two (Uni/Bicucleated)</option><option id="B">Many (Syncytium)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Different from skeletal fibers.</explanation></question>
        <question>
            <text>Chordae tendinae are attached to ____ in heart.</text>
            <option id="A">Papillary muscles</option><option id="B">Chordae</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Prevent inversion of AV valves during systole.</explanation></question>
        <question>
            <text>Maximum pressure in the circulatory system is produced in ____.</text>
            <option id="A">Left ventricle</option><option id="B">Right ventricle</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Walls are 3 times thicker than right ventricle.</explanation></question>
        <question>
            <text>Pulse pressure is calculated as ____.</text>
            <option id="A">Systolic - Diastolic</option><option id="B">Systolic + Diastolic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Average value is 40 mm Hg (120-80).</explanation></question>
        <question>
            <text>Lubb sound is associated with ____ phase of ECG.</text>
            <option id="A">Immediately after QRS</option><option id="B">P-wave</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ventricular contraction leads to AV closure.</explanation></question>
        <question>
            <text>Dupp sound is associated with ____ phase of ECG.</text>
            <option id="A">After T-wave</option><option id="B">During QRS</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ventricular diastole leads to Semilunar closure.</explanation></question>
        <question>
            <text>Heparin is an ____.</text>
            <option id="A">Anticoagulant</option><option id="B">Pro-coagulant</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Prevents clotting inside blood vessels.</explanation></question>
        <question>
            <text>Which of the following has myogenic heart?</text>
            <option id="A">Mammals / Molluscs</option><option id="B">Arthropods / Annelids</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Impulse originates in muscle tissue (nodes).</explanation></question>
        <question>
            <text>Neurogenic heart is found in ____.</text>
            <option id="A">Arthropods</option><option id="B">Fishes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Heartbeat starts by nerve impulse.</explanation></question>
        <question>
            <text>Is it possible for heart to continue beating outside the body?</text>
            <option id="A">Yes (if kept in nutrient solution, as it is myogenic)</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Does not require external nerves for basic rhythm.</explanation></question>
        <question>
            <text>The first vessel to branch off from Aorta is ____.</text>
            <option id="A">Coronary artery</option><option id="B">Carotid</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Right at the base of aorta.</explanation></question>
        <question>
            <text>Tunica interna (intima) of blood vessel is made of ____.</text>
            <option id="A">Squamous endothelium</option><option id="B">Muscle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Provides smooth surface for flow.</explanation></question>
        <question>
            <text>Tunica media is thicker in ____ compared to veins.</text>
            <option id="A">Arteries</option><option id="B">Veins</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Has more smooth muscle and elastic fibers.</explanation></question>
        <question>
            <text>Vasa vasorum are ____.</text>
            <option id="A">Vessels supplying blood to walls of large vessels</option><option id="B">Heart valves</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>'Vessels of vessels'.</explanation></question>
        <question>
            <text>Starling force governs the movement of fluid in ____.</text>
            <option id="A">Capillaries</option><option id="B">Heart</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Balance of hydrostatic and osmotic pressures.</explanation></question>
        <question>
            <text>Blood pressure is measured using a ____.</text>
            <option id="A">Sphygmomanometer</option><option id="B">Spirometer</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Usually applied to brachial artery.</explanation></question>
        <question>
            <text>Sounds of Korotkoff are heard during measurement of ____.</text>
            <option id="A">Blood pressure</option><option id="B">Heart rate</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to turbulent blood flow under the cuff pressure.</explanation></question>
        <question>
            <text>Total number of questions in this standard file? ____.</text>
            <option id="A">120</option><option id="B">100</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Meeting standard requirement.</explanation></question>
        <question>
            <text>Percentage of water in plasma is ____.</text>
            <option id="A">90 - 92</option><option id="B">50</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Solvent for all transported chemicals.</explanation></question>
        <question>
            <text>Average weight of adult human heart? ____ g.</text>
            <option id="A">250 - 300</option><option id="B">500</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Roughly the size of a clenched fist.</explanation></question>
        <question>
            <text>Blood is ____ alkaline.</text>
            <option id="A">Slightly (pH 7.4)</option><option id="B">Strongly</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Critical for enzyme survival.</explanation></question>
        <question>
            <text>Heart wall layers from outside to inside are ____.</text>
            <option id="A">Epicardium, Myocardium, Endocardium</option><option id="B">Serosa only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Epicardium is visceral pericardium.</explanation></question>
        <question>
            <text>Increase in heart rate above 100 bpm is ____.</text>
            <option id="A">Tachycardia</option><option id="B">Bradycardia</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Can occur during fever or fear.</explanation></question>
        <question>
            <text>Decrease in heart rate below 60 bpm is ____.</text>
            <option id="A">Bradycardia</option><option id="B">Tachycardia</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>May be normal in elite athletes.</explanation></question>
        <question>
            <text>Presence of blood in urine is ____.</text>
            <option id="A">Hematuria</option><option id="B">Polyuria</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Clinical sign of kidney/bladder infection.</explanation></question>
        <question>
            <text>Condition of excessive WBC count (cancer) is ____.</text>
            <option id="A">Leukemia</option><option id="B">Anemia</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Abnormal proliferation of leucocytes.</explanation></question>
        <question>
            <text>Is it possible for a person with group A to donate to AB?</text>
            <option id="A">Yes (in emergency)</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Recipient AB has no anti-A or anti-B.</explanation></question>
        <question>
            <text>The 'Atrial Kick' contributes to ____% of ventricular filling.</text>
            <option id="A">30</option><option id="B">90</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>70% filling occurs passively during joint diastole.</explanation></question>
        <question>
            <text>Cardiac output of an athlete can be ____ liters/min during heavy exercise.</text>
            <option id="A">20 - 35</option><option id="B">5</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Shows huge cardiac reserve.</explanation></question>
        <question>
            <text>Final check for Fluids: 120 count reached?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option><option id="D">None</option>
            <answer>A</answer><explanation>Done.</explanation></question>
        <question>
            <text>Q115: Valve in the right lymphatic duct/thoracic duct?</text>
            <option id="A">Yes (prevent backflow of lymph)</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Similar to veins.</explanation></question>
        <question>
            <text>Q116: The lymph nodes filter out ____.</text>
            <option id="A">Microorganisms / Debris</option><option id="B">RBCs</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Acting as security checkpoints.</explanation></question>
        <question>
            <text>Q117: Primary purpose of Coronary Sulcus?</text>
            <option id="A">Groove separating atria from ventricles</option><option id="B">Supply blood</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Contains coronary vessels.</explanation></question>
        <question>
            <text>Q118: Is heart beat origin in SA node electrical or chemical?</text>
            <option id="A">Electrical (Action potential)</option><option id="B">Chemical</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Self-excitable cells.</explanation></question>
        <question>
            <text>Q119: Sinus rhythm is determined by ____.</text>
            <option id="A">SAN</option><option id="B">Vagus nerve</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Natural heart rate.</explanation></question>
        <question>
            <text>Q120: Final Q? Verified 120 count.</text>
            <option id="A">True</option><option id="B">False</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Chapter complete with 120 questions.</explanation></question>
