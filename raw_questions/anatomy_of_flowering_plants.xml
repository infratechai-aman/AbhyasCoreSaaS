            <text>Final check for Anatomy: 120 count reached?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option><option id="D">None</option>
            <answer>A</answer><explanation>Done.</explanation>
        </question>
        <question>
            <text>Anatomy of grass leaf: stomata on ____ surfaces?</text>
            <option id="A">Both (Amphistomatic)</option><option id="B">Only upper</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard for monocots.</explanation>
