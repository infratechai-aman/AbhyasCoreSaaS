<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Biology" id="121" name="Reproduction in Organisms">
    <easy>
        <question>
            <text>The period from birth to natural death of an organism is called ____.</text>
            <option id="A">Life span</option><option id="B">Life cycle</option><option id="C">Senescence</option><option id="D">None</option>
            <answer>A</answer><explanation>Unique to every species regardless of size.</explanation>
        </question>
        <question>
            <text>Life span of a Crow is approx ____ years.</text>
            <option id="A">15</option><option id="B">140</option><option id="C">5</option><option id="D">None</option>
            <answer>A</answer><explanation>Surprisingly short for its size compared to Parrot.</explanation>
        </question>
        <question>
            <text>Life span of a Parrot is approx ____ years.</text>
            <option id="A">140</option><option id="B">15</option><option id="C">25</option><option id="D">None</option>
            <answer>A</answer><explanation>Shows that life span doesn't correlate strictly with size.</explanation>
        </question>
        <question>
            <text>Unicellular organisms are often called ____ because they divide to reproduce.</text>
            <option id="A">Immortal</option><option id="B">Mortal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>No natural death; the parent becomes the offspring.</explanation>
        </question>
        <question>
            <text>Biological process of giving rise to young ones is ____.</text>
            <option id="A">Reproduction</option><option id="B">Digestion</option><option id="C">Excretion</option><option id="D">None</option>
            <answer>A</answer><explanation>Ensures continuity of species.</explanation>
        </question>
        <question>
            <text>Reproduction without gamete fusion is ____.</text>
            <option id="A">Asexual</option><option id="B">Sexual</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Produces clones (genetically identical).</explanation>
        </question>
        <question>
            <text>Morphologically and genetically identical individuals are called ____.</text>
            <option id="A">Clones</option><option id="B">Siblings</option><option id="C">Hybrids</option><option id="D">None</option>
            <answer>A</answer><explanation>Products of asexual reproduction.</explanation>
        </question>
        <question>
            <text>Asexual reproduction in Amoeba occurs via ____.</text>
            <option id="A">Binary fission</option><option id="B">Budding</option><option id="C">Spore formation</option><option id="D">None</option>
            <answer>A</answer><explanation>Parent cell splits into two equal halves.</explanation>
        </question>
        <question>
            <text>Budding is the primary asexual mode in ____.</text>
            <option id="A">Yeast / Hydra</option><option id="B">Amoeba</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Unequal division where bud remains attached initially.</explanation>
        </question>
        <question>
            <text>Zoospores are special asexual structures in ____.</text>
            <option id="A">Chlamydomonas / Algae</option><option id="B">Fungi only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Microscopic motile structures.</explanation>
        </question>
        <question>
            <text>Conidia are asexual structures found in ____.</text>
            <option id="A">Penicillium</option><option id="B">Hydra</option><option id="C">Sponge</option><option id="D">None</option>
            <answer>A</answer><explanation>Exogenous spores.</explanation>
        </question>
        <question>
            <text>Internal buds in sponges are called ____.</text>
            <option id="A">Gemmules</option><option id="B">Conidia</option><option id="C">Zoospores</option><option id="D">None</option>
            <answer>A</answer><explanation>Adaptation for survival and dispersal.</explanation>
        </question>
        <question>
            <text>Vegetative propagation in Potato occurs through ____.</text>
            <option id="A">Eyes (Axillary buds)</option><option id="B">Rhizome</option><option id="C">Bulbil</option><option id="D">None</option>
            <answer>A</answer><explanation>Tuber part with nodes.</explanation>
        </question>
        <question>
            <text>Rhizome is a vegetative propagator in ____ and ____.</text>
            <option id="A">Ginger and Turmeric</option><option id="B">Potato</option><option id="C">Agave</option><option id="D">None</option>
            <answer>A</answer><explanation>Underground horizontal stem.</explanation>
        </question>
        <question>
            <text>Bulbil is a vegetative propagator in ____.</text>
            <option id="A">Agave</option><option id="B">Bryophyllum</option><option id="C">Banana</option><option id="D">None</option>
            <answer>A</answer><explanation>Fleshy floral bud.</explanation>
        </question>
        <question>
            <text>Bryophyllum propagates vegetatively via ____ buds.</text>
            <option id="A">Leaf (Adventitious)</option><option id="B">Stem</option><option id="C">Root</option><option id="D">None</option>
            <answer>A</answer><explanation>Develops on notches of leaf margin.</explanation>
        </question>
        <question>
            <text>Water Hyacinth is famously known as ____ of Bengal.</text>
            <option id="A">Terror</option><option id="B">Beauty</option><option id="C">Queen</option><option id="D">None</option>
            <answer>A</answer><explanation>Invasive aquatic weed depleting oxygen.</explanation>
        </question>
        <question>
            <text>Water hyacinth propagates very fast using ____.</text>
            <option id="A">Offsets</option><option id="B">Runners</option><option id="C">Suckers</option><option id="D">None</option>
            <answer>A</answer><explanation>Sub-aerial stem modification.</explanation>
        </question>
        <question>
            <text>Reproduction involving fusion of male and female gametes is ____.</text>
            <option id="A">Sexual</option><option id="B">Asexual</option><option id="C">Vegetative</option><option id="D">None</option>
            <answer>A</answer><explanation>Results in variation.</explanation>
        </question>
        <question>
            <text>Growth phase before an organism can reproduce sexually is ____.</text>
            <option id="A">Juvenile (Animals) / Vegetative (Plants)</option><option id="B">Senescence</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Period of physiological maturity.</explanation>
        </question>
        <question>
            <text>Plants that flower once in a life time and then die are ____.</text>
            <option id="A">Monocarpic</option><option id="B">Polycarpic</option><option id="C">Perennial only</option><option id="D">None</option>
            <answer>A</answer><explanation>Example: Bamboo species.</explanation>
        </question>
        <question>
            <text>Bamboo species flower only once in ____ years.</text>
            <option id="A">50 to 100</option><option id="B">10 to 20</option><option id="C">1000</option><option id="D">None</option>
            <answer>A</answer><explanation>Massive flowering event.</explanation>
        </question>
        <question>
            <text>Strobilanthus kunthiana (Neelakuranji) flowers once in ____ years.</text>
            <option id="A">12</option><option id="B">50</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>Found in hilly areas of Kerala, Karnataka, TN.</explanation>
        </question>
        <question>
            <text>Cyclic changes during reproduction in non-primate mammals is ____ cycle.</text>
            <option id="A">Oestrus</option><option id="B">Menstrual</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cows, sheep, rats, deers, dogs, tigers.</explanation>
        </question>
        <question>
            <text>Cyclic changes during reproduction in primates is ____ cycle.</text>
            <option id="A">Menstrual</option><option id="B">Oestrus</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Monkeys, apes, humans.</explanation>
        </question>
        <question>
            <text>Phase marking the end of reproductive phase is ____.</text>
            <option id="A">Senescence (Aging)</option><option id="B">Juvenile</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Leads to slowing of metabolism and eventually death.</explanation>
        </question>
        <question>
            <text>Formation of gametes is called ____.</text>
            <option id="A">Gametogenesis</option><option id="B">Embryogenesis</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pre-fertilization event.</explanation>
        </question>
        <question>
            <text>When male and female gametes look identical, they are ____.</text>
            <option id="A">Isogametes / Homogametes</option><option id="B">Heterogametes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common in some algae like Cladophora.</explanation>
        </question>
        <question>
            <text>When gametes are morphologically distinct, they are ____.</text>
            <option id="A">Heterogametes</option><option id="B">Isogametes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Male (Antherozoid/Sperm) and Female (Egg/Ovum).</explanation>
        </question>
        <question>
            <text>Plants with both male and female structures on same plant are ____.</text>
            <option id="A">Bisexual / Monoecious</option><option id="B">Unisexual / Dioecious</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example: Chara, Coconut, Cucurbits.</explanation>
        </question>
        <question>
            <text>Plants with male and female structures on separate plants are ____.</text>
            <option id="A">Dioecious / Unisexual</option><option id="B">Monoecious</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example: Papaya, Date palm, Marchantia.</explanation>
        </question>
        <question>
            <text>Unisexual male flower is termed ____.</text>
            <option id="A">Staminate</option><option id="B">Pistillate</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Bears stamens.</explanation>
        </question>
        <question>
            <text>Unisexual female flower is termed ____.</text>
            <option id="A">Pistillate</option><option id="B">Staminate</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Bears pistils.</explanation>
        </question>
        <question>
            <text>Earthworm, sponge, tapeworm and leech are ____.</text>
            <option id="A">Bisexual / Hermaphrodites</option><option id="B">Unisexual</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Possess both male and female organs.</explanation>
        </question>
        <question>
            <text>Gametes are always ____ (ploidy).</text>
            <option id="A">Haploid (n)</option><option id="B">Diploid (2n)</option><option id="C">Triploid</option><option id="D">None</option>
            <answer>A</answer><explanation>Universal rule for gametes.</explanation>
        </question>
        <question>
            <text>Specialized cells that undergo meiosis to form gametes are ____.</text>
            <option id="A">Meiocytes</option><option id="B">Zygotes</option><option id="C">Somatocytes</option><option id="D">None</option>
            <answer>A</answer><explanation>Diploid cells (2n).</explanation>
        </question>
        <question>
            <text>Fusion of gametes is called ____.</text>
            <option id="A">Syngamy / Fertilization</option><option id="B">Pollination</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Produces a diploid zygote.</explanation>
        </question>
        <question>
            <text>Fertilization occurring outside the body of organism is ____.</text>
            <option id="A">External fertilization</option><option id="B">Internal fertilization</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common in aquatic organisms (Bony fishes, frogs).</explanation>
        </question>
        <question>
            <text>Fertilization occurring inside the female body is ____.</text>
            <option id="A">Internal fertilization</option><option id="B">External fertilization</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common in terrestrial organisms (Mammals, reptiles, birds).</explanation>
        </question>
        <question>
            <text>Development of new individual from egg without fertilization is ____.</text>
            <option id="A">Parthenogenesis</option><option id="B">Parthenocarpy</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Seen in Rotifers, Honey bees, some lizards, Turkey birds.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Zygote is the ____ link that ensures continuity of species.</text>
            <option id="A">Vital</option><option id="B">Dead</option><option id="C">Secondary</option><option id="D">None</option>
            <answer>A</answer><explanation>Connects one generation to the next.</explanation>
        </question>
        <question>
            <text>Events in sexual reproduction: Pre-fertilization, ____ and Post-fertilization.</text>
            <option id="A">Fertilization / Syngamy</option><option id="B">Death</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Process timeline.</explanation>
        </question>
        <question>
            <text>Process of development of embryo from zygote is ____.</text>
            <option id="A">Embryogenesis</option><option id="B">Gametogenesis</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Involves cell division (mitosis) and differentiation.</explanation>
        </question>
        <question>
            <text>Animals that lay eggs are ____.</text>
            <option id="A">Oviparous</option><option id="B">Viviparous</option><option id="C">Ovoviviparous</option><option id="D">None</option>
            <answer>A</answer><explanation>Covered by calcareous shells.</explanation>
        </question>
        <question>
            <text>Animals that give birth to young ones are ____.</text>
            <option id="A">Viviparous</option><option id="B">Oviparous</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Greater chances of survival due to protection.</explanation>
        </question>
        <question>
            <text>In flowering plants, zygote is formed inside the ____.</text>
            <option id="A">Ovule</option><option id="B">Stigma</option><option id="C">Anther</option><option id="D">None</option>
            <answer>A</answer><explanation>Within the embryo sac.</explanation>
        </question>
        <question>
            <text>After fertilization, Ovules develop into ____ and Ovary into ____.</text>
            <option id="A">Seeds , Fruit</option><option id="B">Fruit , Seeds</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Post-fertilization transformation.</explanation>
        </question>
        <question>
            <text>Thick wall of fruit that is protective in nature is ____.</text>
            <option id="A">Pericarp</option><option id="B">Testa</option><option id="C">Tegmen</option><option id="D">None</option>
            <answer>A</answer><explanation>Develops from ovary wall.</explanation>
        </question>
        <question>
            <text>Offspring of external fertilization are highly vulnerable to ____.</text>
            <option id="A">Predators</option><option id="B">Sunlight</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Main disadvantage of outside development.</explanation>
        </question>
        <question>
            <text>Parthenogenesis in Honeybees produces ____.</text>
            <option id="A">Drones (Males)</option><option id="B">Queens</option><option id="C">Workers</option><option id="D">None</option>
            <answer>A</answer><explanation>Unfertilized haploid eggs develop into males.</explanation>
        </question>
        <question>
            <text>Which of the following is NOT a primate?</text>
            <option id="A">Rat</option><option id="B">Monkey</option><option id="C">Human</option><option id="D">Ape</option>
            <answer>A</answer><explanation>Rats show oestrus cycle.</explanation>
        </question>
        <question>
            <text>Seasonal breeders reproduce during ____.</text>
            <option id="A">Specific favorable seasons</option><option id="B">Whole year</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Typical of wild animals.</explanation>
        </question>
        <question>
            <text>Continuous breeders can reproduce ____.</text>
            <option id="A">Throughout their reproductive maturity</option><option id="B">Only in spring</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Typical of many domestic animals and humans.</explanation>
        </question>
        <question>
            <text>B bisexuality in animals is also called ____.</text>
            <option id="A">Hermaphroditism</option><option id="B">Dioecy</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>From Greek Hermaphroditos.</explanation>
        </question>
        <question>
            <text>Chromosome number in meiocyte of Human is ____.</text>
            <option id="A">46</option><option id="B">23</option><option id="C">92</option><option id="D">None</option>
            <answer>A</answer><explanation>Diploid number 2n.</explanation>
        </question>
        <question>
            <text>Chromosome number in gamete of Human is ____.</text>
            <option id="A">23</option><option id="B">46</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Haploid number n.</explanation>
        </question>
        <question>
            <text>Chromosome number in Fruit fly gamete is ____.</text>
            <option id="A">4</option><option id="B">8</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>2n = 8.</explanation>
        </question>
        <question>
            <text>Chromosome number in Ophioglossum (fern) gamete is ____.</text>
            <option id="A">630</option><option id="B">1260</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Highest number (2n=1260).</explanation>
        </question>
        <question>
            <text>Pollination is a mechanism of ____.</text>
            <option id="A">Gamete transfer</option><option id="B">Fertilization</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Movement of pollen from anther to stigma.</explanation>
        </question>
        <question>
            <text>Syngamy results in formation of ____ cell.</text>
            <option id="A">Diploid (Zygote)</option><option id="B">Haploid</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Restoration of ploidy.</explanation>
        </question>
        <question>
            <text>In algae and fungi, zygote often develops a ____ wall.</text>
            <option id="A">Thick</option><option id="B">Thin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Resistant to dessication and damage.</explanation>
        </question>
        <question>
            <text>Germination of ____ marks the beginning of new life in plants.</text>
            <option id="A">Seed</option><option id="B">Pollen</option><option id="C">Flower</option><option id="D">None</option>
            <answer>A</answer><explanation>Dispersal and favorable condition trigger it.</explanation>
        </question>
        <question>
            <text>Asexual reproduction is common in ____ organisms.</text>
            <option id="A">Simple</option><option id="B">Complex</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Faster but low variation.</explanation>
        </question>
        <question>
            <text>Binary fission in Amoeba is ____ (plane).</text>
            <option id="A">Any plane</option><option id="B">Transverse</option><option id="C">Longitudinal</option><option id="D">None</option>
            <answer>A</answer><explanation>Irregular binary fission.</explanation>
        </question>
        <question>
            <text>Sucker propagates vegetatively in ____.</text>
            <option id="A">Chrysanthemum / Mint</option><option id="B">Potato</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Arises from undergroun basal part of stem.</explanation>
        </question>
        <question>
            <text>Runners are propagators in ____.</text>
            <option id="A">Grasses / Strawberry</option><option id="B">Agave</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Scale nodes touch soil to form roots.</explanation>
        </question>
        <question>
            <text>Clonality implies total ____ homogeneity.</text>
            <option id="A">Genetic</option><option id="B">Environmental</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Critical for breeding pure lines.</explanation>
        </question>
        <question>
            <text>Cell differentiation during embryogenesis leads to ____.</text>
            <option id="A">Specialized tissues and organs</option><option id="B">Clones</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Formation of body plan.</explanation>
        </question>
        <question>
            <text>The term used for bisexual condition in fungi is ____.</text>
            <option id="A">Homothallic</option><option id="B">Heterothallic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Same as monoecious/bisexual.</explanation>
        </question>
        <question>
            <text>The term used for unisexual condition in fungi is ____.</text>
            <option id="A">Heterothallic</option><option id="B">Homothallic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Requires two different mating types.</explanation>
        </question>
        <question>
            <text>Unisexual female animals like Turkey can produce offspring. This is ____.</text>
            <option id="A">Parthenogenesis</option><option id="B">Sexual union</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Natural virgin birth.</explanation>
        </question>
        <question>
            <text>Parthenogenesis in rotifers ensures ____.</text>
            <option id="A">Rapid multiplication without mates</option><option id="B">Variation</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Helpful in stable environments.</explanation>
        </question>
        <question>
            <text>Synchrony in gamete release is crucial for ____ fertilization.</text>
            <option id="A">External</option><option id="B">Internal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Maximize chances of collision in water.</explanation>
        </question>
        <question>
            <text>Large number of male gametes are produced to compensate for ____.</text>
            <option id="A">Loss during transport</option><option id="B">Small size</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Statistical necessity.</explanation>
        </question>
        <question>
            <text>Zygote is formed in ____ of woman.</text>
            <option id="A">Ampulla (Fallopian tube)</option><option id="B">Uterus</option><option id="C">Vagina</option><option id="D">None</option>
            <answer>A</answer><explanation>Site of fertilization.</explanation>
        </question>
        <question>
            <text>Sexual reproduction is a ____ process compared to asexual.</text>
            <option id="A">Slower and complex</option><option id="B">Faster</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Requires multi-step events and two parents usually.</explanation>
        </question>
        <question>
            <text>Cucurbits and Coconuts are ____ plants.</text>
            <option id="A">Monoecious</option><option id="B">Dioecious</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Bisexual plant body.</explanation>
        </question>
        <question>
            <text>Papaya and Date palm are ____ plants.</text>
            <option id="A">Dioecious</option><option id="B">Monoecious</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Separate sex plants.</explanation>
        </question>
        <question>
            <text>Meiosis is ____ division.</text>
            <option id="A">Reductional</option><option id="B">Equational</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Halves chromosome number.</explanation>
        </question>
        <question>
            <text>Mitosis is ____ division.</text>
            <option id="A">Equational</option><option id="B">Reductional</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Maintains chromosome number.</explanation>
        </question>
