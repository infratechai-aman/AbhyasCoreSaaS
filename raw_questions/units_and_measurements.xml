<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="13" name="Units and Measurements">
    <easy>
        <question>
            <text>Which of the following is a base SI unit?</text>
            <option id="A">Kilogram</option><option id="B">Gram</option><option id="C">Newton</option><option id="D">Joule</option>
            <answer>A</answer><explanation>Mass is a base quantity in SI.</explanation></question>
        <question>
            <text>The SI unit of light intensity is:</text>
            <option id="A">Candela</option><option id="B">Lumen</option><option id="C">Lux</option><option id="D">Watt</option>
            <answer>A</answer><explanation>Symbol: cd.</explanation></question>
        <question>
            <text>1 micrometer is equal to:</text>
            <option id="A">10^-6 m</option><option id="B">10^-9 m</option><option id="C">10^-3 m</option><option id="D">10^-12 m</option>
            <answer>A</answer><explanation>Prefix 'micro' denotes 10^-6.</explanation></question>
        <question>
            <text>Dimension of speed is:</text>
            <option id="A">[L T^-1]</option><option id="B">[M L T^-1]</option><option id="C">[L T^-2]</option><option id="D">[L^2 T^-1]</option>
            <answer>A</answer><explanation>Distance / Time.</explanation></question>
        <question>
            <text>Which of the following has no dimensions?</text>
            <option id="A">Strain</option><option id="B">Stress</option><option id="C">Force</option><option id="D">Energy</option>
            <answer>A</answer><explanation>Ratio of two similar quantities.</explanation></question>
        <question>
            <text>The number of significant figures in 0.007 is:</text>
            <option id="A">1</option><option id="B">3</option><option id="C">4</option><option id="D">2</option>
            <answer>A</answer><explanation>Leading zeros are not significant.</explanation></question>
        <question>
            <text>1 Astronomical Unit (AU) is the distance between:</text>
            <option id="A">Earth and Sun</option><option id="B">Earth and Moon</option><option id="C">Sun and Moon</option><option id="D">None</option>
            <answer>A</answer><explanation>Approx 1.496 x 10^11 m.</explanation></question>
        <question>
            <text>Light year is a unit of:</text>
            <option id="A">Distance</option><option id="B">Time</option><option id="C">Intensity</option><option id="D">Speed</option>
            <answer>A</answer><explanation>Distance light travels in one year.</explanation></question>
        <question>
            <text>Dimension of Planck's constant (h) is same as:</text>
            <option id="A">Angular momentum</option><option id="B">Linear momentum</option><option id="C">Work</option><option id="D">Power</option>
            <answer>A</answer><explanation>[M L^2 T^-1].</explanation></question>
        <question>
            <text>A physical quantity having both magnitude and direction is:</text>
            <option id="A">Vector</option><option id="B">Scalar</option><option id="C">Both</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard definition.</explanation></question>
        <question>
            <text>Number of significant figures in 2.64 x 10^24:</text>
            <option id="A">3</option><option id="B">24</option><option id="C">27</option><option id="D">None</option>
            <answer>A</answer><explanation>Only digits in scientific notation core count.</explanation></question>
        <question>
            <text>SI unit of plane angle is:</text>
            <option id="A">Radian</option><option id="B">Degree</option><option id="C">Steradian</option><option id="D">None</option>
            <answer>A</answer><explanation>Supplementary unit.</explanation></question>
        <question>
            <text>SI unit of solid angle is:</text>
            <option id="A">Steradian</option><option id="B">Radian</option><option id="C">Degree</option><option id="D">None</option>
            <answer>A</answer><explanation>Symbol: sr.</explanation></question>
        <question>
            <text>Parsec is a unit used to measure:</text>
            <option id="A">Large astronomical distances</option><option id="B">Small atomic distances</option><option id="C">Time</option><option id="D">Mass</option>
            <answer>A</answer><explanation>Approx 3.26 light years.</explanation></question>
        <question>
            <text>Dimension of Area is:</text>
            <option id="A">[L^2]</option><option id="B">[L]</option><option id="C">[M L^2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Length x Width.</explanation></question>
        <question>
            <text>Density has dimensions:</text>
            <option id="A">[M L^-3]</option><option id="B">[M L^3]</option><option id="C">[M L^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Mass / Volume.</explanation></question>
        <question>
            <text>1 kg is equal to how many milligrams?</text>
            <option id="A">10^6</option><option id="B">10^3</option><option id="C">10^9</option><option id="D">None</option>
            <answer>A</answer><explanation>1000g x 1000mg.</explanation></question>
        <question>
            <text>Fundamental quantities are:</text>
            <option id="A">Independent of each other</option><option id="B">Derived from others</option><option id="C">Only length and mass</option><option id="D">None</option>
            <answer>A</answer><explanation>Foundational set.</explanation></question>
        <question>
            <text>Dimensional formula for Force is:</text>
            <option id="A">[M L T^-2]</option><option id="B">[M L T^-1]</option><option id="C">[M L^2 T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Mass x Acceleration.</explanation></question>
        <question>
            <text>dimensional formula for Work is:</text>
            <option id="A">[M L^2 T^-2]</option><option id="B">[M L T^-2]</option><option id="C">[M L^2 T^-3]</option><option id="D">None</option>
            <answer>A</answer><explanation>Force x Distance.</explanation></question>
        <question>
            <text>SI unit of Temperature is:</text>
            <option id="A">Kelvin</option><option id="B">Celsius</option><option id="C">Fahrenheit</option><option id="D">None</option>
            <answer>A</answer><explanation>Symbol: K.</explanation></question>
        <question>
            <text>Dimensional formula for Pressure is:</text>
            <option id="A">[M L^-1 T^-2]</option><option id="B">[M L T^-2]</option><option id="C">[M L^2 T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Force / Area.</explanation></question>
        <question>
            <text>The prefix 'pico' stands for:</text>
            <option id="A">10^-12</option><option id="B">10^-15</option><option id="C">10^-9</option><option id="D">None</option>
            <answer>A</answer><explanation>Extremely small scale.</explanation></question>
        <question>
            <text>The prefix 'femto' stands for:</text>
            <option id="A">10^-15</option><option id="B">10^-18</option><option id="C">10^-12</option><option id="D">None</option>
            <answer>A</answer><explanation>Nuclear scale.</explanation></question>
        <question>
            <text>Accuracy of a measurement depends on:</text>
            <option id="A">Systematic errors</option><option id="B">Least count of instrument</option><option id="C">Both</option><option id="D">None</option>
            <answer>C</answer><explanation>Closeness to true value.</explanation></question>
        <question>
            <text>Precision of a measurement refers to:</text>
            <option id="A">Consistency of repeated measurements</option><option id="B">Closeness to true value</option><option id="C">Scale of instrument</option><option id="D">None</option>
            <answer>A</answer><explanation>Limit of resolution.</explanation></question>
        <question>
            <text>Random errors can be reduced by:</text>
            <option id="A">Taking average of many readings</option><option id="B">Better instrument</option><option id="C">Eliminating parallax</option><option id="D">None</option>
            <answer>A</answer><explanation>Statistical cancellation.</explanation></question>
        <question>
            <text>Absolute error is the difference between:</text>
            <option id="A">True value and measured value</option><option id="B">Two measured values</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Magnitude of deviation.</explanation></question>
        <question>
            <text>Relative error is ratio of absolute error to:</text>
            <option id="A">Mean value</option><option id="B">Maximum value</option><option id="C">Zero</option><option id="D">None</option>
            <answer>A</answer><explanation>Fractional error.</explanation></question>
        <question>
            <text>Dimensional variables are those which:</text>
            <option id="A">Possess dimensions and vary in value</option><option id="B">Are constants</option><option id="C">Have no dimensions</option><option id="D">None</option>
            <answer>A</answer><explanation>e.g., Force, Velocity.</explanation></question>
        <question>
            <text>Formula for percentage error is:</text>
            <option id="A">Relative error x 100</option><option id="B">Absolute error x 100</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Expresses error in %.</explanation></question>
        <question>
            <text>The principle of homogeneity of dimensions states:</text>
            <option id="A">Dimensions of both sides of an equation must be same</option><option id="B">Mass remains constant</option><option id="C">Time is absolute</option><option id="D">None</option>
            <answer>A</answer><explanation>Basis of dimensional check.</explanation></question>
        <question>
            <text>Least count of a standard metric ruler is:</text>
            <option id="A">1 mm</option><option id="B">1 cm</option><option id="C">0.1 mm</option><option id="D">None</option>
            <answer>A</answer><explanation>Smallest division.</explanation></question>
        <question>
            <text>Which instrument measures internal diameter of tube?</text>
            <option id="A">Vernier Calliper</option><option id="B">Screw Gauge</option><option id="C">Ruler</option><option id="D">None</option>
            <answer>A</answer><explanation>Uses upper jaws.</explanation></question>
        <question>
            <text>Which instrument is best for thin wire diameter?</text>
            <option id="A">Screw Gauge</option><option id="B">Vernier Calliper</option><option id="C">Ruler</option><option id="D">None</option>
            <answer>A</answer><explanation>Higher precision.</explanation></question>
        <question>
            <text>Dimensional formula for Frequency is:</text>
            <option id="A">[T^-1]</option><option id="B">[T]</option><option id="C">[M T^-1]</option><option id="D">None</option>
            <answer>A</answer><explanation>Reciprocal of time period.</explanation></question>
        <question>
            <text>Which has dimension [M L T^-1]?</text>
            <option id="A">Linear Momentum</option><option id="B">Force</option><option id="C">Energy</option><option id="D">Pressure</option>
            <answer>A</answer><explanation>Mass x Velocity.</explanation></question>
        <question>
            <text>Unit of universal gravitational constant G:</text>
            <option id="A">N m^2 kg^-2</option><option id="B">N m kg^-1</option><option id="C">kg m^2</option><option id="D">None</option>
            <answer>A</answer><explanation>From F = Gmm/r^2.</explanation></question>
        <question>
            <text>Light intensity unit Candela is based on:</text>
            <option id="A">Monochromatic radiation of specific frequency</option><option id="B">Sunlight</option><option id="C">Bulb</option><option id="D">None</option>
            <answer>A</answer><explanation>Modern SI definition.</explanation></question>
        <question>
            <text>Number of base quantities in SI is:</text>
            <option id="A">7</option><option id="B">5</option><option id="C">9</option><option id="D">None</option>
            <answer>A</answer><explanation>Plus 2 supplementary units.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>If energy (E), velocity (V) and time (T) are fundamental units, dimension of Surface Tension is:</text>
            <option id="A">[E V^-2 T^-2]</option><option id="B">[E V^-1 T^-2]</option><option id="C">[E V T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Method of dimensional analysis.</explanation></question>
        <question>
            <text>The error in measurement of radius of sphere is 1%. Error in volume is:</text>
            <option id="A">3%</option><option id="B">1%</option><option id="C">2%</option><option id="D">4%</option>
            <answer>A</answer><explanation>V is proportional to r^3.</explanation></question>
        <question>
            <text>Dimensional formula for Universal Gas Constant (R) is:</text>
            <option id="A">[M L^2 T^-2 K^-1 mol^-1]</option><option id="B">[M L T^-2]</option><option id="C">[L^2 T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>From PV = nRT.</explanation></question>
        <question>
            <text>If x = a + bt + ct^2 where x is meters and t is seconds, unit of c is:</text>
            <option id="A">m/s^2</option><option id="B">m/s</option><option id="C">m</option><option id="D">m^2/s</option>
            <answer>A</answer><explanation>By homogeneity.</explanation></question>
        <question>
            <text>Result of 1.2 + 3.45 with significant figures:</text>
            <option id="A">4.7</option><option id="B">4.65</option><option id="C">4.6</option><option id="D">5</option>
            <answer>A</answer><explanation>Least decimal places (1).</explanation></question>
        <question>
            <text>Result of 2.0 x 3.00 with significant figures:</text>
            <option id="A">6.0</option><option id="B">6</option><option id="C">6.00</option><option id="D">None</option>
            <answer>A</answer><explanation>Least significant figures (2).</explanation></question>
        <question>
            <text>Which of the following is NOT a unit of energy?</text>
            <option id="A">Watt</option><option id="B">Joule</option><option id="C">Electron volt</option><option id="D">Calorie</option>
            <answer>A</answer><explanation>Watt is power (J/s).</explanation></question>
        <question>
            <text>1 Curie is a unit of radioactivity and equals how many disintegrations/s?</text>
            <option id="A">3.7 x 10^10</option><option id="B">100</option><option id="C">10^20</option><option id="D">None</option>
            <answer>A</answer><explanation>Nuclear physics unit.</explanation></question>
        <question>
            <text>Dimensions of [1/μ0ε0] is same as:</text>
            <option id="A">Velocity squared</option><option id="B">Velocity</option><option id="C">Acceleration</option><option id="D">None</option>
            <answer>A</answer><explanation>c = 1/sqrt(μ0ε0).</explanation></question>
        <question>
            <text>Which pair has same dimensions?</text>
            <option id="A">Impulse and Momentum</option><option id="B">Force and Torque</option><option id="C">Work and Power</option><option id="D">None</option>
            <answer>A</answer><explanation>Both are [M L T^-1].</explanation></question>
        <question>
            <text>Dimension of Coefficient of Viscosity (η):</text>
            <option id="A">[M L^-1 T^-1]</option><option id="B">[M L T^-1]</option><option id="C">[M L^-1 T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>From F = 6πηrv.</explanation></question>
        <question>
            <text>A screw gauge has pitch 1mm and 100 divisions. Least count is:</text>
            <option id="A">0.01 mm</option><option id="B">0.1 mm</option><option id="C">1 mm</option><option id="D">None</option>
            <answer>A</answer><explanation>Pitch / Divisions.</explanation></question>
        <question>
            <text>Parsec is a unit of ____.</text>
            <option id="A">Distance</option><option id="B">Time</option><option id="C">Angle</option><option id="D">None</option>
            <answer>A</answer><explanation>Full name of parallax second.</explanation></question>
        <question>
            <text>Dimension of Surface Tension is:</text>
            <option id="A">[M T^-2]</option><option id="B">[M L T^-2]</option><option id="C">[M L T^-1]</option><option id="D">None</option>
            <answer>A</answer><explanation>Force / Length.</explanation></question>
        <question>
            <text>Dimension of Modulus of Elasticity is same as:</text>
            <option id="A">Pressure</option><option id="B">Stress</option><option id="C">Both A and B</option><option id="D">Strain</option>
            <answer>C</answer><explanation>[M L^-1 T^-2].</explanation></question>
        <question>
            <text>Length of a rod is 4.5 cm. Error is ± 0.1 cm. Percentage error:</text>
            <option id="A">2.2%</option><option id="B">1%</option><option id="C">0.2%</option><option id="D">None</option>
            <answer>A</answer><explanation>(0.1 / 4.5) x 100.</explanation></question>
        <question>
            <text>Which quantity is dimensionless but has a unit?</text>
            <option id="A">Angle</option><option id="B">Relative density</option><option id="C">Strain</option><option id="D">None</option>
            <answer>A</answer><explanation>Unit Radian, dimension [M0 L0 T0].</explanation></question>
        <question>
            <text>Error in sum/difference is equal to ____ of absolute errors.</text>
            <option id="A">Sum</option><option id="B">Difference</option><option id="C">Average</option><option id="D">None</option>
            <answer>A</answer><explanation>Max possible error accumulates.</explanation></question>
        <question>
            <text>Number of significant figures in 500.0 is:</text>
            <option id="A">4</option><option id="B">1</option><option id="C">3</option><option id="D">None</option>
            <answer>A</answer><explanation>Trailing zeros after decimal are significant.</explanation></question>
        <question>
            <text>Number of significant figures in 500 is ____ if measured by ruler with unit marks.</text>
            <option id="A">3</option><option id="B">1</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Specified precision context.</explanation></question>
        <question>
            <text>Unit of Stefan's constant σ:</text>
            <option id="A">W m^-2 K^-4</option><option id="B">J K^-4</option><option id="C">W m^2</option><option id="D">None</option>
            <answer>A</answer><explanation>From E = σT^4.</explanation></question>
        <question>
            <text>Ratio of AU to Light year is approx:</text>
            <option id="A">1.6 x 10^-5</option><option id="B">1</option><option id="C">10^5</option><option id="D">None</option>
            <answer>A</answer><explanation>Calculation of magnitudes.</explanation></question>
        <question>
            <text>Dimensional formula for 'Spring Constant' k is:</text>
            <option id="A">[M T^-2]</option><option id="B">[M L T^-2]</option><option id="C">[M L T^-1]</option><option id="D">None</option>
            <answer>A</answer><explanation>Force / Extension.</explanation></question>
        <question>
            <text>A dimensionless quantity ____ have a unit.</text>
            <option id="A">May</option><option id="B">Never</option><option id="C">Always</option><option id="D">None</option>
            <answer>A</answer><explanation>Example: Radian.</explanation></question>
        <question>
            <text>A unitless quantity ____ have dimensions.</text>
            <option id="A">Never</option><option id="B">May</option><option id="C">Always</option><option id="D">None</option>
            <answer>A</answer><explanation>Fundamental logic.</explanation></question>
        <question>
            <text>Density of water in CGS is 1 g/cm3. In SI, it is:</text>
            <option id="A">1000 kg/m3</option><option id="B">1 kg/m3</option><option id="C">0.001 kg/m3</option><option id="D">None</option>
            <answer>A</answer><explanation>Conversion factors.</explanation></question>
        <question>
            <text>Distance of closest galaxy Andromeda is approx:</text>
            <option id="A">2 x 10^22 m</option><option id="B">10^10 m</option><option id="C">1 m</option><option id="D">None</option>
            <answer>A</answer><explanation>Astronomical scale examples.</explanation></question>
        <question>
            <text>Atomic radius is approx ____ m.</text>
            <option id="A">10^-10</option><option id="B">10^-15</option><option id="C">10^-6</option><option id="D">None</option>
            <answer>A</answer><explanation>Angstrom scale.</explanation></question>
        <question>
            <text>Nuclear radius is approx ____ m.</text>
            <option id="A">10^-15</option><option id="B">10^-10</option><option id="C">10^-6</option><option id="D">None</option>
            <answer>A</answer><explanation>Fermi scale.</explanation></question>
        <question>
            <text>Dimensions of Torque [τ]:</text>
            <option id="A">[M L^2 T^-2]</option><option id="B">[M L T^-2]</option><option id="C">[M L^2 T^-1]</option><option id="D">None</option>
            <answer>A</answer><explanation>Same as Energy / Work.</explanation></question>
        <question>
            <text>Dimension of Angular Momentum [L]:</text>
            <option id="A">[M L^2 T^-1]</option><option id="B">[M L T^-1]</option><option id="C">[M L^2 T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>I x ω gives this result.</explanation></question>
        <question>
            <text>Dimensional formula for G is:</text>
            <option id="A">[M^-1 L^3 T^-2]</option><option id="B">[M L^3 T^-2]</option><option id="C">[M L^2 T^-2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Reverse calculation from unit.</explanation></question>
        <question>
            <text>Coefficient of thermal conductivity (K) dimensions:</text>
            <option id="A">[M L T^-3 K^-1]</option><option id="B">[M L^2 T^-3]</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>From conduction law.</explanation></question>
        <question>
            <text>Power has time dimension T^-3?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>[M L^2 T^-3].</explanation></question>
        <question>
            <text>SI base unit of Amount of substance is:</text>
            <option id="A">Mole</option><option id="B">Gram</option><option id="C">Dozen</option><option id="D">None</option>
            <answer>A</answer><explanation>Symbol: mol.</explanation></question>
        <question>
            <text>Relation between 1 Joule and 1 Erg is:</text>
            <option id="A">1 J = 10^7 erg</option><option id="B">1 J = 10^5 erg</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Conversion of SI to CGS energy.</explanation></question>
        <question>
            <text>Relation between 1 Newton and 1 Dyne is:</text>
            <option id="A">1 N = 10^5 dyne</option><option id="B">1 N = 10^7 dyne</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Conversion of SI to CGS force.</explanation></question>
        <question>
            <text>Error in x = a^p b^q / c^r is fractional error:</text>
            <option id="A">p(Δa/a) + q(Δb/b) + r(Δc/c)</option><option id="B">Sum of all parts</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Generalized error formula.</explanation></question>
        <question>
            <text>The mean absolute error is the ____ of all absolute errors.</text>
            <option id="A">Arithmetic mean</option><option id="B">Sum</option><option id="C">Product</option><option id="D">None</option>
            <answer>A</answer><explanation>Gives representative error.</explanation></question>
        <question>
            <text>Dimensional formula for Electric Charge is:</text>
            <option id="A">[A T]</option><option id="B">[A]</option><option id="C">[M L T A^-1]</option><option id="D">None</option>
            <answer>A</answer><explanation>Current x Time [I x T].</explanation></question>
    </medium>
    <hard>
        <question>
            <text>If the length and time of a simple pendulum have errors of 2% and 3%, max error in g is:</text>
            <option id="A">8%</option><option id="B">5%</option><option id="C">11%</option><option id="D">4%</option>
            <answer>A</answer><explanation>T = 2pi sqrt(L/g) -&gt; g = 4pi^2 L/T^2. Error = 2% + 2(3%) = 8%.</explanation></question>
        <question>
            <text>The dimensions of [L / R] where L is inductance and R is resistance are:</text>
            <option id="A">[T]</option><option id="B">[T^-1]</option><option id="C">[M]</option><option id="D">None</option>
            <answer>A</answer><explanation>Time constant of LR circuit.</explanation></question>
        <question>
            <text>Dimensions of CR (Capacitance x Resistance) are:</text>
            <option id="A">[T]</option><option id="B">[T^-1]</option><option id="C">[M L^2 T^-3]</option><option id="D">None</option>
