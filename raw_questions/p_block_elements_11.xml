<chapter subject="Chemistry" id="210" name="The p-Block Elements (Group 13 and 14)">
    <easy>
        <question>
            <text>p-block elements include groups ____ to ____.</text>
            <option id="A">13 to 18</option><option id="B">3 to 12</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Last electron enters p-orbital.</explanation>
        </question>
        <question>
            <text>Group 13 elements are known as the ____ family.</text>
            <option id="A">Boron</option><option id="B">Carbon</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>B, Al, Ga, In, Tl.</explanation>
        </question>
        <question>
            <text>Group 14 elements are known as the ____ family.</text>
            <option id="A">Carbon</option><option id="B">Boron</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>C, Si, Ge, Sn, Pb.</explanation>
        </question>
