        </question>
        <question>
            <text>Edge atom contribution in unit cell is ____.</text>
            <option id="A">1/4</option><option id="B">1/2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Shared among 4 cubes.</explanation>
        </question>
