            <text>One sphere in FCC is shared by ____ unit cells.</text>
            <option id="A">8 (Corner) / 2 (Face)</option><option id="B">4</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Depends on position.</explanation>
        </question>
