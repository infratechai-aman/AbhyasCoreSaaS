        <question>
            <text>Sequence from Species to Kingdom is in ____ order of hierarchy.</text>
            <option id="A">Ascending</option><option id="B">Descending</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Number of common characters decreases as we go up.</explanation></question>
