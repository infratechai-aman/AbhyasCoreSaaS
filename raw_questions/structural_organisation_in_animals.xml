<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Biology" id="307" name="Structural Organisation in Animals">
    <easy>
        <question>
            <text>Group of similar cells along with intercellular substances performing specific function is ____.</text>
            <option id="A">Tissue</option><option id="B">Organ</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Four basic types: Epithelial, Connective, Muscular, Neural.</explanation>
        </question>
        <question>
            <text>Tissue that has a free surface and provides lining for body parts is ____.</text>
            <option id="A">Epithelial tissue</option><option id="B">Connective tissue</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Cells are compactly packed with little intercellular matrix.</explanation>
        </question>
        <question>
            <text>Epithelium composed of a single layer of cells is ____.</text>
            <option id="A">Simple epithelium</option><option id="B">Compound epithelium</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Functions as lining for body cavities, ducts and tubes.</explanation>
        </question>
        <question>
            <text>Epithelium made of two or more cell layers and having protective function is ____.</text>
            <option id="A">Compound / Stratified epithelium</option><option id="B">Simple</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Found in skin and buccal cavity.</explanation>
        </question>
        <question>
            <text>Simple epithelium made of single thin layer of flattened cells with irregular boundaries is ____.</text>
            <option id="A">Squamous</option><option id="B">Cuboidal</option><option id="C">Columnar</option><option id="D">None</option>
            <answer>A</answer><explanation>Found in walls of blood vessels and air sacs of lungs.</explanation>
        </question>
        <question>
            <text>Simple epithelium composed of single layer of cube-like cells is ____.</text>
            <option id="A">Cuboidal</option><option id="B">Squamous</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Commonly found in ducts of glands and tubular parts of nephrons.</explanation>
        </question>
        <question>
            <text>Simple epithelium composed of single layer of tall and slender cells is ____.</text>
            <option id="A">Columnar</option><option id="B">Cuboidal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Nuclei are located at the base.</explanation>
        </question>
        <question>
            <text>Ciliated epithelium has ____ on the free surface of columnar or cuboidal cells.</text>
            <option id="A">Cilia</option><option id="B">Microvilli</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Helps in moving particles or mucus in a specific direction.</explanation>
        </question>
        <question>
            <text>Glandular epithelium specialized for secretion can be ____ or ____.</text>
            <option id="A">Unicellular / Multicellular</option><option id="B">Cuboidal / Squamous</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Unicellular example: Goblet cells of alimentary canal.</explanation>
        </question>
        <question>
            <text>Glands that release secretions through ducts are ____.</text>
            <option id="A">Exocrine glands</option><option id="B">Endocrine glands</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Secrete mucus, saliva, earwax, oil, milk, etc.</explanation>
        </question>
        <question>
            <text>Ductless glands that secrete hormones directly into fluid bathing them are ____.</text>
            <option id="A">Endocrine glands</option><option id="B">Exocrine glands</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Hypothalamus, Pituitary, etc.</explanation>
        </question>
        <question>
            <text>Most abundant and widely distributed tissue in body of complex animals is ____.</text>
            <option id="A">Connective tissue</option><option id="B">Epithelial tissue</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Names from its function of linking and supporting other tissues.</explanation>
        </question>
        <question>
            <text>Loose connective tissue present beneath skin is ____.</text>
            <option id="A">Areolar tissue</option><option id="B">Adipose tissue</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Serves as support framework for epithelium.</explanation>
        </question>
        <question>
            <text>Loose connective tissue specialized to store fats is ____.</text>
            <option id="A">Adipose tissue</option><option id="B">Areolar tissue</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Found mainly beneath skin.</explanation>
        </question>
        <question>
            <text>Dense connective tissue where collagen fibres are present in rows between parallel bundles? ____.</text>
            <option id="A">Dense Regular</option><option id="B">Dense Irregular</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Example: Tendons and Ligaments.</explanation>
        </question>
        <question>
            <text>Dense irregular connective tissue is found in the ____.</text>
            <option id="A">Skin</option><option id="B">Muscle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Has fibroblasts and many fibres oriented differently.</explanation>
        </question>
        <question>
            <text>Pliable, solid-resisting compression tissue is ____.</text>
            <option id="A">Cartilage</option><option id="B">Bone</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Chondrocytes are enclosed in small cavities.</explanation>
        </question>
        <question>
            <text>Hard, non-pliable ground substance rich in calcium salts and collagen is ____.</text>
            <option id="A">Bone</option><option id="B">Cartilage</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Main tissue for structural frame of body.</explanation>
        </question>
        <question>
            <text>Only fluid connective tissue is ____.</text>
            <option id="A">Blood</option><option id="B">Lymph</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Contains plasma, RBCs, WBCs and platelets.</explanation>
        </question>
        <question>
            <text>Connective tissue that links bone to bone is ____.</text>
            <option id="A">Ligament</option><option id="B">Tendon</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Very elastic.</explanation>
        </question>
        <question>
            <text>Connective tissue that links skeletal muscles to bone is ____.</text>
            <option id="A">Tendon</option><option id="B">Ligament</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Dense regular tissue.</explanation>
        </question>
        <question>
            <text>Muscle fibers that are parallel to each other and show striations are ____ muscles.</text>
            <option id="A">Skeletal / Striated</option><option id="B">Smooth</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Voluntary muscles attached to bones.</explanation>
        </question>
        <question>
            <text>Muscle tissue whose cells taper at both ends (fusiform) and do not show striations is ____.</text>
            <option id="A">Smooth muscle</option><option id="B">Cardiac muscle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Involuntary, found in walls of internal organs.</explanation>
        </question>
        <question>
            <text>Contractile tissue found only in the heart is ____.</text>
            <option id="A">Cardiac muscle</option><option id="B">Skeletal muscle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Striated and involuntary; cells are branched.</explanation>
        </question>
        <question>
            <text>Neural tissue that exerts greatest control over body's responsiveness is ____.</text>
            <option id="A">Neuron</option><option id="B">Neuroglia</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Unit of neural system.</explanation>
        </question>
        <question>
            <text>Supporting cells of neural system that make up more than half its volume are ____.</text>
            <option id="A">Neuroglia</option><option id="B">Nephrons</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Protect and support neurons.</explanation>
        </question>
        <question>
            <text>Commonly used animal for studying structural organization in textbooks? ____.</text>
            <option id="A">Cockroach (Periplaneta americana)</option><option id="B">Frog</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Member of Phylum Arthropoda.</explanation>
        </question>
        <question>
            <text>Earthworm scientific name is ____.</text>
            <option id="A">Pheretima posthuma</option><option id="B">Periplaneta</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Invertebrate found in moist soil.</explanation>
        </question>
        <question>
            <text>Body of Cockroach is divided into three regions: Head, ____ and ____.</text>
            <option id="A">Thorax / Abdomen</option><option id="B">Legs / Wings</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Thorax consists of Prothorax, Mesothorax and Metathorax.</explanation>
        </question>
        <question>
            <text>First segment of Earthworm is called ____.</text>
            <option id="A">Peristomium</option><option id="B">Prostomium</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Buccal segment; contains mouth.</explanation>
        </question>
        <question>
            <text>Fleshy lobe covering mouth in Earthworm is ____.</text>
            <option id="A">Prostomium</option><option id="B">Peristomium</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sensory and aids in burrowing.</explanation>
        </question>
        <question>
            <text>Glandular tissue in Earthworm segments 14-16 is ____.</text>
            <option id="A">Clitellum</option><option id="B">Setae</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Secretes of cocoon material.</explanation>
        </question>
        <question>
            <text>Excretory organs in Earthworm are ____.</text>
            <option id="A">Nephridia</option><option id="B">Malpighian tubules</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Segmentally arranged coiled tubes.</explanation>
        </question>
        <question>
            <text>Respiratory system of Cockroach consists of network of ____.</text>
            <option id="A">Trachea</option><option id="B">Gills</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Open to outside by 10 pairs of spiracles.</explanation>
        </question>
        <question>
            <text>Excretory organs of Cockroach are ____ tubules.</text>
            <option id="A">Malpighian</option><option id="B">Nephridia</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Located at junction of midgut and hindgut.</explanation>
        </question>
        <question>
            <text>Heart of Cockroach is ____-shaped chambers.</text>
            <option id="A">Funnel</option><option id="B">S-shaped</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>13 chambers arranged along dorsal line.</explanation>
        </question>
        <question>
            <text>Blood of Cockroach is called ____.</text>
            <option id="A">Hemolymph</option><option id="B">Plasma</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Colorless plasma and hemocytes.</explanation>
        </question>
        <question>
            <text>Visual units of Cockroach compound eye are ____.</text>
            <option id="A">Ommatidia</option><option id="B">Lenses</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Approx 2000 in each eye.</explanation>
        </question>
        <question>
            <text>Frog scientific name is ____.</text>
            <option id="A">Rana tigrina</option><option id="B">Bufo</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Most common species in India.</explanation>
        </question>
        <question>
            <text>Frogs are poikilotherms, meaning they are ____.</text>
            <option id="A">Cold-blooded</option><option id="B">Warm-blooded</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Body temp varies with environment.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Cell junctions that stop substances from leaking across a tissue are ____.</text>
            <option id="A">Tight junctions</option><option id="B">Gap junctions</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Prevent paracellular transport.</explanation>
        </question>
        <question>
            <text>Cell junctions that perform cementing to keep neighboring cells together are ____.</text>
            <option id="A">Adhering junctions</option><option id="B">Gap junctions</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Example: Desmosomes.</explanation>
        </question>
        <question>
            <text>Cell junctions that facilitate communication between cells via ions and molecules are ____.</text>
            <option id="A">Gap junctions</option><option id="B">Tight junctions</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Connexons form the channels.</explanation>
        </question>
        <question>
            <text>Which epithelium lines the PCT of nephron with microvilli?</text>
            <option id="A">Cuboidal</option><option id="B">Squamous</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Brush-bordered cuboidal epithelium for reabsorption.</explanation>
        </question>
        <question>
            <text>Connective tissue fibers are secreted by cells called ____.</text>
            <option id="A">Fibroblasts</option><option id="B">Mast cells</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Secrete both fibres (collagen/elastin) and matrix.</explanation>
        </question>
        <question>
            <text>Which cells in areolar tissue secrete histamine, heparin and serotonin?</text>
            <option id="A">Mast cells</option><option id="B">Fibroblasts</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Involved in inflammatory reactions.</explanation>
        </question>
        <question>
            <text>Intercalated discs are found in ____ muscle.</text>
            <option id="A">Cardiac</option><option id="B">Skeletal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Communication junctions that allow heart to contract as a unit.</explanation>
        </question>
        <question>
            <text>Each spinal segment of earthworm bears S-shaped ____ for locomotion.</text>
            <option id="A">Setae</option><option id="B">Parapodia</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Embedded in epidermal pits.</explanation>
        </question>
        <question>
            <text>Muscular structure in earthworm for grinding soil particles is ____.</text>
            <option id="A">Gizzard</option><option id="B">Pharynx</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Located in 8th-9th segments.</explanation>
        </question>
        <question>
            <text>Internal fold of intestine in earthworm to increase area of absorption is ____.</text>
            <option id="A">Typhlosole</option><option id="B">Villi</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Present from 26th segment onwards.</explanation>
        </question>
        <question>
            <text>Blood glands of Earthworm (segments 4-6) produce ____.</text>
            <option id="A">Blood cells and Hemoglobin</option><option id="B">Bile</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Hemoglobin is dissolved in blood plasma.</explanation>
        </question>
        <question>
            <text>Earthworms are ____ (sexuality).</text>
            <option id="A">Hermaphrodite (Bisexual)</option><option id="B">Dioecious</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Testes and ovaries in same individual; cross fertilization occurs.</explanation>
        </question>
        <question>
            <text>Mouth parts of Cockroach are ____ type.</text>
            <option id="A">Biting and Chewing</option><option id="B">Sucking</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Consists of labrum, mandibles, maxillae and labium.</explanation>
        </question>
        <question>
            <text>Muscular part of Cockroach foregut for grinding food into fine particles is ____.</text>
            <option id="A">Gizzard (Proventriculus)</option><option id="B">Crop</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Has six highly chitinous teeth.</explanation>
        </question>
        <question>
            <text>Thin-walled structure for storage of food in Cockroach is ____.</text>
            <option id="A">Crop</option><option id="B">Gizzard</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Part of foregut.</explanation>
        </question>
        <question>
            <text>Blind tubules at junction of foregut and midgut in Cockroach are ____.</text>
            <option id="A">Hepatic / Gastric caeca</option><option id="B">Malpighian tubules</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Secrete digestive juice.</explanation>
        </question>
        <question>
            <text>Cockroach excretes nitrogenous waste as ____.</text>
            <option id="A">Uric acid (Uricotelic)</option><option id="B">Urea</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Conservation of water.</explanation>
        </question>
        <question>
            <text>Mushroom glands are found in the ____ reproductive system of Cockroach.</text>
            <option id="A">Male (6th-7th segments)</option><option id="B">Female</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Accessory reproductive glands.</explanation>
        </question>
        <question>
            <text>External genitalia in male Cockroach are ____.</text>
            <option id="A">Phallomeres / Gonapophyses</option><option id="B">Aedeagus</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Chitinous asymmetrical structures.</explanation>
        </question>
        <question>
            <text>Development of Cockroach is ____ (paurometabolous).</text>
            <option id="A">Hemimetabolous (Nymph stages)</option><option id="B">Direct</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Nymph undergoes 13 molts to become adult.</explanation>
        </question>
        <question>
            <text>Frogs use ____ for respiration in water.</text>
            <option id="A">Skin (Cutaneous)</option><option id="B">Lungs</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Diffusion through moist skin.</explanation>
        </question>
        <question>
            <text>Frogs use ____ for respiration on land.</text>
            <option id="A">Skin and Lungs (Pulmonary)</option><option id="B">Gills</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Buccal cavity also acts as respiratory surface.</explanation>
        </question>
        <question>
            <text>Hibernation is ____ sleep, Aestivation is ____ sleep.</text>
            <option id="A">Winter / Summer</option><option id="B">Summer / Winter</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Strategies to cope with extreme temperatures.</explanation>
        </question>
        <question>
            <text>Heart of Frog is ____-chambered.</text>
            <option id="A">Three (2 Atria, 1 Ventricle)</option><option id="B">Four</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Separation of oxygenated and deoxygenated blood is incomplete.</explanation>
        </question>
        <question>
            <text>Ventral triangular structure receiving blood from major veins in frog heart is ____.</text>
            <option id="A">Sinus venosus</option><option id="B">Conus arteriosus</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Located on dorsal side actually (correction: opens into right atrium).</explanation>
        </question>
        <question>
            <text>Portal system in frog between liver and intestine is ____.</text>
            <option id="A">Hepatic portal system</option><option id="B">Renal portal system</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Shared feature with mammals.</explanation>
        </question>
        <question>
            <text>Portal system in frog between kidney and lower body parts is ____.</text>
            <option id="A">Renal portal system</option><option id="B">Hepatic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Absent in mammals.</explanation>
        </question>
        <question>
            <text>Male frog is distinguished by vocal sacs and a ____ pad on first digit of forelimb.</text>
            <option id="A">Copulatory / Nuptial</option><option id="B">Clawed</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Helps in gripping female during amplexus.</explanation>
        </question>
        <question>
            <text>Nervous system of frog involves ____ pairs of cranial nerves.</text>
            <option id="A">10</option><option id="B">12</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Mammals have 12 pairs.</explanation>
        </question>
        <question>
            <text>Fertilization in frogs is ____.</text>
            <option id="A">External (in water)</option><option id="B">Internal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Female lays thousands of ova.</explanation>
        </question>
        <question>
            <text>Larva of frog is ____.</text>
            <option id="A">Tadpole</option><option id="B">Nymph</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Undergoes metamorphosis to become adult.</explanation>
        </question>
        <question>
            <text>Excretory waste of Frog is ____.</text>
            <option id="A">Urea (Ureotelic)</option><option id="B">Ammonia</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Tadpole is Ammonotelic.</explanation>
        </question>
        <question>
            <text>White fibrous tissue is rich in ____ fibers.</text>
            <option id="A">Collagen</option><option id="B">Elastin</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>High tensile strength, inelastic.</explanation>
        </question>
        <question>
            <text>Yellow elastic tissue is rich in ____ fibers.</text>
            <option id="A">Elastin</option><option id="B">Collagen</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Highly elastic, branched.</explanation>
        </question>
        <question>
            <text>Epithelium which is multi-layered and helps in protection against mechanical stress is ____.</text>
            <option id="A">Compound / Stratified Squamous</option><option id="B">Transitional</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Found in skin (keratinized) or pharynx.</explanation>
        </question>
        <question>
            <text>Epithelium that can stretch, lining the urinary bladder? ____.</text>
            <option id="A">Transitional</option><option id="B">Stratified</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Special compound epithelium for stretching.</explanation>
        </question>
        <question>
            <text>Presence of chondroitin salts makes ____ pliable.</text>
            <option id="A">Cartilage</option><option id="B">Bone</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Contrast with bony matrix.</explanation>
        </question>
        <question>
            <text>Bone cells are called ____.</text>
            <option id="A">Osteocytes</option><option id="B">Chondrocytes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Reside in lacunae.</explanation>
