        <question>
            <text>A 10kg mass is steady on floor. Normal reaction? ____ N.</text>
            <option id="A">100</option><option id="B">Zero</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Balances weight exactly.</explanation></question>
        <question>
            <text>Relation between linear momentum p and KE? KE = ____.</text>
            <option id="A">p^2 / 2m</option><option id="B">p * m</option><option id="C">phi</option><option id="D">None</option>
