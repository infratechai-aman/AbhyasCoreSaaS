            <option id="A">-CO-</option><option id="B">-CHO</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Carbonyl group between two carbon atoms.</explanation>
        </question>
        <question>
            <text>Functional group present in Carboxylic acids is ____.</text>
            <option id="A">-COOH</option><option id="B">-COO-</option><option id="C">phi</option><option id="D">None</option>
