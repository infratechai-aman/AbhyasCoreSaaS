<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="101" name="Current Electricity">
    <easy>
        <question>
            <text>Electric current is the rate of flow of ____.</text>
            <option id="A">Electric charge</option><option id="B">Mass</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>I = Q / t.</explanation>
        </question>
        <question>
            <text>The SI unit of electric current is ____.</text>
            <option id="A">Ampere (A)</option><option id="B">Volt (V)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1 Ampere = 1 Coulomb / 1 Second.</explanation>
        </question>
        <question>
            <text>Electric current is a ____ quantity.</text>
            <option id="A">Scalar</option><option id="B">Vector</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>It does not follow vector laws of addition.</explanation>
        </question>
        <question>
            <text>Ohm's law states that V is proportional to ____ for a conductor at constant temp.</text>
            <option id="A">I (Current)</option><option id="B">R (Resistance)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>V = IR.</explanation>
        </question>
        <question>
            <text>The SI unit of resistance is ____.</text>
            <option id="A">Ohm (Ω)</option><option id="B">Siemen (S)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1 Ohm = 1 Volt / 1 Ampere.</explanation>
        </question>
        <question>
            <text>Resistance of a conductor R depends on length L as ____.</text>
            <option id="A">R ∝ L</option><option id="B">R ∝ 1/L</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Longer conductors offer more resistance.</explanation>
        </question>
        <question>
            <text>Resistance of a conductor R depends on area A as ____.</text>
            <option id="A">R ∝ 1/A</option><option id="B">R ∝ A</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Wider area offers less resistance.</explanation>
        </question>
        <question>
            <text>Resistivity (ρ) is a property of the ____.</text>
            <option id="A">Material</option><option id="B">Shape</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Depends on nature of substance and temperature.</explanation>
        </question>
        <question>
            <text>The unit of resistivity is ____.</text>
            <option id="A">Ohm-meter (Ωm)</option><option id="B">Ohm</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ρ = RA / L.</explanation>
        </question>
        <question>
            <text>Conductance is the ____ of resistance.</text>
            <option id="A">Reciprocal (1/R)</option><option id="B">Same</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>G = 1/R.</explanation>
        </question>
        <question>
            <text>The unit of conductance is ____.</text>
            <option id="A">Siemen (S) or Ohm^-1</option><option id="B">Volt</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Also known as mho.</explanation>
        </question>
        <question>
            <text>Electric power P in terms of V and I is P = ____.</text>
            <option id="A">VI</option><option id="B">V/I</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>P = VI = I^2 R = V^2 / R.</explanation>
        </question>
        <question>
            <text>The unit of electric energy is ____ in SI.</text>
            <option id="A">Joule (J)</option><option id="B">Watt (W)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Power x Time.</explanation>
        </question>
        <question>
            <text>Commercial unit of electric energy is ____.</text>
            <option id="A">kWh (Kilowatt-hour)</option><option id="B">Joule</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1 kWh = 3.6 x 10^6 J.</explanation>
        </question>
        <question>
            <text>Drift velocity (v_d) is the average velocity of ____ in a conductor.</text>
            <option id="A">Electrons</option><option id="B">Protons</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Acquired due to applied electric field.</explanation>
        </question>
        <question>
            <text>Mobility (μ) is defined as drift velocity per unit ____.</text>
            <option id="A">Electric field (E)</option><option id="B">Charge</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>μ = v_d / E.</explanation>
        </question>
        <question>
            <text>For metals, resistance ____ with increase in temperature.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to more frequent collisions of electrons.</explanation>
        </question>
        <question>
            <text>For semiconductors, resistance ____ with increase in temperature.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>More charge carriers are released.</explanation>
        </question>
        <question>
            <text>Kirchhoff's First Law (Junction Law) is based on conservation of ____.</text>
            <option id="A">Charge</option><option id="B">Energy</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ΣI = 0 at a junction.</explanation>
        </question>
        <question>
            <text>Kirchhoff's Second Law (Loop Law) is based on conservation of ____.</text>
            <option id="A">Energy</option><option id="B">Charge</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ΣΔV = 0 in a closed loop.</explanation>
        </question>
        <question>
            <text>Wheatstone bridge is balanced when ____.</text>
            <option id="A">P/Q = R/S</option><option id="B">P+Q = R+S</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No current flows through galvanometer.</explanation>
        </question>
        <question>
            <text>The color code of resistors is used to determine ____.</text>
            <option id="A">Resistance and Tolerance</option><option id="B">Temperature</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard way for small components.</explanation>
        </question>
        <question>
            <text>Black color in resistor code represents ____.</text>
            <option id="A">0</option><option id="B">1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>B B R O Y ... (Black=0, Brown=1).</explanation>
        </question>
        <question>
            <text>Internal resistance is the resistance offered by the ____ of a cell.</text>
            <option id="A">Electrolyte</option><option id="B">Wires</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Opposition to ion flow within the cell.</explanation>
        </question>
        <question>
            <text>EMF (Electromotive force) is the potential diff when cell is in ____ circuit.</text>
            <option id="A">Open (No current)</option><option id="B">Closed</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximum possible voltage of the cell.</explanation>
        </question>
        <question>
            <text>Terminal potential V and EMF E are related by V = ____ when discharging.</text>
            <option id="A">E - Ir</option><option id="B">E + Ir</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Potential drop Ir across internal resistance.</explanation>
        </question>
        <question>
            <text>Cells are connected in series to increase ____.</text>
            <option id="A">Voltage</option><option id="B">Current capacity only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Total EMF = nE.</explanation>
        </question>
        <question>
            <text>Cells are connected in parallel to increase ____.</text>
            <option id="A">Current capacity</option><option id="B">Voltage only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>EMF remains same but internal resistance decreases.</explanation>
        </question>
        <question>
            <text>Potentiometer is used to measure ____ without drawing current.</text>
            <option id="A">EMF</option><option id="B">Current</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ideal voltmeter behavior.</explanation>
        </question>
        <question>
            <text>Potentiometer sensitivity increases by ____ the length of wire.</text>
            <option id="A">Increasing</option><option id="B">Decreasing</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Decreases potential gradient.</explanation>
        </question>
        <question>
            <text>Meter bridge is an application of ____.</text>
            <option id="A">Wheatstone bridge</option><option id="B">Potentiometer</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used for finding unknown resistance.</explanation>
        </question>
        <question>
            <text>Current density (J) is current per unit ____.</text>
            <option id="A">Area (Normal to flow)</option><option id="B">Length</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>J = I / A.</explanation>
        </question>
        <question>
            <text>Current density is a ____ quantity.</text>
            <option id="A">Vector</option><option id="B">Scalar</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>It has direction of positive charge flow.</explanation>
        </question>
        <question>
            <text>The unit of current density is ____.</text>
            <option id="A">A/m^2</option><option id="B">A.m</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Derived from Current / Area.</explanation>
        </question>
        <question>
            <text>Conversion of Galvanometer into Voltmeter requires ____ resistance in series.</text>
            <option id="A">High</option><option id="B">Low</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To limit current through coil.</explanation>
        </question>
        <question>
            <text>Conversion of Galvanometer into Ammeter requires ____ resistance in parallel.</text>
            <option id="A">Low (Shunt)</option><option id="B">High</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To bypass most of the current.</explanation>
        </question>
        <question>
            <text>The resistivity of alloys like Manganin varies ____ with temperature.</text>
            <option id="A">Very little</option><option id="B">Highly</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used for making standard resistors.</explanation>
        </question>
        <question>
            <text>Superconductivity is the phenomenon of ____ resistance at low temp.</text>
            <option id="A">Zero</option><option id="B">Infinite</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Occurs below critical temperature.</explanation>
        </question>
        <question>
            <text>Does an ideal cell have internal resistance?</text>
            <option id="A">No (Zero)</option><option id="B">Yes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Theoretical model.</explanation>
        </question>
        <question>
            <text>Which of the following follows Ohm's law strictly?</text>
            <option id="A">Metals (under normal conditions)</option><option id="B">Diodes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Ohmic conductors.</explanation>
        </question>
        <question>
            <text>Drift speed of electrons is usually of the order of ____.</text>
            <option id="A">mm/s</option><option id="B">km/s</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Very slow despite high thermal speed.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Drift velocity v_d is related to current I as I = ____.</text>
            <option id="A">n e A v_d</option><option id="B">n e v_d</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>n=number density, e=electronic charge, A=cross section area.</explanation>
        </question>
        <question>
            <text>Relation between resistivity ρ and relaxation time τ is ρ = ____.</text>
            <option id="A">m / (n e^2 τ)</option><option id="B">n e^2 τ / m</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Where m is electron mass and n is density.</explanation>
        </question>
        <question>
            <text>Vector form of Ohm's law is ____.</text>
            <option id="A">J = σE</option><option id="B">V = IR</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>J is current density, σ is conductivity, E is field.</explanation>
        </question>
        <question>
            <text>Temperature coefficient of resistance (α) is defined as R_t = ____.</text>
            <option id="A">R_0 (1 + αΔT)</option><option id="B">R_0 αΔT</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Linear relation for small temperature changes.</explanation>
        </question>
        <question>
            <text>If a wire is stretched to double its length, its resistance becomes ____ times.</text>
            <option id="A">4</option><option id="B">2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>L' = 2L, A' = A/2 (Volume is constant). R' = ρ(2L)/(A/2) = 4R.</explanation>
        </question>
        <question>
            <text>If a wire of resistance R is melted and recast to half its radius, new resistance is ____.</text>
            <option id="A">16R</option><option id="B">4R</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>r' = r/2 implies A' = A/4. Vol constant implies L' = 16L. R' = ρ(16L)/(A/16) = 16R.</explanation>
        </question>
        <question>
            <text>Two resistors R1 and R2 are in parallel. Their equivalent resistance is ____.</text>
            <option id="A">R1R2 / (R1+R2)</option><option id="B">R1 + R2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1/Rp = 1/R1 + 1/R2.</explanation>
        </question>
        <question>
            <text>Two resistors R1 and R2 are in series. Their equivalent resistance is ____.</text>
            <option id="A">R1 + R2</option><option id="B">R1R2 / (R1+R2)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Voltages are additive.</explanation>
        </question>
        <question>
            <text>For maximum power from a cell, external resistance R should be ____ internal resistance r.</text>
            <option id="A">Equal to</option><option id="B">Much greater than</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximum Power Transfer Theorem.</explanation>
        </question>
        <question>
            <text>Heat produced in a resistor R by current I for time t is H = ____.</text>
            <option id="A">I^2 R t</option><option id="B">VI t</option><option id="C">V^2 t / R</option><option id="D">All of these</option>
            <answer>D</answer><explanation>Joule heating law expression variations.</explanation>
        </question>
        <question>
            <text>In a Wheatstone bridge, if P=10, Q=10, R=10, then S is ____ for balance.</text>
            <option id="A">10</option><option id="B">20</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>P/Q = R/S.</explanation>
        </question>
        <question>
            <text>Meter bridge wire is usually made of ____.</text>
            <option id="A">Manganin or Constantan</option><option id="B">Copper</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Requires low temp coefficient of resistance.</explanation>
        </question>
        <question>
            <text>Potential gradient K of a potentiometer wire is ____.</text>
            <option id="A">V / L</option><option id="B">V * L</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Fall of potential per unit length.</explanation>
        </question>
        <question>
            <text>Sensitivity of potentiometer can be increased by ____.</text>
            <option id="A">Increasing length / Reducing current</option><option id="B">Increasing current</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lower potential gradient gives higher sensitivity.</explanation>
        </question>
        <question>
            <text>Comparison of EMFs using potentiometer: E1/E2 = ____.</text>
            <option id="A">l1 / l2</option><option id="B">l2 / l1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Potential balanced at null points l1, l2.</explanation>
        </question>
        <question>
            <text>Internal resistance r using potentiometer r = ____.</text>
            <option id="A">R (l1/l2 - 1)</option><option id="B">R (l1/l2)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Where l1 is open circuit, l2 is closed with R.</explanation>
        </question>
        <question>
            <text>Mobility unit is ____.</text>
            <option id="A">m^2 V^-1 s^-1</option><option id="B">m V^-1 s</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Derived from v_d / E.</explanation>
        </question>
        <question>
            <text>Which material is used for heating elements in heaters?</text>
            <option id="A">Nichrome</option><option id="B">Copper</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>High resistivity and high melting point.</explanation>
        </question>
        <question>
            <text>The resistivity of a semiconductor ____ as temperature increases.</text>
            <option id="A">Decreases exponentially</option><option id="B">Increases linearly</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to negative temperature coefficient.</explanation>
        </question>
        <question>
            <text>Kirchhoff's bridge balance is independent of ____ sensitivity.</text>
            <option id="A">Galvanometer</option><option id="B">Battery voltage</option><option id="C">phi</option><option id="D">None</option>
            <answer>B</answer><explanation>Zero current condition remains zero regardless of V.</explanation>
        </question>
        <question>
            <text>Fuse wire is an alloy of ____.</text>
            <option id="A">Lead and Tin</option><option id="B">Nickel and Chromium</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Requires low melting point.</explanation>
        </question>
        <question>
            <text>Resistance of a standard 100W, 220V bulb is ____.</text>
            <option id="A">484 Ω</option><option id="B">220 Ω</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>R = V^2 / P = 220*220 / 100 = 484.</explanation>
        </question>
        <question>
            <text>A battery is charged by a DC source. If EMF is E and internal resistance r, terminal voltage V is ____.</text>
            <option id="A">E + Ir</option><option id="B">E - Ir</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Current enters the positive terminal.</explanation>
        </question>
        <question>
            <text>Two bulbs 25W and 100W (rated at same V) are in series. Which bulb is brighter?</text>
            <option id="A">25W bulb</option><option id="B">100W bulb</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>25W has higher R, so more power (P = I^2 R) in series.</explanation>
        </question>
        <question>
            <text>Two bulbs 25W and 100W are in parallel. Which is brighter?</text>
            <option id="A">100W bulb</option><option id="B">25W bulb</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>100W consumes rated power in parallel.</explanation>
        </question>
        <question>
            <text>Superconductors have magnetic susceptibility ____.</text>
            <option id="A">-1 (Perfect Diamagnetism)</option><option id="B">0</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Meissner effect.</explanation>
        </explanation>
        </question>
        <question>
            <text>In metals, relaxation time τ ____ with temperature increase.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Faster vibrations of ions lead to more frequent collisions.</explanation>
        </question>
        <question>
            <text>The resistivity of copper is approx ____ Ωm.</text>
            <option id="A">1.7 x 10^-8</option><option id="B">1.7 x 10^8</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Good conductor.</explanation>
        </question>
        <question>
            <text>Thermistor is a device whose resistance varies ____ with temp.</text>
            <option id="A">Significantly</option><option id="B">Negligibly</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Used for thermal sensing.</explanation>
        </question>
        <question>
            <text>Potentiometer is better than voltmeter because it works on ____ method.</text>
            <option id="A">Null deflection</option><option id="B">Direct deflection</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Does not load the circuit under test.</explanation>
        </question>
        <question>
            <text>Resistance of an ideal ammeter should be ____.</text>
            <option id="A">Zero</option><option id="B">Infinite</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To minimize impact on total current.</explanation>
        </question>
        <question>
            <text>Resistance of an ideal voltmeter should be ____.</text>
            <option id="A">Infinite</option><option id="B">Zero</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>To draw zero current from source.</explanation>
        </question>
        <question>
            <text>A carbon resistor has colors Brown, Black, Red. Its value is ____.</text>
            <option id="A">1 kΩ (10 x 10^2)</option><option id="B">10 Ω</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Brown=1, Black=0, Red=10^2multiplier.</explanation>
        </question>
        <question>
            <text>Tolerance for a Gold band on resistor is ____.</text>
            <option id="A">±5%</option><option id="B">±10%</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard color code tolerance.</explanation>
        </question>
        <question>
            <text>Tolerance for a Silver band is ____.</text>
            <option id="A">±10%</option><option id="B">±5%</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard color code tolerance.</explanation>
        </question>
        <question>
            <text>Kirchhoff's loop law is valid only for ____ electric fields.</text>
            <option id="A">Conservative (Electrostatic)</option><option id="B">Induced</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Work done in closed loop must be zero.</explanation>
        </question>
        <question>
            <text>Value of 1 calorie is approx ____ Joules.</text>
            <option id="A">4.18</option><option id="B">3.6</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Mechanical equivalent of heat.</explanation>
        </question>
        <question>
