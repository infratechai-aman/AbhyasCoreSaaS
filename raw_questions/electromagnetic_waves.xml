        </question>
        <question>
            <text>Energy produced by Sun is radiated as EM waves?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Primary source of light and heat for Earth.</explanation>
        </question>
        <question>
            <text>Is it possible for electric field to be parallel to magnetic field in a plane wave?</text>
            <option id="A">No (always perpendicular)</option><option id="B">Yes</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Derived from Maxwell equations for free space.</explanation>
        </question>
        <question>
            <text>Standardizing EM Waves Medium section - progressing.</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
