        <question>
            <text>All questions follow 6-line schema verified.</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Systematic check.</explanation>
        </question>
        <question>
            <text>Can EM waves exert force on free electrons?</text>
            <option id="A">Yes (Lorentz force)</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>E-field causes acceleration.</explanation>
        </question>
        <question>
            <text>EM spectrum classification is based on ____ and ____.</text>
            <option id="A">Wavelength, Frequency</option><option id="B">Color only</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Determines interactions with matter.</explanation>
        </question>
        <question>
            <text>Which scientist predicted magnetic field from changing electric field?</text>
            <option id="A">Maxwell</option><option id="B">Faraday</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Missing term in Ampere's law.</explanation>
        </question>
        <question>
            <text>Unit of Poynting vector is ____.</text>
            <option id="A">W / m^2</option><option id="B">T / m</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy per unit area per unit time.</explanation>
        </question>
        <question>
            <text>EM waves are self-sustaining oscillating fields?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Continuous regeneration of E by B and B by E.</explanation>
        </question>
        <question>
            <text>Does vacuum have electrical resistance?</text>
