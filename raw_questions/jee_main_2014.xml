    <question>
      <text>Nearest point on line 3x + 4y = 12 from origin:</text>
      <option id="A">(1.44, 1.92)</option>
      <option id="B">(1, 2)</option>
      <option id="C">(2, 1)</option>
      <option id="D">(0, 3)</option>
