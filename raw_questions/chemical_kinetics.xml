        <question>
            <text>Unit of Pre-exponential factor A for third order is ____.</text>
            <option id="A">L^2 mol^-2 s^-1</option><option id="B">s^-1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Matches the units of k.</explanation>
        </question>
        <question>
            <text>Steric factor P generally has a value ____.</text>
