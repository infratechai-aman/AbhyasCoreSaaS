            <text>Copolymers contain ____ type of monomer units.</text>
            <option id="A">More than one</option><option id="B">Only one</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Example: Buna-S.</explanation></question>
        <question>
            <text>Homopolymers consist of ____ type of monomer units.</text>
            <option id="A">Single</option><option id="B">Multiple</option><option id="C">phi</option><option id="D">None</option>
