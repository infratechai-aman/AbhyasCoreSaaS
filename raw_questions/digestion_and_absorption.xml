<?xml version='1.0' encoding='utf-8'?>
<chapter subject="Biology" id="113" name="Digestion and Absorption">
    <easy>
        <question>
            <text>Process of conversion of complex food materials to simple absorbable forms is ____.</text>
            <option id="A">Digestion</option><option id="B">Respiration</option><option id="C">Excretion</option><option id="D">None</option>
            <answer>A</answer><explanation>Basic definition of digestive process.</explanation></question>
        <question>
            <text>Human digestive system consists of ____ and ____.</text>
            <option id="A">Alimentary canal , Associated glands</option><option id="B">Lungs , Heart</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Anatomical organization.</explanation></question>
        <question>
            <text>Type of teeth embedded in sockets of jaw bone is ____.</text>
            <option id="A">Thecodont</option><option id="B">Diphyodont</option><option id="C">Heterodont</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard mammalian tooth attachment.</explanation></question>
        <question>
            <text>Majority of mammals have two sets of teeth during life, called ____.</text>
            <option id="A">Diphyodont</option><option id="B">Monophyodont</option><option id="C">Thecodont</option><option id="D">None</option>
            <answer>A</answer><explanation>Deciduous and permanent sets.</explanation></question>
        <question>
            <text>Human adult dental formula is ____.</text>
            <option id="A">2123 / 2123</option><option id="B">2102 / 2102</option><option id="C">1234 / 1234</option><option id="D">None</option>
            <answer>A</answer><explanation>Incissors, Canines, Premolars, Molars.</explanation></question>
        <question>
            <text>Hard chewing surface of teeth is made of ____.</text>
            <option id="A">Enamel</option><option id="B">Dentin</option><option id="C">Pulp</option><option id="D">None</option>
            <answer>A</answer><explanation>Hardest substance in the body.</explanation></question>
        <question>
            <text>Tongue is attached to the floor of oral cavity by ____.</text>
            <option id="A">Frenulum</option><option id="B">Hyoid bone</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Small fold of tissue.</explanation></question>
        <question>
            <text>Common passage for food and air is ____.</text>
            <option id="A">Pharynx</option><option id="B">None</option><option id="C">Larynx</option><option id="D">Esophagus</option>
            <answer>A</answer><explanation>Divided into three parts.</explanation></question>
        <question>
            <text>Cartilaginous flap that prevents food entry into glottis is ____.</text>
            <option id="A">Epiglottis</option><option id="B">Uvula</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Covers windpipe during swallowing.</explanation></question>
        <question>
            <text>Stomach is located in the ____ portion of abdominal cavity.</text>
            <option id="A">Left</option><option id="B">Right</option><option id="C">Center</option><option id="D">None</option>
            <answer>A</answer><explanation>Upper left quadrant.</explanation></question>
        <question>
            <text>Four parts of stomach are Cardiac, Fundic, ____ and Pyloric.</text>
            <option id="A">Body</option><option id="B">Antrum</option><option id="C">Neck</option><option id="D">None</option>
            <answer>A</answer><explanation>Recent NCERT updates include 'Body'.</explanation></question>
        <question>
            <text>Small intestine has three parts: Duodenum, ____ and Ileum.</text>
            <option id="A">Jejunum</option><option id="B">Cecum</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sequentially from stomach.</explanation></question>
        <question>
            <text>Small blind sac in large intestine which hosts symbiotic microbes is ____.</text>
            <option id="A">Caecum / Cecum</option><option id="B">Rectum</option><option id="C">Anus</option><option id="D">None</option>
            <answer>A</answer><explanation>Starts the large intestine.</explanation></question>
        <question>
            <text>Vestigial organ arising from caecum is ____.</text>
            <option id="A">Vermiform appendix</option><option id="B">Gall bladder</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Narrow finger-like tubular projection.</explanation></question>
        <question>
            <text>Innermost layer of alimentary canal is ____.</text>
            <option id="A">Mucosa</option><option id="B">Serosa</option><option id="C">Muscularis</option><option id="D">Sub-mucosa</option>
            <answer>A</answer><explanation>Has direct contact with food.</explanation></question>
        <question>
            <text>Finger like foldings in small intestine mucosa are ____.</text>
            <option id="A">Villi</option><option id="B">Rugae</option><option id="C">Plicae</option><option id="D">None</option>
            <answer>A</answer><explanation>Increase surface area for absorption.</explanation></question>
        <question>
            <text>Villi are supplied with large lymph vessel called ____.</text>
            <option id="A">Lacteal</option><option id="B">Artery</option><option id="C">Vein</option><option id="D">None</option>
            <answer>A</answer><explanation>For fat absorption.</explanation></question>
        <question>
            <text>Glands of the stomach are called ____ glands.</text>
            <option id="A">Gastric</option><option id="B">Salivary</option><option id="C">Pancreatic</option><option id="D">None</option>
            <answer>A</answer><explanation>Found in mucosal pits.</explanation></question>
        <question>
            <text>Crypts of Lieberkuhn are found in ____.</text>
            <option id="A">Intestine</option><option id="B">Stomach</option><option id="C">Esophagus</option><option id="D">None</option>
            <answer>A</answer><explanation>Between bases of villi.</explanation></question>
        <question>
            <text>Largest gland of human body is ____.</text>
            <option id="A">Liver</option><option id="B">Pancreas</option><option id="C">Thyroid</option><option id="D">None</option>
            <answer>A</answer><explanation>Weight 1.2 to 1.5 kg.</explanation></question>
        <question>
            <text>Storage organ for bile is ____.</text>
            <option id="A">Gall bladder</option><option id="B">Liver</option><option id="C">Spleen</option><option id="D">None</option>
            <answer>A</answer><explanation>Concentrates and stores bile.</explanation></question>
        <question>
            <text>Structural and functional units of liver are ____.</text>
            <option id="A">Hepatic lobules</option><option id="B">Nephrons</option><option id="C">Alveoli</option><option id="D">None</option>
            <answer>A</answer><explanation>Covered by Glisson's capsule.</explanation></question>
        <question>
            <text>Duct of gall bladder is called ____ duct.</text>
            <option id="A">Cystic</option><option id="B">Bile</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Joins hepatic duct to form common bile duct.</explanation></question>
        <question>
            <text>Sphincter of Boyden / Oddi regulates entry into ____.</text>
            <option id="A">Duodenum</option><option id="B">Stomach</option><option id="C">Cecum</option><option id="D">None</option>
            <answer>A</answer><explanation>Opening of hepatopancreatic duct.</explanation></question>
        <question>
            <text>Salivary amylase digests ____ into ____.</text>
            <option id="A">Starch, Maltose</option><option id="B">Protein, Peptides</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Chemical digestion begins in mouth.</explanation></question>
        <question>
            <text>Optimal pH for salivary amylase is ____.</text>
            <option id="A">6.8</option><option id="B">2.0</option><option id="C">8.5</option><option id="D">None</option>
            <answer>A</answer><explanation>Slightly acidic.</explanation></question>
        <question>
            <text>Parietal / Oxyntic cells of stomach secrete ____.</text>
            <option id="A">HCl and Intrinsic factor</option><option id="B">Pepsinogen</option><option id="C">Mucus</option><option id="D">None</option>
            <answer>A</answer><explanation>Critical for protein digestion and B12 absorption.</explanation></question>
        <question>
            <text>Chief / Peptic cells of stomach secrete ____.</text>
            <option id="A">Pepsinogen</option><option id="B">HCl</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Proenzyme form of pepsin.</explanation></question>
        <question>
            <text>Pepsinogen is converted to active Pepsin by ____.</text>
            <option id="A">HCl</option><option id="B">Water</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Self-catalyzed eventually.</explanation></question>
        <question>
            <text>Rennin is a proteolytic enzyme found in gastric juice of ____.</text>
            <option id="A">Infants</option><option id="B">Adults only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>For digestion of milk proteins.</explanation></question>
        <question>
            <text>Chyme is food mixed with ____.</text>
            <option id="A">Gastric juice</option><option id="B">Saliva</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>In the stomach.</explanation></question>
        <question>
            <text>Emulsification of fats is done by ____.</text>
            <option id="A">Bile salts</option><option id="B">Lipase</option><option id="C">Pepsin</option><option id="D">None</option>
            <answer>A</answer><explanation>Breaking fats into tiny micelles.</explanation></question>
        <question>
            <text>Pancreatic juice contains proenzymes: Trypsinogen, Chymotrypsinogen and ____.</text>
            <option id="A">Procarboxypeptidase</option><option id="B">Pepsinogen</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Major protein digestors.</explanation></question>
        <question>
            <text>Trypsinogen is activated by ____ secreted by intestinal mucosa.</text>
            <option id="A">Enterokinase</option><option id="B">Trypsin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Starts the enzyme cascade.</explanation></question>
        <question>
            <text>Succus entericus is the name for ____.</text>
            <option id="A">Intestinal juice</option><option id="B">Gastric juice</option><option id="C">Bile</option><option id="D">None</option>
            <answer>A</answer><explanation>Secretion of Crypts and goblet cells.</explanation></question>
        <question>
            <text>Most of the absorption occurs in ____.</text>
            <option id="A">Small intestine (Jejunum/Ileum)</option><option id="B">Stomach</option><option id="C">Large intestine</option><option id="D">None</option>
            <answer>A</answer><explanation>Maximized area and enzymes.</explanation></question>
        <question>
            <text>Fructose and some amino acids are absorbed by ____ diffusion.</text>
            <option id="A">Facilitated</option><option id="B">Simple</option><option id="C">Active</option><option id="D">None</option>
            <answer>A</answer><explanation>Requires carrier protein.</explanation></question>
        <question>
            <text>Water absorption in intestine depends on ____ gradient.</text>
            <option id="A">Osmotic</option><option id="B">Heat</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Follows solutes.</explanation></question>
        <question>
            <text>Fatty acids are first converted into ____ before transport into lacteals.</text>
            <option id="A">Chylomicrons</option><option id="B">Glucose</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Protein coated fat globules.</explanation></question>
        <question>
            <text>Assimilation is the process of ____.</text>
            <option id="A">Utilization of absorbed food by tissues</option><option id="B">Chewing</option><option id="C">Rejecting food</option><option id="D">None</option>
            <answer>A</answer><explanation>Nutrients becoming part of cell structure.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Auerbach's plexus and Meissner's plexus are ____.</text>
            <option id="A">Nerve networks in gut wall</option><option id="B">Glands in stomach</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Regulate motility and secretion.</explanation></question>
        <question>
            <text>Bile contains no ____.</text>
            <option id="A">Enzymes</option><option id="B">Pigments</option><option id="C">Salts</option><option id="D">Acids</option>
            <answer>A</answer><explanation>It only aids physical digestion/activation.</explanation></question>
        <question>
            <text>Absorption of alcohol occurs mainly in ____.</text>
            <option id="A">Stomach</option><option id="B">Mouth</option><option id="C">Ileum</option><option id="D">None</option>
            <answer>A</answer><explanation>Direct passage through stomach mucosa.</explanation></question>
        <question>
            <text>Large intestine primary function is ____.</text>
            <option id="A">Absorption of water and some minerals/drugs</option><option id="B">Protein digestion</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>No significant chemical digestion here.</explanation></question>
        <question>
            <text>Constipation is caused by ____.</text>
            <option id="A">Retention of feces in rectum due to irregular bowel move</option><option id="B">Fast move</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Clinical digestive disorder.</explanation></question>
        <question>
            <text>Jaundice affects ____ organ primarily.</text>
            <option id="A">Liver</option><option id="B">Heart</option><option id="C">Kidney</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to bile pigment accumulation.</explanation></question>
        <question>
            <text>Vomiting is controlled by vomit center in ____.</text>
            <option id="A">Medulla</option><option id="B">Cerebellum</option><option id="C">Pons</option><option id="D">None</option>
            <answer>A</answer><explanation>Involuntary reflex center.</explanation></question>
        <question>
            <text>Kashiorkor is deficiency of ____.</text>
            <option id="A">Protein only (usually)</option><option id="B">Carbs</option><option id="C">Fat</option><option id="D">Vitamins</option>
            <answer>A</answer><explanation>Accompanied by edema.</explanation></question>
        <question>
            <text>Marasmus is deficiency of ____.</text>
            <option id="A">Protein and Calories (Energy)</option><option id="B">Protein only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Severe wasting of muscles.</explanation></question>
        <question>
            <text>Gastrin hormone stimulates secretion of ____.</text>
            <option id="A">Gastric juice</option><option id="B">Bile</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Feedback loop in stomach.</explanation></question>
        <question>
            <text>Secretin stimulates secretion of ____ from pancreas.</text>
            <option id="A">Watery bicarbonate juice</option><option id="B">Enzymes only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Neutralizes acidity of chyme.</explanation></question>
        <question>
            <text>CCK (Cholecystokinin) stimulates ____ and ____.</text>
            <option id="A">Gall bladder contraction , Pancreatic enzymes</option><option id="B">Saliva</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Triggered by fats/proteins in duodenum.</explanation></question>
        <question>
            <text>Brunner's glands are found in ____ of duodenum.</text>
            <option id="A">Sub-mucosa</option><option id="B">Mucosa</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Secrete alkaline mucus.</explanation></question>
        <question>
            <text>Serosa is made of ____.</text>
            <option id="A">Mesothelium and connective tissue</option><option id="B">Muscle only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Outer visceral peritoneum layer.</explanation></question>
        <question>
            <text>Function of lysozyme in saliva is ____.</text>
            <option id="A">Antibacterial agent</option><option id="B">Digesting sugar</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Prevents infection.</explanation></question>
        <question>
            <text>Intrinsic factor is essential for absorption of ____.</text>
            <option id="A">Vitamin B12</option><option id="B">Vitamin C</option><option id="C">Iron</option><option id="D">None</option>
            <answer>A</answer><explanation>Castle's intrinsic factor.</explanation></question>
        <question>
            <text>Ductless gland part of pancreas is ____.</text>
            <option id="A">Islets of Langerhans</option><option id="B">Acini</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Endocrine portion.</explanation></question>
        <question>
            <text>Bile pigments are ____ and ____.</text>
            <option id="A">Bilirubin and Biliverdin</option><option id="B">Chlorophyll</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Waste from hemoglobin breakdown.</explanation></question>
        <question>
            <text>Maximum protein digestion occurs in ____.</text>
            <option id="A">Small intestine</option><option id="B">Stomach</option><option id="C">Mouth</option><option id="D">None</option>
            <answer>A</answer><explanation>Begins in stomach, finished in intestine.</explanation></question>
        <question>
            <text>Carbohydrate digestion is finished by ____ enzymes.</text>
            <option id="A">Disaccharidases (Maltase, Sucrase, Lactase)</option><option id="B">Lipase</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Brush border enzymes.</explanation></question>
        <question>
            <text>Nucleases in pancreatic juice digest ____.</text>
            <option id="A">Nucleic acids (DNA/RNA)</option><option id="B">Nucleosides</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Into nucleotides.</explanation></question>
        <question>
            <text>Enzyme for milk protein casein digestion in adults is ____.</text>
            <option id="A">Pepsin / Chymotrypsin</option><option id="B">Rennin</option><option id="C">Amylase</option><option id="D">None</option>
            <answer>A</answer><explanation>Adults lack rennin.</explanation></question>
        <question>
            <text>Major site of fat digestion is ____.</text>
            <option id="A">Small intestine</option><option id="B">Stomach</option><option id="C">Mouth</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to bile and pancreatic lipase.</explanation></question>
        <question>
            <text>Lactase converts lactose into ____ and ____.</text>
            <option id="A">Glucose and Galactose</option><option id="B">Glucose and Fructose</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard brush border reaction.</explanation></question>
        <question>
            <text>Sucrase converts sucrose into ____ and ____.</text>
            <option id="A">Glucose and Fructose</option><option id="B">Glucose x 2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Table sugar digestion.</explanation></question>
        <question>
            <text>End product of protein digestion in intestine is ____.</text>
            <option id="A">Amino acids</option><option id="B">Peptides</option><option id="C">Starch</option><option id="D">None</option>
            <answer>A</answer><explanation>Absorbable monomer.</explanation></question>
        <question>
            <text>Function of Rugae in stomach is ____.</text>
            <option id="A">Increase surface area for expansion</option><option id="B">Digesting fat</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Folds visible when empty.</explanation></question>
        <question>
            <text>Kupffer cells in liver are ____.</text>
            <option id="A">Phagocytic (Macrophages)</option><option id="B">Secretory</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Part of immune system in liver sinusoids.</explanation></question>
        <question>
            <text>Bile contains salts like Sodium ____ and Sodium Glycocholate.</text>
            <option id="A">Taurocholate</option><option id="B">Chloride</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Primary emulsifiers.</explanation></question>
        <question>
            <text>Pancreatic lipase is also called ____.</text>
            <option id="A">Steapsin</option><option id="B">Amylopsin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Specific name for lipase.</explanation></question>
        <question>
            <text>Pancreatic amylase is also called ____.</text>
            <option id="A">Amylopsin</option><option id="B">Trypsin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Effective on cooked/raw starch.</explanation></question>
        <question>
            <text>Islet of Langerhans alpha cells secrete ____.</text>
            <option id="A">Glucagon</option><option id="B">Insulin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Hyperglycemic hormone.</explanation></question>
        <question>
            <text>Islet of Langerhans beta cells secrete ____.</text>
            <option id="A">Insulin</option><option id="B">Glucagon</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Hypoglycemic hormone.</explanation></question>
        <question>
            <text>Opening of Bile duct and Pancreatic duct is common, called ____.</text>
            <option id="A">Ampulla of Vater</option><option id="B">Duct of Wirsung</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Anatomical junction.</explanation></question>
        <question>
            <text>Caloric value of fats is ____ kcal/g.</text>
            <option id="A">9.45 (Gross) / 9.0 (Physio)</option><option id="B">4.0</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Highest energy density.</explanation></question>
        <question>
            <text>Caloric value of carbohydrates and proteins is approx ____ kcal/g.</text>
            <option id="A">4.0 (Physiological)</option><option id="B">9.0</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard biochemical energy.</explanation></question>
        <question>
            <text>Feces are temporarily stored in ____ before egestion.</text>
            <option id="A">Rectum</option><option id="B">Ileum</option><option id="C">Colon</option><option id="D">None</option>
            <answer>A</answer><explanation>Triggers defecation reflex.</explanation></question>
        <question>
            <text>The color of feces is due to ____ pigments.</text>
            <option id="A">Stercobilin / Urobilin</option><option id="B">Melanin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Modified bile pigments.</explanation></question>
        <question>
            <text>Muscularis layer of esophagus is made of ____.</text>
            <option id="A">Inner circular , outer longitudinal muscle</option><option id="B">Cilia</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Enables peristalsis.</explanation></question>
        <question>
            <text>Peyer's patches are lymphoid tissues in ____.</text>
            <option id="A">Ileum</option><option id="B">Stomach</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intestinal immune system.</explanation></question>
    </medium>
    <hard>
        <question>
            <text>Which organ is also known as 'Graveyard of RBCs' but secretes bile? No. Spleen is graveyard, Liver secretes bile.</text>
            <option id="A">Liver</option><option id="B">Spleen</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Liver recycles hemoglobin from dead RBCs.</explanation></question>
        <question>
            <text>The enterogastrone hormone ____ gastric motility.</text>
            <option id="A">Inhibits / Slows</option><option id="B">Stimulates</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Prevents overfilling of duodenum.</explanation></question>
        <question>
            <text>Succus entericus contains Dipeptidases which convert ____ to ____.</text>
            <option id="A">Dipeptides to Amino acids</option><option id="B">Protein to Urea</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Terminal digestion step.</explanation></question>
        <question>
            <text>Islet cell delta cells secrete ____.</text>
            <option id="A">Somatostatin</option><option id="B">Insulin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Inhibits other hormones.</explanation></question>
        <question>
            <text>Ejection of stomach contents through mouth is a ____ action.</text>
            <option id="A">Reverse peristaltic / Vomit</option><option id="B">Normal flow</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Medulla reflex.</explanation></question>
        <question>
            <text>Indigestion can be caused by ____.</text>
            <option id="A">Anxiety, overeating, spicy food</option><option id="B">Drinking water</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Inadequate enzyme secretion.</explanation></question>
        <question>
            <text>Pancreatic islets make up ____ percent of the gland.</text>
            <option id="A">1 to 2%</option><option id="B">90%</option><option id="C">50%</option><option id="D">None</option>
            <answer>A</answer><explanation>Rest is exocrine.</explanation></question>
        <question>
            <text>G.I. tract hormones are ____ hormones.</text>
            <option id="A">Local / Peptide</option><option id="B">Steroid</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Secreted by mucosal cells.</explanation></question>
        <question>
            <text>Mechanism of Glucose absorption involves ____ with Na+.</text>
            <option id="A">Secondary active transport (Symport)</option><option id="B">Simple diffusion</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cotransport mechanism.</explanation></question>
        <question>
            <text>Micelles are tiny globules formed by ____.</text>
            <option id="A">Fats and Bile salts in intestinal lumen</option><option id="B">Sugar</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intermediate step for fat absorption.</explanation></question>
        <question>
            <text>Chylomicrons are released from mucosal cells into ____.</text>
            <option id="A">Lacteals</option><option id="B">Blood capillaries directly</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Too large for blood capillaries.</explanation></question>
        <question>
            <text>Glandular portion of esophagus is ____.</text>
            <option id="A">None (It lacks glands mostly, except for mucus)</option><option id="B">Rich</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Purely a conduit.</explanation></question>
        <question>
            <text>Pyloric sphincter connects ____ and ____.</text>
            <option id="A">Stomach and Duodenum</option><option id="B">Esophagus and Stomach</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Regulates exit of chyme.</explanation></question>
        <question>
            <text>Cardiac sphincter connects ____ and ____.</text>
            <option id="A">Esophagus and Stomach</option><option id="B">Stomach and Duodenum</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Prevents acid reflux.</explanation></question>
        <question>
            <text>Starch digestion in oral cavity constitutes ____ percent of total.</text>
            <option id="A">30</option><option id="B">100</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Significant start.</explanation></question>
        <question>
            <text>Mucus and bicarbonates in gastric juice protect ____.</text>
            <option id="A">Stomach wall from HCl and Pepsin</option><option id="B">Food</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Prevent self-digestion (ulcers).</explanation></question>
        <question>
            <text>Bile activates ____ enzyme.</text>
            <option id="A">Lipase</option><option id="B">Amylase</option><option id="C">Pepsin</option><option id="D">None</option>
            <answer>A</answer><explanation>Crucial step for fat breakdown.</explanation></question>
        <question>
            <text>Nucleosidases convert nucleosides into ____ and ____.</text>
            <option id="A">Sugars and Bases</option><option id="B">DNA</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intestinal terminal step.</explanation></question>
        <question>
            <text>Bile pigments Bilirubin/biliverdin comes from ____ breakdown.</text>
            <option id="A">Heme (Hemoglobin)</option><option id="B">Muscle</option><option id="C">Bone</option><option id="D">None</option>
            <answer>A</answer><explanation>Recycling of old RBCs.</explanation></question>
        <question>
            <text>Gastric juice pH is approx ____.</text>
            <option id="A">1.8</option><option id="B">7.0</option><option id="C">8.2</option><option id="D">None</option>
            <answer>A</answer><explanation>Extremely acidic for pepsin action.</explanation></question>
        <question>
            <text>Internal anal sphincter is ____ muscle.</text>
            <option id="A">Involuntary (Smooth)</option><option id="B">Voluntary</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Reflexive control.</explanation></question>
        <question>
            <text>External anal sphincter is ____ muscle.</text>
            <option id="A">Voluntary (Skeletal)</option><option id="B">Involuntary</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Conscious control of defecation.</explanation></question>
        <question>
            <text>Dental formula of child (milk teeth):</text>
            <option id="A">2102 / 2102</option><option id="B">2123 / 2123</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Lack premolars and last molars.</explanation></question>
        <question>
            <text>Parietal cells are oxyntic. Peptic cells are ____.</text>
            <option id="A">Zymogenic</option><option id="B">Oxyntic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Naming variety.</explanation></question>
        <question>
            <text>Maximum quantity of water is absorbed in ____.</text>
            <option id="A">Small intestine</option><option id="B">Large intestine</option><option id="C">Stomach</option><option id="D">None</option>
            <answer>A</answer><explanation>Though large intestine is famous for it, bulk is in small.</explanation></question>
        <question>
            <text>Enterogastric reflex is triggered by ____.</text>
            <option id="A">Acidic chyme in duodenum</option><option id="B">Thinking of food</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Protects the duodenum.</explanation></question>
        <question>
            <text>Major function of Ileocaecal valve:</text>
            <option id="A">Prevent backflow of feces into ileum</option><option id="B">Increase speed</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>One-way gate.</explanation></question>
        <question>
            <text>Smallest section of small intestine is ____.</text>
            <option id="A">Duodenum</option><option id="B">Jejunum</option><option id="C">Ileum</option><option id="D">None</option>
            <answer>A</answer><explanation>C-shaped first part.</explanation></question>
        <question>
            <text>Wisdom tooth is ____ molar.</text>
            <option id="A">Third</option><option id="B">First</option><option id="C">Second</option><option id="D">None</option>
            <answer>A</answer><explanation>Erupts late or stays impacted.</explanation></question>
        <question>
            <text>Presence of rugae, villi, and microvilli serves primarily to ____.</text>
            <option id="A">Increase Surface Area</option><option id="B">Slow down food</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Universal digestive optimization.</explanation></question>
        <question>
            <text>Trypsin converts Chymotrypsinogen into ____.</text>
            <option id="A">Active Chymotrypsin</option><option id="B">Pepsin</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Enzyme activation chain.</explanation></question>
        <question>
            <text>Bile concentration in gall bladder is approx ____ fold.</text>
            <option id="A">10 to 15</option><option id="B">100</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Removal of water.</explanation></question>
        <question>
            <text>Which organ is both endocrine and exocrine?</text>
            <option id="A">Pancreas (Heterocrine)</option><option id="B">Liver</option><option id="C">Stomach</option><option id="D">None</option>
            <answer>A</answer><explanation>Dual functional gland.</explanation></question>
        <question>
            <text>Defecation is a ____ process? No, reflex but voluntary control.</text>
            <option id="A">Mass peristaltic movement</option><option id="B">Gradual</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Driven by strong colonic contractions.</explanation></question>
        <question>
            <text>Final check: Digestion and absorption 120 questions reached?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option><option id="D">None</option>
            <answer>A</answer><explanation>Done.</explanation></question>
