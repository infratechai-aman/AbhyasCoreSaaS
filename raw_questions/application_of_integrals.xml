<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Mathematics" id="208" name="Application of Integrals">
    <easy>
        <question>
            <text>The area under the curve y = f(x) and above x-axis from x=a to x=b is:</text>
            <option id="A">Integral a to b y dx</option><option id="B">Integral a to b x dy</option><option id="C">Integral a to b y^2 dx</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard area definition.</explanation></question>
        <question>
            <text>The area bounded by x = f(y) and y-axis from y=c to y=d is:</text>
            <option id="A">Integral c to d x dy</option><option id="B">Integral c to d y dx</option><option id="C">Integral c to d x^2 dy</option><option id="D">None</option>
            <answer>A</answer><explanation>Area relative to y-axis.</explanation></question>
        <question>
            <text>Area of rectangle with length a and breadth b using integration is:</text>
            <option id="A">ab</option><option id="B">a+b</option><option id="C">a^2 b</option><option id="D">None</option>
            <answer>A</answer><explanation>Calculated as Integral 0 to a b dx = ab.</explanation></question>
        <question>
            <text>Area bounded by y = x, x-axis and lines x=0 to x=2 is:</text>
            <option id="A">2</option><option id="B">4</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 2 x dx = [x^2/2] = 4/2 = 2.</explanation></question>
        <question>
            <text>Area bounded by y = 2x, x-axis and x=1 to x=3 is:</text>
            <option id="A">8</option><option id="B">4</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to 3 2x dx = [x^2] = 9 - 1 = 8.</explanation></question>
        <question>
            <text>Area of region bounded by x^2 + y^2 = 1 is:</text>
            <option id="A">pi</option><option id="B">2pi</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Area of circle with radius 1.</explanation></question>
        <question>
            <text>Area of circle x^2 + y^2 = r^2 is given by:</text>
            <option id="A">pi r^2</option><option id="B">2pi r</option><option id="C">4/3 pi r^3</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard circle area.</explanation></question>
        <question>
            <text>The area of ellipse x^2/a^2 + y^2/b^2 = 1 is:</text>
            <option id="A">pi a b</option><option id="B">pi (a+b)</option><option id="C">pi a^2</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard ellipse area formula.</explanation></question>
        <question>
            <text>Area bounded by y^2 = 4ax and its latus rectum (x=a) is:</text>
            <option id="A">8/3 a^2</option><option id="B">4/3 a^2</option><option id="C">2 a^2</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to a sqrt(4ax) dx = 4 sqrt(a) [2/3 x^{3/2}] = 8/3 a^2.</explanation></question>
        <question>
            <text>Area bounded by y = sin x from x=0 to x=pi is:</text>
            <option id="A">2</option><option id="B">0</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to pi sin x dx = [-cos x] = 1 - (-1) = 2.</explanation></question>
        <question>
            <text>Area bounded by y = cos x from x=0 to x=pi/2 is:</text>
            <option id="A">1</option><option id="B">2</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to pi/2 cos x dx = [sin x] = 1.</explanation></question>
        <question>
            <text>Area bounded by y = e^x, x-axis, x=0 and x=1 is:</text>
            <option id="A">e - 1</option><option id="B">e</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 e^x dx = e^1 - e^0.</explanation></question>
        <question>
            <text>Area bounded by y = x^2, x-axis and lines x=1, x=2 is:</text>
            <option id="A">7/3</option><option id="B">3</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to 2 x^2 dx = [x^3/3] = (8-1)/3 = 7/3.</explanation></question>
        <question>
            <text>Area of triangle with vertices (0,0), (a,0), (0,b) is:</text>
            <option id="A">1/2 ab</option><option id="B">ab</option><option id="C">a+b</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard triangle area.</explanation></question>
        <question>
            <text>Area of region bounded by x^2 = 4y, y-axis and y=1 to y=4 is:</text>
            <option id="A">28/3</option><option id="B">14/3</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to 4 sqrt(4y) dy = 2 [2/3 y^{3/2}] = 4/3(8-1) = 28/3.</explanation></question>
        <question>
            <text>Area between y = x and y = x^2 in first quadrant is:</text>
            <option id="A">1/6</option><option id="B">1/3</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 (x - x^2) dx = 1/2 - 1/3 = 1/6.</explanation></question>
        <question>
            <text>Area bounded by curve y = x^3 and x-axis from x=0 to x=1:</text>
            <option id="A">1/4</option><option id="B">1/3</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 x^3 dx = 1/4.</explanation></question>
        <question>
            <text>Area of square region x^2 + y^2 &lt;= 1 is pi. Area of x^2 + y^2 &lt;= 4 is:</text>
            <option id="A">4pi</option><option id="B">2pi</option><option id="C">16pi</option><option id="D">None</option>
            <answer>A</answer><explanation>Area is proportional to r^2.</explanation></question>
        <question>
            <text>Area bounded by y = 1/x, x-axis, x=1 and x=e is:</text>
            <option id="A">1</option><option id="B">e</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to e 1/x dx = log e - log 1 = 1.</explanation></question>
        <question>
            <text>Area of region bounded by y = |x| and x-axis from -1 to 1 is:</text>
            <option id="A">1</option><option id="B">0</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to 1 x dx = 1.</explanation></question>
        <question>
            <text>Area of region bounded by x + y = 2, x=0, y=0 is:</text>
            <option id="A">2</option><option id="B">4</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Triangle with base 2 and height 2. Area = 1/2 * 2 * 2 = 2.</explanation></question>
        <question>
            <text>Area of region bounded by y^2 = x and x=4 is:</text>
            <option id="A">32/3</option><option id="B">16/3</option><option id="C">8</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to 4 sqrt(x) dx = 2 * [2/3 x^{3/2}] = 4/3 * 8 = 32/3.</explanation></question>
        <question>
            <text>Area bounded by circle x^2 + y^2 = 9 in first quadrant is:</text>
            <option id="A">9pi/4</option><option id="B">9pi</option><option id="C">3pi</option><option id="D">None</option>
            <answer>A</answer><explanation>1/4 of total area 9pi.</explanation></question>
        <question>
            <text>The area bounded by y = x^2 and y = 4 is:</text>
            <option id="A">32/3</option><option id="B">16/3</option><option id="C">8</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to 2 (4 - x^2) dx = 2 * (8 - 8/3) = 32/3.</explanation></question>
        <question>
            <text>Area bounded by curve y = |sin x|, x-axis from x=0 to x=2pi is:</text>
            <option id="A">4</option><option id="B">2</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Area from 0 to pi = 2 * 2 = 4.</explanation></question>
        <question>
            <text>Area between y = sqrt(x) and y = x is:</text>
            <option id="A">1/6</option><option id="B">1/3</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 (sqrt(x) - x) dx = 2/3 - 1/2 = 1/6.</explanation></question>
        <question>
            <text>Area bounded by line y=mx, x-axis and x=a is:</text>
            <option id="A">1/2 m a^2</option><option id="B">m a</option><option id="C">1/2 m^2 a</option><option id="D">None</option>
            <answer>A</answer><explanation>Triangle with base a and height ma.</explanation></question>
        <question>
            <text>Total area of ellipse x^2/4 + y^2/9 = 1 is:</text>
            <option id="A">6pi</option><option id="B">36pi</option><option id="C">13pi</option><option id="D">None</option>
            <answer>A</answer><explanation>pi * 2 * 3 = 6pi.</explanation></question>
        <question>
            <text>Area of region bounded by y = 5x, x-axis, x=1, x=2 is:</text>
            <option id="A">7.5</option><option id="B">5</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to 2 5x dx = 5/2 (4 - 1) = 7.5.</explanation></question>
        <question>
            <text>Shape of region described by x^2 + y^2 &lt;= 1 is:</text>
            <option id="A">Disk</option><option id="B">Line</option><option id="C">Square</option><option id="D">None</option>
            <answer>A</answer><explanation>Interior of circle.</explanation></question>
        <question>
            <text>Area of region bounded by x = y^2, y-axis and y=1 to y=2 is:</text>
            <option id="A">7/3</option><option id="B">1</option><option id="C">3</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to 2 y^2 dy = 7/3.</explanation></question>
        <question>
            <text>Area of triangle with vertices (0,0), (4,0), (0,3) is:</text>
            <option id="A">6</option><option id="B">12</option><option id="C">7</option><option id="D">None</option>
            <answer>A</answer><explanation>1/2 * 4 * 3 = 6.</explanation></question>
        <question>
            <text>The area bounded by x^2 = y and line y=1 is:</text>
            <option id="A">4/3</option><option id="B">2/3</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to 1 (1 - x^2) dx = 2 * (1 - 1/3) = 4/3.</explanation></question>
        <question>
            <text>Area bounded by y=x^3, y=0, x=1, x=2:</text>
            <option id="A">3.75</option><option id="B">4</option><option id="C">3</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to 2 x^3 dx = 1/4(16 - 1) = 3.75.</explanation></question>
        <question>
            <text>Area between x^2 + y^2 = 4 and x-axis is:</text>
            <option id="A">2pi</option><option id="B">4pi</option><option id="C">pi</option><option id="D">None</option>
            <answer>A</answer><explanation>Semi-circle area = 1/2 pi(4) = 2pi.</explanation></question>
        <question>
            <text>Area of quadrant of circle x^2 + y^2 = 16 is:</text>
            <option id="A">4pi</option><option id="B">16pi</option><option id="C">pi</option><option id="D">None</option>
            <answer>A</answer><explanation>1/4 of 16pi.</explanation></question>
        <question>
            <text>Region bounded by y = x and y = -x from x=0 to x=1 has area:</text>
            <option id="A">1</option><option id="B">0</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Triangle with height 1? No, two triangles. Area = Integral (x - (-x)) = Integral 2x = 1.</explanation></question>
        <question>
            <text>Area bounded by y=x and x=2 is:</text>
            <option id="A">2</option><option id="B">4</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 2 x dx = 2.</explanation></question>
        <question>
            <text>Area bounded by y = sqrt(4-x^2) and x-axis is:</text>
            <option id="A">2pi</option><option id="B">4pi</option><option id="C">pi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equation represents upper semi-circle of r=2.</explanation></question>
        <question>
            <text>Area of region y &lt;= x, x &lt;= 1, y &gt;= 0 is:</text>
            <option id="A">1/2</option><option id="B">1</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Triangle with vertices (0,0), (1,0), (1,1).</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Area bounded by y^2 = 4x and x^2 = 4y is:</text>
            <option id="A">16/3</option><option id="B">32/3</option><option id="C">8/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at (0,0) and (4,4). Integral 0 to 4 (sqrt(4x) - x^2/4) dx = 32/3 - 16/3 = 16/3.</explanation></question>
        <question>
            <text>The area between y^2 = 4x and line y = x is:</text>
            <option id="A">8/3</option><option id="B">4/3</option><option id="C">2/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at (0,0) and (4,4). Integral 0 to 4 (sqrt(4x) - x) dx = 32/3 - 8 = 8/3.</explanation></question>
        <question>
            <text>Area bounded by y = x^2 and y = |x| is:</text>
            <option id="A">1/3</option><option id="B">1/6</option><option id="C">2/3</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to 1 (x - x^2) dx = 2 * (1/2 - 1/3) = 1/3.</explanation></question>
        <question>
            <text>Find area of region bounded by x^2 = 4y and y = 2, y = 5 in first quadrant:</text>
            <option id="A">2/3 (10 sqrt(5) - 4 sqrt(2))</option><option id="B">1/3 (10 sqrt(5) - 4 sqrt(2))</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Integral 2 to 5 sqrt(4y) dy = 4/3 [y^{3/2}] 2 to 5.</explanation></question>
        <question>
            <text>Area between y = cos x and x-axis from x=0 to x=2pi is:</text>
            <option id="A">4</option><option id="B">2</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>4 segments of area 1 each.</explanation></question>
        <question>
            <text>Area of triangle formed by lines y = 2x + 1, y = 3x + 1 and x = 4:</text>
            <option id="A">8</option><option id="B">4</option><option id="C">12</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 4 ((3x+1) - (2x+1)) dx = Integral x dx = 8.</explanation></question>
        <question>
            <text>Find the area of the region {(x, y) : x^2 + y^2 &lt;= 1 &lt;= x + y}:</text>
            <option id="A">pi/4 - 1/2</option><option id="B">pi/2 - 1</option><option id="C">pi/4</option><option id="D">None</option>
            <answer>A</answer><explanation>Area of quadrant minus area of triangle = pi/4 - 1/2.</explanation></question>
        <question>
            <text>Area bounded by y^2 = x and line 2y = x is:</text>
            <option id="A">4/3</option><option id="B">2/3</option><option id="C">8/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at (0,0) and (4,2). Integral 0 to 4 (sqrt(x) - x/2) dx = 16/3 - 4 = 4/3.</explanation></question>
        <question>
            <text>Area of segment cut from circle x^2 + y^2 = a^2 by line x = a/2:</text>
            <option id="A">a^2(pi/3 - sqrt(3)/4)</option><option id="B">a^2(pi/6)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 * Integral a/2 to a sqrt(a^2-x^2) dx.</explanation></question>
        <question>
            <text>Area bounded by y = x^2 + 2, y = x, x = 0 and x = 3 is:</text>
            <option id="A">10.5</option><option id="B">12</option><option id="C">9</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 3 (x^2 + 2 - x) dx = [x^3/3 + 2x - x^2/2] = 9 + 6 - 4.5 = 10.5.</explanation></question>
        <question>
            <text>Area of region {(x, y) : y^2 &lt;= 4x, 4x^2 + 4y^2 &lt;= 9}:</text>
            <option id="A">9pi/8 + sqrt(2)/6</option><option id="B">pi - 1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Requires intersection of circle and parabola and splitting integral.</explanation></question>
        <question>
            <text>Area bounded by y = x, x-axis and ORDINATES x = -1, x = 2:</text>
            <option id="A">2.5</option><option id="B">1.5</option><option id="C">0.5</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral -1 to 0 (-x) + Integral 0 to 2 (x) = 1/2 + 2 = 2.5.</explanation></question>
        <question>
            <text>Area bounded by y = sin 2x from x = 0 to x = pi/4 is:</text>
            <option id="A">1/2</option><option id="B">1</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to pi/4 sin 2x dx = [-1/2 cos 2x] = 1/2.</explanation></question>
        <question>
            <text>Area bounded by y = log x, y = 0 and x = e:</text>
            <option id="A">1</option><option id="B">e</option><option id="C">e - 1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 1 to e log x dx = [x log x - x] = (e - e) - (0 - 1) = 1.</explanation></question>
        <question>
            <text>Area of smaller part of circle x^2 + y^2 = 1 cut off by x = 1/sqrt(2):</text>
            <option id="A">pi/4 - 1/2</option><option id="B">pi/8</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Segment area calculation.</explanation></question>
        <question>
            <text>Area of region bounded by y = x^2, x-axis and lines x = -1, x = 1:</text>
            <option id="A">2/3</option><option id="B">1/3</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral -1 to 1 x^2 dx = 2 * (1/3) = 2/3.</explanation></question>
        <question>
            <text>Area between y^2 = 9x and line x = 1 is:</text>
            <option id="A">4</option><option id="B">6</option><option id="C">3</option><option id="D">None</option>
            <answer>A</answer><explanation>2 * Integral 0 to 1 3 sqrt(x) dx = 6 * [2/3] = 4.</explanation></question>
        <question>
            <text>Area between parabola y^2 = 4ax and line x = h is:</text>
            <option id="A">8/3 sqrt(a) h^{3/2}</option><option id="B">4/3 a h</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 * Integral 0 to h 2 sqrt(a) x^{1/2} dx.</explanation></question>
        <question>
            <text>Area bounded by y = |x-1|, y = 0 and x = 0, x = 2:</text>
            <option id="A">1</option><option id="B">2</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Two triangles each of area 1/2.</explanation></question>
        <question>
            <text>Area of region bounded by x^2 = 4y and line x = 4y - 2 is:</text>
            <option id="A">9/8</option><option id="B">3/4</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at x = 2, -1. Integral -1 to 2 ((x+2)/4 - x^2/4) dx = 1/4 [x^2/2 + 2x - x^3/3] = 9/8.</explanation></question>
        <question>
            <text>Area common to x^2 + y^2 = a^2 and y^2 = 3ax in first quadrant:</text>
            <option id="A">a^2(pi/6 + sqrt(3)/8)</option><option id="B">a^2(pi/4)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intersection at x = a/4? No, x = a. Needs splitting.</explanation></question>
        <question>
            <text>Area of ellipse x^2/a^2 + y^2/b^2 = 1 in first quadrant:</text>
            <option id="A">pi a b / 4</option><option id="B">pi a b / 2</option><option id="C">pi a b</option><option id="D">None</option>
            <answer>A</answer><explanation>1/4 of full area.</explanation></question>
        <question>
            <text>Find area bounded by y = 4 - x^2 and x-axis:</text>
            <option id="A">32/3</option><option id="B">16/3</option><option id="C">8</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral -2 to 2 (4 - x^2) dx = 2 * (8 - 8/3) = 32/3.</explanation></question>
        <question>
            <text>Area of triangle with vertices (1,0), (2,2), (3,1):</text>
            <option id="A">1.5</option><option id="B">3</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Using lines: y = 2(x-1), y = -x+4, y = 1/2(x-1). Integral splits.</explanation></question>
        <question>
            <text>Area bounded by y^2 = 8x and line y = 2x is:</text>
            <option id="A">4/3</option><option id="B">2/3</option><option id="C">8/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at (0,0) and (2,4). Integral 0 to 2 (sqrt(8x) - 2x) dx = 4/3 sqrt(8) * 2 sqrt(2) - 4 = 16/3 - 4 = 4/3.</explanation></question>
        <question>
            <text>Area bounded by y = x|x| and x-axis from x = -1 to x = 1:</text>
            <option id="A">2/3</option><option id="B">0</option><option id="C">1/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral -1 to 0 (-x^2) + Integral 0 to 1 (x^2) leads to absolute sum 1/3 + 1/3 = 2/3.</explanation></question>
        <question>
            <text>Area of region bounded by x^2 = y and the line y = x is:</text>
            <option id="A">1/6</option><option id="B">1/3</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 (x - x^2) dx = 1/6.</explanation></question>
        <question>
            <text>Area bounded by y = tan x from x = 0 to x = pi/4:</text>
            <option id="A">1/2 log 2</option><option id="B">log 2</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>log|sec pi/4| = log sqrt(2) = 1/2 log 2.</explanation></question>
        <question>
            <text>Find the area between y = x^2 and y^2 = x:</text>
            <option id="A">1/3</option><option id="B">1/6</option><option id="C">2/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 (sqrt(x) - x^2) dx = 2/3 - 1/3 = 1/3.</explanation></question>
        <question>
            <text>Area of region bounded by y^2 = 4ax and line y = mx:</text>
            <option id="A">8a^2 / 3m^3</option><option id="B">4a^2 / 3m^2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard formula for parabola and central line.</explanation></question>
        <question>
            <text>Area of loop of curve y^2 = x(x-1)^2:</text>
            <option id="A">8/15</option><option id="B">4/15</option><option id="C">2/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Loop from x=0 to x=1. 2 * Integral (1-x)sqrt(x) dx.</explanation></question>
        <question>
            <text>Area bounded by y = x^2 and y = 2x + 3:</text>
            <option id="A">32/3</option><option id="B">16/3</option><option id="C">10</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at x = 3, -1. Integral -1 to 3 (2x + 3 - x^2) dx.</explanation></question>
        <question>
            <text>Find area of ellipse 4x^2 + 9y^2 = 36:</text>
            <option id="A">6pi</option><option id="B">pi/6</option><option id="C">36pi</option><option id="D">None</option>
            <answer>A</answer><explanation>x^2/9 + y^2/4 = 1. Area = pi * 3 * 2 = 6pi.</explanation></question>
        <question>
            <text>Area between y = 2 - x^2 and y = x is:</text>
            <option id="A">4.5</option><option id="B">3</option><option id="C">4</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at x = 1, -2. Integral -2 to 1 (2 - x^2 - x) dx = [2x - x^3/3 - x^2/2] = (2 - 1/3 - 1/2) - (-4 + 8/3 - 2) = 4.5.</explanation></question>
        <question>
            <text>Area of region common to circles x^2 + y^2 = 4 and (x-2)^2 + y^2 = 4:</text>
            <option id="A">8pi/3 - 2 sqrt(3)</option><option id="B">pi - sqrt(3)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Requires integration of circle segments.</explanation></question>
        <question>
            <text>Area bounded by y = sin x and y = cos x between x = 0 and x = pi/4:</text>
            <option id="A">sqrt(2) - 1</option><option id="B">1</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to pi/4 (cos x - sin x) dx = [sin x + cos x] = (1/sqrt(2) + 1/sqrt(2)) - 1 = sqrt(2) - 1.</explanation></question>
        <question>
            <text>Area between y = x^2 and y = 2 - x^2 is:</text>
            <option id="A">8/3</option><option id="B">16/3</option><option id="C">4/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at x = 1, -1. Integral -1 to 1 (2 - 2x^2) dx = 4 - 4/3 = 8/3.</explanation></question>
        <question>
            <text>Area of smaller part of x^2 + y^2 = 4 bounded by line x = 1:</text>
            <option id="A">4pi/3 - sqrt(3)</option><option id="B">pi/3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard segment integral.</explanation></question>
        <question>
            <text>Area of region bounded by y = sqrt(x) and y = x^2 is:</text>
            <option id="A">1/3</option><option id="B">1/6</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to 1 (sqrt(x) - x^2) dx = 2/3 - 1/3 = 1/3.</explanation></question>
        <question>
            <text>Area bounded by y = x^2 + 1 and y = x + 1 is:</text>
            <option id="A">1/6</option><option id="B">1/3</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at x = 0, 1. Integral 0 to 1 (x+1 - (x^2+1)) dx = Integral (x - x^2) = 1/6.</explanation></question>
    </medium>
    <hard>
        <question>
            <text>Area common to x^2 + y^2 = 16 and y^2 = 6x is:</text>
            <option id="A">4/3 sqrt(3) + 16pi/3</option><option id="B">8/3 sqrt(3) + 16pi/3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intersection at x = 2. Area = 2 * [ Integral 0 to 2 sqrt(6x) dx + Integral 2 to 4 sqrt(16-x^2) dx ].</explanation></question>
        <question>
            <text>Area common to y^2 = x and x^2 + y^2 = 2 is:</text>
            <option id="A">pi/4 + 1/6</option><option id="B">pi/2 + 1/3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intersection at x = 1. Area = 2 * [ Integral 0 to 1 sqrt(x) dx + Integral 1 to sqrt(2) sqrt(2-x^2) dx ].</explanation></question>
        <question>
            <text>Area of region {(x, y) : y^2 &lt;= 4x, 4x^2 + 4y^2 &lt;= 9} (smaller part):</text>
            <option id="A">(sqrt(2) + 9pi/4)/6</option><option id="B">pi - 1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intersection at x = 1/2. Split integral at 1/2.</explanation></question>
        <question>
            <text>Area bounded by curvey y = sin x and y = cos x for x in [0, pi] is:</text>
            <option id="A">2 sqrt(2)</option><option id="B">sqrt(2)</option><option id="C">2</option><option id="D">None</option>
            <answer>A</answer><explanation>Integral 0 to pi/4 (cos - sin) + Integral pi/4 to pi (sin - cos) = (sqrt(2)-1) + (sqrt(2)+1) = 2 sqrt(2).</explanation></question>
        <question>
            <text>The area of the region bounded by y = sqrt(16 - x^2) and y = 0 is:</text>
            <option id="A">8pi</option><option id="B">16pi</option><option id="C">4pi</option><option id="D">None</option>
            <answer>A</answer><explanation>Semi-circle of radius 4. Area = 1/2 * pi * 16 = 8pi.</explanation></question>
        <question>
            <text>Find the area of the region {(x, y) : 0 &lt;= y &lt;= x^2 + 1, 0 &lt;= y &lt;= x + 1, 0 &lt;= x &lt;= 2}:</text>
            <option id="A">23/6</option><option id="B">4</option><option id="C">3</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection at x=0, 1. Area = Integral 0 to 1 (x^2+1) dx + Integral 1 to 2 (x+1) dx = 4/3 + 2.5 = 23/6.</explanation></question>
        <question>
            <text>Area of region cut off from parabola y^2 = 4ax by line y = mx:</text>
            <option id="A">8a^2 / (3m^3)</option><option id="B">4a^2 / (3m^3)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard result for parabola-line area.</explanation></question>
        <question>
            <text>Area bounded by y^2 = 4ax and line x = a is divided into two equal parts by x = b. Then b = :</text>
            <option id="A">a / 4^{1/3}</option><option id="B">a / 2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Integral 0 to b = 1/2 Integral 0 to a -&gt; b^{3/2} = 1/2 a^{3/2}.</explanation></question>
        <question>
            <text>Area of region {(x, y) : x^2/a^2 + y^2/b^2 &lt;= 1 &lt;= x/a + y/b}:</text>
            <option id="A">ab(pi/4 - 1/2)</option><option id="B">ab(pi/2 - 1)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Area of quadrant of ellipse - area of triangle.</explanation></question>
        <question>
            <text>The area of the region bounded by y^2 = 4x, y = 2x - 4 and x-axis in fourth quadrant is:</text>
            <option id="A">1/3</option><option id="B">2/3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Intersection calculations and limit selection.</explanation></question>
        <question>
            <text>Area common to y^2 = 4ax and x^2 = 4ay is 16/3. If area is 1, then a = :</text>
            <option id="A">sqrt(3)/4</option><option id="B">3/4</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Area = 16a^2/3. Set equal to 1 -&gt; a^2 = 3/16.</explanation></question>
        <question>
            <text>Area bounded by curves y = sin x and y = cos x and y-axis is:</text>
            <option id="A">sqrt(2) - 1</option><option id="B">1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Integral 0 to pi/4 (cos x - sin x) dx.</explanation></question>
        <question>
            <text>Area of region bounded by x^2 = 4y and line x = 2:</text>
            <option id="A">2/3</option><option id="B">1/3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Integral 0 to 2 x^2/4 dx = [x^3/12] = 8/12 = 2/3.</explanation></question>
        <question>
            <text>Area of region bounded by lines y = 2x+1, y = 3x+1 and x = 4:</text>
            <option id="A">8</option><option id="B">12</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Integral 0 to 4 (x) dx = 8.</explanation></question>
        <question>
            <text>Area of shaded region in ellipse if minor axis is doubled and major axis is halved:</text>
            <option id="A">Remains same</option><option id="B">Doubled</option><option id="C">Halved</option><option id="D">None</option>
            <answer>A</answer><explanation>Area pi a b becomes pi (a/2) (2b) = pi a b.</explanation></question>
        <question>
            <text>Area of the region bounded by x^2 = 4y, y = 1 and y = 4 in the first quadrant:</text>
            <option id="A">28/3</option><option id="B">14/3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Integral 1 to 4 2 sqrt(y) dy = 4/3(8-1) = 28/3.</explanation></question>
        <question>
            <text>Area between y = x^2 and y^2 = x is always ____ the area of unit square:</text>
            <option id="A">1/3 of</option><option id="B">1/6 of</option><option id="C">1/2 of</option><option id="D">None</option>
            <answer>A</answer><explanation>Result 1/3.</explanation></question>
        <question>
            <text>Area of region enclosed between y = sin x and y = cos x from x=pi/4 to x=5pi/4:</text>
            <option id="A">2 sqrt(2)</option><option id="B">sqrt(2)</option><option id="C">2</option><option id="D">None</option>
