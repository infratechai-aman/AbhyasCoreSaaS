        <question>
            <text>Area of region common to y = x^2 and y = |x|:</text>
            <option id="A">1/3</option><option id="B">1/6</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 * (1/2 - 1/3) = 1/3.</explanation></question>
        <question>
            <text>Area bounded by y = sin 2x, y = cos 2x and y-axis in first quadrant:</text>
