            <answer>A</answer><explanation>Symmetry property.</explanation></question>
        <question>
            <text>Ratio of areas bounded by y^2 = 4ax and x^2 = 4ay to area of square side 4a:</text>
            <option id="A">1/3</option><option id="B">1/6</option><option id="C">2/3</option><option id="D">None</option>
