<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Chemistry" id="203" name="Chemical Bonding and Molecular Structure">
    <easy>
        <question>
            <text>Attractive force that holds various constituents together is called ____.</text>
            <option id="A">Chemical bond</option><option id="B">Nuclear force</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Enables formation of stable compounds.</explanation></question>
        <question>
            <text>Atoms combine to achieve a stable configuration of ____ valence electrons (Octet Rule).</text>
            <option id="A">8</option><option id="B">2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Similar to noble gas configuration.</explanation></question>
        <question>
            <text>Kossel and Lewis proposed the ____ theory of valence.</text>
            <option id="A">Electronic</option><option id="B">Nuclear</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Based on electron sharing/transfer.</explanation></question>
        <question>
            <text>A bond formed by complete transfer of electrons is ____.</text>
            <option id="A">Ionic / Electrovalent</option><option id="B">Covalent</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Occurs between metal and non-metal.</explanation></question>
        <question>
            <text>A bond formed by mutual sharing of electrons is ____.</text>
            <option id="A">Covalent</option><option id="B">Ionic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Common between non-metals.</explanation></question>
        <question>
            <text>Lewis structure uses ____ to represent valence electrons.</text>
            <option id="A">Dots</option><option id="B">Lines</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lewis dot symbols.</explanation></question>
        <question>
            <text>Number of valence electrons in Chlorine is ____.</text>
            <option id="A">7</option><option id="B">17</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Halogen group 17.</explanation></question>
        <question>
            <text>Number of valence electrons in Carbon is ____.</text>
            <option id="A">4</option><option id="B">6</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Group 14 element.</explanation></question>
        <question>
            <text>Octet rule exception: PCL5 has ____ electrons around P.</text>
            <option id="A">10 (Expanded octet)</option><option id="B">8</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>P belongs to 3rd period, has d-orbitals.</explanation></question>
        <question>
            <text>Octet rule exception: BF3 has ____ electrons around B.</text>
            <option id="A">6 (Incomplete octet)</option><option id="B">8</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Electron deficient compound.</explanation></question>
        <question>
            <text>Energy required to break one mole of bonds is bond ____.</text>
            <option id="A">Enthalpy</option><option id="B">Length</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Measures bond strength.</explanation></question>
        <question>
            <text>Equilibrium distance between nuclei of two bonded atoms is bond ____.</text>
            <option id="A">Length</option><option id="B">Angle</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Varies with bond order.</explanation></question>
        <question>
            <text>Bond angle in Water (H2O) is approx ____ degrees.</text>
            <option id="A">104.5</option><option id="B">109.5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Bent shape due to lone pair repulsion.</explanation></question>
        <question>
            <text>Bond angle in Ammonia (NH3) is approx ____ degrees.</text>
            <option id="A">107</option><option id="B">109.5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Pyramidal shape.</explanation></question>
        <question>
            <text>Bond angle in Methane (CH4) is ____ degrees.</text>
            <option id="A">109.5</option><option id="B">120</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Perfect tetrahedral angle.</explanation></question>
        <question>
            <text>Polarity of a molecule is measured by its ____ moment.</text>
            <option id="A">Dipole</option><option id="B">Magnetic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Product of charge and distance.</explanation></question>
        <question>
            <text>Dipole moment of CO2 is ____.</text>
            <option id="A">Zero</option><option id="B">High</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Linear molecule with opposing dipoles.</explanation></question>
        <question>
            <text>VSEPR theory stands for Valence Shell Electron Pair ____ theory.</text>
            <option id="A">Repulsion</option><option id="B">Rotation</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Predicts molecular geometry.</explanation></question>
        <question>
            <text>Repulsion order: Lone Pair (LP) - LP ____ LP - Bond Pair (BP) ____ BP - BP.</text>
            <option id="A">&gt; , &gt;</option><option id="B">&lt; , &lt;</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Lone pairs require more space.</explanation></question>
        <question>
            <text>Geometry of CO2 is ____.</text>
            <option id="A">Linear</option><option id="B">Bent</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>sp hybridization.</explanation></question>
        <question>
            <text>Geometry of BF3 is ____.</text>
            <option id="A">Trigonal Planar</option><option id="B">Pyramidal</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>sp2 hybridization.</explanation></question>
        <question>
            <text>Geometry of NH3 is ____.</text>
            <option id="A">Pyramidal</option><option id="B">Tetrahedral</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>One LP, Three BPs.</explanation></question>
        <question>
            <text>Mixing of atomic orbitals to form new equivalent orbitals is ____.</text>
            <option id="A">Hybridization</option><option id="B">Overlap</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Explains bond angles and shapes.</explanation></question>
        <question>
            <text>Hybridization of Carbon in Diamond is ____.</text>
            <option id="A">sp3</option><option id="B">sp2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Tetrahedral network.</explanation></question>
        <question>
            <text>Hybridization of Carbon in Graphite is ____.</text>
            <option id="A">sp2</option><option id="B">sp3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Hexagonal layers.</explanation></question>
        <question>
            <text>A bond formed by Head-on overlap of orbitals is ____ bond.</text>
            <option id="A">Sigma (σ)</option><option id="B">Pi (π)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Stronger than pi bond.</explanation></question>
        <question>
            <text>A bond formed by Lateral / Sideways overlap of orbitals is ____ bond.</text>
            <option id="A">Pi (π)</option><option id="B">Sigma (σ)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Found in double and triple bonds.</explanation></question>
        <question>
            <text>Total number of bonds in Ethyne (C2H2) is ____ sigma and ____ pi.</text>
            <option id="A">3 , 2</option><option id="B">2, 3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>H-C≡C-H. (C-C sig + 2 C-H sig = 3).</explanation></question>
        <question>
            <text>Oxygen molecule (O2) contains a ____ bond.</text>
            <option id="A">Double</option><option id="B">Single</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>One sigma, one pi.</explanation></question>
        <question>
            <text>Nitrogen molecule (N2) contains a ____ bond.</text>
            <option id="A">Triple</option><option id="B">Double</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>One sigma, two pi.</explanation></question>
        <question>
            <text>Paramagnetic nature of O2 was explained by ____ theory.</text>
            <option id="A">Molecular Orbital (MOT)</option><option id="B">Valence Bond (VBT)</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to two unpaired electrons in antibonding.</explanation></question>
        <question>
            <text>In MOT, BMO stands for ____ Molecular Orbital.</text>
            <option id="A">Bonding</option><option id="B">Basic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Lower energy, higher stability.</explanation></question>
        <question>
            <text>In MOT, ABMO stands for ____ Molecular Orbital.</text>
            <option id="A">Antibonding</option><option id="B">Active</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Higher energy, lower stability.</explanation></question>
        <question>
            <text>Bond order = 1/2 [ (Electrons in BMO) - (____) ].</text>
            <option id="A">Electrons in ABMO</option><option id="B">Electrons in total</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>N_b - N_a formula.</explanation></question>
        <question>
            <text>Bond order of Nitrogen (N2) is ____.</text>
            <option id="A">3</option><option id="B">2</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Extremely stable triple bond.</explanation></question>
        <question>
            <text>Attractive force between Hydrogen and electronegative atom (F, O, N) is ____.</text>
            <option id="A">Hydrogen bond</option><option id="B">Ionic bond</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Strongest intermolecular force.</explanation></question>
        <question>
            <text>Water is liquid at room temp due to ____ bonding.</text>
            <option id="A">Hydrogen</option><option id="B">Covalent</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Elevates boiling point compared to H2S.</explanation></question>
        <question>
            <text>Fajan’s Rule deals with ____ character in ionic bonds.</text>
            <option id="A">Covalent</option><option id="B">Magnetic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Polarization of anion by cation.</explanation></question>
        <question>
            <text>Lattice Enthalpy is the energy released during formation of 1 mole of ionic solid from ____.</text>
            <option id="A">Gaseous ions</option><option id="B">Solid elements</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>A measure of ionic bond strength.</explanation></question>
        <question>
            <text>A molecule with zero dipole moment must be ____.</text>
            <option id="A">Symmetrical</option><option id="B">Polar</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Resultant vector sum is zero.</explanation></question>
    </easy>
    <medium>
        <question>
            <text>Hybridization of Xenon in XeF2 is ____.</text>
            <option id="A">sp3d</option><option id="B">sp3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 BP + 3 LP. Geometry Linear.</explanation></question>
        <question>
            <text>Hybridization of Phosphorus in PCl5 is ____.</text>
            <option id="A">sp3d</option><option id="B">sp3</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Trigonal Bipyramidal shape.</explanation></question>
        <question>
            <text>Hybridization of Sulfur in SF6 is ____.</text>
            <option id="A">sp3d2</option><option id="B">sp3d</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Octahedral shape.</explanation></question>
        <question>
            <text>Formal charge on central Oxygen in Ozone (O3) is ____.</text>
            <option id="A">+1</option><option id="B">0</option><option id="C">-1</option><option id="D">None</option>
            <answer>A</answer><explanation>V-L-1/2B formula.</explanation></question>
        <question>
            <text>Bond length in O2, O2+, O2- in increasing order: ____.</text>
            <option id="A">O2+ &lt; O2 &lt; O2-</option><option id="B">O2- &lt; O2 &lt; O2+</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Inversely proportional to bond order (2.5, 2.0, 1.5).</explanation></question>
        <question>
            <text>Which of the following is diamagnetic?</text>
            <option id="A">N2</option><option id="B">O2</option><option id="C">B2</option><option id="D">None</option>
            <answer>A</answer><explanation>All electrons are paired in N2 MOs.</explanation></question>
        <question>
            <text>Hybridization in IF7 is ____.</text>
            <option id="A">sp3d3</option><option id="B">sp3d2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Pentagonal Bipyramidal.</explanation></question>
        <question>
            <text>Isoelectronic with ClO2- ? ____.</text>
            <option id="A">ClF2+ (20 valence electrons + charge? no. 7+14+1 = 22. 7+14-1=20. ClO2- is 7+12+1 = 20.)</option><option id="B">OF2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Matches valence electron count.</explanation></question>
        <question>
            <text>Shape of ClF3 is ____.</text>
            <option id="A">T-shaped</option><option id="B">Trigonal Planar</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>sp3d with 2 lone pairs at equatorial.</explanation></question>
        <question>
            <text>Bond order for He2 is ____.</text>
            <option id="A">0</option><option id="B">1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equal electrons in BMO and ABMO. Doesn't exist.</explanation></question>
        <question>
            <text>Percentage s-character in sp, sp2, sp3 is ____.</text>
            <option id="A">50% , 33% , 25%</option><option id="B">25% , 33% , 50%</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Linear has most s-character.</explanation></question>
        <question>
            <text>High s-character leads to ____ electronegativity of the hybrid orbital.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Electrons closer to nucleus.</explanation></question>
        <question>
            <text>Dipole moment of NF3 is ____ than NH3.</text>
            <option id="A">Lower</option><option id="B">Higher</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>In NF3, lone pair and N-F dipoles oppose. In NH3 they assist.</explanation></question>
        <question>
            <text>Fajan's rule: Small ____ and Large ____ favor covalent character.</text>
            <option id="A">Cation , Anion</option><option id="B">Anion, Cation</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Better polarization.</explanation></question>
        <question>
            <text>Ortho-nitrophenol shows ____ Hydrogen bonding.</text>
            <option id="A">Intramolecular</option><option id="B">Intermolecular</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Bond within the same molecule.</explanation></question>
        <question>
            <text>Para-nitrophenol shows ____ Hydrogen bonding.</text>
            <option id="A">Intermolecular</option><option id="B">Intramolecular</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Bond between different molecules.</explanation></question>
        <question>
            <text>Which has higher boiling point: o-nitrophenol or p-nitrophenol?</text>
            <option id="A">p-nitrophenol</option><option id="B">o-nitrophenol</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Intermolecular H-bonding increases association.</explanation></question>
        <question>
            <text>Maximum number of H-bonds a water molecule can form is ____.</text>
            <option id="A">4</option><option id="B">2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 through H, 2 through lone pairs on O.</explanation></question>
        <question>
            <text>Density of ice is ____ than water due to open cage structure.</text>
            <option id="A">Lower</option><option id="B">Higher</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Ice floats.</explanation></question>
        <question>
            <text>Structure of [BeF4]2- is ____.</text>
            <option id="A">Tetrahedral</option><option id="B">Square Planar</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>sp3 hybridization of Be.</explanation></question>
        <question>
            <text>Hybridization of Al in AlCl3 (dimer Al2Cl6) in gas phase? ____.</text>
            <option id="A">sp3</option><option id="B">sp2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Bridged structure.</explanation></question>
        <question>
            <text>Bonding in Metallic solids is explained by ____ theory.</text>
            <option id="A">Electron Sea / Band</option><option id="B">VBT</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Delocalized electrons.</explanation></question>
        <question>
            <text>Overlap of pz and pz along internuclear axis (z) gives ____ bond.</text>
            <option id="A">Sigma</option><option id="B">Pi</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Direct overlap.</explanation></question>
        <question>
            <text>Overlap of px and px along internuclear axis (z) gives ____ bond.</text>
            <option id="A">Pi</option><option id="B">Sigma</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Parallel side-by-side overlap.</explanation></question>
        <question>
            <text>Bond order of Oxygen molecule O2 is ____.</text>
            <option id="A">2</option><option id="B">2.5</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Double bond.</explanation></question>
        <question>
            <text>Resonance structures differ in position of ____.</text>
            <option id="A">Electrons (Pi/Lone pairs)</option><option id="B">Atoms</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Nuclei remain fixed.</explanation></question>
        <question>
            <text>Resonance hybrid has ____ energy than any canonical form.</text>
            <option id="A">Lower (more stable)</option><option id="B">Higher</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Stability gained by delocalization.</explanation></question>
        <question>
            <text>Equatorial bonds in PCl5 are ____ than axial bonds.</text>
            <option id="A">Shorter</option><option id="B">Longer</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Axial bonds suffer more repulsion.</explanation></question>
        <question>
            <text>Which of the following does not exist? ____.</text>
            <option id="A">NF5</option><option id="B">PCl5</option><option id="C">SF6</option><option id="D">None</option>
            <answer>A</answer><explanation>Nitrogen lacks d-orbitals to expand octet.</explanation></question>
        <question>
            <text>The angle between two sp2 hybrid orbitals is ____.</text>
            <option id="A">120</option><option id="B">180</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Standard planar triangle.</explanation></question>
        <question>
            <text>Bond angle in H2S is ____ than H2O.</text>
            <option id="A">Smaller (approx 92)</option><option id="B">Larger</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Decreased electronegativity of central atom (Drago's? simplified: less repulsion).</explanation></question>
        <question>
            <text>Molecule with highest bond enthalpy: H2, F2, Cl2, N2?</text>
            <option id="A">N2</option><option id="B">H2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Triple bond is very strong.</explanation></question>
        <question>
            <text>Isoelectronic with CO: ____.</text>
            <option id="A">CN- (14 electrons)</option><option id="B">O2+</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Both have 14 electrons.</explanation></question>
        <question>
            <text>Species with bond order 0.5? ____.</text>
            <option id="A">H2+</option><option id="B">He2+</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>1/2 (1 - 0).</explanation></question>
        <question>
            <text>Non-linear molecule among: CO2, BeCl2, SnCl2, HgCl2?</text>
            <option id="A">SnCl2 (Bent due to lone pair)</option><option id="B">CO2</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Group 14 element with 1 lone pair remaining.</explanation></question>
        <question>
            <text>Lattice energy of NaCl is ____ than KCl.</text>
            <option id="A">Higher</option><option id="B">Lower</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Na+ is smaller than K+, stronger attraction.</explanation></question>
        <question>
            <text>Solubility of ionic compounds in organic solvents is ____.</text>
            <option id="A">Low</option><option id="B">High</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Like dissolves like (organic is non-polar).</explanation></question>
        <question>
            <text>Percent ionic character = 16 |xA - xB| + 3.5 |xA - xB|^2. This is ____ equation.</text>
            <option id="A">Hannay-Smith</option><option id="B">Pauling</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Empirical relation for ionic character.</explanation></question>
        <question>
            <text>A triple bond contains ____ sigma and ____ pi components.</text>
            <option id="A">1 , 2</option><option id="B">2, 1</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Always one core sigma bond.</explanation></question>
        <question>
            <text>Bond length of C-C in Benzene is ____.</text>
            <option id="A">Intermediate between C-C and C=C</option><option id="B">Shortest</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Equalized due to resonance (~1.39 A).</explanation></question>
    </medium>
    <hard>
        <question>
            <text>Symmetry of MOs: A ____ orbital is symmetrical about internuclear axis.</text>
            <option id="A">Sigma</option><option id="B">Pi</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Rotation does not change phase.</explanation></question>
        <question>
            <text>Symmetry of MOs: A ____ orbital has a nodal plane containing internuclear axis.</text>
            <option id="A">Pi</option><option id="B">Sigma</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard lateral overlap property.</explanation></question>
        <question>
