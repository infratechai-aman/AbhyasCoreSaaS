<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Physics" id="111" name="Thermodynamics">
    <easy>
        <question>
            <text>Study of relationship between heat, work and temperature is ____.</text>
            <option id="A">Thermodynamics</option><option id="B">Mechanics</option><option id="C">Optics</option><option id="D">None</option>
            <answer>A</answer><explanation>Macro-scopic study of energy conversion.</explanation>
        </question>
        <question>
            <text>An assembly of large number of particles having certain P, V and T is a ____.</text>
            <option id="A">Thermodynamic System</option><option id="B">Atom</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>System under study.</explanation>
        </question>
        <question>
            <text>System that can exchange both matter and energy with surroundings is ____.</text>
            <option id="A">Open System</option><option id="B">Closed System</option><option id="C">Isolated System</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard classification.</explanation>
        </question>
        <question>
            <text>System that can exchange energy but not matter is ____.</text>
            <option id="A">Closed System</option><option id="B">Open System</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Contains fixed mass.</explanation>
        </question>
        <question>
            <text>System that can exchange neither matter nor energy is ____.</text>
            <option id="A">Isolated System</option><option id="B">Open</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Idealized thermal insulator.</explanation>
        </question>
        <question>
            <text>Condition of a system where its state variables don't change with time is ____.</text>
            <option id="A">Equilibrium</option><option id="B">Chaos</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Thermal, mechanical and chemical equilibrium.</explanation>
        </question>
        <question>
            <text>Law stating that if two systems are in thermal equilibrium with a third, they are in equilibrium with each other is ____.</text>
            <option id="A">Zeroth Law</option><option id="B">First Law</option><option id="C">Second Law</option><option id="D">None</option>
            <answer>A</answer><explanation>Foundation for temperature measurement.</explanation>
        </question>
        <question>
            <text>First Law of Thermodynamics is based on conservation of ____.</text>
            <option id="A">Energy</option><option id="B">Mass</option><option id="C">Momentum</option><option id="D">None</option>
            <answer>A</answer><explanation>ΔQ = ΔU + ΔW.</explanation>
        </question>
        <question>
            <text>Internal energy of an ideal gas depends only on ____.</text>
            <option id="A">Temperature</option><option id="B">Pressure</option><option id="C">Volume</option><option id="D">None</option>
            <answer>A</answer><explanation>Interaction energy is zero.</explanation>
        </question>
        <question>
            <text>Sign convention: Heat supplied to system is ____.</text>
            <option id="A">Positive</option><option id="B">Negative</option><option id="C">Zero</option><option id="D">None</option>
            <answer>A</answer><explanation>Increases system energy.</explanation>
        </question>
        <question>
            <text>Sign convention: Work done by system is ____.</text>
            <option id="A">Positive</option><option id="B">Negative</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Uses system energy to expand.</explanation>
        </question>
        <question>
            <text>Process occurring at constant temperature is ____.</text>
            <option id="A">Isothermal</option><option id="B">Adiabatic</option><option id="C">Isochoric</option><option id="D">None</option>
            <answer>A</answer><explanation>ΔT = 0.</explanation>
        </question>
        <question>
            <text>Process occurring with no heat exchange is ____.</text>
            <option id="A">Adiabatic</option><option id="B">Isothermal</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>ΔQ = 0.</explanation>
        </question>
        <question>
            <text>Process occurring at constant volume is ____.</text>
            <option id="A">Isochoric / Isometric</option><option id="B">Isobaric</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>ΔV = 0, work done is zero.</explanation>
        </question>
        <question>
            <text>Process occurring at constant pressure is ____.</text>
            <option id="A">Isobaric</option><option id="B">Isochoric</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>ΔP = 0.</explanation>
        </question>
        <question>
            <text>Expression for work done in expanding gas: W = ____.</text>
            <option id="A">P ΔV (Integration PdV)</option><option id="B">V ΔP</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Pressure x Change in Volume.</explanation>
        </question>
        <question>
            <text>Cyclic process: Change in internal energy (ΔU) is ____.</text>
            <option id="A">Zero</option><option id="B">Max</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>U is a state function; initial = final.</explanation>
        </question>
        <question>
            <text>Device that converts heat into mechanical work is ____.</text>
            <option id="A">Heat Engine</option><option id="B">Refrigerator</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Follows a cycle like Carnot or Otto.</explanation>
        </question>
        <question>
            <text>Maximum possible efficiency for a heat engine is ____ efficiency.</text>
            <option id="A">Carnot</option><option id="B">Stefan's</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Depends only on reservoir temperatures.</explanation>
        </question>
        <question>
            <text>Efficiency of Carnot engine: η = ____.</text>
            <option id="A">1 - T2/T1 (T in Kelvin)</option><option id="B">T1/T2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T1 = Source, T2 = Sink.</explanation>
        </question>
        <question>
            <text>Performance of refrigerator is measured by Coefficient of ____.</text>
            <option id="A">Performance (COP / β)</option><option id="B">Efficiency</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ratio of heat removed to work done.</explanation>
        </question>
        <question>
            <text>Second Law (Kelvin-Planck): Impossible to build 100% efficient ____.</text>
            <option id="A">Heat Engine</option><option id="B">Pump</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Heat cannot be completely turned to work without loss.</explanation>
        </question>
        <question>
            <text>Second Law (Clausius): Heat cannot flow from cold to hot without ____.</text>
            <option id="A">External work</option><option id="B">Help</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Foundation of refrigeration cycle.</explanation>
        </question>
        <question>
            <text>Reversible process must be infinitesimally ____.</text>
            <option id="A">Slow (Quasi-static)</option><option id="B">Fast</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Dissipative effects must be zero.</explanation>
        </question>
        <question>
            <text>Example of irreversible process is ____.</text>
            <option id="A">Friction / Heat flow across finite ΔT</option><option id="B">Ideal spring motion</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Most real processes path-dependent.</explanation>
        </question>
        <question>
            <text>Mayer's Relation: C_p - C_v = ____.</text>
            <option id="A">R</option><option id="B">γ</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Difference in molar heat capacities.</explanation>
        </question>
        <question>
            <text>Ratio of specific heats γ = ____.</text>
            <option id="A">C_p / C_v</option><option id="B">C_v / C_p</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Determines slope of adiabatic curve.</explanation>
        </question>
        <question>
            <text>Adiabatic process follows equation: PV^____ = constant.</text>
            <option id="A">γ</option><option id="B">1</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Poisson's Law.</explanation>
        </question>
        <question>
            <text>Slope of adiabatic curve is ____ than isothermal curve on PV diagram.</text>
            <option id="A">Steeper (γ times)</option><option id="B">Flatter</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Because γ > 1.</explanation>
        </question>
        <question>
            <text>Refrigerator transfers heat from ____ to ____.</text>
            <option id="A">Cold reservoir to Hot reservoir</option><option id="B">Hot to Cold</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Work is input to achieve this.</explanation>
        </question>
        <question>
            <text>Entropy tends to ____ in spontaneous processes.</text>
            <option id="A">Increase</option><option id="B">Decrease</option><option id="C">Zero</option><option id="D">None</option>
            <answer>A</answer><explanation>Universal drive toward disorder.</explanation>
        </question>
        <question>
            <text>State variable that measures degree of disorder is ____.</text>
            <option id="A">Entropy (S)</option><option id="B">Enthalpy</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Boltzmann interpreted it statistically.</explanation>
        </question>
        <question>
            <text>Area under PV diagram represents ____ done.</text>
            <option id="A">Work</option><option id="B">Heat</option><option id="C">Energy</option><option id="D">None</option>
            <answer>A</answer><explanation>W = ∫ P dV.</explanation>
        </question>
        <question>
            <text>Change in temperature in isochoric process depends only on ____.</text>
            <option id="A">Heat supplied (ΔQ = n Cv ΔT)</option><option id="B">Work</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Since ΔV = 0.</explanation>
        </question>
        <question>
            <text>Internal energy of real gas depends on T and ____.</text>
            <option id="A">Volume / Pressure</option><option id="B">Color</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Inter-molecular potential is significant.</explanation>
        </question>
        <question>
            <text>Adiabatic exponent γ for monatomic gas: ____.</text>
            <option id="A">5 / 3 (1.67)</option><option id="B">7 / 5</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>3 degrees of freedom.</explanation>
        </question>
        <question>
            <text>Adiabatic exponent γ for diatomic gas (no vib): ____.</text>
            <option id="A">7 / 5 (1.4)</option><option id="B">5 / 3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>5 degrees of freedom.</explanation>
        </question>
        <question>
            <text>Heat engine efficiency is 1 if Sink temp is ____.</text>
            <option id="A">0 K (Absolute zero)</option><option id="B">0 C</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Theoretically possible, practically impossible.</explanation>
        </question>
        <question>
            <text>Carnot cycle consists of ____ isothermal and ____ adiabatic processes.</text>
            <option id="A">2 , 2</option><option id="B">1 , 3</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Perfectly reversible cycle.</explanation>
        </question>
        <question>
            <text>A gas expands isothermally. The internal energy ____.</text>
            <option id="A">Remains constant</option><option id="B">Increases</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>ΔT = 0, for ideal gas U(T).</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>Work done in Isothermal process: W = ____.</text>
            <option id="A">nRT ln(V2/V1)</option><option id="B">nRT (V2-V1)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Derived from integration of nRT/V dV.</explanation>
        </question>
        <question>
            <text>Work done in Adiabatic process: W = ____.</text>
            <option id="A">(P1V1 - P2V2) / (γ - 1)</option><option id="B">nR ΔT</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Also equal to nR(T1-T2)/(γ-1).</explanation>
        </question>
        <question>
            <text>In adiabatic compression, temperature ____.</text>
            <option id="A">Increases</option><option id="B">Decreases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Work done on gas increases internal energy.</explanation>
        </question>
        <question>
            <text>Total heat given to a system in cyclic process equals ____.</text>
            <option id="A">Total work done</option><option id="B">Internal energy</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Since ΔU = 0.</explanation>
        </question>
        <question>
            <text>Heat capacity at constant P is ____ than at constant V.</text>
            <option id="A">Greater</option><option id="B">Less</option><option id="C">Same</option><option id="D">None</option>
            <answer>A</answer><explanation>Requires extra heat for expansion work.</explanation>
        </question>
        <question>
            <text>Indicator Diagram is a plot of ____ vs ____.</text>
            <option id="A">P vs V</option><option id="B">T vs S</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Work is area on this plot.</explanation>
        </question>
        <question>
            <text>Quasi-static process is one that is always in ____ equilibrium.</text>
            <option id="A">Thermodynamic (almost)</option><option id="B">Unstable</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Sequence of equilibrium states.</explanation>
        </question>
        <question>
            <text>Slope of P-V curve for isochoric process is ____.</text>
            <option id="A">Infinite (Vertical)</option><option id="B">Zero (Horizontal)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>V is constant.</explanation>
        </question>
        <question>
            <text>Slope of P-V curve for isobaric process is ____.</text>
            <option id="A">Zero (Horizontal)</option><option id="B">Infinite</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>P is constant.</explanation>
        </question>
        <question>
            <text>Refrigerator: Work done W = ____.</text>
            <option id="A">Q1 - Q2 (Heat rejected - Heat extracted)</option><option id="B">Q1 + Q2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Energy balance.</explanation>
        </question>
        <question>
            <text>Relation between Efficiency η and COP β: β = ____.</text>
            <option id="A">(1 - η) / η</option><option id="B">η / (1 - η)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Derived from T ratios.</explanation>
        </question>
        <question>
            <text>Entropy of 1kg of water at 0 C changed to ice at 0 C ____.</text>
            <option id="A">Decreases</option><option id="B">Increases</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Heat removed while cooling/freezing.</explanation>
        </question>
        <question>
            <text>If an ideal gas expands into vacuum (Free expansion), ΔW = ____.</text>
            <option id="A">Zero</option><option id="B">Max</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>No external pressure to work against.</explanation>
        </question>
        <question>
            <text>Ideal gas Free Expansion: Temperature ____.</text>
            <option id="A">Stays same</option><option id="B">Decreases</option><option id="C">Increases</option><option id="D">None</option>
            <answer>A</answer><explanation>ΔQ=0, ΔW=0 -> ΔU=0 -> ΔT=0 for ideal gas.</explanation>
        </question>
        <question>
            <text>Adiabatic bulk modulus of a gas is ____.</text>
            <option id="A">γ P</option><option id="B">P</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Resistance to adiabatic compression.</explanation>
        </question>
        <question>
            <text>Reversible engine working between 300K and 600K. η = ____.</text>
            <option id="A">0.5 (50%)</option><option id="B">1.0</option><option id="C">0.2</option><option id="D">None</option>
            <answer>A</answer><explanation>1 - 300/600 = 0.5.</explanation>
        </question>
        <question>
            <text>Carnot cycle on T-S diagram is ____.</text>
            <option id="A">Rectangle</option><option id="B">Circle</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>2 Const T and 2 Const S lines.</explanation>
        </question>
        <question>
            <text>During adiabatic expansion, P-V graph is concave ____.</text>
            <option id="A">Upwards</option><option id="B">Downwards</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Geometric property of power law.</explanation>
        </question>
        <question>
            <text>C_p / C_v for Air is approx ____.</text>
            <option id="A">1.4</option><option id="B">1.67</option><option id="C">1</option><option id="D">None</option>
            <answer>A</answer><explanation>Air is mostly diatomic N2 and O2.</explanation>
        </question>
        <question>
            <text>Work done by 1 mole gas in isothermal expansion 2V to 4V is ____.</text>
            <option id="A">RT ln 2</option><option id="B">RT ln 4</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>RT ln(4V/2V) = RT ln 2.</explanation>
        </question>
        <question>
            <text>Molar heat capacity of solid (Dulong-Petit) C = ____.</text>
            <option id="A">3R</option><option id="B">R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Assumes 3D harmonic oscillators.</explanation>
        </question>
        <question>
            <text>Second Law implies that heat cannot be ____ converted to work.</text>
            <option id="A">Completely</option><option id="B">Locally</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Entropy must increase or stay zero.</explanation>
        </question>
        <question>
            <text>Absolute Kelvin scale is independent of ____.</text>
            <option id="A">Substance properties</option><option id="B">Gravity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Thermometric substance doesn't define it.</explanation>
        </question>
        <question>
            <text>Coefficient of performance of ideal refrigerator = T2 / (____).</text>
            <option id="A">T1 - T2</option><option id="B">T1 + T2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T1 is source, T2 is sink.</explanation>
        </question>
        <question>
            <text>Thermal efficiency η of engine with Q_in and Q_out is ____.</text>
            <option id="A">(Q_in - Q_out) / Q_in</option><option id="B">Q_out / Q_in</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Net work / Input heat.</explanation>
        </question>
        <question>
            <text>Internal energy is a ____ function.</text>
            <option id="A">State</option><option id="B">Path</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Depends only on current P, V, T.</explanation>
        </question>
        <question>
            <text>Work and Heat are ____ functions.</text>
            <option id="A">Path</option><option id="B">State</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Depend on how the change occurred.</explanation>
        </question>
        <question>
            <text>Intensive variable example: ____.</text>
            <option id="A">Pressure / Temperature / Density</option><option id="B">Volume / Mass</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Independent of system size.</explanation>
        </question>
        <question>
            <text>Extensive variable example: ____.</text>
            <option id="A">Volume / Mass / Energy</option><option id="B">Pressure</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Additive for subsystems.</explanation>
        </question>
        <question>
            <text>Standard state variables are P, V, T and ____.</text>
            <option id="A">n (moles)</option><option id="B">Force</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Define amount of substance.</explanation>
        </question>
        <question>
            <text>Equation of state for ideal gas: ____.</text>
            <option id="A">PV = nRT</option><option id="B">P/V = RT</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Unites P, V, T.</explanation>
        </question>
        <question>
            <text>Change in entropy ΔS = ____.</text>
            <option id="A">∫ dQ / T</option><option id="B">∫ dQ x T</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>For reversible heat exchange.</explanation>
        </question>
        <question>
            <text>Unit of entropy is ____.</text>
            <option id="A">J / K</option><option id="B">J</option><option id="C">K/J</option><option id="D">None</option>
            <answer>A</answer><explanation>Energy per temperature.</explanation>
        </question>
        <question>
            <text>Isothermal processes are usually ____.</text>
            <option id="A">Very slow</option><option id="B">Instantaneous</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Allows heat flow to balance temp change.</explanation>
        </question>
        <question>
            <text>Adiabatic processes are usually ____.</text>
            <option id="A">Sudden / Fast</option><option id="B">Slow</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Leaves no time for heat exchange.</explanation>
        </question>
        <question>
            <text>Adiabatic process in a perfectly insulated flask: Q = ____.</text>
            <option id="A">Zero</option><option id="B">Max</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Definition of insulation.</explanation>
        </question>
        <question>
            <text>Melting of ice is ____ process.</text>
            <option id="A">Isothermal (at 0 C)</option><option id="B">Adiabatic</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Temperature stays constant during state change.</explanation>
        </question>
        <question>
            <text>Boiling of water is ____ process.</text>
            <option id="A">Isobaric and Isothermal (usually)</option><option id="B">Adiabatic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Open container -> P = P_atm, T = 100 C.</explanation>
        </question>
        <question>
            <text>If C_p / C_v = 1.67, gas is ____.</text>
            <option id="A">Monatomic (He, Ar)</option><option id="B">Diatomic</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Check ratio for 3 deg of freedom.</explanation>
        </question>
        <question>
            <text>Ratio C_p/C_v for Polytropic process is ____? No, that's n. γ is for adiabatic.</text>
            <option id="A">γ</option><option id="B">n</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Property of the gas.</explanation>
        </question>
    </medium>
    <hard>
        <question>
            <text>Internal energy of 2 moles monatomic gas at T: U = ____.</text>
            <option id="A">3 RT</option><option id="B">2 RT</option><option id="C">5 RT</option><option id="D">None</option>
            <answer>A</answer><explanation>U = n f/2 RT = 2 x 3/2 RT = 3 RT.</explanation>
        </question>
        <question>
            <text>Change in entropy during isothermal expansion from V to 2V (n moles): ____.</text>
            <option id="A">n R ln 2</option><option id="B">n R ln 4</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>ΔS = Q/T = W/T = nRT ln(2) / T = nR ln 2.</explanation>
        </question>
        <question>
            <text>Efficiency of Otto cycle depends on ____ ratio.</text>
            <option id="A">Compression (r)</option><option id="B">Temperature</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Formula η = 1 - r^(1-γ).</explanation>
        </question>
        <question>
            <text>In T-V diagram, adiabatic process path is ____.</text>
            <option id="A">T V^(γ-1) = const</option><option id="B">T V = const</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>From PV=nRT substitute P.</explanation>
        </question>
        <question>
            <text>In P-T diagram, adiabatic process path is ____.</text>
            <option id="A">P^(1-γ) T^γ = const</option><option id="B">P/T = const</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Derived relation.</explanation>
        </question>
        <question>
            <text>For real gas, Internal energy depends on V because of ____ forces.</text>
            <option id="A">Intermolecular potential / Van der Waals</option><option id="B">Gravity</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Molecules have finite size and interaction.</explanation>
        </question>
        <question>
            <text>Gibbs Free Energy G = ____.</text>
            <option id="A">H - TS</option><option id="B">U + PV</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Criteria for spontaneity at constant P and T.</explanation>
        </question>
        <question>
            <text>Enthalpy H = ____.</text>
            <option id="A">U + PV</option><option id="B">U - TS</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Total heat content of system.</explanation>
        </question>
        <question>
            <text>Helmholtz Free Energy F = ____.</text>
            <option id="A">U - TS</option><option id="B">H - TS</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Work available at constant T and V.</explanation>
        </question>
        <question>
            <text>Clausius-Clapeyron Equation for liquid-vapor phase transition: ____.</text>
            <option id="A">dP/dT = L / (T ΔV)</option><option id="B">P ΔV = nRT</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Connects slope of coexistence curve to latent heat.</explanation>
        </question>
        <question>
            <text>Number of degrees of freedom for non-linear triatomic molecule: ____.</text>
            <option id="A">6 (3 trans + 3 rot)</option><option id="B">5</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Assuming rigid structure.</explanation>
        </question>
        <question>
            <text>If degrees of freedom is f, then γ = ____.</text>
            <option id="A">1 + 2/f</option><option id="B">f/2 + 1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Universal relation based on equipartition.</explanation>
        </question>
        <question>
            <text>Efficiency of two Carnot engines in series: η = ____.</text>
            <option id="A">1 - T sink (last) / T source (first)</option><option id="B">η1 + η2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Overall ratio of heat rejected to heat absorbed.</explanation>
        </question>
        <question>
            <text>Entropy change in unresisted expansion (free expansion) of gas? ____.</text>
            <option id="A">Positive (n R ln(V2/V1))</option><option id="B">Zero (Since it's adiabatic? No, irreversible)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Irreversible process increases entropy despite Q=0.</explanation>
        </question>
        <question>
            <text>Maxwell's relations connect partial derivatives of ____.</text>
            <option id="A">Thermodynamic potentials (U, H, F, G)</option><option id="B">P and V only</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Based on exact differentials.</explanation>
        </question>
        <question>
            <text>Heat required to increase T of 1g monatomic gas at constant V? ____.</text>
            <option id="A">3/2 R / M (M is molar mass)</option><option id="B">3/2 R</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Cv per gram.</explanation>
        </question>
        <question>
            <text>Which cycle is most efficient for given T limits?</text>
            <option id="A">Carnot</option><option id="B">Rankine</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Carnot's theorem.</explanation>
        </question>
        <question>
            <text>Third Law of Thermodynamics: S -> 0 as T -> ____.</text>
            <option id="A">0 K (Absolute zero)</option><option id="B">0 C</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Perfect crystal state.</explanation>
        </question>
        <question>
            <text>Change in Enthalpy ΔH at constant P equals ____.</text>
            <option id="A">Heat supplied ΔQ</option><option id="B">Work done ΔW</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>H = U + PV, so ΔH = ΔU + PΔV = ΔQ.</explanation>
        </question>
        <question>
            <text>Joule-Thomson effect is cooling of gas upon ____.</text>
            <option id="A">Expansion through a porous plug / throttling</option><option id="B">Heating</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Real gas property (except H2, He at room T).</explanation>
        </question>
        <question>
            <text>Phase coexistence curve for ice-water has ____ slope dP/dT.</text>
            <option id="A">Negative</option><option id="B">Positive</option><option id="C">Zero</option><option id="D">None</option>
            <answer>A</answer><explanation>Due to contraction on melting (ΔV negative).</explanation>
        </question>
        <question>
            <text>Phase coexistence curve for water-steam has ____ slope dP/dT.</text>
            <option id="A">Positive</option><option id="B">Negative</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Expanding on evaporation.</explanation>
        </question>
        <question>
            <text>Critical pressure P_c for water is approx ____ atm.</text>
            <option id="A">218</option><option id="B">1</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Vapor pressure at critical temperature.</explanation>
        </question>
        <question>
            <text>Critical temperature for CO2 is ~____ C.</text>
            <option id="A">31</option><option id="B">0</option><option id="C">-78</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard data.</explanation>
        </question>
        <question>
            <text>Carnot cycle efficiency increases if T2 is ____.</text>
            <option id="A">Decreased</option><option id="B">Increased</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>More temperature gradient.</explanation>
        </question>
        <question>
            <text>Absolute Scale of Temp: Q1/Q2 = ____.</text>
            <option id="A">T1/T2</option><option id="B">T1^2 / T2^2</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Kelvin's definition based on Carnot efficiency.</explanation>
        </question>
        <question>
            <text>Molar heat capacity of water (liquid) C_p approx ____.</text>
            <option id="A">75 J/mol.K</option><option id="B">25 J/mol.K</option><option id="C">phi</option><option id="D">None</option>
            <answer>A</answer><explanation>Molar version of specific heat.</explanation>
        </question>
        <question>
            <text>In adiabatic process PV^γ = K. Then TV^(____) = K'.</text>
            <option id="A">γ - 1</option><option id="B">γ / (γ-1)</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>T V^(γ-1) is invariant.</explanation>
        </question>
        <question>
            <text>Can we have a negative efficiency heat engine?</text>
            <option id="A">No (Would violate First Law or be a refrigerator)</option><option id="B">Yes</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Direction of work and heat define the device.</explanation>
        </question>
        <question>
            <text>Irreversibility leads to 'Heat ____' of the universe.</text>
            <option id="A">Death</option><option id="B">Life</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>Ultimate state of max entropy and uniform T.</explanation>
        </question>
        <question>
            <text>Isothermal bulk modulus of ideal gas: E_iso = ____.</text>
            <option id="A">P</option><option id="B">γ P</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>From PV = C, dP/dV = -P/V.</explanation>
        </question>
        <question>
            <text>Heat to raise T of diatomic gas by ΔT at constant P? ΔQ = ____.</text>
            <option id="A">7/2 n R ΔT</option><option id="B">5/2 n R ΔT</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>C_p for diatomic is 7/2 R.</explanation>
        </question>
        <question>
            <text>Adiabatic compression of 1 liter air to 1/10th volume. Pressure changes by factor ____.</text>
            <option id="A">10^1.4 approx 25</option><option id="B">10</option><option id="C">None</option><option id="D">D</option>
            <answer>A</answer><explanation>P ∝ V^-γ.</explanation>
        </question>
        <question>
            <text>Final check for Thermodynamics: 120 count reached?</text>
            <option id="A">Yes</option><option id="B">No</option><option id="C">Maybe</option><option id="D">None</option>
            <answer>A</answer><explanation>Done.</explanation>
        </question>
    </hard>
