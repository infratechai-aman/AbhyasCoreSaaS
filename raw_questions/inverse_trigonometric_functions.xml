<?xml version="1.0" encoding="UTF-8"?>
<chapter subject="Mathematics" id="202" name="Inverse Trigonometric Functions">
    <easy>
        <question>
            <text>The domain of sin^-1 x is ____.</text>
            <option id="A">[-1, 1]</option><option id="B">(-1, 1)</option><option id="C">R</option><option id="D">[-π/2, π/2]</option>
            <answer>A</answer><explanation>sin^-1 x is defined for values between -1 and 1 inclusive.</explanation>
        </question>
        <question>
            <text>The principal value branch range of sin^-1 x is ____.</text>
            <option id="A">[-π/2, π/2]</option><option id="B">[0, π]</option><option id="C">(-π/2, π/2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard principal value branch for sine inverse.</explanation>
        </question>
        <question>
            <text>The domain of cos^-1 x is ____.</text>
            <option id="A">[-1, 1]</option><option id="B">R</option><option id="C">[0, π]</option><option id="D">None</option>
            <answer>A</answer><explanation>Same as sin^-1 x since sine and cosine are bounded by ±1.</explanation>
        </question>
        <question>
            <text>The principal value branch range of cos^-1 x is ____.</text>
            <option id="A">[0, π]</option><option id="B">[-π/2, π/2]</option><option id="C">(0, π)</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard principal value branch for cosine inverse.</explanation>
        </question>
        <question>
            <text>The domain of tan^-1 x is ____.</text>
            <option id="A">R</option><option id="B">[-1, 1]</option><option id="C">(-π/2, π/2)</option><option id="D">None</option>
            <answer>A</answer><explanation>tangent function takes all real values.</explanation>
        </question>
        <question>
            <text>The principal value branch range of tan^-1 x is ____.</text>
            <option id="A">(-π/2, π/2)</option><option id="B">[-π/2, π/2]</option><option id="C">[0, π]</option><option id="D">None</option>
            <answer>A</answer><explanation>Exclude the endpoints where tangent is undefined.</explanation>
        </question>
        <question>
            <text>Value of sin^-1(1/2) is ____.</text>
            <option id="A">π/6</option><option id="B">π/3</option><option id="C">π/4</option><option id="D">None</option>
            <answer>A</answer><explanation>sin(π/6) = 1/2.</explanation>
        </question>
        <question>
            <text>Value of cos^-1(1/2) is ____.</text>
            <option id="A">π/3</option><option id="B">π/6</option><option id="C">π/4</option><option id="D">None</option>
            <answer>A</answer><explanation>cos(π/3) = 1/2.</explanation>
        </question>
        <question>
            <text>Value of tan^-1(1) is ____.</text>
            <option id="A">π/4</option><option id="B">π/2</option><option id="C">π/6</option><option id="D">None</option>
            <answer>A</answer><explanation>tan(π/4) = 1.</explanation>
        </question>
        <question>
            <text>The domain of cot^-1 x is ____.</text>
            <option id="A">R</option><option id="B">(-1, 1)</option><option id="C">(0, π)</option><option id="D">None</option>
            <answer>A</answer><explanation>Cotangent function takes all real values.</explanation>
        </question>
        <question>
            <text>The principal value branch range of cot^-1 x is ____.</text>
            <option id="A">(0, π)</option><option id="B">[0, π]</option><option id="C">(-π/2, π/2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard principal value branch for cotangent inverse.</explanation>
        </question>
        <question>
            <text>The range of sec^-1 x is [0, π] excluding ____.</text>
            <option id="A">π/2</option><option id="B">0</option><option id="C">π</option><option id="D">None</option>
            <answer>A</answer><explanation>Cosine is zero at π/2, so secant is undefined.</explanation>
        </question>
        <question>
            <text>The range of cosec^-1 x is [-π/2, π/2] excluding ____.</text>
            <option id="A">0</option><option id="B">π/2</option><option id="C">π</option><option id="D">None</option>
            <answer>A</answer><explanation>Sine is zero at 0, so cosecant is undefined.</explanation>
        </question>
        <question>
            <text>The value of sin(sin^-1 x) is x for x in ____.</text>
            <option id="A">[-1, 1]</option><option id="B">R</option><option id="C">[-π/2, π/2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Outer function sin is defined on R, but inner sin^-1 requires domain [-1, 1].</explanation>
        </question>
        <question>
            <text>The value of sin^-1(sin x) is x only if x is in ____.</text>
            <option id="A">[-π/2, π/2]</option><option id="B">R</option><option id="C">[-1, 1]</option><option id="D">None</option>
            <answer>A</answer><explanation>Restricted to the principal value branch.</explanation>
        </question>
        <question>
            <text>Value of sin^-1(-x) is ____.</text>
            <option id="A">-sin^-1 x</option><option id="B">π - sin^-1 x</option><option id="C">sin^-1 x</option><option id="D">None</option>
            <answer>A</answer><explanation>Identity for negative arguments in sine inverse.</explanation>
        </question>
        <question>
            <text>Value of cos^-1(-x) is ____.</text>
            <option id="A">π - cos^-1 x</option><option id="B">-cos^-1 x</option><option id="C">cos^-1 x</option><option id="D">None</option>
            <answer>A</answer><explanation>Identity for negative arguments in cosine inverse.</explanation>
        </question>
        <question>
            <text>Value of tan^-1(-x) is ____.</text>
            <option id="A">-tan^-1 x</option><option id="B">π - tan^-1 x</option><option id="C">tan^-1 x</option><option id="D">None</option>
            <answer>A</answer><explanation>Identity for negative arguments in tangent inverse.</explanation>
        </question>
        <question>
            <text>Value of cot^-1(-x) is ____.</text>
            <option id="A">π - cot^-1 x</option><option id="B">-cot^-1 x</option><option id="C">cot^-1 x</option><option id="D">None</option>
            <answer>A</answer><explanation>Identity for negative arguments in cotangent inverse.</explanation>
        </question>
        <question>
            <text>Identity: sin^-1 x + cos^-1 x = ____.</text>
            <option id="A">π/2</option><option id="B">π</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Valid for x in [-1, 1].</explanation>
        </question>
        <question>
            <text>Identity: tan^-1 x + cot^-1 x = ____.</text>
            <option id="A">π/2</option><option id="B">π</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Valid for x in R.</explanation>
        </question>
        <question>
            <text>Identity: cosec^-1 x + sec^-1 x = ____.</text>
            <option id="A">π/2</option><option id="B">π</option><option id="C">0</option><option id="D">None</option>
            <answer>A</answer><explanation>Valid for |x| >= 1.</explanation>
        </question>
        <question>
            <text>Value of sin^-1(sin(3π/4)) is ____.</text>
            <option id="A">π/4</option><option id="B">3π/4</option><option id="C">-π/4</option><option id="D">None</option>
            <answer>A</answer><explanation>3π/4 is outside [-π/2, π/2]. Value is π - 3π/4 = π/4.</explanation>
        </question>
        <question>
            <text>Value of cos^-1(cos(7π/6)) is ____.</text>
            <option id="A">5π/6</option><option id="B">7π/6</option><option id="C">π/6</option><option id="D">None</option>
            <answer>A</answer><explanation>7π/6 is outside [0, π]. Use 2π - 7π/6 = 5π/6.</explanation>
        </question>
        <question>
            <text>tan^-1(x) + tan^-1(y) = tan^-1( (x+y)/(1-xy) ) only if xy ____ 1.</text>
            <option id="A">&lt;</option><option id="B">></option><option id="C">=</option><option id="D">None</option>
            <answer>A</answer><explanation>Condition to ensure result stays in principal range.</explanation>
        </question>
        <question>
            <text>2 tan^-1 x = sin^-1( ____ ).</text>
            <option id="A">2x / (1 + x^2)</option><option id="B">2x / (1 - x^2)</option><option id="C">(1-x^2) / (1+x^2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Linked to 2θ formula for sin.</explanation>
        </question>
        <question>
            <text>2 tan^-1 x = cos^-1( ____ ).</text>
            <option id="A">(1-x^2) / (1+x^2)</option><option id="B">(1+x^2) / (1-x^2)</option><option id="C">2x / (1+x^2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Linked to 2θ formula for cos.</explanation>
        </question>
        <question>
            <text>2 tan^-1 x = tan^-1( ____ ).</text>
            <option id="A">2x / (1 - x^2)</option><option id="B">2x / (1 + x^2)</option><option id="C">x^2 / (1-x^2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Linked to 2θ formula for tan.</explanation>
        </question>
        <question>
            <text>sin^-1 x = cosec^-1( ____ ) for x != 0.</text>
            <option id="A">1/x</option><option id="B">-x</option><option id="C">x</option><option id="D">None</option>
            <answer>A</answer><explanation>Reciprocal identity.</explanation>
        </question>
        <question>
            <text>cos^-1 x = sec^-1( ____ ) for x != 0.</text>
            <option id="A">1/x</option><option id="B">-x</option><option id="C">x</option><option id="D">None</option>
            <answer>A</answer><explanation>Reciprocal identity.</explanation>
        </question>
        <question>
            <text>Value of sin^-1(1/sqrt(2)) + cos^-1(1/sqrt(2)) is ____.</text>
            <option id="A">π/2</option><option id="B">π/4</option><option id="C">π</option><option id="D">None</option>
            <answer>A</answer><explanation>Identity sum property.</explanation>
        </question>
        <question>
            <text>Value of tan^-1(sqrt(3)) - sec^-1(-2) is ____.</text>
            <option id="A">-π/3</option><option id="B">π/3</option><option id="C">π/6</option><option id="D">None</option>
            <answer>A</answer><explanation>π/3 - (π - π/3) = π/3 - 2π/3 = -π/3.</explanation>
        </question>
        <question>
            <text>Principle value of cosec^-1(2) is ____.</text>
            <option id="A">π/6</option><option id="B">π/3</option><option id="C">-π/6</option><option id="D">None</option>
            <answer>A</answer><explanation>cosec(π/6) = 1/sin(π/6) = 2.</explanation>
        </question>
        <question>
            <text>Principle value of cot^-1(sqrt(3)) is ____.</text>
            <option id="A">π/6</option><option id="B">π/3</option><option id="C">π/4</option><option id="D">None</option>
            <answer>A</answer><explanation>cot(π/6) = sqrt(3).</explanation>
        </question>
        <question>
            <text>Principle value of cos^-1(-1/sqrt(2)) is ____.</text>
            <option id="A">3π/4</option><option id="B">-π/4</option><option id="C">π/4</option><option id="D">None</option>
            <answer>A</answer><explanation>π - π/4 = 3π/4.</explanation>
        </question>
        <question>
            <text>Value of sin(π/3 - sin^-1(-1/2)) is ____.</text>
            <option id="A">1</option><option id="B">0</option><option id="C">1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>sin(π/3 - (-π/6)) = sin(π/2) = 1.</explanation>
        </question>
        <question>
            <text>Range of cosec^-1 x is ____.</text>
            <option id="A">[-π/2, π/2] - {0}</option><option id="B">(-π/2, π/2)</option><option id="C">[0, π]</option><option id="D">None</option>
            <answer>A</answer><explanation>Principal branch definition.</explanation>
        </question>
        <question>
            <text>Range of sec^-1 x is ____.</text>
            <option id="A">[0, π] - {π/2}</option><option id="B">[-π/2, π/2]</option><option id="C">(0, π)</option><option id="D">None</option>
            <answer>A</answer><explanation>Principal branch definition.</explanation>
        </question>
        <question>
            <text>Value of cot(tan^-1 a + cot^-1 a) is ____.</text>
            <option id="A">0</option><option id="B">1</option><option id="C">Infinite</option><option id="D">None</option>
            <answer>A</answer><explanation>cot(π/2) = 0.</explanation>
        </question>
        <question>
            <text>tan^-1 x = y implies x = ____.</text>
            <option id="A">tan y</option><option id="B">cot y</option><option id="C">sin y</option><option id="D">None</option>
            <answer>A</answer><explanation>Basic definition of inverse.</explanation>
        </question>
    </easy>
    <medium>
        <question>
            <text>If sin(sin^-1(1/5) + cos^-1 x) = 1, then x = ____.</text>
            <option id="A">1/5</option><option id="B">1</option><option id="C">0</option><option id="D">4/5</option>
            <answer>A</answer><explanation>sin^-1(1/5) + cos^-1 x = sin^-1(1) = π/2. This holds when x = 1/5.</explanation>
        </question>
        <question>
            <text>Value of tan^-1(sqrt(3)) - cot^-1(-sqrt(3)) is ____.</text>
            <option id="A">-π/2</option><option id="B">π</option><option id="C">0</option><option id="D">π/2</option>
            <answer>A</answer><explanation>π/3 - (π - π/6) = π/3 - 5π/6 = -3π/6 = -π/2.</explanation>
        </question>
        <question>
            <text>Value of tan^-1(2 cos(2 sin^-1(1/2))) is ____.</text>
            <option id="A">π/4</option><option id="B">π/2</option><option id="C">π/3</option><option id="D">None</option>
            <answer>A</answer><explanation>2 sin^-1(1/2) = 2*π/6 = π/3. cos(π/3)=1/2. tan^-1(2*1/2) = tan^-1(1) = π/4.</explanation>
        </question>
        <question>
            <text>If tan^-1((x-1)/(x-2)) + tan^-1((x+1)/(x+2)) = π/4, then x = ____.</text>
            <option id="A">±1/sqrt(2)</option><option id="B">±1</option><option id="C">±2</option><option id="D">None</option>
            <answer>A</answer><explanation>Use tan^-1 x + tan^-1 y formula and solve.</explanation>
        </question>
        <question>
            <text>Value of cos(sec^-1 x + cosec^-1 x), |x| >= 1 is ____.</text>
            <option id="A">0</option><option id="B">1</option><option id="C">-1</option><option id="D">None</option>
            <answer>A</answer><explanation>cos(π/2) = 0.</explanation>
        </question>
        <question>
            <text>The value of sin^-1(cos(33π/5)) is ____.</text>
            <option id="A">-π/10</option><option id="B">π/10</option><option id="C">3π/5</option><option id="D">None</option>
            <answer>A</answer><explanation>cos(33π/5) = cos(6π + 3π/5) = cos(3π/5). sin^-1(sin(π/2 - 3π/5)) = π/2 - 3π/5 = -π/10.</explanation>
        </question>
        <question>
            <text>Simplified form of tan^-1( (cos x - sin x) / (cos x + sin x) ) is ____.</text>
            <option id="A">π/4 - x</option><option id="B">π/4 + x</option><option id="C">x</option><option id="D">None</option>
            <answer>A</answer><explanation>Divide by cos x inside: tan^-1( (1 - tan x) / (1 + tan x) ) = tan^-1(tan(π/4 - x)).</explanation>
        </question>
        <question>
            <text>Simplified form of tan^-1( x / sqrt(a^2 - x^2) ) is ____.</text>
            <option id="A">sin^-1(x/a)</option><option id="B">cos^-1(x/a)</option><option id="C">tan^-1(x/a)</option><option id="D">None</option>
            <answer>A</answer><explanation>Substitute x = a sin θ.</explanation>
        </question>
        <question>
            <text>Simplified form of tan^-1( 3a^2x - x^3 ) / ( a^3 - 3ax^2 ) is ____.</text>
            <option id="A">3 tan^-1(x/a)</option><option id="B">2 tan^-1(x/a)</option><option id="C">tan^-1(3x/a)</option><option id="D">None</option>
            <answer>A</answer><explanation>Substitute x = a tan θ, results in tan 3θ formula.</explanation>
        </question>
        <question>
            <text>Value of cos(tan^-1 x) is ____.</text>
            <option id="A">1 / sqrt(1 + x^2)</option><option id="B">x / sqrt(1 + x^2)</option><option id="C">sqrt(1 + x^2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Let tan θ = x, then cos θ = 1/sec θ = 1/sqrt(1+tan^2θ).</explanation>
        </question>
        <question>
            <text>Value of sin(tan^-1 x) is ____.</text>
            <option id="A">x / sqrt(1 + x^2)</option><option id="B">1 / sqrt(1 + x^2)</option><option id="C">x</option><option id="D">None</option>
            <answer>A</answer><explanation>Let tan θ = x, then sin θ = tan θ / sec θ = x / sqrt(1 + x^2).</explanation>
        </question>
        <question>
            <text>If sin^-1(1 - x) - 2 sin^-1 x = π/2, then x is ____.</text>
            <option id="A">0</option><option id="B">1/2</option><option id="C">0, 1/2</option><option id="D">None</option>
            <answer>A</answer><explanation>Substitute options or solve rigorously; 1/2 doesn't satisfy.</explanation>
        </question>
        <question>
            <text>tan^-1 x + tan^-1(2x) / (1 - x^2) = tan^-1( ____ ).</text>
            <option id="A">(3x - x^3) / (1 - 3x^2)</option><option id="B">(2x) / (1 - 3x^2)</option><option id="C">3x / (1 - 3x^2)</option><option id="D">None</option>
            <answer>A</answer><explanation>Sum of tan inverse and 2 tan inverse.</explanation>
        </question>
        <question>
            <text>Simplified form of tan^-1( sqrt(1+x^2) - 1 ) / x is ____.</text>
            <option id="A">1/2 tan^-1 x</option><option id="B">tan^-1 x</option><option id="C">2 tan^-1 x</option><option id="D">None</option>
            <answer>A</answer><explanation>Substitute x = tan θ, results in tan(θ/2).</explanation>
        </question>
        <question>
            <text>Value of cos^-1(1/2) + 2 sin^-1(1/2) is ____.</text>
            <option id="A">2π/3</option><option id="B">π/2</option><option id="C">π/3</option><option id="D">None</option>
            <answer>A</answer><explanation>π/3 + 2(π/6) = π/3 + π/3 = 2π/3.</explanation>
        </question>
        <question>
            <text>If |x| &lt;= 1, then sin^-1 x = cos^-1( ____ ).</text>
            <option id="A">sqrt(1 - x^2)</option><option id="B">1 - x^2</option><option id="C">1/x</option><option id="D">None</option>
            <answer>A</answer><explanation>From sin^2 + cos^2 = 1 relationship.</explanation>
        </question>
        <question>
            <text>If x > 0, then cot^-1 x = tan^-1( ____ ).</text>
            <option id="A">1/x</option><option id="B">-x</option><option id="C">π/2 - x</option><option id="D">None</option>
            <answer>A</answer><explanation>Standard identity for positive x.</explanation>
        </question>
        <question>
            <text>The value of tan^-1(1) + cos^-1(-1/2) + sin^-1(-1/2) is ____.</text>
            <option id="A">3π/4</option><option id="B">π/2</option><option id="C">π</option><option id="D">None</option>
            <answer>A</answer><explanation>π/4 + (π - π/3) + (-π/6) = π/4 + 2π/3 - π/6 = 9π/12 = 3π/4.</explanation>
        </question>
        <question>
            <text>If sin(tan^-1 x) = 1/2, then x = ____.</text>
            <option id="A">1 / sqrt(3)</option><option id="B">1 / sqrt(2)</option><option id="C">sqrt(3)</option><option id="D">None</option>
            <answer>A</answer><explanation>tan^-1 x = sin^-1(1/2) = π/6 => x = tan(π/6) = 1/sqrt(3).</explanation>
        </question>
        <question>
            <text>Which of the following describes the graph of tan^-1 x?</text>
            <option id="A">Increasing on R</option><option id="B">Decreasing on R</option><option id="C">Increasing on (-1, 1)</option><option id="D">None</option>
            <answer>A</answer><explanation>Slope is always positive (1 / (1+x^2)).</explanation>
        </question>
        <question>
            <text>Value of tan(cos^-1(4/5) + tan^-1(2/3)) is ____.</text>
            <option id="A">17/6</option><option id="B">6/17</option><option id="C">11/6</option><option id="D">None</option>
            <answer>A</answer><explanation>cos^-1(4/5) = tan^-1(3/4). Result is tan(tan^-1(3/4) + tan^-1(2/3)) = (3/4 + 2/3) / (1 - 1/2) = (17/12) / (1/2) = 17/6.</explanation>
        </question>
        <question>
            <text>If cot^-1(4/3) = x, then cos x is ____.</text>
            <option id="A">4/5</option><option id="B">3/5</option><option id="C">5/4</option><option id="D">None</option>
            <answer>A</answer><explanation>Triangle with adj=4, opp=3, hyp=5.</explanation>
        </question>
        <question>
            <text>Domain of the function f(x) = sin^-1 x + cos x is ____.</text>
            <option id="A">[-1, 1]</option><option id="B">R</option><option id="C">[-π/2, π/2]</option><option id="D">None</option>
            <answer>A</answer><explanation>Intersection of domains: [-1, 1] and R.</explanation>
        </question>
        <question>
            <text>Value of sin^-1(1/sqrt(5)) + sin^-1(2/sqrt(5)) is ____.</text>
            <option id="A">π/2</option><option id="B">π/4</option><option id="C">π/3</option><option id="D">None</option>
            <answer>A</answer><explanation>tan^-1(1/2) + tan^-1(2/1) = π/2 (complementary angles).</explanation>
        </question>
        <question>
            <text>Principle value of tan^-1(-sqrt(3)) is ____.</text>
            <option id="A">-π/3</option><option id="B">2π/3</option><option id="C">π/3</option><option id="D">None</option>
            <answer>A</answer><explanation>Inside (-π/2, π/2).</explanation>
        </question>
        <question>
            <text>Relationship: tan^-1(x) - tan^-1(y) = tan^-1( (x-y)/(1+xy) ) only if xy ____ -1.</text>
            <option id="A">></option><option id="B">&lt;</option><option id="C">=</option><option id="D">None</option>
            <answer>A</answer><explanation>Ensures the argument is defined and in branch.</explanation>
        </question>
        <question>
            <text>If sin^-1 x = y, then y is in which interval?</text>
            <option id="A">[-π/2, π/2]</option><option id="B">( -π/2, π/2)</option><option id="C">[0, π]</option><option id="D">None</option>
            <answer>A</answer><explanation>Definition of principal value branch.</explanation>
        </question>
